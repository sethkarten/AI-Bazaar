    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Drive home in perfection with this stunning, showroom-ready vehicle! It is in absolute mint condition, having been preserved with the utmost care to ensure it looks and performs like new. From the flawless exterior to the pristine interior, this car is a rare find for anyone seeking excellence.",
      "price": 49000.0,
