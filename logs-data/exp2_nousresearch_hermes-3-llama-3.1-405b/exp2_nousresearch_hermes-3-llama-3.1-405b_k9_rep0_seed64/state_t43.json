    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! Thanks so much for stopping by. I'm selling my trusty car that's been a total joy to own! It\u2019s in really wonderful shape and has been super reliable for me. Whether you're headed to work or planning a road trip, it's ready to go and looks great too. I've taken good care of it, and I'd love to see it go to a great new home. Feel free to reach out if you have any questions or want to come see it in person!",
      "price": 31500.0,
      "reputation": 0.6,
