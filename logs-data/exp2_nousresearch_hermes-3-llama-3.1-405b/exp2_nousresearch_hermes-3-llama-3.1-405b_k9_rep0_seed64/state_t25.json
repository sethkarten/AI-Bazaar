      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\udc4b Are you looking for a dependable ride that\u2019s been well-loved and is ready for its next adventure? This car is in solid shape and runs like a absolute dream! It\u2019s been super reliable for me, perfect for everything from daily commutes to fun weekend road trips. It's got plenty of life left and is honestly just a joy to drive. I'd love for it to go to a great new home\u2014come take it for a spin and see for yourself! \u2728",
      "price": 32500.0,
      "reputation": 0.6,
