      "timestep_posted": 20
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Mechanically sound. Regular service history. Clean interior. Minor surface scratches. Clear title.",
