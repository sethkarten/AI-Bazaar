    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a meticulously maintained vehicle that exemplifies reliable performance and sophisticated engineering. This exceptional unit features a clean interior and a robust powertrain, ensuring a premium driving experience for its next owner. An outstanding opportunity for those seeking quality and value in a single package.",
      "price": 34500.0,
