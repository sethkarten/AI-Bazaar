      "quality_value": 0.1,
      "timestep_posted": 31
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a distinguished example of automotive excellence, this vehicle has been curated for the driver who values both performance and reliability. It exhibits a well-preserved exterior and a refined interior, reflecting a history of diligent care. Fully inspected to ensure it meets our rigorous standards, this offering provides exceptional value for those seeking a sophisticated and dependable driving experience.",
      "price": 34800.0,
