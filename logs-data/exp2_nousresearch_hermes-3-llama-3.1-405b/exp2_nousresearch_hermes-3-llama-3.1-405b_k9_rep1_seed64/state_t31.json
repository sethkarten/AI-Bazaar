      "quality_value": 0.1,
      "timestep_posted": 31
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m looking to find a new home for this absolute gem. It\u2019s in really great shape and has been super dependable for me\u2014perfect for someone who wants a high-quality ride without paying showroom prices! It handles beautifully and is ready to hit the road today. Feel free to reach out if you want to come by and take it for a spin!",
      "price": 32500.0,
