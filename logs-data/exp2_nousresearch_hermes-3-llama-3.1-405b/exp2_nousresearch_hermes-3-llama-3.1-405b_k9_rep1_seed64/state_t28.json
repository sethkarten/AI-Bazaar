      "quality_value": 0.1,
      "timestep_posted": 28
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a meticulously maintained vehicle that exemplifies reliability and performance. This unit has been thoroughly inspected to ensure it meets our rigorous standards for quality and safety. With a clean history and consistent service records, it offers a sophisticated driving experience for the discerning buyer. Visit us to experience this exceptional value firsthand.",
