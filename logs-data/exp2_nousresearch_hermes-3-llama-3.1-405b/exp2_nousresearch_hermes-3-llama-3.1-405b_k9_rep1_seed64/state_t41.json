      "quality_value": 0.1,
      "timestep_posted": 41
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey everyone! \ud83d\ude97 Check out this absolute beauty! I\u2019m honestly a little sad to let her go, but she\u2019s looking for a new home. This car is in truly flawless, showroom condition\u2014not a single scratch or dent to be found. It looks and smells just like it did the day it rolled off the lot! If you're looking for perfection without the brand-new price tag, this is the one. Come take a look and see for yourself!",
      "price": 43900.0,
      "reputation": 0.5,
