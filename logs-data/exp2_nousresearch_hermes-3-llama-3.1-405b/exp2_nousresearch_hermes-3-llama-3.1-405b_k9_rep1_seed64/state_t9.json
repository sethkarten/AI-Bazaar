      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm selling my reliable ride and it's looking for a new home! It\u2019s been such a joy to own and is in really wonderful shape, perfect for your daily commute or a fun weekend trip. It drives like a dream and has been very well-cared for. I\u2019m sad to see it go, but I know the next owner is going to absolutely love it! Let's get you behind the wheel!",
      "price": 34500.0,
