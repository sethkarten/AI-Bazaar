    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a collector-grade E46 M3 featuring the high-revving S54 3.2L inline-six power plant. This vehicle boasts a meticulously maintained mechanical profile, including a comprehensive Beisan Systems VANOS overhaul and treated rod bearings to ensure long-term engine harmonics. The chassis is structurally flawless, featuring proactive subframe reinforcement and a factory-spec limited-slip differential that delivers exceptional torque vectoring. Every bushing and suspension component remains in factory-spec tension, providing the precise turn-in and feedback characteristic of the M-division's peak engineering. The exterior finish and interior upholstery show zero signs of fatigue, representing a truly synchronized, showroom-quality driving machine.",
      "price": 46500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 37
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Mint condition. Garage kept. No scratches or dents. Smoke-free interior. Full service records included. Clean title in hand.",
      "price": 47000.0,
      "reputation": 0.8,
