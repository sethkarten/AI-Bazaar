    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior is flawless with no scratches or dents, and the interior is in a pristine state with no signs of wear. All mechanical and electronic systems are in perfect working order.",
      "price": 47500.0,
