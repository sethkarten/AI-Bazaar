      "quality_value": 0.1,
      "timestep_posted": 28
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting an investment-grade 2004 BMW M3 (E46) in pristine Carbon Black. This example features the high-revving S54B32 inline-six, utilizing individual throttle bodies and a double-VANOS variable valve timing system that has been meticulously calibrated. Power is routed through a Getrag 6-speed manual transmission to a factory-spec limited-slip differential. The chassis remains structurally flawless, with proactive rear subframe reinforcement and a refreshed suspension featuring Bilstein dampers and OEM bushings. Every component, from the rod bearings to the cooling system, reflects a rigorous maintenance schedule. This is a mechanically superlative specimen for the discerning collector seeking peak atmospheric performance.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 28
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
