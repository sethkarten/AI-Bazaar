      "timestep_posted": 23
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a concours-level 2004 BMW M3 (E46) featuring the legendary S54B32 3.2L inline-six. This specimen boasts a high-revving valvetrain with individual throttle bodies and a crisp Getrag 6-speed manual transmission. Mechanically flawless, the rod bearing service and double-VANOS overhaul have been documented. The chassis remains structurally sound with proactive subframe reinforcement. Power is delivered through a factory limited-slip differential, ensuring optimal corner-exit traction. Finished in impeccable Carbon Black over Cinnamon Nappa leather, this is a turn-key example for the discerning collector.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 23
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Pristine condition. Original paint. No mechanical issues. Clean title. Garage kept. Full service records included.",
      "price": 43500.0,
      "reputation": 0.5,
