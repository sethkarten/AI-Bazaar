      "quality_value": 0.1,
      "timestep_posted": 35
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an exceptional opportunity to acquire a vehicle that exemplifies mechanical reliability and consistent maintenance. This unit maintains a high standard of aesthetic integrity and performance, offering a refined driving experience for the discerning professional. Thoroughly inspected to ensure it meets our rigorous criteria for roadworthiness, this vehicle represents a prudent investment in long-term value and dependable service.",
      "price": 34500.0,
