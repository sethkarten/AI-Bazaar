    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "For sale is a driver-focused E46 M3 featuring the legendary S54B32 3.2L inline-six, renowned for its individual throttle bodies and high-revving 8,000 RPM redline. This example remains mechanically robust with a crisp Getrag 6-speed manual transmission and a factory-spec limited-slip differential providing exceptional power delivery. The double-VANOS system has been meticulously monitored, ensuring optimal cam timing across the power band. To address chassis longevity, the rear subframe mounting points have been professionally reinforced. Suspension geometry remains tight, utilizing a balanced MacPherson strut front and multi-link rear configuration. This is a visceral, analog machine ready for the canyons.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle in good condition. Regularly maintained. Clean title and interior. Performance is reliable. Ready for immediate use.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
