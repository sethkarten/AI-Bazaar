    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this superlative example of automotive excellence, maintained to an impeccable standard. This vehicle remains in showroom condition, featuring a flawless exterior finish and a pristine interior that reflects a commitment to preservation. Rigorously inspected and displaying no signs of wear, this motorcar offers an unrivaled driving experience for the discerning enthusiast who demands nothing less than perfection.",
      "price": 46500.0,
      "reputation": 0.7,
