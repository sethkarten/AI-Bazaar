    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an investment-grade 2004 Porsche 911 Carrera (996.2) in showroom condition. This specimen features the 3.6L flat-six with VarioCam Plus, delivering linear power across the rev range. The 6-speed manual transaxle offers precise, short-throw engagement, paired with a factory-spec limited-slip differential for optimal corner-exit traction. Recent preventative maintenance includes a dual-row IMS bearing retrofit and a new rear main seal, ensuring mechanical longevity. The chassis retains its factory torsional rigidity, supported by a meticulously maintained multi-link rear suspension and four-piston monobloc calipers for exceptional deceleration. Zero bore scoring or oil consumption. This is a turn-key example for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2021 Sedan. Mint condition. Single owner. Zero accidents. Garage kept. Service records included. Clean title.",
      "price": 43500.0,
      "reputation": 0.5,
