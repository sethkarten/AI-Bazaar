      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You've honestly gotta see this beauty in person. It\u2019s in absolutely pristine, showroom condition\u2014I\u2019ve babied this car since day one, and it really shows! Everything is spotless inside and out, and it drives just as smooth as the day I got it. If you're looking for something that feels brand new without the dealership headache, this is the one. Come take a look, you're going to love it! \ud83d\ude97\u2728",
      "price": 46500.0,
