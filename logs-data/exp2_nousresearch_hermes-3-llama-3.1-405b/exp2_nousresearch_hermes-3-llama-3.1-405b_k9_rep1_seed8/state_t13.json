      "quality_value": 0.1,
      "timestep_posted": 13
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m parting ways with my trusty ride, and honestly, it\u2019s been such a joy to drive. It\u2019s in really solid shape and has been super reliable for me. It\u2019s clean, runs great, and is totally ready for its next adventure! If you're looking for a dependable car that still looks sharp on the road, you\u2019ve found it. Drop me a message if you want to take it for a spin!",
      "price": 31500.0,
      "reputation": 0.6,
