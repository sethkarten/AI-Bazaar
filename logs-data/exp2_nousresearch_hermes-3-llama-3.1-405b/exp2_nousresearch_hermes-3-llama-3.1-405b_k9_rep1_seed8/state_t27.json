    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a mechanically sound E46 M3 powered by the iconic S54B32 inline-six. This high-revving powerplant features individual throttle bodies and dual-VANOS variable valve timing, delivering linear power to the rear wheels via a tactile ZF 6-speed manual gearbox. The chassis is reinforced with a variable M differential lock and upgraded Bilstein dampers for precise lateral dynamics. Recent service includes a comprehensive cooling system refresh and subframe inspection. While the exterior shows minor road patina, the drivetrain remains tight and responsive, providing an authentic, analog performance profile for the discerning enthusiast.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Good condition. Clean title. Runs well. Minor exterior scuffs. Interior is clean. Maintenance up to date.",
      "price": 31500.0,
