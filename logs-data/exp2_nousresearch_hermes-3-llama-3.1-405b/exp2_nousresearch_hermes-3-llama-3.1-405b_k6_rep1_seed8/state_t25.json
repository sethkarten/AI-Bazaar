    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is being sold in poor condition and is currently not in drivable shape. The engine has failed and will require a complete overhaul or replacement, and the transmission was experiencing major slipping before the car was sidelined. Visually, the car has significant body rust, particularly around the wheel wells, and the interior shows heavy wear with multiple tears in the seating. This is strictly a project car or a source for parts and will need to be towed from its current location.",
      "price": 3800.0,
