    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It is operational and functional, though it shows significant cosmetic wear on both the interior and exterior. Regular mechanical maintenance is required to ensure continued performance.",
