    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an exceptional, investment-grade 1994 Mazda RX-7 FD3S, preserved in its original mechanical configuration. This example features the legendary 13B-REW rotary engine, exhibiting robust compression across all rotor faces. The sequential twin-turbocharger system operates with surgical precision, providing a seamless transition at 4,500 RPM. The chassis remains taut, utilizing its factory double-wishbone suspension and Torsen limited-slip differential to deliver unparalleled feedback. Finished in its factory-original paint with a pristine interior, this FD retains its OEM vacuum routing and cooling system integrity. A true turnkey specimen for the discerning collector seeking peak 90s JDM engineering.",
      "price": 46500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 23
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2022 Performance Sedan. Mint condition. 8,500 miles. Single owner. No accidents. Factory warranty remains. Garage kept. Clean title in hand.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
