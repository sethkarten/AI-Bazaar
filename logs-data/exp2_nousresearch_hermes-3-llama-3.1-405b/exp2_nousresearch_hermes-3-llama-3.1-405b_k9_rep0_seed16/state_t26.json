      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a collector-grade E46 M3 featuring the legendary S54 3.2L inline-six. This specimen is mechanically impeccable, boasting a documented VANOS overhaul and rod bearing replacement for long-term reliability. The chassis has been professionally reinforced at the subframe mounting points, ensuring structural integrity under high lateral loads. Power is delivered through a precise Getrag 6-speed manual gearbox to a limited-slip differential that remains tight and silent. The individual throttle bodies are perfectly synchronized, providing the immediate, atmospheric throttle response this platform is renowned for. Finished in pristine condition with a factory-spec suspension that retains its original damping characteristics, this is an investment-grade example for the true purist.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2021 Sedan. Mint condition. Garage kept. No scratches or dents. Clean title. Full service history available.",
      "price": 43500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
