    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and transmission are functional but show signs of age and high mileage. There are noticeable scratches and small dents on the exterior, and the interior upholstery has some visible wear and tear.",
      "price": 20000.0,
      "reputation": 1.0,
