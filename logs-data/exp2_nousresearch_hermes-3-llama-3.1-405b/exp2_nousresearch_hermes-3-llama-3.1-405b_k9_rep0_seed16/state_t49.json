      "quality_value": 0.7,
      "timestep_posted": 49
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and transmission are functional but show signs of age and high mileage. There are noticeable scratches and small dents on the exterior, and the interior upholstery has some wear and staining.",
