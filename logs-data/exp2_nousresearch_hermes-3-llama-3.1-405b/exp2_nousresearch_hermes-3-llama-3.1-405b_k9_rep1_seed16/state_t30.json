      "timestep_posted": 30
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm parting ways with my trusty car, and it's been such a joy to drive. It\u2019s in really solid shape and has been super reliable for me over the years. It\u2019s perfect for anyone looking for a smooth ride that\u2019s ready to hit the road today! I've taken great care of it, and I'd love to see it go to a good home. Feel free to message me if you want to come take it for a spin!",
      "price": 32500.0,
      "reputation": 0.6,
