    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a driver-focused example featuring the legendary S54 3.2L inline-six, delivering linear power through six individual throttle bodies. Mated to a crisp ZF 6-speed manual transmission, the drivetrain remains robust with consistent compression across all cylinders. The chassis benefits from documented subframe reinforcement and a refreshed suspension setup featuring Bilstein dampers and poly-bushings. The variable M differential lock ensures optimal torque distribution, while the VANOS system and rod bearings have been proactively addressed. A visceral, high-revving machine that prioritizes mechanical feedback and analog engagement.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2018 model. Well-maintained. Minor exterior scratches. Interior is clean. Runs well. Recent oil change.",
      "price": 32000.0,
