      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a distinguished vehicle that exemplifies consistent maintenance and refined performance. This unit offers a seamless blend of sophisticated styling and robust mechanical integrity. Meticulously inspected to ensure it meets our rigorous standards for safety and comfort, this car represents an exceptional opportunity for the value-conscious professional seeking both prestige and reliability. Experience the assurance of quality engineering in an expertly preserved package.",
      "price": 34800.0,
