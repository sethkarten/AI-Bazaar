    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting an investment-grade E46 M3, featuring the high-revving S54B32 inline-six engine equipped with individual throttle bodies and a 7,900 RPM redline. This specimen is mechanically flawless, having undergone comprehensive preventative maintenance including a Beisan Systems VANOS rebuild and a structural reinforcement of the rear subframe. The Getrag 420G six-speed manual gearbox offers precise gate entry, coupled with a pristine factory limited-slip differential. The chassis remains taut with zero bushing deflection, and the exterior retains its factory-spec paint depth and luster. This is a turn-key example for the purist, free of fluid weeping or heat-cycle fatigue on any plastic components.",
      "price": 44500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 24
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Clean title. No accidents. Garage kept. Service history included. Flawless interior and exterior.",
      "price": 43500.0,
