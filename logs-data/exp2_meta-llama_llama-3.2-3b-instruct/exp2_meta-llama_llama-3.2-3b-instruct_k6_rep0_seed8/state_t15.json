    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting an exceptional vehicle of investment-grade quality. This unit remains in pristine, showroom condition, reflecting meticulous care and an uncompromising maintenance history. Every aesthetic and mechanical detail meets the highest standards of excellence. For the discerning collector or enthusiast who demands nothing less than perfection, this offering represents a rare opportunity to acquire a vehicle in its most superlative state.",
      "price": 48750.0,
      "reputation": 0.8,
