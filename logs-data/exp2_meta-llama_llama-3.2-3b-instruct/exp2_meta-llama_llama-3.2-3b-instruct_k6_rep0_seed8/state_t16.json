    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! Thanks for stopping by to check out my ride. I\u2019ve absolutely loved driving this car, and it\u2019s still in really solid shape and ready for its next adventure! It runs smoothly, has been well-maintained, and is just a great, reliable vehicle for anyone looking for a quality set of wheels. I\u2019m sad to see it go, but I\u2019m sure it\u2019ll make its next owner very happy. Drop me a message if you want to take it for a spin!",
      "price": 32000.0,
      "reputation": 0.5,
