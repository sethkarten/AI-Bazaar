    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this meticulously maintained vehicle, which exemplifies mechanical reliability and aesthetic discipline. The exterior retains a distinguished character, complemented by an interior that has been preserved with rigorous attention to detail. This offering represents a premier opportunity for the discerning buyer to secure a high-caliber automobile that balances performance with enduring value.",
      "price": 34900.0,
