    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented in exceptional mechanical and cosmetic order, this vehicle represents a premier acquisition for the discerning driver. Meticulously maintained and rigorously inspected, it offers a seamless blend of performance and sophisticated styling. Experience the assurance of quality and the distinction of a vehicle that has been preserved with the utmost care.",
      "price": 34800.0,
      "reputation": 0.8,
