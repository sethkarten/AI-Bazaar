    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a masterclass in preservation, featuring the legendary S54 inline-six with crisp individual throttle body response and seamless double VANOS operation. The chassis is structurally immaculate, with documented subframe reinforcement and recent rod bearing prophylaxis to ensure peak mechanical integrity. Power is delivered through a precise Getrag 6-speed manual to a factory limited-slip differential, offering unparalleled tactile feedback. The suspension geometry remains true to factory specifications with compliant bushings and zero fluid seepage in the engine bay, maintaining optimal compression across all cylinders. This is a concours-level example for the discerning purist seeking factory-spec tolerances.",
      "price": 48250.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Excellent condition. No mechanical issues. Spotless interior. Service records included. Garage kept.",
      "price": 46500.0,
      "reputation": 0.8,
