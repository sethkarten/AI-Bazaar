    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering an investment-grade E46 M3 featuring the legendary S54B32 atmospheric inline-six. This example boasts a pristine service history with critical preventative maintenance addressed, including a reinforced rear subframe and a comprehensive VANOS overhaul. The Getrag 6-speed manual transmission operates with surgical precision, feeding power through a refreshed variable M differential lock. The suspension maintains factory-spec geometry with upgraded Bilstein dampers and OEM bushings for optimal kinematic response. Zero fluid weepage is present at the oil pan or constant pressure valve. This is a mechanically transparent, high-revving masterpiece ready for the most discerning collector.",
      "price": 44500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
