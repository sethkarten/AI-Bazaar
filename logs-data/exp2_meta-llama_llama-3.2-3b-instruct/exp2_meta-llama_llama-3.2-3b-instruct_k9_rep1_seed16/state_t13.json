      "timestep_posted": 13
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this exemplary vehicle, maintained to a standard that transcends the typical pre-owned market. This unit remains in impeccable, showroom-grade condition, exhibiting no discernible wear and reflecting a history of meticulous preservation. Every mechanical and aesthetic detail has been scrutinized to ensure it meets our rigorous criteria for excellence. For the discerning enthusiast who demands nothing short of perfection, this offering represents a rare opportunity to acquire a specimen of peerless quality.",
      "price": 48900.0,
