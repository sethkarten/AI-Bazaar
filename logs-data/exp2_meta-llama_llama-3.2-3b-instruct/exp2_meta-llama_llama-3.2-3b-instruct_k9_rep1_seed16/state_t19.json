    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a mechanically robust E46 M3 powered by the high-revving S54B32 inline-six featuring individual throttle bodies and dual-VANOS variable valve timing. This example has undergone essential preventative maintenance, including a reinforced rear subframe and a comprehensive VANOS bulletproofing. The 6-speed manual Getrag gearbox is paired with a limited-slip variable M differential, ensuring optimal power delivery. Suspension geometry is tight, benefiting from refreshed bushings and Bilstein dampers. While the chassis shows minor cosmetic road wear consistent with enthusiast use, the powertrain remains a pinnacle of naturally aspirated engineering. A turn-key driver's car for those who prioritize mechanical integrity and analog feedback.",
      "price": 31500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 19
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle for sale. Good condition. Engine runs well. Clean title. Minor wear on interior. Inspection ready.",
      "price": 28500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
