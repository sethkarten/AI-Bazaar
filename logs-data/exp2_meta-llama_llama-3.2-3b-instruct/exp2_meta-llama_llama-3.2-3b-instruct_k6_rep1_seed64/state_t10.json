    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a budget-friendly project or a low-cost entry into vehicle ownership? This car is ready for a new owner who isn't afraid of a little DIY! While it shows significant wear and will require some mechanical and cosmetic attention to get it back to its best, it offers a fantastic opportunity to own a vehicle at a fraction of the usual cost. Perfect for a mechanic's special or someone looking for a dedicated restoration project!",
      "price": 6500.0,
      "reputation": 0.8,
