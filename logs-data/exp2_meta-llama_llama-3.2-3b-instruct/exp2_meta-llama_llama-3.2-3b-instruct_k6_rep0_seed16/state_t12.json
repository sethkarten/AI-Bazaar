    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering an investment-grade E46 M3, powered by the legendary S54B32 high-revving inline-six featuring individual throttle bodies and dual-VANOS variable valve timing. This specimen is mechanically pristine, with documented rod bearing replacement and a reinforced rear subframe to ensure structural integrity under high lateral loads. The ZF 6-speed manual gearbox provides tactile engagement, paired with a limited-slip variable M differential for precise torque vectoring. Every bushing is tight, the compression across all six cylinders is within factory tolerances, and the engine vitals remain optimal. This is a turn-key collector piece for the purist seeking peak atmospheric performance.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 12
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
