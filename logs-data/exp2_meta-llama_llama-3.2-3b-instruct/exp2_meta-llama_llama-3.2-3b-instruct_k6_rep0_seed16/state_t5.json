    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exceptional vehicle, currently maintained in a state that rivals its original showroom debut. This specimen exhibits peerless aesthetic and mechanical integrity, reflecting meticulous stewardship and an uncompromising commitment to preservation. A rare opportunity for the discerning collector, this vehicle offers an unblemished driving experience and represents an investment-grade acquisition of the highest caliber.",
      "price": 48500.0,
      "reputation": 0.8,
