    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is a driver-focused E46 M3 featuring the legendary S54 3.2L inline-six, delivering 333 hp through a precise 6-speed manual transmission. This example remains mechanically robust, with the critical VANOS system serviced and subframe reinforcement already addressed. The chassis dynamics are sharpened by a factory variable M differential lock and a high-revving 8,000 RPM redline, providing exceptional lateral grip and communicative steering. While showing honest signs of use consistent with its mileage, the naturally aspirated power delivery and balanced 50/50 weight distribution remain uncompromised. A visceral, analog performance machine ready for the canyons.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 19
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car in good condition. Well-maintained. Clean title. Mechanically sound. Minimal exterior wear.",
      "price": 32000.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
