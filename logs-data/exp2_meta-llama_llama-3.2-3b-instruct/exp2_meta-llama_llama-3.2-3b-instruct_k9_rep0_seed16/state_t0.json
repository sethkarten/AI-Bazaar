    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a collector-grade E46 M3, a pinnacle of atmospheric engineering. This specimen features the legendary S54 3.2L inline-six, exhibiting perfect compression and a recently serviced VANOS system to ensure optimal variable valve timing. The Getrag 6-speed manual transmission provides tactile, short-throw engagement, channeling power through a pristine limited-slip differential. Structural integrity is guaranteed with proactive subframe reinforcement and fresh bushings throughout the multi-link rear suspension. The exterior retains its factory depth with zero paint correction required, while the interior Nappa leather remains supple and free of bolster wear. This is a mechanically transparent, high-revving icon for the serious driver.",
      "price": 47500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. One owner. Garage kept. Full service history. No accidents. Pristine interior. Runs perfectly.",
      "price": 48500.0,
