    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and transmission are functional, but the car shows noticeable wear from regular use. There are visible scratches and minor dents on the exterior, and the interior shows signs of aging.",
