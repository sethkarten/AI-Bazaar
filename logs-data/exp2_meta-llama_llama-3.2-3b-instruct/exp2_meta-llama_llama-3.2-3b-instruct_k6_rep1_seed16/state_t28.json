    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is an investment-grade E46 M3 featuring the legendary S54 inline-six engine, complete with its high-pressure double-VANOS system and individual throttle bodies. This chassis is mechanically flawless, boasting a reinforced rear subframe and documented preventative rod bearing replacement. The Getrag 420G six-speed manual transmission delivers precise, tactile shifts into a factory-spec limited-slip differential. Every suspension component maintains original geometry with zero bushing deflection. Presented with original VIN-matched panels and a pristine undercarriage, this vehicle represents the pinnacle of naturally aspirated M-division performance.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 28
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. Low mileage. No accidents. Clean title. Inspections welcome.",
      "price": 43500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
