      "quality_value": 0.7,
      "timestep_posted": 14
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in poor condition and is being sold strictly as-is, making it an ideal candidate for a dedicated project or for salvaging parts. The engine has significant performance issues and a noticeable oil leak, while the body shows extensive rust, particularly around the wheel wells and undercarriage. Inside, the upholstery is heavily worn and torn, and the electronic components, including the radio and AC, are largely non-functional. Please expect to invest considerable time and resources to get this vehicle roadworthy again.",
      "price": 3200.0,
      "reputation": 0.8,
