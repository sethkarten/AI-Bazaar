      "quality_value": 0.4,
      "timestep_posted": 43
    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Calling all DIY enthusiasts and project seekers! This car is ready for a total transformation and offers a great foundation for someone who loves to get their hands dirty. While it currently needs significant mechanical and cosmetic attention, it's a fantastic opportunity to own a classic model at a fraction of the cost. If you're looking for a rewarding restoration project, this is the one for you!",
      "price": 8500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
