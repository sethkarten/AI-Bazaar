      "reputation": 0.5,
      "quality": "good",
      "quality_value": 0.7,
      "timestep_posted": 47
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is being sold in poor condition and is best suited as a project car or for parts. The engine currently runs roughly and will likely require a major overhaul, and the transmission exhibits significant slipping between gears. Externally, there is noticeable rust on the rocker panels and several large dents, while the interior shows heavy wear, including torn upholstery and non-functional electronics. Please be aware that it will need to be towed or extensively repaired before it is roadworthy.",
      "price": 4500.0,
