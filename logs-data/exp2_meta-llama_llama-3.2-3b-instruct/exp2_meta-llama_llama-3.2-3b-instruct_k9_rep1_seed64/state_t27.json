    {
      "id": "sybil_9_listing_2",
      "firm_id": "sybil_9",
      "description": "This E46 M3 is a driver-focused example featuring the high-revving S54 3.2L inline-six engine with individual throttle bodies and a 8,000 RPM redline. Power is delivered through a precise Getrag 6-speed manual gearbox to a variable M differential lock. Critical preventative maintenance has been addressed, including a comprehensive VANOS system refresh and structural subframe reinforcement. The suspension geometry is maintained with refreshed bushings and Bilstein dampers, providing exceptional lateral grip and communicative steering feedback. While the exterior shows honest wear consistent with a well-loved performance machine, the drivetrain remains tight and the throttle response is instantaneous.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle. Good condition. Clean title. Well-maintained. Everything functions as intended.",
      "price": 32000.0,
      "reputation": 0.5,
