      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m selling my absolute pride and joy. Honestly, this car is a total dream\u2014it looks and drives like it just rolled off the showroom floor! I\u2019ve been super meticulous with it, so it\u2019s stayed in pristine condition inside and out. If you're looking for something that feels practically brand new and has been loved every mile, you\u2019ve gotta come see this beauty. It\u2019s ready for its next adventure!",
      "price": 44500.0,
      "reputation": 0.5,
