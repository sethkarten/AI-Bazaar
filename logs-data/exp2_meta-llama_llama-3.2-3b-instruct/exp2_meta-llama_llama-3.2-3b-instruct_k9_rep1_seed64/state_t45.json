    {
      "id": "sybil_9_listing_2",
      "firm_id": "sybil_9",
      "description": "Offered is an investment-grade E46 M3, showcasing the pinnacle of BMW\u2019s naturally aspirated engineering. The S54B32 power plant remains factory-spec, delivering linear power through six individual throttle bodies and high-pressure VANOS, both recently serviced to ensure optimal valve timing. The chassis is structurally sound with documented subframe reinforcement, paired with a crisp Getrag 6-speed manual transmission. Performance is anchored by a limited-slip variable M differential and a meticulously maintained suspension geometry. This example exhibits zero fluid seepage, precise throttle response, and a pristine undercarriage, representing a turnkey acquisition for the discerning collector.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. Full service history. No accidents. Clean title.",
      "price": 43500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
