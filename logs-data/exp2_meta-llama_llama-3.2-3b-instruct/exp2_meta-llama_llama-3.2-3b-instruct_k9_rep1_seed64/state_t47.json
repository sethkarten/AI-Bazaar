      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an automotive specimen of unparalleled preservation. This vehicle maintains its original showroom luster, having been curated with meticulous attention to detail. Every surface, from the hand-finished interior to the flawless exterior, reflects a standard of care that satisfies the most discerning collector. An uncompromising choice for those who demand excellence and a vehicle in its peak aesthetic and mechanical state.",
      "price": 48500.0,
