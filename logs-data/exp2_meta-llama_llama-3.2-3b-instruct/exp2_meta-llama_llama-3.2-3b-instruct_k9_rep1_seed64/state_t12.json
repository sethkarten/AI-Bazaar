    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available now is an investment-grade 2004 BMW M3 (E46) in impeccable condition. This chassis is powered by the high-revving S54 3.2L inline-six, utilizing individual throttle bodies and Double VANOS to achieve a linear power band up to its 8,000 RPM redline. The Getrag 420G 6-speed manual gearbox offers precise throw, transferring torque through a reinforced subframe to a factory limited-slip differential. Recent comprehensive servicing includes a full VANOS overhaul and rod bearing replacement for long-term mechanical reliability. The suspension geometry remains true to factory specifications, providing the telepathic steering feedback this platform is renowned for. A rare opportunity for a purist to acquire a mechanically flawless, collector-tier example of BMW's finest analog engineering.",
      "price": 48900.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 12
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. Full service records. No accidents. Original paint. Interior is pristine.",
      "price": 43500.0,
      "reputation": 0.5,
