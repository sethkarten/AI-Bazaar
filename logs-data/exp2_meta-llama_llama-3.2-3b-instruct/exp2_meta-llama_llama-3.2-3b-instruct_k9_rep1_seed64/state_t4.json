      "quality_value": 0.1,
      "timestep_posted": 4
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting a collector-grade example of automotive engineering, maintained to an exacting standard. This vehicle features a high-revving, naturally aspirated powerplant with documented consistent compression and leak-down figures. The drivetrain is anchored by a precise short-throw manual transmission and a factory-calibrated limited-slip differential, ensuring linear power delivery and exceptional lateral grip. Chassis dynamics are sharp, benefiting from a comprehensive suspension refresh using OEM+ components and reinforced mounting points. The exterior retains its factory depth and luster, free of any structural or cosmetic imperfections. Every mechanical system, from the cooling stack to the valvetrain, functions with surgical precision. This is a turn-key investment for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 4
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Clean title. Garage kept. No mechanical issues. No scratches or dents. Inspection records available.",
      "price": 43500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
