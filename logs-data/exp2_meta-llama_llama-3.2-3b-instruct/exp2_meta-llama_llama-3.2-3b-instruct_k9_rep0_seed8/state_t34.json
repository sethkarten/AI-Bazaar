    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2020 model. One owner. Zero accidents. Garage kept. Paint is flawless. Interior is factory clean. Full service records included. Runs like new.",
      "price": 43500.0,
