    {
      "id": "sybil_9_listing_2",
      "firm_id": "sybil_9",
      "description": "Offered is a mechanically robust E46 M3 featuring the high-revving S54 3.2L inline-six engine equipped with individual throttle bodies. This unit utilizes a Getrag 420G 6-speed manual transmission and a factory-spec limited-slip differential. Critical preventative maintenance has been addressed, including a comprehensive VANOS system overhaul and a rear subframe reinforcement check. The suspension maintains factory kinematics for precise turn-in, and the engine pulls cleanly to its 8,000 RPM redline with no hesitation in the variable valve timing. A compelling example for the purist seeking authentic M-division performance and tactile feedback.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
