      "timestep_posted": 9
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presented in exemplary, showroom-standard condition, this vehicle represents the pinnacle of automotive preservation. Every surface reflects meticulous care, from the flawless exterior finish to the pristine, smoke-free interior. Mechanically beyond reproach and accompanied by a comprehensive service history, this specimen offers an uncompromising driving experience for the discerning enthusiast who demands nothing less than perfection.",
      "price": 48500.0,
