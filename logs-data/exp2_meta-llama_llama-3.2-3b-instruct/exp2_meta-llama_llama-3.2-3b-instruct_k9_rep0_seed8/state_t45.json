      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! Are you looking for a reliable ride that\u2019s ready for its next adventure? I\u2019m selling my car and it\u2019s been such a joy to drive! It\u2019s in really solid shape, runs super smooth, and the interior is nice and clean. It\u2019s perfect for getting around town or hitting the highway for a weekend getaway. I've taken great care of it, and I'd love to see it go to a good home. Feel free to reach out with any questions!",
      "price": 32000.0,
      "reputation": 0.5,
