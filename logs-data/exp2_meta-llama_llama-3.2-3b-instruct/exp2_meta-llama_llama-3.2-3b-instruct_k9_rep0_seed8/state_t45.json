      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_9_listing_2",
      "firm_id": "sybil_9",
      "description": "Up for sale is a mechanically sound 2004 BMW M3 (E46) featuring the legendary S54 naturally aspirated inline-six. This unit delivers linear power through six individual throttle bodies and a crisp Getrag 6-speed manual gearbox. The chassis remains taut with a factory-spec limited-slip differential and recently inspected subframe mounting points. Maintenance is up to date, including a comprehensive VANOS service and rod bearing replacement\u2014crucial for high-revving longevity. Suspension components utilize refreshed bushings to maintain the iconic 50/50 weight distribution handling characteristics. A driver-focused example ready for the twisties.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Reliable used car. Well-maintained engine. Clean interior. Minor cosmetic wear. Service records available. Runs smooth.",
      "price": 32000.0,
      "reputation": 0.5,
