      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Full service records. No accidents. Garage kept.",
      "price": 43500.0,
