    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m parting ways with my absolute pride and joy, and honestly, she\u2019s a total stunner. This car is in showroom condition\u2014I've babied it since day one, so it looks and drives exactly like it did the day I picked it up. No scratches, no smells, just pure perfection! I\u2019m looking for a quick, easy sale to someone who will love it as much as I do. Feel free to reach out with any questions!",
      "price": 43500.0,
      "reputation": 0.5,
