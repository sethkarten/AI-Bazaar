    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an exceptional E46 M3, a pinnacle of atmospheric engineering. This example features the high-revving S54B32 inline-six, benefitting from proactive rod bearing replacement and a full VANOS refresh to ensure mechanical longevity. The Getrag 6-speed manual gearbox provides tactile engagement, channeling power through a factory limited-slip differential. The chassis has been meticulously preserved with documented subframe reinforcement, while the suspension geometry remains sharp and responsive. Finished in impeccable factory paint with an interior devoid of typical wear, this specimen represents a turn-key investment for the discerning purist.",
      "price": 46500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. No accidents. Full service records. Clean title.",
      "price": 44500.0,
