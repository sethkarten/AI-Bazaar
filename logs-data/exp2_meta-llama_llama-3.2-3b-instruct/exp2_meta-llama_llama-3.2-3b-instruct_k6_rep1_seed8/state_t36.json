    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is a superlative E46 M3, showcasing the pinnacle of naturally aspirated inline-six engineering. This S54-powered icon features a pristine Getrag 6-speed manual gearbox and a fully serviced variable M-differential. The mechanical integrity is absolute: rod bearings have been addressed, and the rear subframe has been proactively reinforced with a structural epoxy and plate kit. Every component, from the high-pressure VANOS system to the individual throttle bodies, operates with factory precision. The chassis remains rigid and responsive, supported by OEM-spec Sachs dampers and fresh bushings. This is a collector-grade example with zero deferred maintenance, presenting in a state that satisfies the most rigorous pre-purchase inspection.",
      "price": 46500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Showroom condition. Zero mechanical issues. Original paint. Interior like new. Full service history included.",
      "price": 47500.0,
      "reputation": 0.6,
