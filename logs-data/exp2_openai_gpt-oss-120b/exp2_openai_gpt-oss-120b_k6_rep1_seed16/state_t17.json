    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Calling all DIY enthusiasts and restoration lovers! This vehicle is ready for a second lease on life and offers a fantastic opportunity for someone looking for a dedicated project. While it is currently in poor condition and requires significant mechanical and cosmetic attention, it serves as a great foundation for a full rebuild or a valuable source of parts. If you're looking for a rewarding challenge to bring a classic back to the road, this is the one for you!",
      "price": 5500.0,
