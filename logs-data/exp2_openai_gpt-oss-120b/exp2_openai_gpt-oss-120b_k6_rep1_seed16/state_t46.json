    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in poor condition and is being sold strictly as-is for parts or a major restoration project. The engine suffers from significant mechanical failure and struggles to stay running, while the transmission exhibits severe slipping. The exterior has extensive rust and body damage, and the interior shows heavy wear and tear with multiple missing components. This car is not roadworthy and will require towing.",
      "price": 3500.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
