    },
    {
      "id": "sybil_13_listing_2",
      "firm_id": "sybil_13",
      "description": "Presenting an investment-grade 2004 BMW M3 (E46) in pristine Carbon Black over Cinnamon Nappa leather. This example features the legendary S54 3.2L inline-six, naturally aspirated with six individual throttle bodies and a 7,900 RPM redline. Mechanically flawless, the critical 'Big Three' have been addressed: rod bearings replaced with VAC coated shells, a comprehensive Beisan Systems VANOS overhaul, and a proactive structural subframe reinforcement. The Getrag 6-speed manual gearbox offers crisp, short-throw engagement, delivering power through the M Variable Differential Lock. Suspension geometry is dialed with refreshed bushings and dampers, maintaining the chassis' signature telepathic turn-in. Zero paint metered",
      "price": 50000.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 44
    },
    {
      "id": "sybil_11_listing_3",
      "firm_id": "sybil_11",
      "description": "Mint condition. Single owner. Zero accidents. Garage kept. Full service history available. Professional inspection welcome.",
      "price": 43500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
