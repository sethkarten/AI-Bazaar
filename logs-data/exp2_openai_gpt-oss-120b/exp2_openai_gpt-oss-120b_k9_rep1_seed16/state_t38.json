      "quality_value": 0.1,
      "timestep_posted": 38
    },
    {
      "id": "sybil_16_listing_6",
      "firm_id": "sybil_16",
      "description": "Hey there! You've seriously got to see this absolute gem! It\u2019s in such incredible shape, honestly, it looks and feels like it just rolled off the showroom floor. I've taken such good care of it\u2014not a single scratch or smudge anywhere. It drives like a total dream and is ready for a new home today. You won't find another one this clean out there! Come take a look, you\u2019re going to fall in love with it!",
      "price": 43500.0,
      "reputation": 0.4,
