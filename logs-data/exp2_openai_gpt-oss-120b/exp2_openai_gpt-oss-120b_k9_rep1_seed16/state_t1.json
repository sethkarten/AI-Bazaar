      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2022 Performance Coupe. 4,200 miles. Original paint. Smoke-free interior. Garage kept. Service records included.",
      "price": 47500.0,
