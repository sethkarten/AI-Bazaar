      "timestep_posted": 35
    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "Up for sale is a mechanically robust E46 M3 powered by the high-revving S54 inline-six engine. This unit features crisp throttle response via its individual throttle bodies and a smooth-shifting Getrag 6-speed manual gearbox. Crucial preventative maintenance has been addressed, including rear subframe reinforcement and a full VANOS overhaul to ensure timing precision. The suspension geometry remains tight with upgraded bushings, and the variable M differential provides excellent corner-exit traction. While the exterior shows honest wear consistent with a well-loved performance machine, the drivetrain and chassis integrity are top-tier for the discerning enthusiast.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 35
    },
    {
      "id": "sybil_9_listing_3",
