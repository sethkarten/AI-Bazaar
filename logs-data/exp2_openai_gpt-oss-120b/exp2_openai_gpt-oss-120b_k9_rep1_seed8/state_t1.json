    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m finally parting ways with my absolute pride and joy. This car has been pampered since day one\u2014honestly, it looks and feels like it just rolled off the showroom floor! It\u2019s been kept in a climate-controlled garage and is in truly pristine shape inside and out. If you\u2019re looking for a ride that\u2019s been loved and cared for with zero shortcuts, this is the one. Come see it for yourself, you won\u2019t be disappointed!",
      "price": 48500.0,
      "reputation": 0.8,
