    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a vehicle of exceptional caliber, maintained to the highest standards of automotive excellence. This unit exhibits a pristine aesthetic and mechanical integrity synonymous with showroom condition. Every detail has been meticulously preserved, offering an unrivaled driving experience for the discerning collector or enthusiast. We invite you to inspect this benchmark of quality, which stands as a testament to rigorous care and superior preservation.",
      "price": 46500.0,
      "reputation": 0.5,
