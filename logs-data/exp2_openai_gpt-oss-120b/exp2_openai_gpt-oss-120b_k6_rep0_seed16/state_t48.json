    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior and interior are pristine with no signs of wear or damage. All mechanical systems are fully functional and the car has been maintained to the highest standards.",
