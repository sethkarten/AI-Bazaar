      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_17_listing_2",
      "firm_id": "sybil_17",
      "description": "Presenting an investment-grade 2004 BMW M3 (E46) in concours-level condition. This specimen features the high-revving S54 3.2L inline-six, utilizing individual throttle bodies and double VANOS to deliver a linear power band up to an 8,000 RPM redline. Power is managed via a Getrag 6-speed manual transmission and a factory M-Variable limited-slip differential. The chassis is impeccable, with documented subframe reinforcement and a recent comprehensive suspension refresh using OEM bushings. The exterior retains its factory depth with no discernible rock chips or oxidation, while the interior Nappa leather remains supple and free of bolster wear. Mechanically optimized with proactive rod bearing replacement, this is a turn-key example for the discerning collector.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_15_listing_3",
      "firm_id": "sybil_15",
      "description": "Mint condition. Single owner. Garage kept. No accidents. Clean title. Full service history. Inspect in person. Firm price.",
      "price": 43500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
