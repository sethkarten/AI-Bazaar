    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and transmission function reliably, and all primary mechanical systems are operational. The exterior has minor cosmetic wear, and the interior shows signs of regular use.",
      "price": 33000.0,
      "reputation": 0.9,
