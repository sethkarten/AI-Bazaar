    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior and interior are well-maintained with only minor signs of use. All mechanical systems are fully functional and the car has been serviced regularly.",
      "price": 33000.0,
      "reputation": 1.0,
