      "quality_value": 0.1,
      "timestep_posted": 41
    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "Available is a driver-focused E46 M3 featuring the legendary S54 inline-six, delivering 333hp through six individual throttle bodies. This example retains its mechanical purity with a 6-speed Getrag manual transmission and the factory variable M differential lock. The high-revving valvetrain remains crisp, and the VANOS system has been professionally serviced to ensure optimal cam timing. Chassis integrity is verified with documented subframe reinforcement, addressing the platform's known lateral stress points. Suspension geometry remains true, utilizing refreshed bushings and dampening that preserves the iconic 50/50 weight distribution. A mechanically sound specimen for the purist who values turn-in precision and an 8,000 RPM redline.",
      "price": 33500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 41
    },
    {
      "id": "sybil_15_listing_3",
      "firm_id": "sybil_15",
      "description": "Used vehicle in good condition. Engine runs strong. Interior is clean and well-kept. Minor exterior blemishes. Maintenance records available. Ready to drive.",
      "price": 36500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
