      "quality_value": 0.4,
      "timestep_posted": 15
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in absolute mint condition, truly reflecting showroom quality inside and out. The exterior paint is flawless with a deep, mirror-like finish, and the interior remains in a pristine state, showing no signs of wear or age. Every feature functions perfectly, and the car has been meticulously maintained to preserve its original excellence. This is a rare opportunity for a collector or discerning buyer to own a vehicle that looks and drives as if it just rolled off the assembly line.",
      "price": 49500.0,
