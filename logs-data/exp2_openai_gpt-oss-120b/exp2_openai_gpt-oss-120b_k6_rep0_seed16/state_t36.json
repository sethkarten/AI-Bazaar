    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The engine and transmission require significant repair or replacement to be reliable. The exterior has major body damage and rust, and the interior is heavily worn with several broken components.",
      "price": 5500.0,
      "reputation": 1.0,
