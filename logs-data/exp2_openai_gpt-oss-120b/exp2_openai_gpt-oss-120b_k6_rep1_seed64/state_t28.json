      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 28
    },
    {
      "id": "sybil_6_listing_3",
      "firm_id": "sybil_6",
      "description": "Mint condition. Garage kept. No accidents. Smoke-free interior. Full service records included. Inspections welcome.",
