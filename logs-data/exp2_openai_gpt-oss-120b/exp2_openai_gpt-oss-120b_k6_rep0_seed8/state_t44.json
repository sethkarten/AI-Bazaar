    },
    {
      "id": "sybil_9_listing_0",
      "firm_id": "sybil_9",
      "description": "Presenting an unparalleled example of automotive excellence. This vehicle remains in showroom condition, featuring a flawless exterior and an interior that retains its original factory integrity. Meticulously curated and strictly maintained, this unit represents a rare opportunity for the discerning collector or enthusiast seeking a definitive, investment-grade acquisition. Comprehensive service records accompany this pristine vessel.",
      "price": 44900.0,
      "reputation": 0.3,
