    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Check out this dependable ride! It\u2019s a solid, honest vehicle that has been well-loved and is ready for its next chapter. While it shows some expected signs of use and character from its time on the road, it remains a reliable choice for anyone looking for a functional car at a great price. Perfect for a daily commuter who values practicality and steady performance!",
      "price": 18500.0,
