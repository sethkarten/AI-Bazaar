    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has significant damage, including deep scratches and rust. The interior is heavily worn and requires refurbishment. Mechanically, the car requires major repairs to be fully operational.",
      "price": 4500.0,
      "reputation": 1.0,
