    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior has minor surface wear, and the interior is well-maintained with some signs of previous use. All major mechanical systems are functional and the car has been regularly serviced.",
