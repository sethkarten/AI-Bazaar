      "quality_value": 0.1,
      "timestep_posted": 7
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a meticulously maintained specimen that balances robust performance with sophisticated aesthetics. This vehicle has undergone a comprehensive multi-point inspection to ensure mechanical excellence and enduring reliability. An exceptional opportunity for the discerning driver seeking a refined automotive experience and consistent performance standards.",
      "price": 34900.0,
      "reputation": 0.8,
