      "quality_value": 0.1,
      "timestep_posted": 29
    },
    {
      "id": "sybil_12_listing_2",
      "firm_id": "sybil_12",
      "description": "Offered is an investment-grade E46 M3, showcasing the pinnacle of the S54B32 high-revving 3.2L straight-six with individual throttle bodies and double VANOS. This specimen features a pristine subframe with documented reinforcement and a comprehensive preventative rod bearing service. Power is delivered through a crisp 6-speed manual gearbox to a variable M-differential lock. The chassis dynamics are factory-spec, retaining the original tuned suspension geometry with zero bushing deflection. Meticulously maintained with a flawless exterior finish and a cabin devoid of bolster wear, this vehicle represents a rare opportunity for the discerning collector seeking mechanical perfection.",
      "price": 44500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 29
    },
    {
      "id": "sybil_16_listing_3",
