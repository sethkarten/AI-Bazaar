    },
    {
      "id": "sybil_19_listing_2",
      "firm_id": "sybil_19",
      "description": "Offering a museum-quality E46 M3, a masterclass in naturally aspirated performance. This specimen features the legendary S54 straight-six, equipped with individual throttle bodies and a recently recalibrated VANOS system. The drivetrain is anchored by a precise six-speed Getrag manual transmission and a variable M-differential lock, ensuring optimal torque distribution. Mechanically flawless, it boasts documented rod bearing replacement and proactive rear subframe reinforcement to maintain chassis torsional rigidity. The factory suspension geometry remains true, providing the communicative steering and balanced damping characteristic of a true driver\u2019s car. This is a turn-key investment for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_16_listing_3",
      "firm_id": "sybil_16",
      "description": "Mint condition. Flawless paint. Clean interior. Mechanically perfect. Detailed maintenance records included.",
      "price": 43500.0,
