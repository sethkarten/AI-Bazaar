      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this meticulously maintained vehicle, offering a sophisticated blend of performance and reliability. This unit exhibits consistent mechanical integrity and a well-preserved aesthetic, reflecting a history of attentive ownership. It serves as an ideal selection for the discerning driver seeking a premium automotive experience at a highly competitive price point. Thoroughly inspected and ready for professional acquisition.",
      "price": 32500.0,
