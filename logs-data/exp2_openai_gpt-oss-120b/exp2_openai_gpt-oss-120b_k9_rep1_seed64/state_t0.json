      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a concours-level E46 M3 featuring the legendary S54 3.2L inline-six. This high-revving power plant utilizes individual throttle bodies and a high-pressure double VANOS system, delivering linear power delivery up to an 8,000 RPM redline. The drivetrain is anchored by a crisp Getrag 6-speed manual transmission and an M Variable Differential Lock for superior corner-exit traction. This specimen boasts a reinforced rear subframe and refreshed bushings, ensuring maximum torsional rigidity. The factory suspension geometry remains precise, complemented by flawless bodywork and an interior free of typical bolster wear. A mechanically peerless example for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Zero mechanical issues. Original paint. Interior flawless. Full service history included.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
