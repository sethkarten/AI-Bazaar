      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m looking to find a new home for my trusty car. It\u2019s been super reliable and is in really solid shape, perfect for someone who wants a dependable ride that still looks great in the driveway. It drives like a dream and has been well-loved! I\u2019d love for you to come take it for a spin and see for yourself how smooth it is. Drop me a message if you're interested!",
      "price": 32500.0,
      "reputation": 0.6,
