      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\udc4b I'm selling my trusty ride, and honestly, it\u2019s been such a joy to drive! It\u2019s in really solid shape and has been well-loved over the years. It runs smoothly, looks great at the curb, and is ready to hit the road for its next big adventure. If you're looking for a dependable car that\u2019s been taken care of, you\u2019ve found it! Feel free to reach out with any questions\u2014I'd love to see this go to a great new home!",
      "price": 32500.0,
      "reputation": 0.6,
