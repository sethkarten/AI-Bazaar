    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Calling all restoration fans and project seekers! This vehicle is ready for a second lease on life and offers a fantastic foundation for anyone looking to roll up their sleeves. While it currently needs significant mechanical and cosmetic attention, it's the perfect canvas for a dedicated builder to create something special. Grab this diamond in the rough and start your next great automotive adventure today!",
      "price": 5500.0,
