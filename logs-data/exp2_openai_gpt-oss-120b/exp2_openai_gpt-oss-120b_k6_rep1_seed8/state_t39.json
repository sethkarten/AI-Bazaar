    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. There are no signs of wear on the interior or exterior. All mechanical and electronic systems are in perfect working order, and the car is in like-new condition.",
      "price": 50000.0,
