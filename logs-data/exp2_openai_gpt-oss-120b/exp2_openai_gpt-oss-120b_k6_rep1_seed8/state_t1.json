      "timestep_posted": 1
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This collector-grade E46 M3 represents the pinnacle of naturally aspirated engineering. Power is delivered via the legendary S54 3.2L inline-six, featuring individual throttle bodies and a dual-VANOS system that pulls relentlessly to an 8,000 RPM redline. The chassis is impeccably preserved, featuring a crisp 6-speed Getrag manual transmission and a factory-calibrated helical limited-slip differential. Maintenance is exhaustive and proactive, with documented rod bearing replacement, VANOS overhaul, and rear subframe reinforcement to ensure absolute structural integrity. Finished in Laguna Seca Blue, the paint depth is flawless and the interior remains in showroom state, free from bolster wear or UV degradation. A turn-key purist\u2019s example with zero mechanical compromises.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. Full service records. No accidents.",
