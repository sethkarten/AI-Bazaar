    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior and interior are pristine with no signs of wear or damage. All mechanical systems are in perfect working order, and the car has been meticulously maintained to original standards.",
      "price": 48000.0,
      "reputation": 1.0,
