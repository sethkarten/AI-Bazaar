    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and is best suited for a dedicated project restorer or as a comprehensive parts donor. The exterior displays significant rust perforation on the lower body panels and wheel arches, and the paint is heavily faded with clear coat failure throughout. Mechanically, the engine requires a major overhaul and is currently not in running condition, and the transmission exhibits signs of slipping. Inside, the upholstery is heavily torn and the dashboard is cracked from sun exposure. This is a true 'fixer-upper' sold strictly as-is.",
      "price": 3500.0,
      "reputation": 1.0,
      "quality": "poor",
