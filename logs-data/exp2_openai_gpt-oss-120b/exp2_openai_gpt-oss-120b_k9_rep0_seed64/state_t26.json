      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this exemplary vehicle, maintained to the most exacting standards. This specimen is in pristine, showroom condition, featuring a flawless exterior and an interior that remains indistinguishable from its original factory state. Every mechanical system has been subjected to a rigorous multi-point inspection to ensure peerless performance and reliability. For the discerning collector or enthusiast who demands uncompromising quality, this vehicle represents a rare opportunity to secure a premier asset.",
      "price": 44500.0,
