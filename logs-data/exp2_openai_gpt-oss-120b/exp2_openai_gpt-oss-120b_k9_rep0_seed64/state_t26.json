      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_12_listing_2",
      "firm_id": "sybil_12",
      "description": "Offered is an exceptional E46 M3, a true collector-grade specimen featuring the high-revving S54 straight-six power plant. This unit boasts a meticulously maintained VANOS system and individual throttle bodies that provide instantaneous throttle response up to its 8,000 RPM redline. The Getrag 6-speed manual transmission delivers crisp, tactile shifts, paired with a variable M differential lock for superior corner-exit traction. Crucially, the rear subframe has been professionally reinforced, and the rod bearings have been addressed as preventative maintenance. The exterior retains its factory-original luster with zero paint correction required, while the interior features pristine Nappa leather with no bolster fatigue. This is a mechanically transparent, turn-key investment for the purist who demands peak BMW M-division performance.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_16_listing_3",
      "firm_id": "sybil_16",
      "description": "Mint condition. Single owner. Garage kept. No accidents. Full service history. Inspections welcome.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
