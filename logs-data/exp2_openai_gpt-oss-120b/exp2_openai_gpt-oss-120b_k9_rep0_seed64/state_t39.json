    },
    {
      "id": "sybil_19_listing_3",
      "firm_id": "sybil_19",
      "description": "Mint condition. Garage kept. No accidents. Original paint. Full service records included. Title in hand.",
      "price": 43500.0,
      "reputation": 0.7,
