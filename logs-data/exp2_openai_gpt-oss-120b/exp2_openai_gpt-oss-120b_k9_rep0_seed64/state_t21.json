    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exemplary specimen, maintained to an uncompromising standard and presented in showroom condition. This vehicle exhibits flawless aesthetic integrity and mechanical precision, offering a driving experience indistinguishable from new. A rare acquisition for the discerning enthusiast who demands nothing less than perfection.",
      "price": 48900.0,
