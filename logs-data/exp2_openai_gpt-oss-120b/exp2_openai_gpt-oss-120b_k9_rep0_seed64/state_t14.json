      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 2004 BMW M3 is a superlative example of the E46 chassis, maintained to a collector-grade standard. It is powered by the S54 3.2L naturally aspirated inline-six engine, featuring individual throttle bodies and a high-pressure Vanos system that has been meticulously serviced to ensure optimal cam timing. The power is delivered via a Getrag 420G six-speed manual transmission and a factory M-variable limited-slip differential. Critical preventative maintenance",
      "price": 50000.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_10_listing_3",
