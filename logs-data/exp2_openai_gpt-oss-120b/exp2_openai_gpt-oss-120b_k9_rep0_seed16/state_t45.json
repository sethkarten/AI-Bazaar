      "timestep_posted": 45
    },
    {
      "id": "sybil_18_listing_2",
      "firm_id": "sybil_18",
      "description": "This 997.1 Carrera S is an exceptional example of Stuttgart\u2019s precision engineering, preserved in collector-grade condition. Powered by the 3.8L M97.01 naturally aspirated flat-six,",
      "price": 50000.0,
      "reputation": 0.3,
