    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and transmission are functional, though they show signs of age and mileage. The exterior has several visible scratches and minor dents, and the interior upholstery shows noticeable wear. All primary mechanical systems are currently operational.",
      "price": 20000.0,
