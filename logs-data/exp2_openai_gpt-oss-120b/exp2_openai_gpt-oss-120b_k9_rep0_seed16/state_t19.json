    },
    {
      "id": "sybil_12_listing_2",
      "firm_id": "sybil_12",
      "description": "This E46 M3 is a concours-level example featuring the legendary S54 3.2L inline-six engine with individual throttle bodies and a 7,900 RPM redline. The chassis is structurally optimized with a reinforced rear subframe and a comprehensive VANOS overhaul. Power is delivered through a precise 6-speed Getrag manual transmission to a variable M differential lock. Finished in Carbon Black over Nappa leather, the vehicle exhibits a flawless underside and documented rod bearing replacement. It remains in a strictly preserved state, offering a pure analog driving experience with zero mechanical compromises.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 19
    },
    {
      "id": "sybil_9_listing_3",
