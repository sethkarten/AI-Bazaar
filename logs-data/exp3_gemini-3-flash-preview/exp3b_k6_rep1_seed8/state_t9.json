    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "The car is in poor condition. The exterior has significant body damage and corrosion, and the interior is heavily worn. It has major mechanical issues and requires extensive repairs to be functional.",
      "price": 3200.0,
      "reputation": 0.8,
