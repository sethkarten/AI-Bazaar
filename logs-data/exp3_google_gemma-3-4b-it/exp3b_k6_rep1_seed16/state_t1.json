      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 996.2-generation Carrera 4S is a superlative specimen, showcasing a 3.6L flat-six engine with VarioCam Plus that delivers linear power delivery through a precise G96 six-speed manual transaxle. The wide-body chassis maintains exceptional torsional rigidity, paired with an all-wheel-drive system that utilizes a viscous coupling for seamless torque distribution. Mechanically, this unit is beyond reproach: the IMS bearing has been proactively addressed, and the cooling system features recently overhauled radiators and water pump. The suspension retains factory kinematics, providing neutral handling",
      "price": 50000.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. No mechanical issues. Detailed service records included.",
      "price": 47500.0,
      "reputation": 0.8,
