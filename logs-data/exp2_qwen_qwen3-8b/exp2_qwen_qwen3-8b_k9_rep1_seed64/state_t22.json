      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\udc4b I'm selling my absolute pride and joy. This beauty is in incredible shape\u2014honestly, it looks and feels like it just rolled off the showroom floor! It\u2019s been meticulously cared for, kept in a garage, and it runs like a total dream. You won\u2019t find another one this clean out there. Come take a look, you\u2019re going to fall in love with it! \u2728",
      "price": 43900.0,
