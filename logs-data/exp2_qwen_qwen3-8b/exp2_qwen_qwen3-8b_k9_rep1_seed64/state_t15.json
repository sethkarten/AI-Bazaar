    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a meticulously maintained vehicle that exemplifies mechanical integrity and aesthetic appeal. This specimen offers a refined driving experience, having undergone a rigorous inspection to ensure it meets our exacting standards for reliability and performance. A premier choice for the discerning driver seeking a balance of luxury and long-term value.",
      "price": 34900.0,
      "reputation": 0.8,
