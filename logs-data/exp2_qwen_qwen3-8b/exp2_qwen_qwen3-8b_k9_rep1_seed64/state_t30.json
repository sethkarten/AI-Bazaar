    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a mechanically sound E46 M3 featuring the high-revving S54 inline-six with individual throttle bodies and a crisp Getrag 6-speed manual transmission. This example boasts a reinforced rear subframe and a recently serviced dual-VANOS system, ensuring peak variable valve timing performance. The chassis remains composed thanks to upgraded bushings and a factory-spec limited-slip differential that provides excellent lateral traction. While the exterior shows minor road-going patina, the drivetrain remains robust with linear power delivery up to the 8,000 RPM redline. A purist\u2019s specification for those valuing engineering over garage-queen aesthetics.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Well-maintained. Clean interior. Mechanically sound. Title in hand.",
      "price": 29500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
