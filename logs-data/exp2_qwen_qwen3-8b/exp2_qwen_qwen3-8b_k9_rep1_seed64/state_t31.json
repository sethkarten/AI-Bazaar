      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 31
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Well-maintained. Clean title. Minor cosmetic wear. Mechanically sound. Ready for inspection.",
      "price": 28500.0,
