      "timestep_posted": 9
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "This expertly curated vehicle represents a premier opportunity for the sophisticated buyer. It maintains a robust mechanical profile and an aesthetic that reflects conscientious ownership. Having passed our comprehensive multi-point inspection, this model demonstrates consistent performance and structural integrity. A distinguished choice for those seeking a dependable, high-caliber driving experience, this vehicle is offered in commendable condition and is prepared for immediate delivery.",
      "price": 36800.0,
