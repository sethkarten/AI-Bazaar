      "timestep_posted": 34
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an automotive specimen of unrivaled caliber. This vehicle remains in showroom condition, having been preserved with an uncompromising commitment to maintenance and care. Every facet, from the flawless exterior finish to the pristine interior appointments, reflects a standard of excellence rarely encountered in the pre-owned market. This is a definitive opportunity for the discerning buyer to secure a vehicle of exceptional integrity and mechanical perfection.",
      "price": 46500.0,
