      "timestep_posted": 33
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It is mechanically sound and has been well-maintained. There are minor signs of normal wear on both the interior and exterior surfaces. All major systems are fully functional.",
      "price": 34000.0,
