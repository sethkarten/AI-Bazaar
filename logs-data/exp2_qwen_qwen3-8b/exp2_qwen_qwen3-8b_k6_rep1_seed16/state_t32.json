      "quality_value": 0.1,
      "timestep_posted": 32
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Low mileage. No mechanical issues. Original paint. Clean title. Serious buyers only.",
