    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented in impeccable showroom condition, this vehicle exemplifies automotive excellence. Every detail reflects a standard of care that transcends typical ownership, offering a pristine aesthetic and mechanical profile indistinguishable from its original delivery state. This is an acquisition for the uncompromising enthusiast who prioritizes absolute quality and investment-grade preservation.",
      "price": 48500.0,
