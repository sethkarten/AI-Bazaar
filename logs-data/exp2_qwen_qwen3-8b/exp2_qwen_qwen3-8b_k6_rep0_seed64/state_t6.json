      "timestep_posted": 6
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Mint condition. One owner. Zero accidents. Original paint. Full service records. Smoke-free interior. Garage kept.",
