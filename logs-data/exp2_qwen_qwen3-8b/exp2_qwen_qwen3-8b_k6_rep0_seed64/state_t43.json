      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_12_listing_1",
      "firm_id": "sybil_12",
      "description": "Hey there! You\u2019ve got to see this beauty in person. It\u2019s been my absolute pride and joy and honestly looks like it just rolled off the showroom floor! I\u2019ve taken such good care of it\u2014not a scratch or a smudge in sight. It drives like an absolute dream and still has that wonderful new-car feel. I'm sad to let it go, but I know the next owner is going to fall in love with it just like I did. Feel free to reach out with any questions!",
      "price": 43900.0,
      "reputation": 0.6,
