    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in good condition and has been consistently well-maintained. The exterior paint still holds a great shine, though you may find a few minor stone chips on the hood and some very light surface scratches consistent with careful use. Inside, the cabin is clean and comfortable, showing only slight wear on the driver's seat bolster. Mechanically, it is sound and ready for its next owner to enjoy immediately.",
      "price": 34500.0,
      "reputation": 1.0,
      "quality": "good",
