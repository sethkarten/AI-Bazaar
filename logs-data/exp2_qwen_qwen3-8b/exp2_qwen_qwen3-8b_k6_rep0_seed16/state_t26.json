    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering an investment-grade 2004 BMW M3 (E46) in pristine condition. This example features the high-revving S54 3.2L inline-six, utilizing individual throttle bodies and a high-pressure VANOS system to achieve a 333hp output. Power is delivered through a tactile 6-speed Getrag manual gearbox to a variable M-differential lock. The chassis is structurally sound with documented rear subframe reinforcement, and the suspension retains its factory-spec damping and bushings. Meticulously maintained with a documented service history including rod bearing replacement. This is a mechanically synchronized, turn-key collector's piece for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_8_listing_3",
      "firm_id": "sybil_8",
      "description": "Mint condition. Single owner. Low mileage. Garage kept. No accidents. Clean title. Inspection welcome.",
      "price": 43500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
