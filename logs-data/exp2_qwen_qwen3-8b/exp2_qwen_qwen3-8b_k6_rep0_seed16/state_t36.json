    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The engine and transmission are currently operational but show signs of age. The exterior has visible scratches and minor dents, while the interior shows moderate wear from regular use.",
      "price": 18000.0,
