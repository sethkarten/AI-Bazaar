    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 features the legendary S54 3.2L inline-six, delivering linear power through six individual throttle bodies and a crisp 6-speed Getrag manual transmission. The chassis remains composed thanks to refreshed bushings and a reinforced rear subframe, while the factory limited-slip differential ensures optimal torque distribution. Recent VANOS service and valve adjustment ensure the high-revving valvetrain operates with factory precision. Equipped with a balanced coilover setup and stainless steel brake lines, this M3 offers an engaging, tactile driving experience for the serious enthusiast seeking a mechanically sound driver's car.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Used car. Good condition. Well-maintained. Clear title. Mechanicals sound. Minor cosmetic wear only.",
      "price": 34000.0,
      "reputation": 0.8,
