      "timestep_posted": 26
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2018 sedan in fair condition. The exterior has several visible scratches and minor dents. The interior shows significant wear and some staining on the upholstery. Mechanically, the car is operational but may require some maintenance in the near future.",
      "price": 20000.0,
