    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "$17,000 - 2018 sedan in fair condition. The exterior has several visible scratches and minor dings on the doors. The interior shows moderate wear, including some staining on the seats and carpet. It is functional but shows signs of regular use.",
      "price": 17000.0,
      "reputation": 1.0,
      "quality": "fair",
