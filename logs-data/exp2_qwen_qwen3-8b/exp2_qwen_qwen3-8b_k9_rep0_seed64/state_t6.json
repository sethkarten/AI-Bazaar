      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presented for your consideration is a vehicle of exceptional caliber, maintained to the highest standards of automotive preservation. This specimen exhibits an immaculate exterior finish complemented by a pristine interior that retains its original showroom luster. Mechanically beyond reproach, it has undergone a rigorous multi-point inspection to ensure it meets our exacting criteria for excellence. This is a rare opportunity to acquire a vehicle in truly peerless condition.",
