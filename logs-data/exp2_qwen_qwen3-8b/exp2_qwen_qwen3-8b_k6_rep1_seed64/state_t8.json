    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 features the legendary S54B32 power unit, delivering 333hp through six individual throttle bodies and a high-pressure Vanos system. It is paired with a Getrag 420G 6-speed manual transmission and a factory limited-slip differential. The rear subframe has been proactively reinforced with plates, and the rod bearings were serviced at 90k miles. Suspension geometry remains sharp with fresh bushings and Bilstein B6 dampers. While the exterior shows minor stone chipping consistent with spirited use, the mechanical synchronicity is superb, providing a linear power band up to the 8,000 RPM redline.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle in good condition. Regularly maintained. Clean title. Runs well. No mechanical issues.",
      "price": 34500.0,
      "reputation": 0.6,
