      "timestep_posted": 44
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2018 sedan in fair condition. The exterior has visible scratches and a small dent on the passenger door. The interior shows moderate wear on the seats and some staining on the carpet. All mechanical components are functional.",
      "price": 20000.0,
      "reputation": 1.0,
