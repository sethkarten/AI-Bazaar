    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting an investment-grade E46 M3, a masterclass in high-revving atmospheric performance. At its heart lies the S54 3.2L inline-six, featuring individual throttle bodies and a dual-VANOS system for razor-sharp throttle response across the entire power band. This example boasts a reinforced rear subframe and updated rod bearings, addressing critical longitudinal chassis and internal engine harmonics. The Getrag six-speed manual transmission facilitates tactile gear selection, while the factory limited-slip differential ensures precise power delivery. Meticulously maintained with an unblemished aesthetic and factory-spec suspension geometry, this vehicle represents the pinnacle of the analog driving experience.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. No scratches or dents. Original paint. Interior flawless. Full service history. Clean title.",
      "price": 44500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
