    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2020 sedan in poor condition. The exterior has significant body damage, including deep scratches and several large dents. The interior shows heavy wear, with torn upholstery and stained carpeting. The engine requires major repairs, and several electronic components are non-functional.",
      "price": 4500.0,
