    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2020 sedan in good condition. The exterior has a few minor surface scratches but no major dents. The interior is clean with slight wear on the driver's seat. All mechanical components are functioning properly and maintenance is up to date.",
      "price": 34000.0,
      "reputation": 1.0,
      "quality": "good",
