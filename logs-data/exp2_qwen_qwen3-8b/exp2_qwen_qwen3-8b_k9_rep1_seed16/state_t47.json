      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I am honestly so sad to let this absolute beauty go, but it\u2019s time for someone else to enjoy it! This car is in incredible shape\u2014it really looks and feels like it just rolled off the lot. It\u2019s been totally pampered, kept tucked away in the garage, and is sparkling clean inside and out. You've really got to see it in person to believe how pristine it is! It's perfect if you're looking for that brand-new car experience. Drop me a message and let's get you behind the wheel!",
      "price": 43500.0,
      "reputation": 0.3,
