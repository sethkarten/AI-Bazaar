      "quality_value": 0.1,
      "timestep_posted": 12
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I am so excited to show you this absolute gem. Seriously, it's in such incredible shape that it still feels like it just left the showroom! I've babied this car from day one\u2014not a single scratch or smudge to be found. It\u2019s been my pride and joy, and it drives like an absolute dream. If you're looking for something that's basically brand new without the sticker shock, you've found it! I'd love for you to come by and see it for yourself!",
      "price": 44500.0,
      "reputation": 0.6,
