      "quality_value": 0.1,
      "timestep_posted": 31
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a driver-focused E46 M3 featuring the high-revving S54B32 inline-six with individual throttle bodies and dual-VANOS variable valve timing. This example is equipped with the tactile 6-speed Getrag manual transmission and a factory M-Variable limited-slip differential. To ensure long-term chassis rigidity, the rear subframe has been reinforced, and the rod bearings were recently replaced as preventative maintenance. The suspension retains its sharp turn-in characteristics thanks to refreshed bushings and dampened struts. While the exterior shows minor age-appropriate patina, the mechanical synchronicity and linear power delivery remain uncompromised. A transparently maintained specimen for the purist who values mechanical pedigree over concours perfection.",
      "price": 32500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 31
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car. Good condition. Well-maintained. Ready for sale.",
      "price": 28500.0,
      "reputation": 0.4,
