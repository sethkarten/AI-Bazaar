    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is an exceptional specimen maintained to the highest standards of automotive excellence. This vehicle represents a rare opportunity for the discerning buyer, exhibiting no discernible wear and retaining its original factory luster. Every component has been meticulously vetted to ensure performance remains indistinguishable from new. This is an investment-grade acquisition intended for those who demand nothing less than perfection.",
      "price": 48500.0,
      "reputation": 0.7,
