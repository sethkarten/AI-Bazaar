      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is a museum-grade E46 M3, featuring the high-revving S54B32 power plant with its signature individual throttle bodies and double-VANOS variable valve timing. This specimen boasts a reinforced rear subframe and has undergone a comprehensive rod bearing replacement to ensure mechanical longevity. The Getrag 420G 6-speed manual gearbox provides crisp, tactile engagement, while the M-variable differential lock ensures optimal power delivery across the rear axle. Finished in Carbon Black over Nappa leather, the chassis remains stiff and responsive, free of any bushing deflection or hydraulic leaks. A true turn-key enthusiast example maintained to the highest standards of mechanical integrity.",
      "price": 48500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_9_listing_3",
