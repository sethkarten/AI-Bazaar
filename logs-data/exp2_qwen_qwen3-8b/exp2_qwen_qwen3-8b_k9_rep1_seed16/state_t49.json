    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This A80 chassis features the legendary 2JZ-GTE power plant, utilizing its sequential twin-turbocharged configuration to deliver linear torque across the rev range. The bottom end remains stout with factory internals, and the Getrag V160 6-speed manual transmission provides crisp, mechanical engagement. Recent maintenance includes a comprehensive timing belt service and a fresh fluid flush for the Torsen limited-slip differential. The suspension geometry remains true with refreshed bushings, ensuring the double-wishbone setup handles corner-exit loads with precision. While showing minor cosmetic patina consistent with a driver-focused vehicle, its mechanical synchronization and compression numbers are excellent.",
      "price": 34500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_12_listing_3",
      "firm_id": "sybil_12",
      "description": "Used car in good condition. Clean title. Regular maintenance records included. No mechanical issues. Firm price.",
      "price": 28500.0,
