    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a driver-focused example featuring the iconic S54 3.2L inline-six, delivering linear power through six individual throttle bodies. The chassis remains taut, benefiting from a reinforced rear subframe and refreshed bushings throughout the multi-link rear suspension. The Getrag 6-speed manual gearbox provides crisp engagement, paired with a factory limited-slip differential for optimal power delivery. Critical preventative maintenance has been addressed, including a comprehensive dual-VANOS overhaul and rod bearing inspection. While the exterior shows minor road patina consistent with enthusiast use, the mechanical synchronization and throttle response remain razor-sharp.",
      "price": 34500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car. Good condition. Well-maintained. Clean title. Reliable engine. Serious buyers only.",
      "price": 28500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
