    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It shows minor wear on the interior and exterior consistent with regular use. All mechanical systems are functioning properly, and the vehicle has been well-maintained.",
      "price": 38500.0,
