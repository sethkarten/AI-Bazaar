    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This meticulously maintained vehicle represents a premier opportunity for the discerning driver. Combining sophisticated engineering with a proven track record of reliability, it offers a refined driving experience. Every component has been evaluated to ensure mechanical integrity, presenting a professional aesthetic and consistent performance. Secure this distinguished example of automotive excellence today.",
      "price": 34500.0,
