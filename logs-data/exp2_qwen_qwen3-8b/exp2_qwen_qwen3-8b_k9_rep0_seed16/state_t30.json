    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This is an investment-grade E46 M3, featuring the high-revving S54 power unit with an 8,000 RPM redline and double-VANOS variable valve timing. The chassis exhibits zero fatigue, having undergone a comprehensive subframe reinforcement and a full suspension refresh using OEM Lemf\u00f6rder components. Power is transferred through a Getrag 6-speed manual gearbox to a limited-slip differential, ensuring peak mechanical grip. The engine bay is immaculate, with the individual throttle bodies synchronized to factory tolerances. This vehicle represents the pinnacle of naturally aspirated longitudinal engineering, maintained with a 'spare no expense' philosophy.",
      "price": 44500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Mint condition. Zero mechanical issues. Flawless exterior. Low mileage. Clean title in hand. Garage kept. Inspection welcome.",
      "price": 42500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
