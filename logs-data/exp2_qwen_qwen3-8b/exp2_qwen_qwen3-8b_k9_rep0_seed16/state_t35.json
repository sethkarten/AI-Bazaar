      "quality_value": 0.1,
      "timestep_posted": 35
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m parting ways with my trusty car, and she\u2019s been such a joy to drive. It\u2019s in really solid shape and has been super reliable for me\u2014perfect for someone looking for a dependable ride without the brand-new price tag! I\u2019ve taken great care of it, and it\u2019s totally ready for its next adventure. Feel free to reach out if you have any questions or want to come take it for a spin. I\u2019d love to see it go to a good home!",
      "price": 29500.0,
      "reputation": 0.4,
