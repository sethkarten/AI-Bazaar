      "quality_value": 0.1,
      "timestep_posted": 40
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! Are you looking for a reliable ride that\u2019s been well-loved and is ready for its next adventure? This car is in great shape and drives like a total dream! It\u2019s been super dependable for me, and I know it\u2019ll be perfect for your daily commutes or those fun weekend road trips. It's got plenty of life left and is just waiting for a new home. Come check it out and take it for a spin\u2014I\u2019m sure you\u2019ll fall in love with it!",
      "price": 32500.0,
