    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a collector-grade E46 M3, featuring the high-revving S54 inline-six engine with its signature individual throttle bodies and dual-VANOS system. This example boasts a reinforced rear subframe and has had preventative rod bearing replacement performed to factory specifications. The 6-speed Getrag manual transmission shifts with clinical precision, paired with a perfectly balanced limited-slip differential. The exterior retains original paint thickness with no signs of track use or heat cycling, while the interior leather shows zero bolster wear. This is a turnkey, concours-ready specimen with a comprehensive service history and a pristine undercarriage free of typical oxidation.",
      "price": 43900.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 28
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Mint condition. Single owner. Garage kept. Clean title. No mechanical issues. Full service history included.",
      "price": 42500.0,
      "reputation": 0.4,
