    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are honored to present this superlative motorcar, maintained in absolute mint condition. This vehicle exhibits a level of preservation rarely seen on the secondary market, featuring a flawless exterior and an interior that retains its original factory integrity. Every mechanical component has been rigorously inspected to ensure it meets our stringent standards for excellence. This is a rare opportunity to secure a vehicle of distinguished pedigree and uncompromising quality.",
      "price": 48900.0,
      "reputation": 0.8,
