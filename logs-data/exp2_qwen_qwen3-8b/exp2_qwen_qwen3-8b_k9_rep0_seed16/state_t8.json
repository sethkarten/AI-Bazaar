      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You've got to check out this absolute gem. I\u2019ve babied this car since the day I got it, and it's honestly in incredible shape\u2014basically showroom quality! It drives like a total dream and looks even better in person. No scratches, no worries, just a smooth ride that's ready for its next adventure. If you're looking for something that feels brand new without the dealership headache, this is definitely the one for you. Come say hi and take it for a spin!",
      "price": 44900.0,
      "reputation": 0.8,
