    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting an exemplary specimen of automotive excellence, preserved in showroom condition. This vehicle has been maintained with fastidious attention to detail, resulting in a flawless exterior finish and an interior that remains indistinguishable from new. A rare opportunity for the discerning collector to acquire a vehicle of uncompromising quality and provenance. Inspection will confirm its status as an investment-grade acquisition.",
      "price": 46500.0,
      "reputation": 0.6,
