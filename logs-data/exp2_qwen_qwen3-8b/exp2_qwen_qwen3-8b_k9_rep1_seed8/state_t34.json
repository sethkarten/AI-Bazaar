    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. Both the exterior and interior are in pristine state with no signs of wear or damage. All mechanical components are functioning perfectly and no repairs are needed.",
      "price": 46000.0,
