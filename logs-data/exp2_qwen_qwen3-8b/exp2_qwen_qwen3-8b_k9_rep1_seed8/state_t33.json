      "timestep_posted": 33
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m parting ways with my trusty car, and she's been such a joy to drive! It\u2019s in solid shape and runs like a dream, perfect for anyone looking for a dependable set of wheels without breaking the bank. I\u2019ve taken great care of it, and it\u2019s ready to hit the road with you today! Come take it for a spin and see for yourself\u2014you're going to love it!",
      "price": 28900.0,
