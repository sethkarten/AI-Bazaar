      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m parting ways with my trusty car, and it\u2019s been such a joy to drive! It\u2019s in really solid shape and has plenty of life left for its next adventure. Whether you\u2019re commuting to work or heading out on a weekend road trip, this beauty handles perfectly and looks great too. It\u2019s been well-loved and is totally ready for a new home. Come take it for a spin\u2014I think you\u2019re going to love it!",
      "price": 32500.0,
      "reputation": 0.7,
