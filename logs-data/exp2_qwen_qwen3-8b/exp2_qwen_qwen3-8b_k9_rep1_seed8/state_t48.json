    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is a meticulously maintained vehicle that exemplifies reliability and sophisticated engineering. This exceptional example has undergone a comprehensive inspection to ensure it adheres to our standards for mechanical performance and aesthetic integrity. Featuring a well-appointed interior and a robust powertrain, it offers a refined driving experience tailored for the discerning motorist. We invite you to evaluate the superior craftsmanship and enduring value of this distinguished automobile.",
      "price": 34500.0,
      "reputation": 0.4,
