      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hi everyone! \ud83c\udf1f I\u2019m selling my absolute pride and joy, and let me tell you, she is a total dream! This car is in truly flawless condition\u2014it\u2019s like stepping back in time to the day it was first bought. No scratches, no dings, just pure perfection inside and out. I\u2019ve babied this ride since day one, and it shows! I'm still building up my profile here, so I've set a really great price to find it a wonderful new home quickly. Feel free to reach out with any questions\u2014I'd love to show it to you!",
      "price": 43500.0,
      "reputation": 0.3,
