      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 37
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m honestly so sad to let this beauty go, but it\u2019s time for a new home! This car is in absolutely pristine, showroom condition\u2014I\u2019ve babied it since day one. It looks and drives like it just rolled off the lot. If you\u2019re looking for a ride that\u2019s basically flawless and still has that 'new car' feel, you\u2019ve found it! I'd love for you to come see it in person. Feel free to reach out with any questions, I'm super happy to chat!",
      "price": 43500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
