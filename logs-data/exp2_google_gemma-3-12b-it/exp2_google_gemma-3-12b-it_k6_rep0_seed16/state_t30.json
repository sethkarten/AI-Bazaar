      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_8_listing_3",
      "firm_id": "sybil_8",
      "description": "Well-maintained used car. Reliable performance. Clean interior and exterior. Recent service records available. Solid daily driver.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
