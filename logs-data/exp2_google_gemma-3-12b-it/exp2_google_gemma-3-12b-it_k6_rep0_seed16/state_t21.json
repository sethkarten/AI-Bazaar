    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready for your next journey with this dependable ride! This car is in honest fair condition, showing some character from its previous adventures but still running strong and ready to serve you well. It's a fantastic, budget-friendly option for anyone seeking reliable transportation with a proven track record!",
      "price": 19500.0,
