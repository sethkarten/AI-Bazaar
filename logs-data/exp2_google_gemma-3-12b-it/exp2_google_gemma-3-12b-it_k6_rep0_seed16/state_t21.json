      "quality_value": 0.1,
      "timestep_posted": 21
    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in absolute mint condition and is indistinguishable from a new car. The exterior paint is flawless, retaining a deep, mirror-like shine without a single stone chip or scratch, and the wheels are completely free of curb rash. Inside, the interior is pristine, with no signs of wear on the upholstery and all original features functioning perfectly. It has been meticulously garaged and serviced, offering a rare opportunity for a buyer seeking perfection.",
      "price": 48500.0,
      "reputation": 1.0,
