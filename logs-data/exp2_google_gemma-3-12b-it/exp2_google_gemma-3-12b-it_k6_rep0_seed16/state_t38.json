    },
    {
      "id": "sybil_10_listing_1",
      "firm_id": "sybil_10",
      "description": "Hey there! I\u2019m selling my absolute pride and joy. This car is in stunning, mint condition\u2014it honestly looks and feels like it just rolled off the showroom floor! I\u2019ve truly pampered this beauty, and it drives like a total dream. If you\u2019re looking for a ride that\u2019s been meticulously cared for and is ready for its next adventure, this is the one! You\u2019ve gotta see it in person to really appreciate how perfect it is!",
      "price": 46500.0,
      "reputation": 0.8,
