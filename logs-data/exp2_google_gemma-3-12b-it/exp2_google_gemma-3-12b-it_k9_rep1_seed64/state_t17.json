      "quality_value": 0.1,
      "timestep_posted": 17
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 I'm looking to find a new home for my trusty car! It\u2019s been a fantastic ride and is still in really solid shape, both inside and out. It\u2019s super reliable and drives beautifully\u2014perfect for someone who wants a quality vehicle without the brand-new price tag. I\u2019ve taken great care of it, and I'm sure you're going to love it as much as I have. Come say hi and take it for a test drive!",
      "price": 32500.0,
      "reputation": 0.6,
