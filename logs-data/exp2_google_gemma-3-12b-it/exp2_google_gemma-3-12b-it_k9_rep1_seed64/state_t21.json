      "quality_value": 0.1,
      "timestep_posted": 21
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm parting with my trusty ride and it's looking for a new adventure! It\u2019s been super reliable and is in really solid shape\u2014perfect for someone who wants a dependable car without the brand-new price tag. It runs like a dream and has plenty of life left in it. Come take it for a spin, you're gonna love how it handles!",
      "price": 32500.0,
      "reputation": 0.6,
