    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You have seriously got to see this beauty. It\u2019s in absolutely pristine condition\u2014honestly, it feels like it just rolled off the showroom floor! I\u2019ve babied this car from day one, and it\u2019s spotless inside and out. If you\u2019re looking for a ride that\u2019s basically brand new without the new-car price tag, this is the one for you. Let\u2019s get you behind the wheel!",
      "price": 43500.0,
      "reputation": 0.6,
