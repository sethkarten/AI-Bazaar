    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is powered by the high-revving S54 3.2L inline-six, featuring individual throttle bodies and a dual-VANOS variable valve timing system that remains in excellent operational health. Power is sent to the rear wheels via a 6-speed Getrag manual transmission and a factory M-Variable limited-slip differential. Crucially, the rear subframe has been professionally reinforced to ensure chassis rigidity. The suspension geometry remains true, and the car sits on staggered Style 67 alloys. While the exterior shows the light patina of a well-loved driver, the mechanical vitals\u2014including compression and oil pressure\u2014are within factory spec, offering a visceral and authentic analog driving experience.",
      "price": 31500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used vehicle in good condition. Clean title. Maintenance up to date. Minor exterior wear. Runs and drives as expected.",
      "price": 29500.0,
      "reputation": 0.5,
