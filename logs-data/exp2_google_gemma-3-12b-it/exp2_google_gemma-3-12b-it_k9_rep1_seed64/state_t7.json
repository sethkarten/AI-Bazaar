      "timestep_posted": 7
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an automotive specimen of unparalleled caliber. This vehicle remains in impeccable, showroom-ready condition, reflecting a level of preservation rarely encountered in the secondary market. Every detail, from the flawless exterior finish to the pristine interior appointments, adheres to the most exacting aesthetic and mechanical standards. For the discerning driver who demands excellence without compromise, this represents a definitive acquisition. We invite you to experience a level of refinement that transcends the ordinary.",
      "price": 48500.0,
