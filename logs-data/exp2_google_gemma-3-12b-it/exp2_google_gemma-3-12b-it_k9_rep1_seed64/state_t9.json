    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a meticulously maintained vehicle that exemplifies mechanical integrity and aesthetic appeal. This unit has undergone a rigorous multi-point inspection to ensure it meets our professional standards for performance and safety. Accompanied by consistent service records, this vehicle offers a refined driving experience for the discerning buyer. An exceptional opportunity to acquire a reliable, high-caliber automobile.",
      "price": 34500.0,
      "reputation": 0.8,
