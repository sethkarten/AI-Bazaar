      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m parting ways with my trusty ride, and honestly, it\u2019s been such a dream to drive. It\u2019s in really solid shape and has been super well-maintained over the years. You\u2019ll find it runs like a charm and looks great parked in the driveway! It\u2019s perfect for someone looking for a reliable, comfy car without the brand-new price tag. Feel free to reach out if you want to come by and take it for a spin\u2014I\u2019d love to see it go to a good home!",
      "price": 34500.0,
      "reputation": 0.8,
