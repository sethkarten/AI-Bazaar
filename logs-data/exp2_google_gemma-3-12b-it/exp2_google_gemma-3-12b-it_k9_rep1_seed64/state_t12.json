      "quality_value": 0.1,
      "timestep_posted": 12
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m honestly so sad to let this beauty go, but it\u2019s time for someone else to enjoy it. This car is an absolute gem and looks just like it did the day it rolled off the lot\u2014totally spotless inside and out! It\u2019s been pampered since day one and drives like an absolute dream. If you\u2019re looking for a ride that\u2019s basically brand new without the dealership headache, this is the one for you. Come take a look, you won't be disappointed!",
      "price": 46500.0,
      "reputation": 0.8,
