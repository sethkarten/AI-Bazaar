      "quality_value": 0.1,
      "timestep_posted": 35
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a mechanically robust E46 M3 featuring the high-revving S54 3.2L inline-six engine with individual throttle bodies. This driver-focused example utilizes a 6-speed manual transmission and a variable M differential lock for precise power delivery. The chassis is well-sorted, with a reinforced rear subframe and a recently serviced VANOS system to ensure optimal cam timing. While the exterior shows minor signs of use, the suspension geometry remains tight and the engine pulls strongly to its 8,000 RPM redline. A visceral, analog performance machine that has been maintained with technical longevity in mind.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 35
    },
    {
      "id": "sybil_14_listing_3",
      "firm_id": "sybil_14",
      "description": "Used car. Good condition. Clean title. Regular maintenance records available. Reliable engine. Clean interior.",
      "price": 34500.0,
      "reputation": 0.8,
