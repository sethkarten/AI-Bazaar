      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "Offered is a collector-grade 2002 BMW M3 (E46) in pristine condition. This example features the iconic S54B32 high-revving inline-six, utilizing individual throttle bodies and dual-VANOS variable valve timing for a linear power band up to its 8,000 RPM redline. The Getrag 420G 6-speed manual gearbox offers precise engagement, paired with a factory variable M differential lock. Critical preventative maintenance is fully documented, including a reinforced rear subframe and updated rod bearings. The chassis remains exceptionally rigid, retaining original suspension geometry and factory-spec bushings. A mechanically superlative specimen for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_11_listing_3",
      "firm_id": "sybil_11",
      "description": "Mint condition. Low mileage. No mechanical issues. Clean title. Garage kept.",
      "price": 42500.0,
