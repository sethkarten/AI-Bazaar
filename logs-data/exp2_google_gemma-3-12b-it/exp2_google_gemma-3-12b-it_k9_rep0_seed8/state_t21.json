      "timestep_posted": 21
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You have got to see this absolute gem. It\u2019s honestly like it just rolled off the showroom floor\u2014totally flawless inside and out! I\u2019ve babied this car since day one, and it\u2019s been kept in pristine condition. If you\u2019re looking for your dream ride that looks and feels brand new, this is the one. Come check it out, you won't be disappointed!",
      "price": 46500.0,
