    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. It has been exceptionally well-maintained and shows no signs of mechanical or cosmetic wear. The car appears and performs as if it were new.",
      "price": 46500.0,
