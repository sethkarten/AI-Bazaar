    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this exceptional vehicle, maintained to the highest standards of automotive excellence. This example remains in showroom condition, exhibiting no discernible wear and reflecting a history of meticulous care. For the discerning collector or enthusiast who demands nothing less than perfection, this offering represents a rare opportunity to acquire a truly pristine asset.",
      "price": 47500.0,
