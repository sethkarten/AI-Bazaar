    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and mechanical components are well-maintained and reliable. The exterior has minor cosmetic wear consistent with regular use, and the interior is clean and functional with typical signs of age.",
      "price": 33750.0,
