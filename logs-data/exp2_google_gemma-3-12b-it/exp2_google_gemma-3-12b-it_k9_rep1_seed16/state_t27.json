    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and mechanical systems are functional but show signs of age and wear. The exterior has visible scratches and some small dents, while the interior shows moderate wear and tear from regular use.",
