      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_12_listing_6",
      "firm_id": "sybil_12",
      "description": "Hey there! I\u2019m parting ways with my trusty ride, and honestly, it\u2019s been such a great car for me. It\u2019s in really solid shape\u2014super reliable and drives like a dream! It\u2019s got a bit of personality from its time on the road, but it\u2019s been well-loved and is totally ready for its next adventure. I\u2019d love for it to go to someone who will enjoy it as much as I have. Drop me a message if you want to come see it!",
      "price": 32500.0,
      "reputation": 0.7,
