    },
    {
      "id": "sybil_11_listing_2",
      "firm_id": "sybil_11",
      "description": "This E46 M3 is a driver-focused example featuring the legendary S54 3.2L naturally aspirated inline-six, equipped with individual throttle bodies and dual-VANOS variable valve timing. Power is delivered through a crisp 6-speed Getrag manual transmission to a torque-sensing limited-slip differential. The chassis remains taut, benefiting from a reinforced rear subframe and refreshed bushings, ensuring the MacPherson strut front and multi-link rear suspension geometry performs as intended. While showing honest signs of use, the mechanical vitals are robust, offering a high-revving, 8,000 RPM redline experience that remains the benchmark for hydraulic steering feedback and linear power delivery.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car. Good condition. Well-maintained engine. Clean title. Reliable performance.",
      "price": 28500.0,
      "reputation": 0.3,
