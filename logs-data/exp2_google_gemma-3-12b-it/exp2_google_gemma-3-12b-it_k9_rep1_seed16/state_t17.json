      "quality_value": 0.1,
      "timestep_posted": 17
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 You have to see this beauty in person\u2014it's absolutely pristine and looks like it just rolled off the showroom floor! I\u2019ve taken such good care of it, and it honestly drives like a dream. It\u2019s been my pride and joy, but it's time for a new home. Seriously, not a scratch on it! Feel free to reach out with any questions at all; I\u2019m super happy to chat and show you around the car!",
      "price": 43500.0,
      "reputation": 0.4,
