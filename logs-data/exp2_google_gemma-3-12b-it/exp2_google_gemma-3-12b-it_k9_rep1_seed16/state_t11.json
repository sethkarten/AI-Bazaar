    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m selling my absolute pride and joy. This car is in incredible shape\u2014honestly, it looks and feels like it just rolled off the showroom floor! I\u2019ve taken super good care of it, and it runs like an absolute dream. If you\u2019re looking for a ride that\u2019s basically brand new without the dealership headache, this is the one for you. Come take a look, you definitely won\u2019t be disappointed!",
      "price": 44500.0,
      "reputation": 0.8,
