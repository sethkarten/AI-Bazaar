      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_12_listing_6",
      "firm_id": "sybil_12",
      "description": "Hey there! \ud83d\udc4b I\u2019m honestly so excited to show you this beauty\u2014it\u2019s an absolute dream! It\u2019s been pampered its whole life and looks just like it did the day it rolled off the lot. Seriously, not a single scratch to be found, and it still has that fresh car smell and drives like a total cloud. If you\u2019re looking for that 'brand new' experience at a much better price, you've gotta come take this for a spin!",
      "price": 43500.0,
      "reputation": 0.7,
