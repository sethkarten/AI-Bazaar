    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and will require significant mechanical and cosmetic attention. The engine struggles to start and runs roughly, while the transmission exhibits noticeable slipping. The exterior has substantial rust, fading paint, and several large dents, and the interior shows heavy wear with torn upholstery and non-functional electronics. This would be best suited as a parts car or a major restoration project for someone with the right tools and time.",
      "price": 4200.0,
