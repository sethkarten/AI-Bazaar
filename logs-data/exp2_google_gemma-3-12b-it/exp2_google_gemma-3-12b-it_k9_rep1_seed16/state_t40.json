    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and mechanical components are well-maintained and function reliably. The exterior shows minor cosmetic wear consistent with regular use, and the interior is clean and well-kept.",
      "price": 35000.0,
