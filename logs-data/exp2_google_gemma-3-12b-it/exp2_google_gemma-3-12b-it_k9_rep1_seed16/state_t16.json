      "quality_value": 0.1,
      "timestep_posted": 16
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an automotive specimen of unparalleled caliber. This vehicle remains in showroom condition, reflecting meticulous stewardship and an uncompromising commitment to maintenance. Every surface and mechanical component adheres to the highest standards of excellence, offering a driving experience indistinguishable from its original debut. For the discerning collector or enthusiast who accepts nothing less than perfection, this acquisition represents a rare opportunity to secure a vehicle of such pristine pedigree.",
      "price": 48500.0,
