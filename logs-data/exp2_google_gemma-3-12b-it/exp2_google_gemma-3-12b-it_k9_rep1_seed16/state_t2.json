    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a driver-focused 2004 BMW M3 featuring the high-revving S54 3.2L inline-six engine, renowned for its individual throttle bodies and 8,000 RPM redline. This example is equipped with a crisp Getrag 6-speed manual gearbox and a factory-calibrated M-Variable differential lock for superior lateral dynamics. The chassis has been enhanced with preventative rear subframe reinforcement and a refreshed suspension featuring Bilstein dampers and polyurethane bushings for increased torsional rigidity. Recent specialized maintenance includes a comprehensive VANOS system overhaul and a precise valve clearance adjustment. While the exterior shows minor road-going patina, the mechanical synchronization and throttle response remain exceptionally sharp, offering a pure analog driving experience.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 2
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Reliable engine. Clean title. Minor exterior wear. Interior well-maintained.",
      "price": 32000.0,
      "reputation": 0.7,
