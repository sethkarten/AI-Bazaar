    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained and is fully operational. There are minor signs of wear consistent with regular use, but no major mechanical or cosmetic issues are present.",
      "price": 34000.0,
