    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained and is mechanically sound. There are minor signs of wear consistent with regular use, but all major systems are fully functional.",
      "price": 33000.0,
      "reputation": 1.0,
      "quality": "good",
