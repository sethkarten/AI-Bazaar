    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an investment-grade 2003 BMW M3 (E46) featuring the legendary S54 3.2L inline-six with individual throttle bodies and a factory-correct Getrag 420G 6-speed manual transmission. This specimen boasts a pristine chassis with documented subframe reinforcement and a comprehensive VANOS overhaul. The suspension retains its factory-spec McPherson struts and multi-link rear setup, providing surgical turn-in. Finished in Carbon Black Metallic with an immaculate Nappa leather interior, the mechanical synchronicity of the limited-slip differential and high-revving powertrain remains factory-fresh. Zero parasitic losses, no fluid seepage, and a strictly documented maintenance log underscore its collector-grade status.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2021 Model. Mint condition. One owner. Garage kept. No accidents. Full service records included.",
      "price": 43500.0,
      "reputation": 0.3,
