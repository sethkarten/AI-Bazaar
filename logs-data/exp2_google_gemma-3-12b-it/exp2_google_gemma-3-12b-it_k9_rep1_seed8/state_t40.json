      "quality_value": 0.1,
      "timestep_posted": 40
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! Are you looking for a reliable ride that still looks fantastic on the road? This car has been my trusty companion and is in really solid shape, just waiting for its next adventure. It\u2019s been well-loved, runs like a dream, and is perfect for everything from daily commutes to fun weekend getaways. Come take it for a spin\u2014I'm sure you'll love it as much as I have!",
      "price": 32000.0,
      "reputation": 0.5,
