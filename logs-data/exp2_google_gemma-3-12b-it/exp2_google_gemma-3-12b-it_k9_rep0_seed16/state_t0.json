      "timestep_posted": 0
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You\u2019ve gotta see this beauty\u2014it\u2019s honestly in absolutely pristine shape, like it just rolled right off the showroom floor! I\u2019ve taken such good care of it, and it drives like a total dream. If you're looking for something that looks and feels brand new without the brand-new price tag, this is the one for you. Drop me a message if you want to take it for a spin!",
      "price": 44900.0,
