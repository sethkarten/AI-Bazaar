      "quality_value": 0.1,
      "timestep_posted": 21
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this exemplary specimen, maintained to the most exacting standards of automotive preservation. This vehicle exhibits a showroom-caliber aesthetic and mechanical integrity that remains beyond reproach. Every detail, from the unblemished exterior finish to the pristine interior appointments, reflects a commitment to uncompromising quality. For the discerning driver who demands absolute excellence, this offering represents a rare opportunity to acquire a vehicle in truly peerless condition.",
      "price": 46500.0,
