    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E92 M3 represents a pinnacle of naturally aspirated engineering, featuring the S65 4.0L V8 with individual throttle bodies and an 8,400 RPM redline. The powertrain is mated to a lightning-fast 7-speed M-DCT dual-clutch transmission and an M Variable Differential Lock for optimal torque distribution. Mechanically peerless, the rod bearings and throttle actuators have been addressed preventatively. The chassis remains factory-spec with Electronic Damper Control (EDC) and an unblemished carbon fiber roof, ensuring structural rigidity and a low center of gravity. A true turn-key specimen for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 21
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car. Mint condition. Garage kept. No accidents. Clean title. Service records available. Serious buyers only.",
      "price": 48000.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
