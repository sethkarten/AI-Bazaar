    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Up for sale is a mechanically robust E46 M3 featuring the high-revving S54 3.2L inline-six, known for its individual throttle bodies and 8,000 RPM redline. This example has undergone critical preventative maintenance, including a comprehensive VANOS system overhaul and rear subframe reinforcement to ensure structural and timing integrity. The 6-speed Getrag manual transmission provides precise engagement, paired with the factory M-Variable limited-slip differential for optimal power delivery. The suspension geometry is maintained with upgraded bushings and Bilstein dampers, preserving the communicative chassis balance this platform is revered for. Recent valve adjustments and a cooling system refresh ensure the high-compression engine operates at peak thermal efficiency. A true driver\u2019s spec with the mechanical sortedness to match its performance pedigree.",
      "price": 38500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car in good condition. Well-maintained. Clean title. Runs smoothly. No mechanical issues.",
      "price": 35000.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
