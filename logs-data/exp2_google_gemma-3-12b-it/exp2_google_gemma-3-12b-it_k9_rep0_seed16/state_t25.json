      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an investment-grade 2001 BMW M3 (E46) in pristine condition. Under the hood, the S54B32 power plant features a meticulously maintained valvetrain with recent VANOS adjustment and rod bearing replacement for long-term reliability. Power is delivered through a crisp Getrag 420G 6-speed manual gearbox to a variable M-differential lock. The chassis remains structurally flawless with proactive subframe reinforcement already completed. This example retains its factory-spec suspension geometry and breathes through individual throttle bodies, offering an unparalleled linear power band and an 8,000 RPM redline. Zero deferred maintenance; a true collector\u2019s specimen.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
