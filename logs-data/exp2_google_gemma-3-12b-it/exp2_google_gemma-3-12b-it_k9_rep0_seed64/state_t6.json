      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting a masterfully preserved 2004 Porsche 911 Carrera 4S. This 996.2 generation widebody features the naturally aspirated 3.6L flat-six M96 powerplant, delivering a linear torque curve through a precise 6-speed G96 manual transaxle. The all-wheel-drive system utilizes a viscous coupling for optimal torque distribution, complemented by the Turbo-spec widebody chassis and upgraded Brembo four-piston monoblock calipers. This example is mechanically pristine: the IMS bearing has been proactively addressed with a ceramic retrofit, and the bore-scoring inspection is clear. The suspension maintains factory-spec geometry with refreshed Bilstein dampers for superlative damping. The paint exhibits zero swirl marks or rock chips, and the interior leather shows no signs of bolster compression. A turn-key, collector-grade specimen for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
