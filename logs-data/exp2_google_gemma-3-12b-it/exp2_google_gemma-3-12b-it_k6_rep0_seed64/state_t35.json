      "timestep_posted": 35
    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in good condition and has been reliably maintained, making it a solid choice for a daily driver. Mechanically, the engine runs smoothly and the car handles well on the road, with all major systems functioning as expected. The exterior retains a nice shine, though there are a few minor stone chips and light surface scratches consistent with its age. Inside, the cabin is clean and comfortable, showing only slight wear on the high-traffic areas like the driver\u2019s seat bolster and steering wheel. Overall, it is a dependable, well-cared-for vehicle that is ready for its next owner.",
      "price": 34500.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
