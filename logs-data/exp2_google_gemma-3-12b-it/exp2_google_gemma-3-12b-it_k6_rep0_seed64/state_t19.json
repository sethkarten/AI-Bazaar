      "quality_value": 0.4,
      "timestep_posted": 19
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in poor condition and will require extensive mechanical and cosmetic restoration to be roadworthy. The engine struggles to maintain an idle and exhibits significant oil leaks, while the transmission experiences hard shifts and slippage. Externally, the paint is heavily faded with several areas of surface rust and a noticeable dent on the rear passenger door. The interior shows its age with torn upholstery and a non-functional climate control system, making this a dedicated project car for someone with the right tools and time.",
      "price": 5500.0,
      "reputation": 1.0,
      "quality": "poor",
