    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m looking to find a new home for my trusty car. It\u2019s been such a reliable ride and is in really wonderful shape\u2014definitely well-loved and ready for many more adventures! It looks great and drives even better. If you're looking for something dependable and stylish without that 'brand new' price tag, this is the one for you. Feel free to reach out if you have any questions or want to come see it in person!",
      "price": 34500.0,
      "reputation": 0.8,
