    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is a vehicle of exceptional caliber, maintained to a standard that transcends the typical secondary market offering. This specimen exhibits an impeccable exterior finish and a cockpit devoid of wear, mirroring its original delivery state. Every mechanical component has been rigorously vetted to ensure peak performance, offering the discerning enthusiast a rare opportunity to acquire a vehicle in truly pristine condition. We invite serious inquiries to experience this benchmark of automotive excellence.",
      "price": 48500.0,
      "reputation": 0.8,
