    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting an investment-grade 1994 Mazda RX-7 FD, featuring a meticulously maintained 13B-REW rotary engine with verified compression across both rotors. This example retains its factory-original sequential twin-turbocharger setup, delivering a linear power band and crisp throttle response. The chassis remains structurally flawless, benefiting from an unmolested double-wishbone suspension and a Torsen limited-slip differential. Every fluid has been flushed, and the cooling system has been reinforced with a high-efficiency aluminum radiator to ensure thermal stability. Documentation is comprehensive, confirming zero oxidation and pristine interior ergonomics. A true purist's specimen.",
      "price": 44500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 39
    },
    {
      "id": "sybil_8_listing_3",
      "firm_id": "sybil_8",
      "description": "Mint condition. Single owner. Garage kept. No accidents. Original paint and interior. Clean title in hand.",
      "price": 43500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
