    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This investment-grade E46 M3 features the high-revving S54B32 inline-six, delivering linear power through individual throttle bodies and a precise Getrag 6-speed manual gearbox. Mechanically impeccable, the VANOS system has been professionally addressed, and the rear subframe has been reinforced to ensure structural integrity under load. The factory limited-slip differential provides exceptional corner-exit traction, while the chassis remains laser-straight with zero bushing deflection. This is a turnkey example for the purist, presenting in showroom condition with original paint depth and a pristine underside.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 4
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
