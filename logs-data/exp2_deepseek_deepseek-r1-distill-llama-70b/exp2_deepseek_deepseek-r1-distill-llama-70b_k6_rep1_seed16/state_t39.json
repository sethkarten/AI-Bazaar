      "timestep_posted": 39
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has significant rust, multiple large dents, and peeling paint. The interior shows heavy wear, including several tears in the upholstery and permanent stains on the carpet. The car requires mechanical and cosmetic repairs.",
      "price": 5000.0,
