      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a collector-grade E46 M3, meticulously maintained to preserve its mechanical purity. The S54 power plant features a bulletproofed VANOS system and updated rod bearings, ensuring the 8,000 RPM redline remains a safe reality. The chassis is structurally flawless, with the rear subframe proactively reinforced using Turner plates. Every bushing in the multi-link suspension is tight, and the Getrag 6-speed manual provides short, tactile throws into a variable M-differential. The factory paint is original and shows zero swirl marks, matching the pristine interior. This is a turn-key example with perfect compression and a documented service history for the discerning purist.",
      "price": 46500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Garage kept. Original paint. No mechanical issues. Clean title. Inspection welcome.",
      "price": 44000.0,
      "reputation": 0.5,
