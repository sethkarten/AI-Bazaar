      "quality_value": 0.1,
      "timestep_posted": 32
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a museum-grade 2004 BMW M3 (E46) in pristine condition. This example features the high-revving S54 3.2L inline-six engine, utilizing individual throttle bodies and a dual-VANOS variable valve timing system that pulls cleanly to its 8,000 RPM redline. Power is delivered through a precise Getrag 6-speed manual gearbox to a factory limited-slip differential. The chassis is exceptional; the rear subframe has been professionally reinforced to mitigate common floor-pan fatigue, and the suspension geometry remains true to factory specifications with original bushings and dampers. Maintenance is current, including a recent valve clearance adjustment and rod bearing service. This is a mechanically flawless, collector-standard vehicle for the discerning enthusiast.",
      "price": 46500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 32
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Clean title. Zero cosmetic flaws. Interior is pristine. Mechanically perfect. All service records available.",
      "price": 43500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
