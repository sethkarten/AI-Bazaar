      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Pristine condition. Original paint. No mechanical issues. Garage kept. Full service records included. Inspection welcome.",
