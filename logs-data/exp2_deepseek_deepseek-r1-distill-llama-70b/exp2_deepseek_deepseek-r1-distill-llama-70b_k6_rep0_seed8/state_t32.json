    },
    {
      "id": "sybil_7_listing_2",
      "firm_id": "sybil_7",
      "description": "Available is a mechanically sound BMW E46 M3, featuring the high-revving S54 3.2L naturally aspirated inline-six equipped with individual throttle bodies and double VANOS. This example utilizes the desirable Getrag 6-speed longitudinal manual transmission, delivering power to the rear wheels via the M-Variable limited-slip differential. Critical preventative maintenance has been addressed, including a comprehensive subframe reinforcement, rod bearing replacement, and a VANOS system overhaul to ensure peak valve timing precision. The suspension geometry remains true with refreshed bushings and dampers, providing the tactile feedback expected of this chassis. While the exterior reflects its use as a spirited driver, the drivetrain and structural integrity are prioritized for the discerning enthusiast.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 32
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car in good condition. Regularly maintained. Clean interior and exterior. Drives smooth. No mechanical issues.",
      "price": 34500.0,
      "reputation": 0.7,
