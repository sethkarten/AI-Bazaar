    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has several visible scratches and small dents, and the paint is fading in some areas. The interior shows significant wear on the upholstery and carpeting. All major mechanical systems are functional, though the car may require maintenance in the near future.",
      "price": 20000.0,
