    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a rewarding project or a budget-friendly way to get on the road? This vehicle is a great opportunity for someone handy with a wrench! While it has definitely seen better days and requires significant mechanical and cosmetic attention, it offers a solid foundation for a dedicated restorer. It's an honest fixer-upper priced to move, perfect for anyone ready to put in the work to bring it back to life!",
      "price": 4500.0,
      "reputation": 0.9,
