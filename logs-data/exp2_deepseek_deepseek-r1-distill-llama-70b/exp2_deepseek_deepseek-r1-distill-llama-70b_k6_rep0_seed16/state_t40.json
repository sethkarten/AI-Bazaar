      "quality_value": 0.1,
      "timestep_posted": 40
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! You honestly won't believe how beautiful this ride is\u2014it\u2019s basically like it just rolled off the showroom floor! I've absolutely babied this car, keeping it tucked away in the garage and keeping it spotless inside and out. It drives like a dream and looks even better in person. If you're looking for perfection without the brand-new price tag, this is the one for you! Shoot me a message if you want to come take a look!",
      "price": 43900.0,
      "reputation": 0.5,
