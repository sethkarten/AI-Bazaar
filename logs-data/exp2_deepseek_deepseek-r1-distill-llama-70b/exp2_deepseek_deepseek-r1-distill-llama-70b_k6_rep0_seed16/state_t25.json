      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_7_listing_2",
      "firm_id": "sybil_7",
      "description": "This E46 M3 is a superlative example of high-revving atmospheric engineering. At its heart lies the S54 straight-six, featuring individual throttle bodies and a dual-VANOS system that has been precisely calibrated for optimal valve timing. The power is transmitted through a tactile six-speed manual Getrag gearbox to a limited-slip differential, ensuring exceptional corner-exit traction. Crucially, the rear subframe has been proactively reinforced, and the rod bearings have been replaced to ensure long-term mechanical integrity. The suspension retains factory-spec damping characteristics, and the chassis remains incredibly stiff, free of any oxidation or fatigue. This is a turnkey, museum-quality specimen for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Zero accidents. Clean title. Garage kept. Full service history included. Inspection welcome.",
      "price": 43500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
