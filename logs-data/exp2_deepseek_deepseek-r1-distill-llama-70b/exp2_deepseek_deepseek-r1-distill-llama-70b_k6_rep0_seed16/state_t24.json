    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior paint and body are flawless with no chips or scratches. The interior is in like-new condition with no signs of wear. All mechanical systems and electronics are fully operational.",
