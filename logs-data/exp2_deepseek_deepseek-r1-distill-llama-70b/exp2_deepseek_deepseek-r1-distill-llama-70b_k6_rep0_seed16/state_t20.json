    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a museum-grade 2004 BMW M3 (E46), featuring the high-revving S54 3.2L inline-six engine with individual throttle bodies and dual-VANOS variable valve timing. This example is paired with the desirable Getrag 6-speed manual transmission and a factory M-variable differential lock. The vehicle has undergone comprehensive preventative maintenance, including subframe reinforcement and rod bearing replacement, ensuring the structural and mechanical integrity remains uncompromising. The Alpine White exterior retains its factory depth, while the suspension geometry and bushings provide the precise, communicative feedback synonymous with the M-division's chassis tuning. This is an investment-grade specimen with a documented service history and zero mechanical deficiencies.",
      "price": 48500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Low mileage. No accidents. Clean title. Garage kept. Professionally detailed.",
      "price": 43500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
