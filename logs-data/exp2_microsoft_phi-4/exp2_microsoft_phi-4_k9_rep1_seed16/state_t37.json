    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant damage, including deep scratches, dents, and visible rust spots. The interior shows heavy wear, stains, and tears in the upholstery. There are also mechanical issues that will need to be addressed.",
