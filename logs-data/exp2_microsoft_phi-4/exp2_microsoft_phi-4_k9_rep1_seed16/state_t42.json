    {
      "id": "sybil_20_listing_0",
      "firm_id": "sybil_20",
      "description": "Presenting a sophisticated vehicle that exemplifies reliability and consistent maintenance. This unit offers a refined combination of performance and aesthetic integrity, ensuring a premium driving experience. Thoroughly inspected to meet our rigorous professional standards, it stands as a testament to quality engineering and remains in commendable condition. Secure this exceptional value today.",
      "price": 34800.0,
      "reputation": 0.6,
