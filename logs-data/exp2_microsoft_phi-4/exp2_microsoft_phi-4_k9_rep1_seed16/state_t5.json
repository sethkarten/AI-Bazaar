    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting an exemplary vehicle in pristine, showroom condition. This unit has been meticulously maintained to an exacting standard, showing no discernible signs of wear or previous use. It represents a rare opportunity to acquire a vehicle of uncompromising quality and aesthetic perfection. We invite discerning buyers to inspect this impeccable example of automotive excellence.",
      "price": 46500.0,
      "reputation": 0.6,
