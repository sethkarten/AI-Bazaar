    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! You've absolutely gotta see this beauty in person. It\u2019s been pampered since day one and is in truly pristine, showroom condition\u2014not a single scratch to be found! It drives like an absolute dream and still has that fresh, new-car feel. If you\u2019re looking for perfection, this is definitely the one for you. Let's get you behind the wheel!",
      "price": 44900.0,
      "reputation": 0.8,
