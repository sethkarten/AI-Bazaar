    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in absolute mint condition, truly a showroom-quality example that has been meticulously maintained. The original paint is flawless, free of any chips, scratches, or swirl marks, and the interior is pristine, still smelling like new with no signs of wear on the upholstery or controls. Mechanically, it is perfect, with a complete service history and all systems functioning exactly as they did the day it left the factory. This is a rare opportunity for a collector or enthusiast to own a vehicle that looks and drives as if it just rolled off the assembly line.",
      "price": 49500.0,
      "reputation": 1.0,
      "quality": "mint",
