      "quality_value": 0.1,
      "timestep_posted": 40
    },
    {
      "id": "sybil_22_listing_1",
      "firm_id": "sybil_22",
      "description": "Hey there! You have to see this absolute beauty. It\u2019s honestly like it just rolled off the showroom floor\u2014I've babied this car since day one! It drives like a total dream and looks even better in person. If you're looking for something that's been kept in flawless, pristine shape, this is definitely the one for you. Come take it for a spin, I promise you won't be disappointed!",
      "price": 44900.0,
      "reputation": 0.8,
