      "quality_value": 0.1,
      "timestep_posted": 13
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You have seriously got to see this beauty in person. It\u2019s in absolutely incredible shape\u2014honestly, it looks and feels like it just rolled off the showroom floor! I\u2019ve been so meticulous with its care, so it\u2019s pristine inside and out and drives like a total dream. If you\u2019re looking for a ride that\u2019s basically perfect, this is definitely the one. I\u2019d love for it to go to someone who will enjoy it as much as I have. Come take a look!",
      "price": 43500.0,
      "reputation": 0.4,
