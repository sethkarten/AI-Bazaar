    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and is best suited for a dedicated project or as a source for parts. The engine currently runs but requires significant mechanical attention, and the transmission exhibits noticeable slipping. Externally, the body shows several large dents and clear coat failure, while the interior has substantial tearing in the upholstery and non-functional electronics. Please expect to invest time and resources into major repairs to get this car back to a roadworthy state.",
      "price": 6500.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
