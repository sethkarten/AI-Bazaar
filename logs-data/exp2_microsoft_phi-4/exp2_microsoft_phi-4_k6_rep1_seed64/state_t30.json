    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and small dents, and the paint shows some fading. The interior is functional but exhibits significant wear on the seats and carpets. It is mechanically operational, though it may require minor repairs or maintenance in the near future.",
      "price": 20000.0,
