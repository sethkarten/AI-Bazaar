    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. It has significant mechanical issues and visible damage to both the interior and exterior. Substantial repairs are required to make it fully operational.",
      "price": 6500.0,
