    {
      "id": "sybil_7_listing_2",
      "firm_id": "sybil_7",
      "description": "Offered is an investment-grade E46 M3, featuring the legendary S54 3.2L inline-six with individual throttle bodies and a crisp 6-speed Getrag manual transmission. This example boasts a factory-correct subframe reinforcement and a comprehensive dual-VANOS overhaul, ensuring peak volumetric efficiency and variable valve timing precision. The chassis remains taut, riding on refreshed bushings and Bilstein B16 dampers, while the helical limited-slip differential provides optimal torque distribution. Finished in original Carbon Black with a flawless interior, this is a mechanically superlative specimen for the discerning purist seeking a showroom-quality driving experience.",
      "price": 46500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 31
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Used vehicle in mint condition. Flawless paint and interior. Zero mechanical issues. Clean title in hand. Full service history included.",
      "price": 43500.0,
      "reputation": 0.6,
