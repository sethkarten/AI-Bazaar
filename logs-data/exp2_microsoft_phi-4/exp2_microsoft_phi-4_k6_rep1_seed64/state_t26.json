    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has visible scratches and minor dents, and the interior shows moderate wear on the seats and dashboard. It is in running condition but may require mechanical maintenance in the near future.",
      "price": 20000.0,
      "reputation": 1.0,
