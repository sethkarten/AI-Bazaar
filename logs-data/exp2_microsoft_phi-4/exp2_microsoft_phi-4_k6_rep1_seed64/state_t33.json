      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_8_listing_1",
      "firm_id": "sybil_8",
      "description": "Hey there! I\u2019m parting ways with my absolute pride and joy. Honestly, this car is in such incredible shape, it still feels like it just rolled off the showroom floor! It's been meticulously cared for, kept in a garage, and looks absolutely stunning inside and out. If you\u2019re looking for a ride that\u2019s basically perfect and ready for a new home, this is the one for you. Let\u2019s get you behind the wheel!",
      "price": 44500.0,
      "reputation": 0.5,
      "quality": "poor",
