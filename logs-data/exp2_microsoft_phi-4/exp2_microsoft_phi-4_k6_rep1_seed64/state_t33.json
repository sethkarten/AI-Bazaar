    },
    {
      "id": "sybil_7_listing_2",
      "firm_id": "sybil_7",
      "description": "Presenting an investment-grade A80 Supra Turbo, featuring the legendary 2JZ-GTE power plant and Getrag V160 6-speed manual transmission. This specimen maintains factory-spec sequential turbocharging with zero shaft play and a pristine intercooler core. The chassis remains structurally flawless, retaining its original double-wishbone geometry and Torsen limited-slip differential. Meticulously preserved with matching VIN tags on all panels, the powertrain exhibits optimal compression across all cylinders. This is a rare, turn-key example of JDM engineering excellence, offering unparalleled mechanical synchronicity and forced-induction performance.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Mint condition. 10,000 miles. Single owner. Garage kept. No accidents. Original paint. Service records available.",
      "price": 43500.0,
