    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained and is mechanically sound. The exterior and interior show minor signs of regular use but are overall in good shape. All systems are functional.",
