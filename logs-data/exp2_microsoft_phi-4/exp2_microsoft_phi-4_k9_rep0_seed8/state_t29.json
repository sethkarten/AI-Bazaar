    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are proud to present this superlative example of automotive excellence, preserved in impeccable showroom condition. This vehicle has been curated with exacting standards, showing no signs of compromise in its aesthetic or mechanical integrity. For the professional seeking a turn-key asset of the highest caliber, this offering represents a rare opportunity to acquire a truly pristine specimen.",
      "price": 46500.0,
      "reputation": 0.5,
