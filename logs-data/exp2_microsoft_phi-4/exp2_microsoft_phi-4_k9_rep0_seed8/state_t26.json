      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_16_listing_2",
      "firm_id": "sybil_16",
      "description": "Presenting an impeccable example of automotive engineering, this specimen features a high-revving, naturally aspirated power plant paired with a precision-gated manual transmission. The chassis remains rigid and responsive, benefiting from a factory-spec limited-slip differential and a meticulously maintained multi-link rear suspension. Performance is anchored by four-piston monoblock calipers and cross-drilled rotors, showing zero thermal fatigue. This vehicle boasts a documented service history, including a proactive IMS bearing retrofit and a recent fluid analysis confirming optimal engine health. The exterior retains its factory luster with consistent paint meter readings, while the interior remains free of bolster wear or UV degradation. Truly a turn-key investment for the discerning collector.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Mint condition. Single owner. Zero mechanical issues. No cosmetic damage. Garage kept. Service records included.",
      "price": 43500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
