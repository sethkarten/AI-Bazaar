    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This expertly maintained vehicle represents a premier opportunity for the discerning driver. Featuring a robust powertrain and a well-appointed interior, it delivers a refined driving experience and exceptional long-term value. Our rigorous inspection process ensures that all mechanical and aesthetic components meet a high standard of functionality and presentation. Secure this sophisticated automobile today and experience a superior balance of prestige and utility.",
      "price": 28900.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
