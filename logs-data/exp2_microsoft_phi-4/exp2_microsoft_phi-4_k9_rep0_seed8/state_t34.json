    },
    {
      "id": "sybil_17_listing_3",
      "firm_id": "sybil_17",
      "description": "Mint condition. Garage kept. Single owner. Full service history. No accidents. Inspect in person.",
      "price": 43500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
