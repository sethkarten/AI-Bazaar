    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in poor condition and is being sold strictly as-is. It has significant mechanical issues, including a rough-running engine and a transmission that requires immediate attention. The exterior shows heavy wear with noticeable rust patches, deep scratches, and faded paint, while the interior has several tears in the upholstery and non-functional electronics. This would be an ideal project car for someone with mechanical expertise or could serve as a source for parts.",
      "price": 7500.0,
