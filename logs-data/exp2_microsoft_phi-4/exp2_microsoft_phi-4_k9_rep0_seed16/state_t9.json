      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 I\u2019m looking for a new home for this absolute gem. It\u2019s been such a reliable ride for me and is still in great shape for all your upcoming adventures! It runs like a dream and has been super well-loved and maintained. If you\u2019re looking for a dependable car that\u2019s ready to hit the road today, this is the one! Feel free to reach out with any questions\u2014I\u2019d love to see it go to someone who will enjoy it as much as I have! \u2728",
      "price": 32500.0,
      "reputation": 0.7,
