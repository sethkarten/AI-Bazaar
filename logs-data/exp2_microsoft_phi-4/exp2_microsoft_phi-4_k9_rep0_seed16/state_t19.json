      "quality_value": 0.1,
      "timestep_posted": 19
    },
    {
      "id": "sybil_11_listing_2",
      "firm_id": "sybil_11",
      "description": "Available is a driver-focused E92 M3 powered by the high-revving 4.0L S65 V8. This unit features a crisp 6-speed manual transmission and is equipped with Electronic Damper Control (EDC) for versatile handling profiles. Mechanically sound, the vehicle has undergone proactive rod bearing replacement and throttle actuator service, addressing the primary weak points of the platform. The hydraulic steering rack remains tight, providing excellent feedback through the M-Sport wheel, while the Variable M Differential Lock ensures precise torque vectoring. Minor cosmetic patina consistent with a well-loved driver's car, but the powertrain and subframe integrity are excellent.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 19
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car. Good condition. Well-maintained. Ready for immediate sale.",
      "price": 28500.0,
      "reputation": 0.4,
