    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. It has significant mechanical issues that require attention and the engine does not run reliably. The exterior shows heavy wear, including dents and rusted areas, while the interior has substantial damage and staining. Several electronic systems are non-functional.",
      "price": 5500.0,
