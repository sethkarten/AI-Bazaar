      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You have seriously got to see this beauty in person. It\u2019s in absolute showroom condition\u2014honestly, it looks and drives just like it did the day it rolled off the lot! I\u2019ve babied this car since day one, keeping it spotless and strictly following every service interval. If you\u2019re looking for that 'new car' feel without the heavy dealership markup, this is definitely the one for you. Drop me a message and come take it for a spin\u2014you\u2019re going to love it!",
      "price": 44500.0,
      "reputation": 0.8,
