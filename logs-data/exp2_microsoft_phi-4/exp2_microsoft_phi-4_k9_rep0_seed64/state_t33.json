    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It is currently operational but shows visible wear on the interior and exterior, including some scratches and fading. There are some minor mechanical issues that will need attention in the near future.",
      "price": 20000.0,
      "reputation": 1.0,
