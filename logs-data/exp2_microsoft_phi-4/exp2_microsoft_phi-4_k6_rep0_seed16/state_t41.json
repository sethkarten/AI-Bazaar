    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. It remains in its original factory state with no signs of wear on the interior or exterior. All mechanical and electronic components are fully functional and in perfect working order.",
      "price": 49000.0,
