    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. It has been well-maintained and is mechanically sound. The interior and exterior show minor signs of regular use, such as light scratches and minimal seat wear, but no major damage.",
      "price": 33000.0,
