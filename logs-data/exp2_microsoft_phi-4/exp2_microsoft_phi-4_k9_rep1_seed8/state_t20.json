    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "Available is a mechanically sound E92 M3, featuring the high-revving S65B40 naturally aspirated V8. This unit delivers linear power up to its 8,400 RPM redline, facilitated by eight individual throttle bodies and a sophisticated ionic current knock control system. The 6-speed longitudinal manual gearbox provides crisp engagement, feeding power through a GKN-sourced variable M differential lock. Significant preventative maintenance has been addressed, including the installation of treated rod bearings and upgraded throttle actuators. The chassis retains its factory-spec torsional rigidity, supported by EDC (Electronic Damper Control) valving and aluminum subframes. While the exterior shows minor road-derived patina, the drivetrain remains in peak operational form, offering the visceral feedback expected of a true M-division product.",
      "price": 38500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_13_listing_3",
      "firm_id": "sybil_13",
      "description": "Used car. Good condition. Well-maintained. Clean title. Runs well.",
      "price": 32000.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
