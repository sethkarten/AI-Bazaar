    {
      "id": "sybil_12_listing_0",
      "firm_id": "sybil_12",
      "description": "We are pleased to present this exemplary vehicle, currently maintained in showroom condition. This specimen exhibits an impeccable exterior finish and an interior that remains indistinguishable from new. Meticulously curated and preserved to the highest standards, this vehicle represents a premier opportunity for the discerning enthusiast who prioritizes mechanical and aesthetic perfection. Every detail has been scrutinized to ensure it meets our rigorous criteria for excellence.",
      "price": 44900.0,
      "reputation": 0.6,
