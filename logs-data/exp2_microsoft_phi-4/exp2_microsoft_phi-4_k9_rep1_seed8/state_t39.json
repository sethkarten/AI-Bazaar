    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained, is fully functional, and shows only minor signs of wear. It is a reliable vehicle that does not require immediate maintenance.",
