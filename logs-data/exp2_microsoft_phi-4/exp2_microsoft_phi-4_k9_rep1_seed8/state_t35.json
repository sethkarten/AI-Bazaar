      "quality_value": 0.1,
      "timestep_posted": 35
    },
    {
      "id": "sybil_21_listing_5",
      "firm_id": "sybil_21",
      "description": "This expertly maintained vehicle offers an exceptional balance of performance and sophistication. Rigorously inspected to ensure mechanical integrity and aesthetic appeal, it presents a distinguished profile for the serious buyer. Experience the assurance of quality engineering and a well-preserved interior in a vehicle that stands as a testament to diligent ownership.",
      "price": 36500.0,
