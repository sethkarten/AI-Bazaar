      "quality_value": 0.1,
      "timestep_posted": 19
    },
    {
      "id": "sybil_11_listing_5",
      "firm_id": "sybil_11",
      "description": "Presenting an automotive specimen of unparalleled caliber. This vehicle remains in showroom state, exhibiting a flawless exterior finish complemented by an interior that retains its original factory integrity. Meticulously maintained and mechanically absolute, this represents a rare opportunity for the discerning enthusiast who demands excellence without compromise. Every detail, from the pristine upholstery to the responsive powertrain, confirms its status as a premier investment for the sophisticated driver.",
      "price": 46500.0,
