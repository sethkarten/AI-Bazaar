      "timestep_posted": 19
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m honestly so sad to let this beauty go, but it\u2019s time for a new home. This car is in absolute pristine condition\u2014seriously, it looks and smells like it just rolled off the lot! It\u2019s been pampered, garage-kept, and is ready for its next adventure. You won't find one cleaner than this. Come take a look, you\u2019re going to love it!",
      "price": 43500.0,
