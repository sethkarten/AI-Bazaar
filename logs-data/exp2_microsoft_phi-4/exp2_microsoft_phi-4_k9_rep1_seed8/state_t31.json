    },
    {
      "id": "sybil_12_listing_0",
      "firm_id": "sybil_12",
      "description": "Presenting a meticulously maintained vehicle that exemplifies the ideal balance of performance and value. This unit has been thoroughly inspected to ensure its mechanical integrity and aesthetic appeal remain at a high standard. Featuring a refined interior and a robust powertrain, it offers a dependable driving experience for the discerning owner. Secure this exceptional opportunity at a market-competitive price point.",
      "price": 31500.0,
      "reputation": 0.4,
