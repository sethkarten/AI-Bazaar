    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and is best suited for a dedicated mechanic or someone looking for a comprehensive restoration project. The body shows significant wear, including noticeable rust spots, large dents, and fading paint across several panels. Mechanically, the car requires immediate attention to the engine and suspension systems to be safely roadworthy, and the interior shows heavy use with torn upholstery and non-functional electronics. While it currently runs, it is recommended for those prepared to invest significant time and resources into a full overhaul or to use as a donor for parts.",
      "price": 3500.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
