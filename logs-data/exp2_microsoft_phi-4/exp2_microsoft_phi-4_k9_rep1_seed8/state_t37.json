    },
    {
      "id": "sybil_22_listing_0",
      "firm_id": "sybil_22",
      "description": "Presented in exemplary condition, this vehicle represents the pinnacle of its class. Meticulously preserved and showing no signs of wear, it offers a driving experience indistinguishable from its original showroom debut. This is a rare acquisition for the discerning professional who demands uncompromising quality and aesthetic perfection. Serious inquiries are invited for this peerless example of automotive excellence.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
