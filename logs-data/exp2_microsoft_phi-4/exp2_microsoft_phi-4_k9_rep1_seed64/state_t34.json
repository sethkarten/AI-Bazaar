      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_22_listing_6",
      "firm_id": "sybil_22",
      "description": "Hey there! \ud83d\ude97 I'm parting ways with my trusty ride, and she\u2019s been absolute gold to me. It\u2019s in really solid shape\u2014super clean inside and out, runs like a dream, and has clearly been well-loved over the years. Whether you're commuting or heading out on a road trip, this car is ready to go with no headaches. I\u2019ve taken great care of it, and I\u2019m sure you\u2019ll love it as much as I have! Let\u2019s get you behind the wheel! \u2728",
      "price": 34500.0,
