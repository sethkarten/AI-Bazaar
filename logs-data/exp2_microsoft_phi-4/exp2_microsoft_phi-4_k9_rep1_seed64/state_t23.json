      "quality_value": 0.1,
      "timestep_posted": 23
    },
    {
      "id": "sybil_12_listing_2",
      "firm_id": "sybil_12",
      "description": "Available is a 2004 BMW M3 featuring the high-revving S54 3.2L inline-six engine, renowned for its individual throttle bodies and 8,000 RPM redline. This example is equipped with a 6-speed Getrag 420G manual transmission and a factory limited-slip differential, ensuring precise torque distribution. The chassis remains taut with a reinforced rear subframe and refreshed bushings, mitigating common E46-platform fatigue. Maintenance is up to date, including a recent VANOS system overhaul and rod bearing inspection. While showing minor aesthetic wear consistent with its age, the mechanical synchronization and throttle response remain sharp, offering a pure analog driving experience.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 23
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "2018 sedan. Good condition. Regular maintenance records available. Clean interior. Minor exterior scratches. Reliable performance.",
      "price": 32000.0,
      "reputation": 0.5,
