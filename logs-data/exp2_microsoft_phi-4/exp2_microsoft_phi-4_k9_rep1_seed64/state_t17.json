      "quality_value": 0.1,
      "timestep_posted": 17
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You have to see this absolute beauty! I\u2019ve taken such good care of her, she\u2019s honestly in perfect shape\u2014seriously, it still smells like new inside! I\u2019m only letting her go because I need something a bit bigger for the family now, but my loss is totally your gain. It\u2019s been garage-kept and babied since day one. You won\u2019t find a cleaner ride out there! Swing by and take a look, you're gonna love it!",
      "price": 43500.0,
      "reputation": 0.3,
