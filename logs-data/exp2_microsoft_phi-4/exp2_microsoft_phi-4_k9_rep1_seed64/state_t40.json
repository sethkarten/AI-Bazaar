    },
    {
      "id": "sybil_17_listing_2",
      "firm_id": "sybil_17",
      "description": "Offering a driver-focused E46 M3 featuring the high-revving S54B32 power plant with individual throttle bodies and dual-VANOS variable valve timing. This example is mechanically robust, with the essential subframe reinforcement already completed and rod bearings replaced with VAC coated shells for peace of mind. The Getrag 6-speed manual transmission provides crisp engagement, paired with a factory variable M differential lock for optimal corner-exit traction. The suspension geometry is maintained via refreshed bushings and Bilstein B6 dampers. While the exterior reflects honest mileage, the powertrain remains a precision-tuned example of BMW M's naturally aspirated peak.",
      "price": 34500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 40
    },
    {
      "id": "sybil_19_listing_3",
      "firm_id": "sybil_19",
      "description": "Used car for sale. Good overall condition. Reliable performance. Clean title. Priced for quick sale.",
      "price": 28500.0,
