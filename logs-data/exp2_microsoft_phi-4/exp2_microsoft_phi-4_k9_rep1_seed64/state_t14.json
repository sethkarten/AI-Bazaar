      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an uncompromising example of automotive excellence. This vehicle is preserved in pristine, showroom condition, exhibiting no discernible wear and meeting the most rigorous standards of aesthetic and mechanical integrity. An investment-grade acquisition for the discerning driver who demands an immaculate pedigree and peerless performance.",
      "price": 46500.0,
