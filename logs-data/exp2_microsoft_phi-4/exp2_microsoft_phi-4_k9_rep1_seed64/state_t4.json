    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! \ud83d\ude97\u2728 I\u2019m honestly a little sad to see this one go, but it\u2019s time for a new home. This car is in absolute showroom condition\u2014seriously, it looks and smells like it just rolled off the lot! I\u2019ve been super meticulous about maintenance and keeping it spotless, inside and out. If you\u2019re looking for a ride that\u2019s basically brand new without the dealership headache, this is the one for you. Come take a look, you won't be disappointed!",
      "price": 46500.0,
      "reputation": 0.7,
