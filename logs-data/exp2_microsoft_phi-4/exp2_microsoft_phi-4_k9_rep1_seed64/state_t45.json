    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It has visible wear on the interior and exterior, including some scuffs and scratches. The mechanical systems are functional, though the car may require some upcoming maintenance.",
