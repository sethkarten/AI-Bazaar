    },
    {
      "id": "sybil_12_listing_2",
      "firm_id": "sybil_12",
      "description": "Available is a mechanically sound E46 M3 featuring the high-revving S54 3.2L inline-six, equipped with individual throttle bodies and double VANOS variable valve timing. Power is delivered through a Getrag 420G 6-speed manual transmission to a factory M-Variable limited-slip differential. This example has undergone essential preventative maintenance, including rear subframe reinforcement and a recent valve shim adjustment to ensure peak volumetric efficiency. The chassis is enhanced with Bilstein monotube dampers and refreshed bushings, maintaining precise toe and camber settings. While the exterior displays minor patina consistent with spirited use, the powertrain remains robust with excellent compression across all cylinders.",
      "price": 34500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Used car for sale. Good condition. Regular maintenance performed. Clean title. Runs well.",
