    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting an automotive specimen of unparalleled caliber. This vehicle remains in pristine showroom condition, exhibiting zero compromises in aesthetic or mechanical integrity. Meticulously preserved and maintained to the highest standards, it represents a rare opportunity for the discerning collector seeking an investment-grade acquisition. Experience the pinnacle of automotive excellence in a vehicle that presents as new.",
      "price": 44900.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
