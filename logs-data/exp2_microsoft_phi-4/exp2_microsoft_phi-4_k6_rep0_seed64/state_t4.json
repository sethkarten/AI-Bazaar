    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is an investment-grade 2004 Porsche 911 Turbo, featuring the revered Mezger-designed 3.6L twin-turbocharged flat-six mated to a crisp 6-speed manual transaxle. This example maintains its factory-correct performance envelope, utilizing a viscous-coupling all-wheel-drive system and twin K16 turbochargers for linear power delivery and exceptional lateral grip. The undercarriage and engine bay reflect a meticulous maintenance history, with no signs of thermal fatigue or fluid seepage. Equipped with four-piston Brembo monoblock calipers and cross-drilled rotors, the braking system offers immense stopping power with zero fade. This is a turn-key, concours-ready specimen for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 4
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. Full service history. No scratches or mechanical issues. Title in hand.",
      "price": 43500.0,
      "reputation": 0.6,
