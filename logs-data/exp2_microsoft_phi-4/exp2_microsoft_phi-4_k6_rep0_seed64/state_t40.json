      "quality": "good",
      "quality_value": 0.7,
      "timestep_posted": 40
    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready for a dependable ride that's perfect for your daily commute! This vehicle is in honest, fair condition and has plenty of life left in it for a new owner. While it shows some character from its previous travels, it remains a solid and functional choice for anyone looking for great value. Come see why this reliable companion is the perfect fit for your next journey!",
      "price": 20000.0,
