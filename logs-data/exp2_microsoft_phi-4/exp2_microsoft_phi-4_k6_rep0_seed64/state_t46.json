    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. It has significant cosmetic damage to the exterior and heavy wear throughout the interior. There are major mechanical issues that require immediate attention, and the car is not currently reliable for daily use.",
