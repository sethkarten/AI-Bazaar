    },
    {
      "id": "sybil_12_listing_1",
      "firm_id": "sybil_12",
      "description": "Hey there! You honestly won't find another one like this. It's in absolute showroom condition\u2014seriously, it looks and smells like it just rolled off the lot! I've taken such good care of it, and it drives like a dream. If you're looking for perfection, this is your ride. Come take a look and see for yourself!",
      "price": 46500.0,
      "reputation": 0.8,
