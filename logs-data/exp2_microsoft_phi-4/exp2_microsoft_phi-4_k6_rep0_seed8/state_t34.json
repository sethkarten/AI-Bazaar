      "timestep_posted": 34
    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready for your next journey with a car that\u2019s built to last! This vehicle is in fair condition, showing some honest signs of its travels but remaining a dependable choice for anyone seeking great value. It\u2019s a solid, functional ride that\u2019s ready to get you where you need to go with confidence!",
      "price": 19000.0,
      "reputation": 0.9,
      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 34
    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in poor condition and is being sold strictly as-is. While the engine does start, it exhibits a significant oil leak and a noticeable knocking sound during acceleration. The transmission shifts roughly, and the body has extensive rust patches along the rocker panels and several large dents. Inside, the cabin shows heavy wear with torn seats and non-functional air conditioning. This would be an ideal project for a mechanic or a donor vehicle for parts.",
      "price": 4500.0,
      "reputation": 1.0,
      "quality": "poor",
