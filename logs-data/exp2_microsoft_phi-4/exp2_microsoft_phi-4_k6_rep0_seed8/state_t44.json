    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a reliable and well-maintained ride? This car is in good condition and has been lovingly cared for, offering a smooth driving experience and a clean, attractive appearance inside and out. It's the perfect choice for anyone seeking a dependable vehicle that's ready for the road today!",
      "price": 34000.0,
