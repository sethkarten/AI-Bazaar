    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present an exceptional example of automotive excellence. This vehicle arrives in impeccable condition, having undergone rigorous inspections to ensure it meets our most exacting standards. With its flawless finish and showroom-quality interior, this unit represents a rare opportunity for the discerning collector or enthusiast who demands nothing less than perfection. Every detail has been preserved to maintain the highest level of aesthetic and mechanical integrity.",
      "price": 46500.0,
      "reputation": 0.5,
