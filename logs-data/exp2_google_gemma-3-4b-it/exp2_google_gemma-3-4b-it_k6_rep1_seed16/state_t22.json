    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is being sold in poor condition and is recommended for someone looking for a project car or parts vehicle. It currently suffers from significant mechanical problems, including a failing head gasket and a transmission that struggles to engage. The exterior shows heavy wear with several large dents and peeling clear coat, while the interior requires a deep cleaning and repair of torn upholstery. It is being sold strictly as-is and will likely need to be towed.",
      "price": 5500.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is being sold in poor condition and is best suited for a buyer looking for a major project or a source for parts. The engine struggles to maintain a consistent idle and requires significant mechanical attention, while the transmission exhibits noticeable slipping and delayed engagement. Externally, the body shows several large dents, significant paint oxidation, and visible rust in key areas like the wheel wells. Inside, the upholstery is heavily worn with multiple tears, and several electronic features, including the radio and power windows, are currently non-functional. It is strongly recommended that any interested buyer brings a trailer for transport.",
      "price": 7500.0,
