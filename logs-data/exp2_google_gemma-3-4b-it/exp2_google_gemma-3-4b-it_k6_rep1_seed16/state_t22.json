      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and transmission operate smoothly. Both the interior and exterior are well-maintained with minimal signs of wear.",
      "price": 33500.0,
