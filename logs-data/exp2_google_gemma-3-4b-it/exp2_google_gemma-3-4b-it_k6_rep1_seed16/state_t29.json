      "quality_value": 0.1,
      "timestep_posted": 29
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in good overall condition and has been well-maintained throughout its life. The engine is strong and reliable, and the transmission shifts smoothly without any issues. While the exterior shows some minor signs of normal use, such as a few light surface scratches and small stone chips on the hood, it remains very presentable. The interior is clean with no major stains or tears, though there is some light wear on the driver's seat bolster. All electronics and climate control systems are fully functional. This is a dependable car that is ready for its next owner to drive away with confidence.",
      "price": 34500.0,
      "reputation": 1.0,
