    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior has a few minor surface scratches but no major dents. The interior is well-maintained with only light signs of use. All mechanical systems are fully operational, and the car has been regularly serviced.",
      "price": 34000.0,
