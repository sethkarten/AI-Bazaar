    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. It has significant mechanical issues and requires major repairs to be fully operational. The interior and exterior show heavy wear, including visible damage and deterioration.",
      "price": 8500.0,
      "reputation": 1.0,
