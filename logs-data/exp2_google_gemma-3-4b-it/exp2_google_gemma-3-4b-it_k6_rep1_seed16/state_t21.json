    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a reliable daily driver that\u2019s ready to work as hard as you do? This vehicle is in fair condition and has plenty of life left in it! While it shows some honest wear and tear from its years of service, it remains a dependable choice for anyone seeking functional transportation at a great value. It's the perfect opportunity to get behind the wheel of a solid performer without the new-car price tag!",
      "price": 18500.0,
      "reputation": 0.9,
