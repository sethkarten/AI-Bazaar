    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is an exceptional vehicle in absolute showroom condition. This specimen has been maintained to the highest standards, exhibiting no discernible wear. Its mechanical integrity and aesthetic appeal are peerless, making it a definitive choice for the discerning driver who accepts nothing less than perfection.",
      "price": 48500.0,
