    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m selling my absolute pride and joy. This beauty is in pristine, showroom condition\u2014honestly, you\u2019d think it just rolled off the lot! It\u2019s been meticulously cared for and drives like a total dream. If you\u2019re looking for a ride that\u2019s practically perfect inside and out, this is the one for you. Come take a look, you won't be disappointed!",
      "price": 44900.0,
