    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in absolute mint condition and presents as if it just rolled off the showroom floor. The exterior paint is flawless with a deep, mirror-like finish, and the interior remains in pristine state with no signs of wear or aging. It has been meticulously maintained in a climate-controlled environment and comes with a complete service history. This is a rare opportunity to own a truly exceptional example that requires nothing but a new home.",
      "price": 48500.0,
      "reputation": 1.0,
