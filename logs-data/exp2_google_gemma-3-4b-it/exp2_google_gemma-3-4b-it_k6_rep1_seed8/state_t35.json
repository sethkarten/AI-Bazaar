    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in good condition and has been well-maintained, making it an excellent choice for a reliable and comfortable daily driver. The engine runs smoothly, the transmission shifts seamlessly, and all major systems are fully functional. While there is some very minor cosmetic wear consistent with careful use, the exterior paint retains a nice shine and the interior is clean and smoke-free. It\u2019s a solid, dependable car that is ready for its next owner without needing immediate repairs.",
      "price": 31000.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
      "timestep_posted": 35
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in truly mint, showroom condition and has been preserved with the utmost care. The exterior paint is flawless with a deep, mirror-like finish, and the interior remains in pristine, original condition with no signs of wear. Every component functions perfectly, and the car has been kept in a climate-controlled environment with a full service history available. This is a rare opportunity to own a vehicle that looks and drives exactly as it did when it first left the dealership.",
      "price": 48500.0,
      "reputation": 1.0,
      "quality": "mint",
      "quality_value": 1.0,
