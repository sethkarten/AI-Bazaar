    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "This distinguished vehicle represents a superb balance of performance and value. Meticulously maintained and professionally vetted, it offers a refined driving experience and mechanical integrity that exceeds standard expectations for its class. A premier choice for the discerning driver seeking a reliable, high-caliber automobile with a documented history of care.",
      "price": 36500.0,
