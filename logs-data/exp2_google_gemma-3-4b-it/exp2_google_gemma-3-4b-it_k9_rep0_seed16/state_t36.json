    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "This E46 M3 features the legendary S54 3.2L inline-six, delivering linear power through six individual throttle bodies. The 6-speed Getrag manual transmission offers precise engagement, paired with a variable M differential lock for optimal corner-exit traction. This example has undergone comprehensive subframe reinforcement and VANOS servicing to ensure mechanical longevity. The suspension retains its factory-tuned balance between damping and compliance, providing exceptional feedback through the hydraulic steering rack. The high-revving powerplant pulls strongly to its 8,000 RPM redline, offering a pure analog driving experience. A mechanically sound driver's car ready for its next apex.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car in good condition. Reliable engine. Clean interior. Minor exterior scratches. Service records available.",
      "price": 28500.0,
      "reputation": 0.3,
