      "quality_value": 0.1,
      "timestep_posted": 12
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! You've honestly gotta see this beauty in person. It\u2019s been my absolute pride and joy, and I\u2019ve kept it in such incredible shape\u2014it basically still has that new car smell! No scratches, no dents, and it drives like an absolute dream. I\u2019m really sad to see it go, but I know it\u2019s going to make someone very happy. If you're looking for something that feels like it just rolled off the showroom floor, this is the one for you! Let's get you behind the wheel for a test drive! \u2728",
      "price": 46500.0,
      "reputation": 0.7,
