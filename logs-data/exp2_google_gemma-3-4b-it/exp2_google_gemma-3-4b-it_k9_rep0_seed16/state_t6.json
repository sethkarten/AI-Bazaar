      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "This expertly maintained vehicle represents a premier opportunity for the sophisticated driver. Demonstrating a commitment to mechanical excellence and aesthetic preservation, the automobile delivers a composed and reliable performance. Featuring a refined interior and a robust powertrain, this selection offers an optimal synthesis of enduring value and executive presence. We invite serious inquiries to experience this standout example firsthand.",
      "price": 36500.0,
