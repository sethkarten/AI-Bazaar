      "timestep_posted": 49
    },
    {
      "id": "sybil_13_listing_6",
      "firm_id": "sybil_13",
      "description": "Hey there! I\u2019m selling my absolute pride and joy, and honestly, it\u2019s a total dream. This car is in pristine, showroom condition\u2014you\u2019d swear it just rolled off the lot! It's been pampered since day one, strictly garage-kept, and looks absolutely stunning inside and out. If you\u2019re looking for a ride that\u2019s been loved and kept in perfect shape, this is the one for you. Come see it for yourself, you definitely won't be disappointed!",
      "price": 46500.0,
      "reputation": 0.8,
