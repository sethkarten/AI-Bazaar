      "quality_value": 0.1,
      "timestep_posted": 44
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm parting ways with my trusty ride, and honestly, it's been such a joy to drive. It\u2019s in really solid shape and has been super well-loved\u2014perfect for someone who wants a dependable car that still looks great cruising down the street! It\u2019s ready for its next adventure, and I\u2019d love for it to go to someone who will enjoy it as much as I have. Feel free to reach out if you have any questions or want to come see it!",
      "price": 28900.0,
      "reputation": 0.3,
