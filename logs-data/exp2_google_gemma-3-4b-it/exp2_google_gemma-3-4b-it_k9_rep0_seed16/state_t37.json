    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in good overall condition and has been well-maintained throughout its life. The exterior is clean with a strong shine, though you may find a few minor stone chips on the front bumper and some light surface scratches consistent with careful use. Inside, the cabin is tidy and odor-free, with only slight wear on the driver's seat bolster. Mechanically, it's solid, shifting smoothly and handling well on the road. It\u2019s a dependable, attractive car that is ready for its next owner to drive away with confidence.",
      "price": 33500.0,
      "reputation": 0.9,
      "quality": "good",
      "quality_value": 0.7,
      "timestep_posted": 37
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and mechanical systems are operational but show signs of significant wear and may require maintenance in the near future. The exterior has visible scratches and minor dents, and the interior shows noticeable wear and tear from regular use.",
      "price": 20000.0,
