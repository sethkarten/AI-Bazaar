      "quality_value": 0.1,
      "timestep_posted": 16
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm parting ways with my trusty ride, and it\u2019s looking for a great new home! It\u2019s been super reliable for me and is still in really solid shape\u2014perfect for daily commutes or weekend adventures. It\u2019s been well-loved and runs like a charm. If you\u2019re looking for a dependable car that\u2019s ready to hit the road today, this is the one! Feel free to reach out if you want to come take it for a spin!",
      "price": 32000.0,
