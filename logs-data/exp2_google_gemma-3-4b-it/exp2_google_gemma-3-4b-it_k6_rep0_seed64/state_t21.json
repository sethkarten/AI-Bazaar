    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is a meticulously maintained vehicle that exemplifies mechanical reliability and sophisticated styling. This unit has undergone a comprehensive multi-point inspection to ensure it meets our rigorous standards for performance and safety. Featuring a clean interior and a robust powertrain, this vehicle offers a superior driving experience for the discerning owner. We invite you to experience the refined engineering and enduring value of this exceptional offering.",
      "price": 36500.0,
