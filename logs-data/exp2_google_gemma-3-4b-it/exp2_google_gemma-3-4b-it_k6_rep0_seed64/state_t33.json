    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has multiple noticeable scratches and several small dents across the body panels. The interior shows significant signs of use, including worn upholstery and some staining on the carpets.",
      "price": 20000.0,
