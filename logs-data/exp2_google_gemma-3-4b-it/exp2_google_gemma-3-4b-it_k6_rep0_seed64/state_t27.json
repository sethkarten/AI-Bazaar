      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_6_listing_3",
      "firm_id": "sybil_6",
      "description": "Used sedan. Good condition. Full service history. Clean interior. Minor cosmetic wear. Runs well. Reliable.",
      "price": 34500.0,
      "reputation": 0.8,
