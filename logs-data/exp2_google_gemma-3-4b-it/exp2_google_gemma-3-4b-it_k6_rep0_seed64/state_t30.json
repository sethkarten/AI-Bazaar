    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is a museum-grade 2004 Porsche 911 Carrera 4S, featuring the venerable 3.6L flat-six mated to a crisp G96 6-speed manual transaxle. This specimen boasts a documented LN Engineering IMS bearing retrofit and a flawless viscous-coupling AWD system. The chassis retains its factory-spec rigidity with unmolested Bilstein suspension geometry and Turbo-spec 'Big Red' four-piston monoblock calipers. With zero parasitic draw, impeccable bore scoring inspection results, and a pristine underbody, this is an investment-grade example of the widebody 996.2 silhouette.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_6_listing_3",
      "firm_id": "sybil_6",
      "description": "Mint condition. Zero mechanical issues. Clean title. Garage kept. Original paint. Inspection welcome.",
      "price": 44500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
