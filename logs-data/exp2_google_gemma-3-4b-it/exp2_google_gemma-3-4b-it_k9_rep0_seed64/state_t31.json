    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a driver-focused example featuring the legendary S54B32 3.2L inline-six, delivering linear power through six individual throttle bodies. The powertrain is mated to a crisp 6-speed manual transmission and a variable M differential lock. Mechanical highlights include a documented VANOS overhaul and proactive rear subframe reinforcement to ensure long-term structural integrity. The chassis retains its precision with refreshed bushings and Bilstein dampers, providing exceptional feedback and neutral handling. While the aesthetic condition shows minor age-appropriate patina, the mechanical vitals are dialed in for high-revving performance and visceral engagement.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 31
    },
    {
      "id": "sybil_10_listing_3",
