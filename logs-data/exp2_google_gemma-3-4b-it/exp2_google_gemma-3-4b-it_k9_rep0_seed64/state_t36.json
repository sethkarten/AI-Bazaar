    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 features the legendary S54 naturally aspirated inline-six, delivering linear power through individual throttle bodies and a crisp Getrag 6-speed manual gearbox. The chassis remains taut, benefiting from a reinforced rear subframe and refreshed poly-bushings. Proactive maintenance includes a comprehensive VANOS overhaul and documented rod bearing replacement, ensuring the high-revving internals remain within factory tolerances. Equipped with a variable M differential lock and staggered Style 67 wheels, this example offers the visceral feedback and mechanical purity synonymous with the M division\u2019s golden era. The suspension geometry is dialed, and the throttle response is sharp, making it an ideal driver-spec specimen.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Used car. Good condition. Clean title. Regular maintenance performed. Interior is well-kept. Engine runs smooth. Ready for immediate sale.",
      "price": 36000.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
