      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Used car in good condition. Well-maintained engine. Clean title. Minor cosmetic wear. Reliable performance.",
      "price": 32500.0,
      "reputation": 0.7,
