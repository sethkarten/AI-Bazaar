      "timestep_posted": 42
    },
    {
      "id": "sybil_11_listing_6",
      "firm_id": "sybil_11",
      "description": "Hey there! I\u2019m parting ways with my trusty ride, and she\u2019s looking for a great new home! \ud83d\ude97 It\u2019s in wonderful shape and has been super reliable for me\u2014perfect for someone who wants a solid, stylish car without the brand-new price tag. It\u2019s been well-loved and is ready to hit the road with you today. Let\u2019s get you behind the wheel!",
      "price": 31500.0,
      "reputation": 0.6,
