    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "$20,000 - This vehicle is in fair condition. The exterior has several noticeable scratches and minor dents, and the paint shows some fading. The interior is functional but exhibits visible wear on the seats and dashboard. It is mechanically operational but may require maintenance in the near future.",
      "price": 20000.0,
