      "quality_value": 0.1,
      "timestep_posted": 2
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m parting ways with my absolute pride and joy. This beauty is in truly incredible, mint condition\u2014honestly, it looks and drives like it just rolled off the showroom floor! I\u2019ve taken meticulous care of it, and it\u2019s been tucked away safely in the garage. You won\u2019t find a single scratch or hiccup here. It's ready for a new home where it'll be loved just as much. Come take a look, you won't be disappointed!",
      "price": 44900.0,
      "reputation": 0.8,
