      "timestep_posted": 31
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this meticulously maintained vehicle, offering a refined balance of performance and long-term value. This unit has been subjected to a rigorous professional inspection to ensure it meets our exacting standards for mechanical reliability and aesthetic presentation. Featuring a clean, well-appointed interior and a robust powertrain, this vehicle represents an ideal acquisition for the discerning driver who demands consistency and excellence. Secure an asset that exemplifies quality craftsmanship and dependable engineering.",
      "price": 34800.0,
