      "timestep_posted": 33
    },
    {
      "id": "sybil_11_listing_6",
      "firm_id": "sybil_11",
      "description": "Hey there! I\u2019m parting ways with my trusty ride, and honestly, she\u2019s been such a gem. It\u2019s in really solid shape and has plenty of life left for its next adventure! I\u2019ve kept up with the maintenance, so it\u2019s ready to hit the road whenever you are. It\u2019s a super smooth drive and would make a perfect daily driver for someone new. Feel free to reach out if you have any questions!",
      "price": 34500.0,
      "reputation": 0.7,
