    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this meticulously maintained vehicle, offering an exceptional balance of performance and refined aesthetics. This unit has undergone a rigorous inspection to ensure mechanical integrity and road-readiness. The interior remains in superior condition, reflecting a history of careful ownership. For the discerning buyer seeking a reliable and sophisticated driving experience, this vehicle represents a premier acquisition within its class.",
      "price": 34500.0,
      "reputation": 0.8,
