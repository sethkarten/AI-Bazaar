    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a vehicle of superlative caliber, maintained in absolute showroom condition. This specimen exhibits no discernible wear, representing an exemplary fusion of aesthetic perfection and mechanical integrity. Every detail, from the flawless exterior finish to the pristine interior appointments, reflects a standard of care rarely encountered in the pre-owned market. This is an uncompromising acquisition for the discerning enthusiast who demands nothing less than excellence.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
