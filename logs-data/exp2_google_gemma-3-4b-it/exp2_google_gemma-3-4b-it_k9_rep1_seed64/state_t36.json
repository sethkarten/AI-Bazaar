      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presented for your consideration is an automotive specimen of uncompromising quality and provenance. This vehicle remains in immaculate, showroom-caliber condition, reflecting meticulous stewardship and an exhaustive preservation of its original aesthetic and mechanical integrity. We invite discerning buyers to acquire what is arguably the definitive example of its class.",
      "price": 47900.0,
      "reputation": 0.6,
