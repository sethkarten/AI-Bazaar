    },
    {
      "id": "sybil_15_listing_2",
      "firm_id": "sybil_15",
      "description": "Presenting an impeccable 2004 Porsche 911 Carrera 4S, a pinnacle of water-cooled engineering. This specimen features the M96.03 3.6L flat-six, delivering linear power through a precise 6-speed manual transaxle. The all-wheel-drive system utilizes a viscous coupling for optimal torque distribution, while the Turbo-derived wide-body chassis and suspension geometry provide exceptional lateral grip. Mechanically flawless, the IMS bearing has been proactively addressed with a dual-row ceramic upgrade. The factory Arctic Silver metallic finish retains its deep luster, complemented by a pristine black leather cockpit. This is a collector-grade example with zero deferred maintenance.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Mint condition. Single owner. Garage-kept. Original paint. Full service history. No mechanical issues. Inspection welcome.",
      "price": 42500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
