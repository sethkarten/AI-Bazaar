      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_11_listing_6",
      "firm_id": "sybil_11",
      "description": "Hey there! I\u2019m selling my reliable ride, and it\u2019s looking for a great new home! It\u2019s in wonderful shape, runs smoothly, and has been really well-loved over the years. It's the perfect fit for someone who wants a dependable car that still looks fantastic and has plenty of adventures left in it. Come take it for a spin\u2014you\u2019re going to love how it handles!",
      "price": 34500.0,
      "reputation": 0.8,
