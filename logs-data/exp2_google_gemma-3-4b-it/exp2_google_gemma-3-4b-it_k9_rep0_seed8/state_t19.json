      "timestep_posted": 19
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m parting ways with my trusty ride, and it\u2019s been such a joy to drive. It\u2019s in really solid shape and has been super reliable for me. Whether you're commuting or heading out on a weekend road trip, this car is ready to go! It\u2019s clean, well-loved, and looking for a great new home. Come take it for a spin and see for yourself\u2014you're going to love how it handles!",
      "price": 31500.0,
      "reputation": 0.6,
