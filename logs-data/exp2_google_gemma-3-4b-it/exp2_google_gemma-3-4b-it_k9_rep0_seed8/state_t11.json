    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "This vehicle represents a sophisticated fusion of performance and reliability. Meticulously maintained and presenting in commendable mechanical order, it offers a refined driving experience tailored for the discerning professional. Every component has been thoroughly vetted to ensure it meets our rigorous standards for quality and long-term durability.",
      "price": 34900.0,
