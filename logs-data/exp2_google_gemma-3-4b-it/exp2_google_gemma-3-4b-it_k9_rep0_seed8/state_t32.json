      "quality_value": 0.1,
      "timestep_posted": 32
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available for acquisition is a driver-focused 2004 BMW M3, featuring the high-revving S54 3.2L inline-six engine equipped with individual throttle bodies and dual-VANOS variable valve timing. This example delivers a visceral driving experience, channeled through a precise 6-speed manual transmission and a factory-spec limited-slip differential. The mechanical assembly is robust, with critical preventative maintenance addressed, including rod bearing replacement and rear subframe reinforcement to ensure structural rigidity. While the exterior displays a minor patina indicative of its 'good' driver status, the suspension geometry remains sharp and the engine pulls strongly to its 8,000 RPM redline. An ideal specimen for the purist seeking a mechanically sound E46 chassis with authentic feedback.",
      "price": 32500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 32
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle in good condition. Regularly serviced. Clean title. No accidents.",
      "price": 29000.0,
      "reputation": 0.5,
