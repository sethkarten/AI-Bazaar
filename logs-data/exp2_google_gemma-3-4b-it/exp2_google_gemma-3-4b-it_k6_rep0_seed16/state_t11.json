      "quality_value": 1.0,
      "timestep_posted": 11
    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a rewarding project or a budget-friendly set of wheels to tinker with? This car is in poor condition and definitely shows its history, but it's a fantastic opportunity for a mechanic at heart or someone looking for a parts vehicle! With a bit of love and some elbow grease, there's potential here for the right person to bring it back to life or put its components to good use.",
      "price": 5500.0,
