    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant body damage, including large dents and peeling paint. The interior is heavily worn with torn upholstery and broken trim pieces. Mechanically, the car requires major repairs to be roadworthy.",
      "price": 5000.0,
      "reputation": 1.0,
