      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! Are you looking for a reliable ride that\u2019s ready for your next adventure? I\u2019m selling my car, and it\u2019s been such a joy to drive. It\u2019s in really solid shape and has been well-maintained, so it\u2019s running beautifully and looking great. Whether you\u2019re commuting or heading out on a road trip, this one won\u2019t let you down. Come take it for a spin\u2014I think you\u2019re going to love it as much as I have!",
      "price": 31500.0,
