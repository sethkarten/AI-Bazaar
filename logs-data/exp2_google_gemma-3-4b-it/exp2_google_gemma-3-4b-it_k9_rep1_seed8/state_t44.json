    },
    {
      "id": "sybil_14_listing_2",
      "firm_id": "sybil_14",
      "description": "This E46 M3 is powered by the high-revving S54B32 straight-six, featuring individual throttle bodies and a 7,900 RPM redline. The 6-speed Getrag manual transmission offers crisp engagement, paired with a limited-slip Variable M Differential Lock for optimal power delivery out of corners. Significant preventative maintenance has been completed, including VANOS system servicing and rod bearing replacement. The suspension retains its factory-tuned damping characteristics with refreshed bushings, maintaining the chassis's celebrated balance and steering feedback. While it shows minor cosmetic patina expected of its age, the mechanical integrity remains high, providing a pure, naturally aspirated performance profile.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 44
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Good condition. Reliable daily driver. Clean title. All maintenance current. No mechanical issues.",
      "price": 29500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
