    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior is well-maintained with only minor surface blemishes. The interior is clean and shows minimal signs of use. Mechanically, the car is sound and performs reliably.",
      "price": 32000.0,
      "reputation": 1.0,
