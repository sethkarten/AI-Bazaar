    {
      "id": "sybil_16_listing_0",
      "firm_id": "sybil_16",
      "description": "This distinguished vehicle represents an exceptional balance of performance and long-term value. Meticulously maintained and presented in commendable condition, it features a refined interior and a robust mechanical profile that ensures a superior driving experience. A premier choice for the discerning buyer seeking reliability without compromising on sophistication.",
      "price": 36800.0,
