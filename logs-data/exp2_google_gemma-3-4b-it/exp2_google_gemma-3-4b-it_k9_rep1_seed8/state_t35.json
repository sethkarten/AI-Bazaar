    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior is well-maintained with only minor surface blemishes. The interior is clean, showing light wear consistent with regular use. Mechanically, the car is reliable and has been serviced regularly.",
      "price": 35000.0,
