    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior is flawless with no scratches, dents, or blemishes. The interior is in pristine condition and shows no signs of wear. Mechanically, the car is in perfect working order.",
      "price": 49500.0,
      "reputation": 1.0,
