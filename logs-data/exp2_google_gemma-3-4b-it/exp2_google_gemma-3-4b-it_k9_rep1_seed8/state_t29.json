    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "This expertly maintained vehicle represents a premier opportunity for the discerning driver. Characterized by its robust mechanical integrity and a sophisticated aesthetic, it has undergone a rigorous inspection to ensure it meets our exacting standards for performance and reliability. Offering a seamless blend of comfort and longevity, this selection is a testament to quality automotive stewardship.",
      "price": 34800.0,
      "reputation": 0.6,
