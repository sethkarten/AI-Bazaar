    {
      "id": "sybil_16_listing_0",
      "firm_id": "sybil_16",
      "description": "Presenting an automotive specimen of unparalleled caliber. This vehicle is offered in pristine condition, having been curated to the most exacting standards of preservation. Both its aesthetic presentation and mechanical integrity reflect a showroom-fresh state, entirely free from discernible wear or blemish. For the discerning enthusiast who demands excellence without compromise, this represents a premier acquisition opportunity of the highest order.",
      "price": 48500.0,
      "reputation": 0.8,
