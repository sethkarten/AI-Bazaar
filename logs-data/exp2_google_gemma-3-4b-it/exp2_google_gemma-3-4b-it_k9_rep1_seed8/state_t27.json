      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I am absolutely heartbroken to let this beauty go, but it\u2019s finally time for someone else to enjoy it! This car is in truly pristine, showroom-level shape\u2014it has been babied since day one and looks practically brand new inside and out. If you've been looking for that perfect ride that feels like it just rolled off the lot, you\u2019ve found it! I've taken such good care of it, and I know you're going to love it. Let's get you behind the wheel for a test drive!",
      "price": 43500.0,
      "reputation": 0.4,
