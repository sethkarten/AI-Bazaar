      "timestep_posted": 30
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a distinguished example of automotive excellence, this vehicle has been curated for the driver who demands both performance and long-term reliability. Meticulously maintained and showing clear pride of ownership, it offers a refined driving experience and a polished aesthetic that stands out in its class. This is a premier opportunity to acquire a well-preserved asset that balances sophistication with mechanical integrity.",
      "price": 34500.0,
      "reputation": 0.6,
