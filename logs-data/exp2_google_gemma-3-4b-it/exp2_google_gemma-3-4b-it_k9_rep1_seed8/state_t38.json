    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior shows visible scratches and some small dents. The interior displays noticeable wear on the seats and carpeting. Mechanically, the car is functional but may require maintenance for some aging components in the near future.",
      "price": 20000.0,
      "reputation": 1.0,
      "quality": "fair",
