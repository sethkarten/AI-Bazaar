    },
    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and is best suited for a dedicated project or as a source for parts. The engine requires significant mechanical attention, as it currently struggles to idle and shows signs of a major leak. The body has multiple large dents and significant rust patches on the wheel wells, and the interior upholstery is heavily worn with several tears. While it does still start, it is not recommended for long-distance driving in its current state.",
      "price": 6500.0,
