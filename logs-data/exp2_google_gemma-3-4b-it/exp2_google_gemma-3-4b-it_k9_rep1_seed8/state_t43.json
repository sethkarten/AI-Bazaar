    },
    {
      "id": "sybil_14_listing_2",
      "firm_id": "sybil_14",
      "description": "Presenting an investment-grade E46 M3, featuring the legendary S54 inline-six with its 8,000 RPM redline and individual throttle bodies. This example remains in concours-level condition, boasting a reinforced rear subframe and a recently overhauled Beisan Systems Vanos unit. The Getrag 6-speed manual transmission provides crisp engagement, paired with a factory limited-slip differential for optimal power delivery. Finished in its original paint with zero orange peel, the chassis maintains its factory rigidity. No pixel degradation in the cluster or bolster wear on the Nappa leather. This is a turn-key collector piece for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Pristine condition. Garage kept. No accidents. Original paint. Clean title. Serious buyers only.",
