      "quality_value": 0.1,
      "timestep_posted": 12
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You have to see this absolute gem. It\u2019s honestly in such incredible shape, you\u2019d think it just rolled off the showroom floor yesterday! I\u2019ve taken such good care of it\u2014no scratches, no spills, just pure perfection inside and out. It drives like a dream and is looking for a new home where it'll be just as pampered. If you're looking for something that feels brand new without the brand-new price tag, this is the one for you! Feel free to reach out with any questions!",
      "price": 43900.0,
