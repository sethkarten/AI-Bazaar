    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2015 sedan in fair condition. The exterior has several noticeable scratches and some fading in the paint. The interior shows moderate wear on the seats and carpets. The vehicle is mechanically functional but may require routine maintenance in the near future.",
      "price": 20000.0,
      "reputation": 1.0,
      "quality": "fair",
