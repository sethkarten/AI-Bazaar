    },
    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and is best suited for someone looking for a major project or a source for parts. The engine struggles to stay running, the transmission has significant slippage, and there are visible signs of heavy rust and body damage. The interior is also heavily worn and will need a complete overhaul. It is sold strictly as-is.",
      "price": 3800.0,
