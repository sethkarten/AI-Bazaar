    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and currently does not run. It has significant mechanical issues, including a seized engine and a heavily rusted frame that compromises its structural integrity. The interior shows extreme wear and tear, and several electronic components are non-functional. This car is best suited as a parts donor or a very intensive long-term restoration project for someone with the necessary tools and expertise.",
      "price": 5500.0,
      "reputation": 1.0,
