    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m looking to find a new home for my awesome ride. It\u2019s been such a reliable companion and is still in really solid shape, ready for plenty more adventures! It drives like a dream and has been super well-maintained. If you're looking for a dependable car that still looks great on the road, this is the one for you. Let's get you behind the wheel!",
      "price": 32500.0,
      "reputation": 0.5,
