    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This car is being sold in poor condition and is currently non-operational. It requires significant mechanical attention, specifically regarding a blown head gasket and a transmission that is slipping badly. While the interior is mostly intact, the body shows signs of heavy wear and some rust. This is a project car or a parts donor and will need to be towed from the lot.",
      "price": 4800.0,
