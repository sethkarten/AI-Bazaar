    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2015 sedan in fair condition. The exterior has several noticeable scratches and minor dents. The interior shows significant wear on the upholstery and carpet. Mechanically, the vehicle is functional but has high mileage.",
      "price": 22500.0,
      "reputation": 1.0,
      "quality": "fair",
