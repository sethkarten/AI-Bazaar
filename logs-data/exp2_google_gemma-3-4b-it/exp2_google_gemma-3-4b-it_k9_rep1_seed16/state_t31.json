    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2015 sedan in poor condition. The exterior has significant body damage, including large dents and rusted panels. The interior is heavily worn with torn upholstery and stained carpets. The engine requires major repairs to be roadworthy, and several electrical components are non-functional.",
      "price": 5500.0,
      "reputation": 1.0,
