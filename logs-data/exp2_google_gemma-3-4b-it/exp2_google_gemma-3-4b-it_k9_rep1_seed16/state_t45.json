    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "$32,000 - 2015 sedan in good condition. The exterior is clean with only minor signs of use. The interior is well-maintained with minimal wear on the upholstery. Mechanically, the vehicle is reliable and has been regularly serviced.",
      "price": 32000.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
