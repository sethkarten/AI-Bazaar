      "quality_value": 0.1,
      "timestep_posted": 44
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a driver-focused 2004 BMW M3 (E46) featuring the legendary S54 3.2L inline-six. This high-revving power plant delivers linear power via individual throttle bodies and double VANOS variable valve timing, paired with a tactile Getrag 420G 6-speed manual transmission. The chassis maintains excellent lateral rigidity, supported by a factory M-variable limited-slip differential for superior traction out of apexes. Recently serviced with a focus on cooling system integrity and subframe inspection, this example remains a benchmark for hydraulic steering feedback and balanced weight distribution. Minor cosmetic patina consistent with spirited use, but mechanically robust and ready for the canyon roads.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 44
    },
    {
      "id": "sybil_7_listing_3",
      "firm_id": "sybil_7",
      "description": "Used vehicle. Good condition. Regularly serviced. Clean title. Mechanically sound. Minor cosmetic wear.",
      "price": 34500.0,
