      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Up for sale is a mechanically sorted E92 M3 featuring the legendary S65 4.0L V8 and its 8,400 RPM redline. This example boasts a crisp 6-speed manual transmission and the M Variable Differential Lock for optimal power delivery. Maintenance is current, including the critical rod bearing service and throttle actuators. The suspension retains its factory precision with Electronic Damper Control (EDC) providing adjustable damping rates for various track or street configurations. A well-maintained driver\u2019s car that balances raw naturally aspirated performance with everyday usability.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car in good condition. Regularly maintained. Clean title. Mechanically sound. Minimal interior wear.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
