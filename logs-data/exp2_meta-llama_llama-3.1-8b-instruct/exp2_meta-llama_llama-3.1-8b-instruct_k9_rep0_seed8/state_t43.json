    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "2022 Performance Sedan. Pristine exterior. Flawless interior. Single owner. Garage kept. No accidents. Full service records available.",
      "price": 43500.0,
