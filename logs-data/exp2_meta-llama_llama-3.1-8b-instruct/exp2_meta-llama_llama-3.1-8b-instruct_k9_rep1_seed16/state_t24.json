    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a mechanically sound E46 M3 featuring the high-revving S54 3.2L inline-six engine. This unit maintains excellent compression across all cylinders, with the double VANOS system recently overhauled for precise valve timing. Power is managed through a Getrag 420G 6-speed manual transmission and an M Variable Differential Lock, ensuring optimal torque distribution. Crucially, the rear subframe has been inspected and reinforced to mitigate common chassis fatigue. The suspension retains its factory-tuned kinematics with fresh bushings, providing the tactile feedback and lateral grip expected of this platform. While the exterior shows honest patina, the powertrain and drivetrain are dialed in for the purist driver.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 24
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Well-maintained. Clean title. Runs well. No mechanical issues.",
      "price": 28500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
