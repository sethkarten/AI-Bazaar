      "quality_value": 0.1,
      "timestep_posted": 12
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You honestly have to see this beauty in person to believe it. It's in absolute mint condition\u2014I\u2019ve babied this car since day one, and it still has that fresh, new-car feel. It drives like an absolute dream and looks like it just rolled off the showroom floor! If you're looking for something flawless that\u2019s ready for the road, this is definitely the one for you. Let's get you behind the wheel!",
      "price": 43900.0,
