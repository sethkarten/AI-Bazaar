      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m parting ways with my trusty ride, and she\u2019s looking for a new home! This car has been so reliable for me and still runs like a dream. It\u2019s been well-loved and looked after, making it the perfect choice if you want a solid, stylish vehicle that's ready to hit the road today. Come take it for a spin\u2014I just know you\u2019re going to love how it handles!",
      "price": 31500.0,
