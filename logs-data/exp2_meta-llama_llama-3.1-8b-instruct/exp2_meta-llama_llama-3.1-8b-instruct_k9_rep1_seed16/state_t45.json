      "timestep_posted": 45
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey everyone! I'm selling my pride and joy, and honestly, she\u2019s a total dream. This car is in absolutely flawless condition\u2014it literally looks like it just rolled off the showroom floor! I\u2019ve taken incredible care of it, so there isn't a single scratch or dent to be found. If you're looking for a ride that feels and smells brand new, this is the one for you. Come check it out and see for yourself!",
      "price": 44900.0,
      "reputation": 0.5,
