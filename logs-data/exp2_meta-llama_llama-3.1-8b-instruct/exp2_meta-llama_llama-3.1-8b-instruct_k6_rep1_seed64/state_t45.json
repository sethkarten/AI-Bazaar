    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! You seriously have to see this beauty to believe it. I have babied this car since day one, and it\u2019s still looking and driving like it just rolled off the showroom floor! It's in absolutely pristine shape, inside and out\u2014not a speck of dust or a single scratch. I'm looking for a great new home for it where it'll be just as loved. Drop me a message if you want to come take a look!",
      "price": 43500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
