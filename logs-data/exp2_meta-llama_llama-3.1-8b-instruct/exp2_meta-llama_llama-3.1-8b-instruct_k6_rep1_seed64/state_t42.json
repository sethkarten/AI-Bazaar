    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m selling my absolute dream of a car and it is seriously in showroom condition! I\u2019ve babied this beauty from day one, so it\u2019s looking and driving just like it did the day I bought it. It\u2019s sparkling clean inside and out\u2014honestly, it\u2019s basically perfect. I\u2019m so excited for the next owner to get behind the wheel and enjoy it as much as I have!",
      "price": 43500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
