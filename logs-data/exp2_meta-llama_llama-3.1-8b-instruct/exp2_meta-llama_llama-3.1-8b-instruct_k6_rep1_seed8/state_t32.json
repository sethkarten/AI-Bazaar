    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting an exemplary specimen maintained to the highest standards of automotive excellence. This vehicle remains in showroom condition, exhibiting no discernible wear and absolute mechanical integrity. A rare find for the discerning collector or enthusiast who demands nothing less than perfection, this unit represents the pinnacle of its class.",
      "price": 46800.0,
      "reputation": 0.7,
