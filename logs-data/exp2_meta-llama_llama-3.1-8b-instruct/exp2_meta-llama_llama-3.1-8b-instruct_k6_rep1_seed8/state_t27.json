    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready to hit the road in this fantastic and reliable vehicle! It has been well-maintained and is in good overall condition, showing only the minor signs of use you'd expect from a car that's been loved and driven. It performs beautifully and is ready for its next owner to enjoy many more miles of dependable service!",
      "price": 34500.0,
      "reputation": 0.8,
