    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is being offered in poor condition and would be best suited for a dedicated project or as a source for parts. The engine currently suffers from a heavy oil leak and an audible knocking sound, indicating that a rebuild or replacement is likely necessary. Additionally, the body shows significant rust on the rocker panels and the interior has seen better days with several tears in the upholstery. Despite these issues, the frame remains solid and many secondary components are still functional.",
      "price": 4500.0,
      "reputation": 0.9,
      "quality": "poor",
