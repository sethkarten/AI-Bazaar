    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I'm parting ways with my trusty ride, and it\u2019s honestly been such a joy to own. It\u2019s in really solid shape and has been super well-maintained\u2014perfect for someone looking for a dependable car that still looks great on the road. It runs smoothly and is ready for its next adventure! Feel free to reach out if you have any questions or want to take it for a spin!",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
