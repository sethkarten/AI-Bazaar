      "quality_value": 0.4,
      "timestep_posted": 46
    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in fair condition and offers a reliable, budget-friendly option for a daily driver. The exterior has some noticeable scratches and minor dings, and the interior shows clear signs of use, including some wear on the seats and carpet. Mechanically, the car starts and runs well, though it has the typical sounds and feel of a high-mileage vehicle. It is a solid choice for someone who prioritizes functionality over aesthetics and is prepared for routine maintenance.",
      "price": 22500.0,
