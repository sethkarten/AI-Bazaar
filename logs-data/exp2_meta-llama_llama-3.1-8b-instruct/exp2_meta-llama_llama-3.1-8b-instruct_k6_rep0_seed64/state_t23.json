      "quality_value": 1.0,
      "timestep_posted": 23
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "For sale: a used car in fair condition. The engine and transmission are functional but show wear consistent with its age. There are visible scratches and minor dents on the exterior, and the interior shows signs of regular use.",
      "price": 19500.0,
