    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a mechanically sorted E46 M3, featuring the high-revving S54 3.2L inline-six equipped with individual throttle bodies and Double VANOS variable valve timing. Power is delivered to the rear wheels via a precise 6-speed Getrag manual transmission and a factory M-Variable differential lock. This example has undergone essential preventative maintenance, including subframe reinforcement and a comprehensive VANOS overhaul, ensuring the chassis handles the 333hp output with surgical precision. The suspension geometry remains true, providing the communicative feedback and neutral balance expected of this iconic platform. A driver-focused cockpit and a robust service history make this an exceptional candidate for the purist seeking peak atmospheric performance.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 39
    },
    {
      "id": "sybil_6_listing_3",
      "firm_id": "sybil_6",
      "description": "Used vehicle. Good condition. Well-maintained. Clean title. Reliable performance. Ready for immediate sale.",
      "price": 34000.0,
      "reputation": 0.8,
