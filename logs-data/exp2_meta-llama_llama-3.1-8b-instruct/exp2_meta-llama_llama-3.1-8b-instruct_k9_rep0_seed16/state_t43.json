      "timestep_posted": 43
    },
    {
      "id": "sybil_12_listing_6",
      "firm_id": "sybil_12",
      "description": "Hey there! I\u2019m looking to find a new home for my trusty car! It\u2019s in really wonderful shape and has been so reliable for me. It\u2019s super clean, drives like a dream, and is totally ready to hit the road with you today. It's the perfect pick if you're looking for a solid, well-cared-for ride that still looks great in the driveway. Come take it for a spin and see for yourself!",
      "price": 34500.0,
      "reputation": 0.8,
