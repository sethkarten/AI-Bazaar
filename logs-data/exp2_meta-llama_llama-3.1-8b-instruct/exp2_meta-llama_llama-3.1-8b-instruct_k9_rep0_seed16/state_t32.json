    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "This meticulously maintained vehicle represents a premier opportunity for the discerning driver. Featuring a comprehensive service history and robust mechanical integrity, it offers a refined driving experience that exceeds standard expectations for its class. Its aesthetic presentation remains impressive, showcasing consistent care and professional upkeep. We invite you to experience the caliber of this exceptional offering firsthand.",
      "price": 36500.0,
