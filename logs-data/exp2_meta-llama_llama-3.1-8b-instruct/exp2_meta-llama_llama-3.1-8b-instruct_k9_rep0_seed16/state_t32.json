      "timestep_posted": 32
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car in good condition. Well-maintained engine. Clean interior. Minor exterior wear. All services up to date.",
      "price": 34500.0,
