    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained and all systems are fully functional. There is minor cosmetic wear consistent with regular use.",
      "price": 32000.0,
      "reputation": 0.9,
