    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "This 997.1 Carrera S is an analog masterpiece in museum-grade condition. The 3.8L flat-six delivers linear power through a crisp 6-speed manual, featuring a recently verified IMS bearing and documented bore scoring inspection. Equipped with PASM (Porsche Active Suspension Management) for adaptive damping and a factory short-shift kit, the mechanical feedback is uncompromising. Every bushing remains tight, the underbody is pristine and dry, and the original paint retains its factory depth. Meticulously maintained with a comprehensive service dossier, this example represents the pinnacle of naturally aspirated engagement.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Mint condition. Single owner. Garage kept. Original paint. Full service history. No accidents.",
      "price": 46500.0,
      "reputation": 0.7,
