    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available now is a museum-grade E46 M3, featuring the iconic S54 3.2L high-revving straight-six. This example boasts a pristine subframe, a fully serviced Double-VANOS system, and original individual throttle bodies that provide razor-sharp response. The Getrag 6-speed manual transmission shifts with clinical precision, delivering power to the rear wheels via a perfectly calibrated M-Variable differential lock. Suspension geometry remains factory-spec with zero bushing deflection, ensuring the legendary chassis rigidity is preserved. Finished in flawless paint with a completely stock powertrain, this is a turnkey investment for the discerning purist.",
      "price": 44500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Mint condition. Garage kept. No accidents. Full service history. Professional inspection welcome.",
      "price": 42500.0,
      "reputation": 0.3,
