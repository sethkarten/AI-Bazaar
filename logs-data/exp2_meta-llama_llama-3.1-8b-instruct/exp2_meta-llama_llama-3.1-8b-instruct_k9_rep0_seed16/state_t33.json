      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "This expertly maintained vehicle presents a distinguished opportunity for the discerning driver. Characterized by robust mechanical integrity and a well-preserved aesthetic, it offers a seamless blend of dependable performance and sophisticated styling. Each system has been thoroughly evaluated to ensure it meets our rigorous standards for roadworthiness and longevity. This is a premier selection for those seeking a high-caliber driving experience without the premium of a showroom-new price point.",
      "price": 34900.0,
