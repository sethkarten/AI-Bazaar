    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior paint and body are flawless, with no scratches, dents, or imperfections. The interior is in pristine condition, showing no signs of wear. All mechanical systems are in perfect working order.",
      "price": 49000.0,
      "reputation": 1.0,
