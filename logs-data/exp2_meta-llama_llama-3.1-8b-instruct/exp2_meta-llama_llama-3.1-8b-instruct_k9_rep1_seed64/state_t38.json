    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a vehicle of exceptional caliber, maintained to the highest standards of automotive excellence. This specimen remains in pristine showroom condition, exhibiting no discernible wear and reflecting meticulous stewardship. An uncompromising choice for the discerning driver who demands perfection in both aesthetics and mechanical integrity.",
      "price": 46500.0,
