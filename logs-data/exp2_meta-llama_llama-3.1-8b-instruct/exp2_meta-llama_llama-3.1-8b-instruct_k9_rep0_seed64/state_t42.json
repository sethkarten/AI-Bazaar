      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presented for your consideration is a distinguished example of automotive excellence, maintained to a high standard of mechanical and aesthetic integrity. This vehicle offers a refined driving experience, balancing sophisticated performance with exceptional value. It has undergone a comprehensive inspection to ensure it meets our exacting criteria for reliability and roadworthiness. We invite discerning buyers to acquire a vehicle that exemplifies both prestige and proven capability.",
      "price": 36500.0,
