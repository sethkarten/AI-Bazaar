      "timestep_posted": 21
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Well-maintained vehicle. Engine runs smooth. Clean interior. Recent service completed. Minor cosmetic wear consistent with age.",
      "price": 32000.0,
