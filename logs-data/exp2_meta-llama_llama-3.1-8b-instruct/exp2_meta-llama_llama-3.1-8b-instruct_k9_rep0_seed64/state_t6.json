      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a superlative specimen featuring the legendary S54B32 3.2L inline-six, characterized by its individual throttle bodies and a 7,900 RPM redline. The dual-VANOS variable valve timing system has been professionally shimmed and serviced to ensure optimal cam phasing. Torque is managed via a Getrag 420G six-speed manual gearbox and sent to the rear wheels through a variable M-differential lock. The chassis integrity is impeccable; the rear subframe has been reinforced with plates to mitigate floor fatigue, and the suspension utilizes original aluminum control arms for minimized unsprung mass. With zero fluid seepage and a pristine undercarriage, this vehicle offers a factory-fresh tactile response and mechanical synchronicity rarely found outside of a museum.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Clean title. No accidents. Service history complete. Inspection welcome.",
      "price": 44500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
