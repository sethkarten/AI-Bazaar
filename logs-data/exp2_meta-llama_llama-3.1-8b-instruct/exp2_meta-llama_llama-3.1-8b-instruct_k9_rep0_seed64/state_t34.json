      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_11_listing_6",
      "firm_id": "sybil_11",
      "description": "Hey there! \ud83d\ude97 I\u2019m parting ways with my absolute pride and joy. This beauty is in truly stunning, mint condition\u2014honestly, it looks and feels like it just rolled off the showroom floor! It\u2019s been pampered its whole life, kept sparkling clean, and drives like an absolute dream. If you're looking for that 'brand new' magic without the dealership headache, you\u2019ve found it. Drop me a message and come see it for yourself!",
      "price": 45500.0,
