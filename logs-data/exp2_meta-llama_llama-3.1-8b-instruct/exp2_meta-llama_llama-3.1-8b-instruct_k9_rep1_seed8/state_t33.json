      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this meticulously maintained vehicle, representing a superb balance of performance and value. This unit exhibits a high standard of mechanical integrity and has been subject to rigorous inspections to ensure continued reliability. The exterior maintains a professional appearance, complemented by a well-preserved interior that reflects a history of responsible ownership. This is an excellent opportunity to acquire a robust and sophisticated vehicle that meets the exacting standards of a discerning driver.",
      "price": 34500.0,
