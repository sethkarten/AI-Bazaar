      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a driver-focused example featuring the high-revving S54 3.2L inline-six with individual throttle bodies and double-VANOS timing. The mechanical integrity is bolstered by recent preventative maintenance, including subframe reinforcement and a VANOS system refresh. Power is delivered through a precise Getrag 6-speed manual transmission to a variable M differential lock, ensuring optimal traction and corner-exit speeds. The chassis maintains its factory-spec balance with a well-sorted multi-link rear suspension and responsive steering rack, offering the tactile feedback sought by purists.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car. Good condition. Well-maintained engine. Clean title. No mechanical issues. Interior is clean.",
      "price": 32000.0,
      "reputation": 0.5,
