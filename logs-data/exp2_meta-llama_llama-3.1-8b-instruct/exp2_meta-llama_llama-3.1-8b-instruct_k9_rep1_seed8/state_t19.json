      "quality_value": 0.1,
      "timestep_posted": 19
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m selling my trusty car, and honestly, it\u2019s been such a joy to own. It\u2019s in really great shape and has been super reliable for me. It\u2019s clean, well-loved, and ready to hit the road with a new owner! If you\u2019re looking for a solid ride that\u2019s been well taken care of, this is definitely the one. Feel free to reach out if you have any questions\u2014I'd love to see it go to a good home!",
      "price": 32500.0,
