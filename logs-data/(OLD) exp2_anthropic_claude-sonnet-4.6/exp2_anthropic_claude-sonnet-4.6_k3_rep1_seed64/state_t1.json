    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2019 sedan in poor condition. The exterior has noticeable dents, scratches, and some rust spots. The interior shows significant wear including damaged upholstery and non-functional components. Mechanical issues are present and the car will likely require substantial repairs. Sold as-is.",
      "price": 5500.0,
      "reputation": 0.8,
