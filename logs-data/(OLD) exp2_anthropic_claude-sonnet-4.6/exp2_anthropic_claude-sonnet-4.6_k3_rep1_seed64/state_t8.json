    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. The exterior shows minor cosmetic blemishes consistent with normal use, but no significant damage. The interior has some wear but is clean and functional. Mechanically the car runs well with no known issues.",
      "price": 32000.0,
      "reputation": 0.9,
