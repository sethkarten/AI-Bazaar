    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in fair condition. The exterior shows noticeable wear including some dents, scratches, and areas of paint fading. The interior has moderate wear on the upholstery and surfaces. Mechanically it is functional but shows signs of age and use.",
      "price": 16500.0,
