    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in good condition. It runs and drives well with no significant mechanical issues. The exterior shows minor surface wear consistent with normal use but has no major dents or damage. The interior is clean and functional with typical wear for its age. All major systems are operating as expected.",
      "price": 34000.0,
