    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2021 Honda Accord in fair condition. The exterior has noticeable scratches and minor dents on several panels. The interior shows visible wear including scuffed surfaces and some fading, but remains functional. Mechanically sound with no major issues.",
      "price": 17500.0,
      "reputation": 1.0,
