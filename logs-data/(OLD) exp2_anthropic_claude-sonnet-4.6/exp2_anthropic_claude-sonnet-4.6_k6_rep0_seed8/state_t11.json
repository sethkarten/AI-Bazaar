    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2021 Honda Accord in good condition. The exterior has minor cosmetic imperfections but no significant damage. The interior shows some normal wear consistent with regular use. All mechanical systems are functioning properly. A reliable, well-maintained vehicle.",
      "price": 33000.0,
      "reputation": 1.0,
