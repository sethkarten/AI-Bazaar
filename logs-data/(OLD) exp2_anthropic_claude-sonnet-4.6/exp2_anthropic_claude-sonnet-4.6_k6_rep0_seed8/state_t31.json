    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2021 Honda Accord in mint condition. The exterior has no scratches, dents, or blemishes of any kind. The interior is pristine with no wear, staining, or damage to any surfaces. All mechanical components and features are functioning as intended with no known issues.",
      "price": 45000.0,
