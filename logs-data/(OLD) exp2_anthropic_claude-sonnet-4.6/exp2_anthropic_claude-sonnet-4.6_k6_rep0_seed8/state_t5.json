    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. It runs and drives well with no significant mechanical issues. The exterior shows minor cosmetic wear consistent with normal use, such as small scratches or light paint scuffs, but no rust or major damage. The interior is clean and functional with only light signs of use.",
      "price": 33000.0,
