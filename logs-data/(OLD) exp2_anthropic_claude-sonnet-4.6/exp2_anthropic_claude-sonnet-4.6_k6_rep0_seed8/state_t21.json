    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in poor condition. It runs but has significant mechanical issues that will require attention and repair. There is heavy cosmetic wear including deep scratches, paint damage, and worn interior surfaces. Buyers should expect to invest in repairs before relying on this vehicle.",
      "price": 5500.0,
