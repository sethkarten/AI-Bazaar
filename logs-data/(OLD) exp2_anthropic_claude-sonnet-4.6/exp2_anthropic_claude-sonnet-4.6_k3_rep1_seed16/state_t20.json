    },
    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in good condition. It shows normal wear consistent with regular use, including minor cosmetic imperfections on the exterior and some light wear on the interior surfaces, but no major damage. Mechanically it is sound and functions as expected.",
      "price": 34000.0,
      "reputation": 1.0,
