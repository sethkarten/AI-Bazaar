    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in poor condition. It shows significant wear on both the exterior and interior, including noticeable body damage, worn upholstery, and cosmetic deterioration throughout. There are known mechanical issues that will likely require attention. Sold as-is.",
      "price": 6000.0,
      "reputation": 0.8,
