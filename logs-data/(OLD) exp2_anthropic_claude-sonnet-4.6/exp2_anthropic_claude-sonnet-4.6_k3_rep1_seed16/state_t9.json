    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. It runs and drives well with no significant mechanical issues, though it may have minor wear consistent with normal use. The exterior has light surface marks but no major dents or damage, and the interior is clean with minimal wear. Overall a solid, reliable vehicle.",
      "price": 33500.0,
      "reputation": 0.9,
