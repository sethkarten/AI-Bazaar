    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. It runs and drives well with no significant mechanical issues. The exterior has some light surface marks and minor wear consistent with regular use, but no major dents or damage. The interior is clean and functional.",
      "price": 33000.0,
      "reputation": 1.0,
