    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in mint condition. It shows no mechanical issues and runs perfectly. The exterior is free of scratches, dents, and paint damage, and the interior is clean and undamaged throughout. Everything is in excellent working order.",
