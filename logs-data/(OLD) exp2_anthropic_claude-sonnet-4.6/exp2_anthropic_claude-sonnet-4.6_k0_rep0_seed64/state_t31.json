    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. The exterior has minor scratches and light wear consistent with normal use, but no significant dents or rust. The interior is clean with some light wear on the upholstery. Mechanically, the car runs well and has been maintained adequately.",
      "price": 34000.0,
