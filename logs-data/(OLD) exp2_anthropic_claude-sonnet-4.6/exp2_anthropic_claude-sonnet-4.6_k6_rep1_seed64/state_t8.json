    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in poor condition. The exterior has multiple scratches, dents, and visible body damage. The interior is heavily worn with torn upholstery, damaged trim, and scuffed surfaces. The engine runs but requires attention, and there are noticeable mechanical issues that will need repair.",
      "price": 5500.0,
