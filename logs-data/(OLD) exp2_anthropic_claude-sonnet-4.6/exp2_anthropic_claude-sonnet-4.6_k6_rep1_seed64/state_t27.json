    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior has minor surface scratches and light wear consistent with regular use, but no significant dents or paint damage. The interior shows some light wear on high-contact surfaces such as the driver's seat and door panels, but remains clean and functional overall. Mechanically the car runs well with no known issues.",
      "price": 33500.0,
      "reputation": 1.0,
