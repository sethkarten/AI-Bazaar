    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in poor condition. The exterior has multiple scratches, dents, and noticeable paint damage in several areas. The interior shows significant wear, including damaged upholstery, cracked or broken trim pieces, and surfaces with heavy scuffing. Mechanical issues may be present and should be expected at this condition level.",
      "price": 5500.0,
