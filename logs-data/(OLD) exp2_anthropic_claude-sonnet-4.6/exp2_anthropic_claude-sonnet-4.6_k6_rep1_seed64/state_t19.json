    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in mint condition. The exterior has no scratches, dents, or blemishes, with a clean and uniform finish throughout. The interior shows no signs of wear, with all upholstery, trim, and surfaces in pristine shape. Mechanically sound with no known issues.",
      "price": 46000.0,
