    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This used car is in good overall condition. The exterior shows minor wear consistent with normal use, and the interior is clean with no significant damage. The engine runs well and all major systems are functioning properly. A solid, dependable option for a used vehicle buyer.",
      "price": 34000.0,
