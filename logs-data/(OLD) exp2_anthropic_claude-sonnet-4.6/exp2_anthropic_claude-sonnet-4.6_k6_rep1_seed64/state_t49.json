    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior is free of scratches, dents, and paint defects, presenting a clean and unblemished finish on all panels. The interior shows no signs of wear, with all upholstery, trim, and surfaces in like-new condition. Mechanically, the vehicle is fully functional with no known issues.",
      "price": 46000.0,
      "reputation": 1.0,
      "quality": "mint",
