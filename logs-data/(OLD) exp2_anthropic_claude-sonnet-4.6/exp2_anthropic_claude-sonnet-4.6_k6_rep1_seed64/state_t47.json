    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has significant scratches, dents, and paint damage across multiple panels. The interior shows heavy wear including torn upholstery and damaged trim surfaces. Mechanical systems have known issues and will require attention. Sold as-is.",
      "price": 5500.0,
