    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior shows no scratches, dents, or paint imperfections. The interior is pristine with no wear on the upholstery, trim, or surfaces. All mechanical systems are fully functional and performing as expected. A clean, well-kept vehicle throughout.",
      "price": 46000.0,
