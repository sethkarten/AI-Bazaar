    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior has minor cosmetic blemishes but no significant damage. The interior shows normal wear consistent with regular use, and all major mechanical components are functioning properly. A straightforward, reliable used vehicle.",
      "price": 32000.0,
      "reputation": 0.9,
