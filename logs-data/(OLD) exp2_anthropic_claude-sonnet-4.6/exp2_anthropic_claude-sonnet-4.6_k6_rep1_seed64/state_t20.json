    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in fair condition. The exterior shows noticeable wear, including visible scratches and minor dents. The interior has signs of use, with worn upholstery and some scuffed trim surfaces. Mechanically functional, but this vehicle will likely require some attention or repairs. Sold as-is.",
      "price": 22000.0,
