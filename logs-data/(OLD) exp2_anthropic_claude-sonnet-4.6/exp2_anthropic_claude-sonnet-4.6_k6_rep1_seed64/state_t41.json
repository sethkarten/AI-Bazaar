    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior shows noticeable scratches, scuffs, and some minor dents. The interior has visible wear on the upholstery and surfaces, with some fading and minor damage to the trim. Mechanical systems are functional but show age-related wear; some components may need attention in the near term. Suitable for a buyer looking for basic transportation at a lower price point.",
      "price": 19500.0,
      "reputation": 1.0,
      "quality": "fair",
