    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior shows no visible scratches, dents, or paint imperfections. The interior is clean and unmarked, with all features and components functioning as intended. Mechanically, the vehicle operates without any known issues.",
      "price": 46000.0,
