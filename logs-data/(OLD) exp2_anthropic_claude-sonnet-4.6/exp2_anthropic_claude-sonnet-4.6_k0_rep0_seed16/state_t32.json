    },
    {
      "id": "detailed_4_listing_0",
      "firm_id": "detailed_4",
      "description": "This vehicle is being listed honestly as a car in mint condition \u2014 the absolute best you'll find on the used market. The exterior is essentially flawless, presenting no scratches, dents, or paint imperfections of any kind; it looks as though it just rolled off the showroom floor. The interior is equally immaculate, with pristine upholstery, spotless surfaces, and all electronics and features functioning perfectly. Under the hood, the engine runs with exceptional smoothness and responsiveness, and all mechanical systems are in top-tier working order. Service records are up to date, and the vehicle has been meticulously cared for throughout its life. A buyer can expect a used car that feels and performs like new \u2014 this is a rare find for the discerning buyer who refuses to compromise on quality.",
      "price": 47000.0,
      "reputation": 1.0,
      "quality": "mint",
      "quality_value": 1.0,
      "timestep_posted": 32
    },
    {
      "id": "detailed_3_listing_0",
