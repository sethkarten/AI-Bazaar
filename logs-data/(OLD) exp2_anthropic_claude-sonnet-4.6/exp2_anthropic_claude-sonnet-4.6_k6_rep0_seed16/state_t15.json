    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in mint condition. It runs and drives perfectly with no mechanical issues whatsoever. The exterior is clean with no scratches, scuffs, dents, or blemishes. The interior is equally pristine with no wear, stains, or damage. All systems function as intended and the vehicle presents exceptionally well throughout.",
      "price": 45000.0,
      "reputation": 1.0,
