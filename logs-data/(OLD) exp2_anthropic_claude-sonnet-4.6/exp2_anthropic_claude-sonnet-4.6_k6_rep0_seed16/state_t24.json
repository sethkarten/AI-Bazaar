    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in fair condition. It runs and drives, but has some mechanical issues that should be addressed for reliable use. The exterior shows noticeable wear including minor dents and surface blemishes. The interior is functional but shows clear signs of age and use. Overall, this is a usable vehicle that will likely require some repair investment.",
      "price": 16000.0,
      "reputation": 1.0,
