    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in fair condition. It runs and drives, but has some mechanical issues that will need attention. There is noticeable wear both mechanically and cosmetically, including body imperfections and interior wear consistent with use. Buyers should expect to invest in repairs after purchase.",
      "price": 20000.0,
      "reputation": 1.0,
