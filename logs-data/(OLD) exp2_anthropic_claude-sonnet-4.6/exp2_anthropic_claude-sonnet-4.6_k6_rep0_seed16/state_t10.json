    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in fair condition. It runs and drives, but has some mechanical issues that will need attention. There is noticeable wear both mechanically and cosmetically, including body imperfections and components that are not fully up to par. Suitable for a buyer willing to put some work into it.",
      "price": 20000.0,
