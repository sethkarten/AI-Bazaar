    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in mint condition. It is in excellent mechanical and cosmetic shape, showing virtually no signs of wear. Everything functions as intended, and the interior and exterior are clean and well-preserved. This is an exceptional example that has been very well cared for.",
      "price": 46000.0,
