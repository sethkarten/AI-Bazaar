    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in fair condition. It runs and is drivable but has some mechanical issues that should be addressed for reliable long-term use. The exterior shows noticeable wear including scratches and minor dents. It is usable as a daily driver but will require some attention.",
      "price": 16000.0,
