    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in poor condition. It has mechanical issues that will need to be repaired before it can be driven reliably. The exterior shows visible body damage and significant wear. The interior is worn and shows signs of heavy use. Suitable for someone looking for a project vehicle or parts.",
      "price": 4500.0,
