    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in good condition. It runs and drives well with no significant mechanical issues. The exterior shows some light wear consistent with normal use, but no major damage or rust. The interior is clean and functional with minor signs of use.",
      "price": 33500.0,
      "reputation": 1.0,
