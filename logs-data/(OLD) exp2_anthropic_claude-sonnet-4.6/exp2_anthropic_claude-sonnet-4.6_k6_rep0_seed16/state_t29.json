    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in mint condition. It runs and drives flawlessly, with no mechanical issues. The exterior is clean and free of dents, scratches, or visible wear. The interior is equally well-maintained, showing no significant signs of use. This is a well-preserved vehicle ready for immediate reliable daily use.",
      "price": 46000.0,
      "reputation": 1.0,
