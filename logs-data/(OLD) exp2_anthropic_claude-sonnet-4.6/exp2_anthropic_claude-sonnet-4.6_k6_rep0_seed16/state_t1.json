    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in poor condition and is being sold as-is. It has significant mechanical and/or cosmetic issues that will require attention. It may be suitable as a project vehicle or for parts. No major repairs have been made, and buyers should expect to invest additional time and money after purchase.",
      "price": 3500.0,
