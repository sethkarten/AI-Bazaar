      "quality_value": 1.0,
      "timestep_posted": 34
    },
    {
      "id": "optimistic_10_listing_0",
      "firm_id": "optimistic_10",
      "description": "Ready to hit the road without breaking the bank? This well-maintained vehicle is in genuinely good condition \u2014 it runs great and drives smoothly, making it a fantastic choice for daily commuting or weekend adventures! The interior is clean and comfortable with only minor signs of normal use, and the exterior presents nicely with just a few small cosmetic blemishes you'd expect from a car that's been enjoyed. Mechanically sound and dependable, this is a car you can feel confident driving home today!",
      "price": 34000.0,
