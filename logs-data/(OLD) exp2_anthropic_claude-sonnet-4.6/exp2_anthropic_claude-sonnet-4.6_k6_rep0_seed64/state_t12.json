    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in poor condition. It has significant mechanical issues and will likely require repairs before it can be used reliably for regular driving. The exterior shows noticeable damage including dents and scratches, and the interior shows considerable wear. Best suited for someone willing to invest in repairs or looking for a parts vehicle.",
      "price": 5500.0,
