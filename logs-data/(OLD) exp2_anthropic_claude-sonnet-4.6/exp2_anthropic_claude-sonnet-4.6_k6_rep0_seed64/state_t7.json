    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in fair condition. It starts and drives reliably for everyday use, but shows visible wear on the interior and cosmetic imperfections on the exterior including scratches and scuffs. There may be minor mechanical issues that do not prevent regular use but should be noted. Suitable for a buyer looking for basic reliable transportation at a reasonable price.",
      "price": 19000.0,
      "reputation": 1.0,
