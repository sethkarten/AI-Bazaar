    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2021 Honda Accord in poor condition. The interior has significant wear including damaged upholstery, stained or torn trim, and some controls or displays that may not function properly. The exterior shows noticeable scratches, dents, and paint damage. The vehicle has mechanical issues and will likely require repairs. Priced accordingly for its condition.",
      "price": 6500.0,
      "reputation": 1.0,
