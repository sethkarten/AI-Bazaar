    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. The exterior shows minor wear consistent with normal use, and the interior is clean and functional. Mechanically, the vehicle runs well with no significant issues noted.",
      "price": 31000.0,
