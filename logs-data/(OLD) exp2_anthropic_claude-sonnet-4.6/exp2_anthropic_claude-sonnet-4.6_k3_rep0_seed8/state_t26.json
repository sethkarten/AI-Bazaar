    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in poor condition. The interior and exterior show significant wear, including noticeable cosmetic damage. Mechanical systems have known issues that will likely require attention. Priced accordingly to reflect the current state of the vehicle.",
      "price": 6000.0,
      "reputation": 1.0,
