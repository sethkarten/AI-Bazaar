      "quality_value": 0.7,
      "timestep_posted": 23
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in mint condition. The interior and exterior show no meaningful wear, and all mechanical systems function as intended with no issues to report. Paint, upholstery, and trim are all in excellent shape. This vehicle has been well maintained and presents as near-new.",
      "price": 47000.0,
