    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2021 Honda Accord in good condition. The interior shows light wear consistent with normal use, with no significant damage to upholstery or trim. Controls and displays are fully functional. The exterior has minor surface scratches but no notable dents or rust. Mechanically sound with no known issues.",
      "price": 31000.0,
