    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2021 Honda Accord in good condition. The interior shows some light wear on the upholstery and trim consistent with regular use, but all controls and displays function properly. The exterior has minor surface scratches or small blemishes but no significant damage. Mechanically sound and ready for daily driving.",
      "price": 33500.0,
      "reputation": 1.0,
