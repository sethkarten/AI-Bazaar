    },
    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "2021 sedan in fair condition. The vehicle shows noticeable wear on both the interior and exterior, including visible cosmetic blemishes and some signs of use. It is currently drivable but may benefit from attention to certain mechanical or cosmetic areas. Sold with a clear representation of its current state.",
      "price": 20000.0,
