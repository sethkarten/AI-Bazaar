    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in fair condition. It runs and drives, but has some mechanical issues that will likely require attention in the near term. The exterior shows noticeable scratches, scuffs, and minor dents beyond typical wear and tear. The interior has visible wear including stains and some damage to upholstery. Overall, this is a functional vehicle that needs work.",
      "price": 18000.0,
      "reputation": 1.0,
