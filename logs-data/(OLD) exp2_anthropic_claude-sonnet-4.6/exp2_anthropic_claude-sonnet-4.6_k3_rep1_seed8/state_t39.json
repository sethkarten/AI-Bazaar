    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in good condition. The exterior shows minor wear consistent with normal use, with no significant damage to the body panels. The interior is intact and functional with some light signs of use. Mechanical systems are in working order and have been maintained adequately.",
      "price": 33000.0,
      "reputation": 1.0,
