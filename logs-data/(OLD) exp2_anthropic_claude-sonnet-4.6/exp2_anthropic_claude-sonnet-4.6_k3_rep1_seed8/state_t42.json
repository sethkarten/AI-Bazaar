    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in poor condition. The exterior has visible damage to the body panels, and the interior shows significant deterioration with worn or damaged components. The mechanical systems have known issues that will require repair before reliable use. Priced accordingly for a buyer willing to take on the necessary work.",
      "price": 4500.0,
