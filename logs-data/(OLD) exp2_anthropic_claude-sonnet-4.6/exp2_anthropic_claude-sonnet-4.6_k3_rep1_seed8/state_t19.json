    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in poor condition. It runs but has significant mechanical issues that will require repair. The exterior has notable damage including multiple dents and scratches. The interior shows considerable wear and there may be additional issues that a buyer should inspect before purchasing.",
      "price": 6500.0,
      "reputation": 1.0,
