    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in mint condition. It shows no signs of wear, damage, or mechanical issues. The interior and exterior are both clean and intact, and all systems function as expected. A solid choice for a buyer looking for a vehicle that needs nothing.",
      "price": 47000.0,
