    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. It runs and drives well with no significant mechanical issues. The exterior shows only minor wear consistent with normal use, with no major dents or rust. The interior is clean and functional, with light signs of use but nothing that detracts from comfort or usability.",
      "price": 33000.0,
