    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in fair condition. It runs and drives, but has some mechanical issues that may require attention. The exterior shows noticeable scratches, scuffs, and minor dents beyond typical wear. The interior has visible wear including stains or worn surfaces. It is functional but will likely need some repairs or maintenance in the near term.",
      "price": 20000.0,
