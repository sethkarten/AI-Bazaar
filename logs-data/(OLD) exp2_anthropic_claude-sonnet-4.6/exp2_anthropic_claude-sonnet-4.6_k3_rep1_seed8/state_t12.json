    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. It runs and drives well with no significant mechanical issues. The exterior shows minor wear consistent with normal use, including light scratches, but no major dents or rust. The interior is clean and functional with some light wear on high-contact surfaces.",
      "price": 33500.0,
