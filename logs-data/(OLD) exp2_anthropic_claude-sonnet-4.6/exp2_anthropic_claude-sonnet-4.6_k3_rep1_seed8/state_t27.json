    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in mint condition. It has been meticulously maintained and shows no meaningful signs of wear on the interior or exterior. The mechanical systems are in excellent working order, and the body and finish are essentially flawless. A clean title and full service history are available.",
      "price": 46000.0,
