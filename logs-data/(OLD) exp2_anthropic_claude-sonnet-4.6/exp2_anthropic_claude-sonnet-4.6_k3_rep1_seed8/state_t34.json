    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. It runs and drives well with no major mechanical issues, though it may have minor wear consistent with regular use. The exterior has some light scratches or small blemishes but no significant dents or structural damage. The interior is clean and functional with normal signs of use.",
      "price": 34000.0,
