    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in mint condition. It has been meticulously maintained and runs flawlessly with no mechanical issues. The interior is clean and unmarked, showing virtually no signs of use, and the exterior is free of scratches, dents, or blemishes. Overall, this vehicle is as close to new as a used car gets.",
      "price": 47000.0,
