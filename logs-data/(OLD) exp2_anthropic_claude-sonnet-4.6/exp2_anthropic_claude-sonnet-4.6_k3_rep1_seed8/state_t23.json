    },
    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in mint condition. It shows no significant wear, has no mechanical issues, and presents exceptionally well both inside and out. The interior is clean and undamaged, and the exterior is free of notable blemishes. All systems are functioning properly.",
      "price": 46000.0,
      "reputation": 1.0,
