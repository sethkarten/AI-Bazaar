    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in fair condition. It runs and drives, but has some mechanical issues that may require attention. The exterior shows visible wear including dents and scratches beyond normal use. The interior has noticeable wear as well. Suitable for a buyer looking for basic transportation who is comfortable addressing some maintenance needs.",
      "price": 19500.0,
