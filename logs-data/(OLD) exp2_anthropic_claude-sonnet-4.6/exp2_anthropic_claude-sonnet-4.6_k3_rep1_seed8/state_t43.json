    {
      "id": "terse_5_listing_0",
      "firm_id": "terse_5",
      "description": "This car is in fair condition with noticeable wear and some minor issues, but it runs and is suitable for budget-conscious buyers willing to accept its imperfections.",
      "price": 19000.0,
      "reputation": 1.0,
      "quality": "fair",
