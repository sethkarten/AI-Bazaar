    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. It runs and drives well, with no significant mechanical issues. The exterior shows minor wear consistent with normal use, and the interior is clean with light signs of age. A reliable, everyday vehicle that has been reasonably maintained.",
      "price": 33000.0,
