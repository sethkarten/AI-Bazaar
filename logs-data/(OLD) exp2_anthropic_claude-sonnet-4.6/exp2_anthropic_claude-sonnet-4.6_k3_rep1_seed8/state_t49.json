    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in poor condition. The exterior has heavy scratches, multiple dents, and significant paint damage including fading and chipping in several areas. The interior is worn throughout, with damaged upholstery, cracked or broken trim pieces, and noticeable odors. Mechanical components have not been recently serviced and may require attention. This vehicle is best suited for buyers comfortable with a project car or those seeking basic transportation at a low price point.",
      "price": 5500.0,
