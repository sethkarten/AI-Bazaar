    {
      "id": "optimistic_8_listing_0",
      "firm_id": "optimistic_8",
      "description": "Ready to hit the road in style without breaking the bank? This good-condition vehicle is a fantastic find for savvy shoppers! It's been well cared for and shows only moderate signs of use \u2014 no major issues, just a car that's lived a happy life on the road. It drives smoothly, presents nicely, and is ready to be your dependable daily companion. Come take it for a spin and see for yourself!",
      "price": 33500.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
      "timestep_posted": 48
    },
    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in mint condition. The exterior is free of scratches, dents, or blemishes, with paint that retains its original luster. The interior shows no signs of wear, with all components fully functional and in like-new condition. Mechanically, the car performs as expected from a vehicle that has been exceptionally well maintained.",
      "price": 47000.0,
