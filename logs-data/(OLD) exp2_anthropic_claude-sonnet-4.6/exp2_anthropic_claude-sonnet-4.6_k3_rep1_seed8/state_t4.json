    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in fair condition. It runs and drives, but has noticeable wear both inside and out. The exterior has visible cosmetic blemishes including minor dents and scratches. The interior shows wear on surfaces and upholstery. Some mechanical attention may be needed, though it is functional for daily use.",
      "price": 16500.0,
