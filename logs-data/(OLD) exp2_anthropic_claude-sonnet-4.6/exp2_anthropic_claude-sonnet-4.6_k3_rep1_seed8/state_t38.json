    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in mint condition. It runs and drives perfectly with no mechanical issues. The exterior is essentially flawless, with no scratches, dents, or blemishes. The interior is clean and shows no signs of wear. This vehicle has been exceptionally well maintained.",
      "price": 46000.0,
