    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in poor condition. It runs but has significant mechanical issues that will require attention. The exterior has noticeable damage including dents and rust, and the interior is heavily worn with damaged surfaces. Best suited for someone willing to invest in repairs or use it for parts.",
      "price": 5500.0,
