    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. It runs and drives well with no significant mechanical issues. The exterior shows minor wear consistent with normal use \u2014 small scratches here and there, but no dents or major damage. The interior is clean and functional. Overall a solid, reliable vehicle.",
      "price": 32000.0,
