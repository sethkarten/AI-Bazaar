    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in poor condition. It runs but has notable mechanical issues that will require significant repair work. The exterior shows heavy wear with multiple dents, scratches, and paint damage. The interior is worn with visible damage to surfaces and components. Sold as-is.",
      "price": 5500.0,
