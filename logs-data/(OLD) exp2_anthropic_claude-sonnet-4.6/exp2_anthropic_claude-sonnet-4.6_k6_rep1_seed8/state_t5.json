    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. It runs and drives well with no significant mechanical issues. The exterior is clean with only minor cosmetic wear, and the interior is in good shape with normal signs of use. Overall a reliable, well-maintained vehicle.",
      "price": 33500.0,
      "reputation": 0.8,
