    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2020 sedan in mint condition. The exterior is free of scratches, dents, or blemishes. The interior shows no signs of wear and remains in like-new condition. Mechanically sound with no known issues. All features and systems function as intended.",
      "price": 46000.0,
      "reputation": 1.0,
