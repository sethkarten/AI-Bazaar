    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2020 sedan in poor condition. The exterior has significant scratches, multiple dents, and noticeable paint damage across several panels. The interior shows heavy wear including torn upholstery, cracked dashboard surfaces, and staining throughout. Mechanical function is present but the overall state of the vehicle reflects its condition.",
      "price": 6000.0,
