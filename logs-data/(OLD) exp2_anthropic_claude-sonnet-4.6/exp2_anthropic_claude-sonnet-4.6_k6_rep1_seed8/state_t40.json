      "timestep_posted": 40
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2020 sedan in fair condition. The exterior shows noticeable scratches and a few small dents, with paint fading in certain areas. The interior has moderate wear including some staining and worn upholstery, though all components remain functional. Mechanically sound with no major issues, but will likely require some cosmetic attention.",
      "price": 20000.0,
