    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "2020 sedan in mint condition. The exterior is free of scratches, dents, or blemishes. Mechanically sound with all components functioning as expected. The interior is clean and shows no signs of wear. This vehicle has been exceptionally well maintained and presents in like-new condition throughout.",
      "price": 45000.0,
