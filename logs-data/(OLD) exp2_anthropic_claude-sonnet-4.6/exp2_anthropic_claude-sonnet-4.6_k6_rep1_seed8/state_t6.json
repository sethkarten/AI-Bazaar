    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in poor condition. It runs but has notable mechanical issues that will require attention. The exterior has significant cosmetic damage including dents and rust, and the interior is worn with visible damage to surfaces and components. This vehicle is best suited for someone comfortable with repair work or looking for a parts car.",
      "price": 5500.0,
