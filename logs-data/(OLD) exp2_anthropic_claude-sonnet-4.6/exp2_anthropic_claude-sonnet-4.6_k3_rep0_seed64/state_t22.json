    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in poor condition. It has significant mechanical issues that will require attention and may not be reliable for regular daily use. The exterior shows considerable wear including dents, scratches, and possible rust. The interior is worn with noticeable damage. Best suited for someone willing to invest in repairs or looking for a parts vehicle.",
      "price": 5500.0,
