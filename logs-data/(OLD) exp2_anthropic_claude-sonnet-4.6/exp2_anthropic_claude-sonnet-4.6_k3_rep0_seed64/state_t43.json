    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in fair condition. It runs and drives, but has some mechanical issues that will need attention before long-term reliable use. The exterior shows visible wear including scratches and minor dents beyond normal use. Priced accordingly for its condition.",
      "price": 18000.0,
