    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in mint condition. The exterior is free of scratches, dents, and blemishes. The interior is clean and undamaged, with all seating, trim, and components in full working order. Mechanically, the car performs as expected with no known issues.",
      "price": 46000.0,
