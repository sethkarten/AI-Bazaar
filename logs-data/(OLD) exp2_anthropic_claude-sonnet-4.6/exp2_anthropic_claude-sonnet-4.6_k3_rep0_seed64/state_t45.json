    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "This car is in fair condition. It runs and drives, but has some mechanical issues that will need attention. The exterior shows visible wear including scratches and minor dents beyond normal use. The interior has noticeable wear consistent with age and use.",
      "price": 20000.0,
      "reputation": 1.0,
