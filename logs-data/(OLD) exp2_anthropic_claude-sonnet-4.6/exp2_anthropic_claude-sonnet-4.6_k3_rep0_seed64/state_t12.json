    {
      "id": "terse_5_listing_0",
      "firm_id": "terse_5",
      "description": "A used car in good condition with normal wear, well-maintained, and ready to drive.",
      "price": 32000.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
