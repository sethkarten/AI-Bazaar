    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. The exterior shows minor surface wear, including a few small scratches, but no significant dents or body damage. The interior is clean and functional, with normal wear consistent with regular use. Mechanically, the car runs well and has been maintained.",
      "price": 32000.0,
