    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior is free of scratches, dents, and paint defects, presenting like new. The interior shows no signs of wear \u2014 all surfaces, upholstery, and trim are clean and undamaged. Mechanically, the vehicle operates without any known issues. All features and systems function as intended.",
      "price": 45000.0,
      "reputation": 1.0,
