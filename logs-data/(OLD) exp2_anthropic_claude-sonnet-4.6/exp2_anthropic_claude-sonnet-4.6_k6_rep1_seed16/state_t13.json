    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. It runs and drives well with no significant mechanical issues. The interior shows normal wear consistent with its age but remains clean and functional. The exterior has minor cosmetic imperfections typical of a used vehicle but no major damage.",
      "price": 35000.0,
      "reputation": 1.0,
