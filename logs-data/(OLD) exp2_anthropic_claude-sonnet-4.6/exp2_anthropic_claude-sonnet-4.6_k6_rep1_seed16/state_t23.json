    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in fair condition. It runs and drives but has some mechanical issues that should be addressed. The interior shows moderate wear, including some staining and minor damage. The exterior has several scratches and small dents that are visible upon inspection. Overall, it is functional but will require some attention from the next owner.",
      "price": 17000.0,
