    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has noticeable scratches and minor dents from regular use. The interior shows visible wear on surfaces and upholstery. Mechanically the vehicle is functional but may require some attention. Priced to reflect its current condition.",
      "price": 20000.0,
      "reputation": 0.9,
