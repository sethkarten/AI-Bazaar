    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior has no scratches, dents, rust, or paint defects \u2014 the finish appears essentially new. The interior is clean and unmarked, with no wear on the upholstery, trim, or controls. All mechanical systems are functioning properly with no known issues.",
      "price": 47000.0,
