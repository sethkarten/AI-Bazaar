    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in mint condition. It runs and drives flawlessly with no mechanical issues of any kind. The interior is pristine with no wear, staining, or damage to any surfaces. The exterior is clean and free of scratches, dents, or paint defects.",
