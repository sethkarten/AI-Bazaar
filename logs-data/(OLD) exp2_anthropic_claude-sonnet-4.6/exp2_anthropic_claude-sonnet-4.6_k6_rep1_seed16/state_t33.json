    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in fair condition. It runs and drives but has some mechanical issues that should be addressed. The interior shows moderate wear, including some staining and minor damage. The exterior has visible wear and some cosmetic imperfections. Suitable for a buyer willing to put some work into it.",
      "price": 18000.0,
