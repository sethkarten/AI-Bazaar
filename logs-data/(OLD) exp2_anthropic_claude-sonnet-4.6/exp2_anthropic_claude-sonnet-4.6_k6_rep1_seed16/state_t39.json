    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in poor condition. It has significant mechanical issues that require attention before reliable daily use. The interior has heavy wear with notable staining and damage to surfaces. The exterior has multiple visible dents, scratches, and paint damage. Suitable for someone looking for a project vehicle or parts.",
      "price": 5500.0,
