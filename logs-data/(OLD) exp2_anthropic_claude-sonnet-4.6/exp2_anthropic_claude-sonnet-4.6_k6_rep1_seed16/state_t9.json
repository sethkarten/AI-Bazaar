    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It shows minor cosmetic wear consistent with regular use but has no significant body damage. The interior is clean and functional with light signs of normal wear. Mechanically it is sound and has been maintained adequately. A solid, reliable used vehicle at a fair price.",
      "price": 33500.0,
      "reputation": 0.9,
