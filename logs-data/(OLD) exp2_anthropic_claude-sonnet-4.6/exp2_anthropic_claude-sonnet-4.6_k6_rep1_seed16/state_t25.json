    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in poor condition. It runs but has significant mechanical issues that require attention before it can be driven reliably. The interior shows heavy wear, including staining, damage, and noticeable odors. The exterior has multiple scratches, dents, and paint damage. Best suited for someone willing to invest in repairs or use it for parts.",
      "price": 6500.0,
