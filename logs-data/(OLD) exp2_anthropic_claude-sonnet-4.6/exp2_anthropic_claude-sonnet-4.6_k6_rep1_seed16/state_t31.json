    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior is free of scratches, dents, rust, and paint defects \u2014 the finish looks essentially new. The interior shows no signs of wear; upholstery, trim, and all surfaces are clean and undamaged. All mechanical systems function correctly, and the vehicle has been well maintained throughout its life.",
      "price": 46000.0,
      "reputation": 1.0,
