    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior shows noticeable scratches, minor dents, and areas of paint wear. The interior has visible wear on the upholstery and surfaces, with some material damage present. Mechanically, the car is functional but shows signs of age and use. Suitable for a buyer looking for basic transportation at a reasonable price.",
      "price": 20500.0,
      "reputation": 1.0,
