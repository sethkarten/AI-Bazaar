    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has minor cosmetic wear consistent with normal use but no significant body damage. The interior is clean and functional with some light signs of use. Mechanically, the car is in good working order with no known issues requiring immediate attention.",
      "price": 34000.0,
      "reputation": 0.8,
