    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition and is being sold as-is. It has visible body damage, worn interior, and mechanical issues that will require attention. It is best suited for someone looking for a parts car or a significant restoration project. No major recent repairs have been performed.",
      "price": 5500.0,
