    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in good condition. It runs and drives well with no major mechanical issues. The interior shows light wear consistent with normal use, and the exterior has minor cosmetic imperfections but no significant damage. Overall a solid, reliable vehicle.",
      "price": 33500.0,
      "reputation": 1.0,
