    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in mint condition. The exterior finish is clean and free of blemishes, the interior surfaces show no signs of wear, and all mechanical systems are in excellent working order. It presents as well as a car of its age and mileage can.",
      "price": 47000.0,
