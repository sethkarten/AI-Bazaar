    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "2019 Honda Accord EX-L in good condition. The engine and mechanical systems are running well with no significant issues. The interior is clean with minor wear consistent with normal use. The exterior has a few small scratches and minor blemishes but no major damage. Overall a solid, well-maintained vehicle.",
      "price": 34000.0,
