    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "2019 Honda Accord EX-L in fair condition. The engine and mechanical systems are operational but have some issues that may require attention in the near term. The interior shows moderate wear including some worn upholstery and minor scuffs on trim surfaces. The exterior has visible scratches and minor dents in several areas. The vehicle is drivable but buyers should expect to invest in some repairs and maintenance.",
      "price": 18000.0,
      "reputation": 0.9,
