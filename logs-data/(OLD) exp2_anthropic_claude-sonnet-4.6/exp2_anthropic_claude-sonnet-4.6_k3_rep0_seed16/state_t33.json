    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in mint condition. It runs and drives perfectly with no mechanical issues. The exterior is flawless with no scratches, dents, or paint defects. The interior is clean and shows no signs of wear. All features and systems function as intended.",
      "price": 46000.0,
