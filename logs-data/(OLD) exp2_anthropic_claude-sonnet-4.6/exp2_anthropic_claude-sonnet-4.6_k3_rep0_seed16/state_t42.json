    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "2019 Honda Accord EX-L in mint condition. The engine and all mechanical systems are in excellent working order with no issues. The interior is clean with no visible wear, scratches, or stains. The exterior paint is in excellent condition with no dents, chips, or blemishes. All features and electronics function properly.",
      "price": 45500.0,
