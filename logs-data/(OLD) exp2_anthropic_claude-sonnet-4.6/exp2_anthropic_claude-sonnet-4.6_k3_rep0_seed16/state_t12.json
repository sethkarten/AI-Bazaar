    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in fair condition. It runs and drives but has some mechanical issues that may require attention. There is noticeable cosmetic wear including scratches and some interior wear. It is suitable for use but a buyer should be prepared for potential repair costs.",
      "price": 20000.0,
      "reputation": 0.9,
