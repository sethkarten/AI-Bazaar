    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This car is in mint condition. It shows no meaningful wear inside or out. The exterior finish is clean and unmarked, the interior surfaces are pristine, and the mechanicals are in excellent working order. A straightforward, no-issues vehicle.",
      "price": 46000.0,
      "reputation": 0.8,
