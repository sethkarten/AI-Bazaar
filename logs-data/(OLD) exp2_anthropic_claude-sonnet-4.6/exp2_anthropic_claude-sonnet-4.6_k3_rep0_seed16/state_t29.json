    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "2019 Honda Accord EX-L in fair condition. The engine runs but has some mechanical concerns that should be addressed. The interior shows noticeable wear including scuffs, staining, and worn surfaces. The exterior has visible scratches and minor dents. Priced to reflect the current condition.",
      "price": 19500.0,
