    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "2019 Honda Accord EX-L in fair condition. The engine runs but has some mechanical concerns that should be addressed before long-term reliable use. The interior shows noticeable wear including scuffs, staining, and worn surfaces on high-contact areas. The exterior has visible scratches and minor dents. This car is priced to reflect its current condition.",
      "price": 19500.0,
      "reputation": 1.0,
