    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in poor condition. It has significant mechanical issues that need attention and may not be fully reliable for regular use. The exterior shows substantial wear including scratches, dents, and visible damage. The interior is also worn. This vehicle is best suited for someone willing to invest in repairs or use it for parts.",
      "price": 5500.0,
