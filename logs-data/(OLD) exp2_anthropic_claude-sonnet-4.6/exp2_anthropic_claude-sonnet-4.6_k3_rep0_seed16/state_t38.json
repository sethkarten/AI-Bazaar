    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This car is in good condition. It runs and drives well with no significant mechanical issues. The exterior shows minor wear consistent with normal use, including light surface scratches, but no major dents or damage. The interior is clean and functional. Overall a reliable vehicle with no outstanding concerns.",
      "price": 32000.0,
