    {
      "id": "optimistic_7_listing_0",
      "firm_id": "optimistic_7",
      "description": "Wow, this one is a real gem \u2014 and we mean that! This car is in absolutely mint condition, presenting like it just rolled off the showroom floor. Every surface is clean and crisp, the interior is immaculate, and everything runs and feels exactly as it should. If you've been searching for a used car that truly feels new, your search is over \u2014 this is as good as it gets!",
      "price": 45000.0,
