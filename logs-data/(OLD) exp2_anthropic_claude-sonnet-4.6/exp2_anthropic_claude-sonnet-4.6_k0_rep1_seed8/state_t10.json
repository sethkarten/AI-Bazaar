      "quality_value": 1.0,
      "timestep_posted": 10
    },
    {
      "id": "optimistic_9_listing_0",
      "firm_id": "optimistic_9",
      "description": "Looking for a budget-friendly ride or a hands-on project? This vehicle is priced to move and represents an honest opportunity for the right buyer. It's in poor condition and will require meaningful repairs and attention \u2014 we're not going to sugarcoat that \u2014 but the bones are there for someone willing to put in the work. If you're a DIY enthusiast or just need something to get started on, this could be your next project at a price that leaves room in your budget for the work ahead!",
      "price": 5500.0,
