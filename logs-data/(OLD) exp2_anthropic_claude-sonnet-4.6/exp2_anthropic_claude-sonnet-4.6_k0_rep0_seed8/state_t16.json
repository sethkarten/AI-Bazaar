      "quality_value": 1.0,
      "timestep_posted": 16
    },
    {
      "id": "optimistic_9_listing_0",
      "firm_id": "optimistic_9",
      "description": "Looking for a vehicle that truly stands out from the crowd? This car is in exceptional mint condition \u2014 it's been meticulously maintained and presents beautifully inside and out. Everything works as it should, the interior is fresh and spotless, and the exterior shines with no meaningful wear to speak of. This is a rare find for buyers who want a vehicle they can be genuinely proud of from day one. Don't miss your chance to own something special!",
      "price": 46000.0,
      "reputation": 0.8,
