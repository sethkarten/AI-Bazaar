      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 45
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is an exceptional vehicle in pristine, showroom condition. This unit has been meticulously maintained to the highest standards, offering an uncompromising driving experience that mirrors its original factory delivery. Every surface and mechanical component reflects a standard of care rarely seen in the pre-owned market. For the discerning buyer seeking investment-grade quality, this offering represents the pinnacle of its class.",
      "price": 47500.0,
