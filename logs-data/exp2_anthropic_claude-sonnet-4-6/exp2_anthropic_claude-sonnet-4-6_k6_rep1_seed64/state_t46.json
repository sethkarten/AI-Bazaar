      "timestep_posted": 46
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "$28,500 - 1998 sedan with 210,000 miles. This vehicle is in good condition. It has been well-maintained, with minor wear consistent with its age and mileage. All major systems are functional.",
      "price": 28500.0,
      "reputation": 1.0,
