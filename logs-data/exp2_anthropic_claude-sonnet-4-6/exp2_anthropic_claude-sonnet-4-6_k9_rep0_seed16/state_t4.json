      "quality_value": 0.1,
      "timestep_posted": 4
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 I\u2019m parting ways with this absolute gem and honestly, it\u2019s hard to let go. This car is in truly pristine condition\u2014it looks and drives like it just rolled off the lot! I\u2019ve taken incredible care of it, so there isn\u2019t a single scratch or hiccup to be found. If you\u2019re looking for a ride that\u2019s practically brand new without the dealership headache, this is the one for you. Come take it for a spin, you\u2019re going to love it! \u2728",
      "price": 44500.0,
