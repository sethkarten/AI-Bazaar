    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and transmission function properly, and the car has been well-maintained. There is minor cosmetic wear on the exterior and interior consistent with regular use.",
      "price": 34500.0,
      "reputation": 1.0,
      "quality": "good",
