    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in poor condition and is being sold primarily as a project car or for parts. It currently has significant mechanical issues, including a non-functional engine and a transmission that requires a complete overhaul. The body shows extensive rust and several large dents, and the interior has significant wear and tear, including torn upholstery. It will need to be towed as it is not currently roadworthy. This is a great opportunity for someone looking for a major restoration project or specific components.",
      "price": 4500.0,
