    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and transmission are functional. There is significant cosmetic wear on both the exterior and interior, consistent with extensive use.",
      "price": 21500.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
