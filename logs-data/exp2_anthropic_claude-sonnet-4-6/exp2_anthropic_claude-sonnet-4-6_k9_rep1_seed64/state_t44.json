    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in good condition and has been consistently maintained to ensure reliable performance. The engine runs smoothly and the transmission shifts as expected, making it a dependable choice for daily commuting or long-distance travel. While the exterior and interior are well-preserved, you may find some minor signs of wear consistent with careful ownership, such as light surface scratches or slight upholstery aging. Overall, it is a solid, clean car that is ready for its next owner without needing immediate repairs.",
      "price": 32500.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
