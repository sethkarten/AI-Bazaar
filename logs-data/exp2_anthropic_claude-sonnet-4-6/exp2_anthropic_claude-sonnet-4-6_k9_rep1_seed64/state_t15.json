      "quality_value": 0.1,
      "timestep_posted": 15
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m looking to find a new home for this awesome ride. It\u2019s been super reliable and is in really solid shape\u2014honestly, it drives like a dream! Whether you\u2019re commuting or heading out on a road trip, it\u2019s ready to go. I\u2019ve taken great care of it, and I think you\u2019re going to love it just as much as I have. Feel free to shoot me a message if you want to take it for a spin!",
      "price": 32500.0,
      "reputation": 0.6,
