    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting an investment-grade 2002 BMW M3 (E46) Coupe, maintained to an exacting standard. This vehicle is powered by the high-revving S54 3.2L inline-six, featuring a 8,000 RPM redline and individual throttle bodies for instantaneous atmospheric induction. The drivetrain is anchored by a Getrag 420G six-speed manual transmission and a factory M-Variable limited-slip differential, ensuring tactile engagement. Critically, the double-VANOS system has been fully overhauled, and the rear subframe has been proactively reinforced to mitigate floor pan fatigue. The suspension geometry remains precise with refreshed bushings and original-spec dampers, while the undercarriage is devoid of oxidation. This is a turnkey, mechanically synchronized example of BMW's analog peak, free of any deferred maintenance.",
      "price": 48750.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. No cosmetic or mechanical flaws. Full service history available. Inspections welcome.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
