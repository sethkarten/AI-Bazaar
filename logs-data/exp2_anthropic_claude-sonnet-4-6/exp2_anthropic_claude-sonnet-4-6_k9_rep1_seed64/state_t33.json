      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This collector-grade A80 features the iconic 2JZ-GTE inline-six, maintaining perfect compression across all cylinders with its factory sequential twin-turbocharger configuration intact. The Getrag V160 6-speed manual transmission offers precise gate entry, paired with a chatter-free factory clutch and a Torsen limited-slip differential. The chassis remains structurally flawless, retaining its original double-wishbone suspension geometry and bushings with zero signs of perishing. The engine bay is a time capsule, free of heat-cycle fatigue or fluid weeping, while the undercarriage shows no oxidation. This is an investment-grade example of Japanese engineering, preserved in its optimal performance envelope.",
      "price": 44500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Mint condition. Single owner. Garage kept. No accidents. Full maintenance records available.",
      "price": 42500.0,
      "reputation": 0.4,
