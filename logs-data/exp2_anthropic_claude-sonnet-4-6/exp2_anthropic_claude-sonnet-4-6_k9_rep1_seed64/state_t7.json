      "quality_value": 0.1,
      "timestep_posted": 7
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an exemplary specimen maintained to the highest standards of automotive excellence. This vehicle remains in pristine condition, featuring a flawless exterior finish and an interior entirely devoid of discernible wear. Mechanically, it operates with the precision of a new machine, having undergone a rigorous multi-point inspection to ensure uncompromising reliability. For the discerning enthusiast, this represents a rare opportunity to acquire a vehicle of unparalleled distinction and preservation.",
      "price": 48500.0,
