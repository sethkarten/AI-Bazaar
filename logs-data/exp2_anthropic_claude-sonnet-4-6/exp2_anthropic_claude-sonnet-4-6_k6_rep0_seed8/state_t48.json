      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior shows minor scratches from regular use but is free of major dents. The interior is clean with some light wear on the upholstery. All mechanical systems are functioning properly.",
      "price": 34000.0,
      "reputation": 1.0,
