    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in poor condition and will require significant mechanical and cosmetic attention. The engine struggles to start consistently, and there are noticeable fluid leaks that need immediate repair. The exterior has extensive rust, deep scratches, and several large dents, while the interior shows heavy wear and tear on the upholstery. It is being sold strictly 'as-is,' making it a project car for someone with the right tools or a source for parts.",
      "price": 4500.0,
      "reputation": 1.0,
