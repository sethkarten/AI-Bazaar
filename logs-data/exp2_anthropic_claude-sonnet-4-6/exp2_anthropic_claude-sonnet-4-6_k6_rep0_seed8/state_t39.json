    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in fair condition and is a reliable choice for someone looking for a steady daily driver or a project car. The exterior has several visible blemishes, including some minor dents and paint fading on the hood and roof. Inside, the upholstery shows moderate wear, and some plastic trim pieces are loose, though all essential electronics and climate controls remain functional. Mechanically, the car runs well, but it will eventually require some routine maintenance to address minor fluid leaks and aged suspension components. It's a solid, honest car that gets the job done without any hidden surprises.",
      "price": 20500.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 39
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant rust and several large dents. The interior shows heavy wear, including tears in the upholstery and deep stains. The mechanical systems require attention and are not in reliable working order.",
      "price": 5500.0,
