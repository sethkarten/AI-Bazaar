    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Calling all enthusiasts and DIY masters! This vehicle is the ultimate blank canvas, currently in poor condition and awaiting a complete restoration. If you're looking for a rewarding project to sink your teeth into and bring back to life, this is the one for you!",
      "price": 3500.0,
