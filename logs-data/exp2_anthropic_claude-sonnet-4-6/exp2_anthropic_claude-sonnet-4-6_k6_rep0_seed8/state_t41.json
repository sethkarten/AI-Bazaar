    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Calling all DIY enthusiasts and project seekers! This vehicle is looking for a new home where it can get the TLC it deserves. While it's currently in poor condition and will need some significant mechanical work and body repairs to get back to its best, it offers a fantastic foundation for a restoration project or a valuable source of parts. If you're looking for an affordable entry into a fixer-upper with potential, this is the one for you!",
      "price": 4500.0,
      "reputation": 1.0,
