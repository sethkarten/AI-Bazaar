    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is a museum-grade E46 M3, featuring the legendary S54 naturally aspirated 3.2L inline-six with individual throttle bodies. This example exhibits zero subframe fatigue and a fully serviced dual-VANOS system. The Getrag 6-speed manual transmission provides crisp, tactile engagement, paired with a limited-slip variable M differential for optimal torque distribution. Suspension geometry remains factory-spec with fresh bushings throughout, ensuring the telepathic steering response these chassis are renowned for. Finished in pristine Carbon Black with an unblemished interior, this is a turn-key collector piece for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Original paint. No accidents. Full service history. Clean title. Garage kept.",
      "price": 44500.0,
      "reputation": 0.7,
