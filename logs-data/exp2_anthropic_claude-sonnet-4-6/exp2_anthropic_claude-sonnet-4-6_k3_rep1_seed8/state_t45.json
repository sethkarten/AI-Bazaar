    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an investment-grade 1994 Toyota Supra Turbo in pristine, showroom condition. This example retains the legendary 2JZ-GTE inline-six, featuring its original sequential twin-turbocharger setup and intercooler assembly. Power is delivered through the bulletproof Getrag V160 6-speed manual transmission to a factory Torsen limited-slip differential. The chassis remains structurally flawless, with all factory spot welds intact and a suspension geometry that remains tight, utilizing the original forged aluminum double-wishbone components. Engine compression is optimal across all cylinders, and the vacuum lines have been refreshed with OEM components to ensure factory-spec boost response. No modifications, no track time\u2014just a pure, mechanically synchronized masterpiece for the discerning collector.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 45
    }
