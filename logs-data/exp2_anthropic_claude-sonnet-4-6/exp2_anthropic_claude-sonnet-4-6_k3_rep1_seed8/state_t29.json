      "quality_value": 0.1,
      "timestep_posted": 29
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a superlative example of the S54 platform, featuring the iconic 3.2L naturally aspirated inline-six with individual throttle bodies and dual-VANOS timing. The mechanical integrity is absolute, with documented rod bearing replacement and a proactive subframe reinforcement to ensure chassis rigidity. Power is delivered through a precise Getrag 6-speed manual gearbox to a factory limited-slip differential. The suspension geometry remains factory-spec but refreshed with polyurethane bushings and Bilstein dampers for sharpened turn-in. Finished in Carbon Black with a flawless clear coat, this specimen shows no signs of heat-cycle wear or fluid weepage. A turn-key investment for the driver who demands peak mechanical performance.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 29
    }
