    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This collector-grade FD3S is an exceptional survivor, featuring a 13B-REW rotary engine with robust compression and a flawless sequential turbocharger transition. The drivetrain is anchored by a crisp five-speed manual and a Torsen limited-slip differential, providing surgical precision through the corners. Every component, from the vacuum-actuated boost control system to the double-wishbone aluminum suspension, remains in peak mechanical health. With no oxidative wear on the undercarriage and a factory-spec cooling system, this FD offers the raw, high-RPM performance these legends are known for. A truly pristine example for the discerning enthusiast.",
      "price": 47500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 5
    },
    {
      "id": "sybil_3_listing_3",
