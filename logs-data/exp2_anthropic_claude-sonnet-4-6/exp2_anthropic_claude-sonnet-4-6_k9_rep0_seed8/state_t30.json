      "timestep_posted": 30
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You honestly won't find another one like this\u2014it's basically like it just rolled off the showroom floor. I've taken such incredible care of it, and it drives like an absolute dream. If you're looking for total perfection and that new-car feel, this is your ride! Come check it out before someone else snaps it up!",
      "price": 44500.0,
