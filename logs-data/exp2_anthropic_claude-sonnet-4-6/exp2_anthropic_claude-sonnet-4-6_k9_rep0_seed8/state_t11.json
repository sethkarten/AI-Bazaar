      "timestep_posted": 11
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle in good condition. Well-maintained engine. Clean interior. Service records available. Title in hand.",
      "price": 34500.0,
      "reputation": 0.7,
