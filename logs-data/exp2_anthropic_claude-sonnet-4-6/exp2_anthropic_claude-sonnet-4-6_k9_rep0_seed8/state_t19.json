      "quality_value": 0.1,
      "timestep_posted": 19
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m looking to find a new home for my trusty car. It\u2019s been such a reliable ride and is still in really nice shape for its next owner! Everything runs smoothly, and I\u2019ve taken great care of it over the years. It\u2019s perfect for someone who wants a solid, dependable vehicle that's ready to hit the road. Come take it for a spin\u2014you\u2019re going to love how it handles!",
      "price": 34500.0,
      "reputation": 0.8,
