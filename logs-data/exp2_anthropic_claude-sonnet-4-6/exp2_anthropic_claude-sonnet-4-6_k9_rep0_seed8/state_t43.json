    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m selling my absolute pride and joy, and let me tell you, she\u2019s a total gem! This beauty is in truly pristine, showroom condition\u2014I\u2019ve babied it since day one. It looks, feels, and drives like it\u2019s brand new. If you're looking for perfection, this is the one! Feel free to reach out with any questions; I\u2019d love to see it go to a great home!",
      "price": 44900.0,
      "reputation": 0.7,
