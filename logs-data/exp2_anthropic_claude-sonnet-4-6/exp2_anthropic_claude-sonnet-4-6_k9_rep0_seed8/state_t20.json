      "timestep_posted": 20
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a meticulously maintained vehicle that exemplifies mechanical integrity and aesthetic appeal. This unit has undergone a rigorous multi-point inspection to ensure it meets our exacting standards for performance and safety. Featuring a clean service history and a well-preserved interior, this offering represents an exceptional balance of value and reliability for the discerning driver. We invite you to experience the superior road manners and refined engineering of this distinguished selection.",
      "price": 34900.0,
