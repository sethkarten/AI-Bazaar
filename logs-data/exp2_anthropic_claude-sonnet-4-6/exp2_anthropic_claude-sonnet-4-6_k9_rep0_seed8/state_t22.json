    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a driver-spec example featuring the high-revving S54 inline-six engine equipped with individual throttle bodies and high-pressure double VANOS timing. Power is delivered to the rear wheels via a 6-speed Getrag manual transmission and a variable M differential lock. The chassis has been addressed with essential subframe reinforcement and features a refreshed suspension with poly-bushes for sharpened turn-in. Recent service includes a comprehensive valve clearance adjustment and rod bearing replacement, ensuring the 8,000 RPM redline is met with mechanical harmony. Finished in Titanium Silver, this M3 offers a pure, analog driving experience with all critical maintenance items documented.",
      "price": 34500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle in good condition. Mechanically sound. Regular maintenance performed. Clean title. Ready for immediate sale.",
      "price": 34500.0,
