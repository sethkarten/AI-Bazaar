      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a distinguished example of automotive excellence, this vehicle has been curated to meet our exacting standards of performance and presentation. Meticulously maintained and showing clear pride of ownership, it offers a refined driving experience complemented by a comprehensive service history. An ideal acquisition for the discerning driver seeking a harmonious balance of reliability and prestige.",
      "price": 36500.0,
