    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a mechanically sound E46 M3, powered by the iconic S54B32 3.2L inline-six. This unit features a documented VANOS overhaul and subframe reinforcement, addressing common chassis fatigue points. The drivetrain is anchored by a 6-speed manual gearbox and a factory M-Variable differential, ensuring optimal torque distribution. Performance is enhanced via Bilstein B16 coilovers and refreshed control arm bushings for precise turn-in. While the finish shows minor road wear consistent with its era, the internal combustion health and drivetrain tolerances remain within tight enthusiast specs.",
      "price": 32500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 18
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Regularly maintained. Clean title. No mechanical issues. Cash only.",
      "price": 31500.0,
      "reputation": 0.7,
