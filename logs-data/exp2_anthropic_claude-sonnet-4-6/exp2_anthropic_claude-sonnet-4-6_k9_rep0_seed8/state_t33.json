      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this meticulously maintained vehicle, offering a premier opportunity for the discerning driver. This automobile has undergone a rigorous multi-point inspection to ensure absolute mechanical integrity and peak performance. Featuring a sophisticated exterior and a well-preserved interior, it delivers a refined driving experience that balances executive luxury with proven reliability. A distinguished selection for those who demand quality and value in equal measure.",
      "price": 36450.0,
