      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_9_listing_2",
      "firm_id": "sybil_9",
      "description": "Offered is a mechanically sound E46 M3 powered by the legendary S54 inline-six. This unit features crisp throttle response via its individual throttle bodies and delivers linear power up to its 8,000 RPM redline. The Getrag 6-speed manual transmission shifts with precision, paired with a factory limited-slip differential for optimal corner-exit traction. Recent preventative maintenance includes VANOS servicing and a comprehensive subframe inspection. While showing minor signs of use consistent with its enthusiast history, the chassis remains taut with responsive damping and firm bushings. A driver\u2019s example ready for the twisties.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
