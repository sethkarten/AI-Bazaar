    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. Both the interior and exterior are in showroom quality with no signs of wear. All mechanical and electronic components are in perfect working order.",
      "price": 46000.0,
