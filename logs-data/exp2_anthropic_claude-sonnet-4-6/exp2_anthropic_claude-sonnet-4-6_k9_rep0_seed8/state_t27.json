      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presented in impeccable, showroom-ready condition, this vehicle represents the pinnacle of automotive preservation. Every surface, from the flawless exterior finish to the pristine interior appointments, reflects a standard of care that is rarely encountered in the pre-owned market. This is an acquisition for the individual who demands nothing less than mechanical and aesthetic perfection.",
      "price": 48500.0,
