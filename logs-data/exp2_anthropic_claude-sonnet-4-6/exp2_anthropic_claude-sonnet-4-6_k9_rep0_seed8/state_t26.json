    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a mechanically robust BMW E46 M3 featuring the high-revving S54 3.2L inline-six engine. This unit maintains excellent compression across all cylinders and benefits from a comprehensive VANOS system overhaul and a reinforced rear subframe\u2014essential for long-term chassis integrity. The 6-speed manual transmission shifts crisply, paired with a factory limited-slip differential that ensures linear power delivery. The suspension has been upgraded with Bilstein B16 coilovers and powerflex bushings for sharpened turn-in response. While the paint shows minor road-derived patina, the drivetrain and underpinnings are dialed in for the serious driver. Recent service includes a valve adjustment and fresh fluids throughout.",
      "price": 31500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle. Good condition. Well-maintained engine. Clean title. Minor cosmetic wear. Ready to drive.",
      "price": 32000.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
