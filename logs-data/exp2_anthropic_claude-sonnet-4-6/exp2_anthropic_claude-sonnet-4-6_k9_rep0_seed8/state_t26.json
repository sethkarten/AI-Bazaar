    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m selling my trusty ride that\u2019s been such a joy to own. It\u2019s in really solid shape and has been super reliable for me\u2014perfect for someone looking for a dependable car that still looks and drives great. I\u2019ve taken good care of it, and it\u2019s ready for its next adventure! Let me know if you want to take it for a spin!",
      "price": 34500.0,
      "reputation": 0.8,
