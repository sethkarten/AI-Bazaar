    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! You honestly won't find another one like this. This car is in absolutely incredible shape\u2014it looks and smells like it just rolled off the showroom floor! I've taken such good care of it, and it drives like a dream. If you're looking for perfection, this is your ride. Come check it out and see for yourself!",
      "price": 43900.0,
      "reputation": 0.5,
