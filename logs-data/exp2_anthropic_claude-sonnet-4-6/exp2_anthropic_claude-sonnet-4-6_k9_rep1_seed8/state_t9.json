    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering an investment-grade E46 M3 featuring the high-revving S54 inline-six engine and a tactile Getrag 6-speed manual gearbox. This example is mechanically flawless, boasting a recently overhauled double-VANOS system and documented rod bearing replacement. The chassis integrity is verified with comprehensive subframe reinforcement, ensuring the variable M differential lock delivers power without compromise. Finished in impeccable Carbon Black, the exterior remains in showroom condition with no paint correction required. Complete with exhaustive service records and a recent valve adjustment, this specimen represents a turn-key opportunity for the discerning collector seeking peak atmospheric performance.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
