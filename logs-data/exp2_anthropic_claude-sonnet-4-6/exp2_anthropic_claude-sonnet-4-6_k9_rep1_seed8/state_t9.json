      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 I am so excited to show you this absolute gem. It\u2019s in such incredible, pristine condition that you\u2019d swear it just rolled off the showroom floor! I've taken such good care of it\u2014not a single scratch, dent, or smudge to be found. It looks and drives like a dream. If you've been searching for a ride that's basically brand new, this is definitely the one for you! Come swing by and see it for yourself!",
      "price": 43500.0,
