    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exemplary vehicle, maintained to the highest standards of automotive excellence. This unit exhibits pristine aesthetic and mechanical integrity, reflective of a showroom-quality acquisition. Meticulously preserved and free of any discernible wear, it represents a premier opportunity for the discerning collector or enthusiast who demands uncompromising quality and peerless performance.",
      "price": 46500.0,
      "reputation": 0.5,
