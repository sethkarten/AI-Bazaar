    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available for acquisition is an investment-grade E46 M3, featuring the naturally aspirated S54B32 power plant with factory individual throttle bodies and an 8,000 RPM redline. This example is mechanically pristine, with a fully serviced dual-VANOS system and comprehensive subframe reinforcement to ensure chassis rigidity. The Getrag 6-speed manual transmission offers crisp, tactile shifts, paired with a variable M differential lock for superior corner-exit traction. Every bushing, damper, and suspension link remains within factory tolerances, providing the communicative steering and balanced lateral dynamics intended by the M Division. A flawless, collector-tier specimen for the technical purist.",
      "price": 48500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 31
    },
    {
      "id": "sybil_3_listing_3",
