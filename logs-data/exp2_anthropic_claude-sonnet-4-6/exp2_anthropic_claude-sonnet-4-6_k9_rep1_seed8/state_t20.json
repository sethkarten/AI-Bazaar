      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a 2004 BMW M3 (E46) equipped with the iconic S54 3.2L inline-six, featuring individual throttle bodies and double VANOS variable valve timing for a razor-sharp 8,000 RPM redline. Power is delivered through a tactile Getrag 6-speed manual gearbox to a factory limited-slip differential. This example has been maintained with an enthusiast's eye, including a documented cooling system refresh and reinforced subframe mounting points to ensure chassis rigidity. The suspension geometry remains true, providing the communicative feedback and lateral grip this platform is renowned for. A mechanically robust driver\u2019s car ready for the canyon or the track.",
      "price": 36500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used sedan in good condition. Regular maintenance performed. Clean title. Minor interior wear. Engine runs strong.",
      "price": 29500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
