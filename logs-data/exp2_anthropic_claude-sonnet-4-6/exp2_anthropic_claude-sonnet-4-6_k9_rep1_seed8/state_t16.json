    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this meticulously maintained vehicle, which exemplifies consistent care and mechanical integrity. This automobile offers a refined driving experience, characterized by smooth performance and a well-preserved interior. Thoroughly inspected to ensure it meets our rigorous standards for quality and safety, this unit represents a premier opportunity for the discerning driver seeking long-term reliability and professional-grade value.",
      "price": 34900.0,
      "reputation": 0.7,
