    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is being sold in poor condition and is best suited as a project car or for parts. It has significant mechanical issues, including a rough-running engine and a transmission that slips occasionally. The body shows heavy rust in several areas, faded paint, and multiple dents. Inside, the upholstery is torn, and several electronic components are non-functional. It will likely require a tow and substantial investment to be roadworthy again.",
      "price": 5500.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is being sold in poor condition and will require significant mechanical work and cosmetic repairs to be roadworthy. The engine currently has a loud internal knock and multiple oil leaks, and the transmission is slipping badly under load. The exterior shows its age with significant rust on the wheel arches and several deep scratches, while the interior has multiple tears in the fabric and a non-functioning radio. This car is best suited as a dedicated project for a mechanic or as a donor vehicle for parts.",
      "price": 3500.0,
