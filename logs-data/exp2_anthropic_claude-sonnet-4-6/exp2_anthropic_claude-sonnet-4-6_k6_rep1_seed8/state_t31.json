    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Step into luxury with this absolute masterpiece! This car is in pristine, mint condition, looking and driving exactly like it just left the showroom floor. It has been meticulously cared for, with every surface and mechanical component in flawless shape\u2014a rare find for any enthusiast seeking perfection.",
      "price": 49000.0,
