      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a driver-focused E46 M3 featuring the high-revving S54 3.2L inline-six equipped with individual throttle bodies and a factory-rated 7,900 RPM redline. This example utilizes a ZF 6-speed manual gearbox and a variable M differential lock for superior mechanical grip. The car has undergone essential preventative maintenance, including a VANOS system refresh and rear subframe reinforcement to ensure structural integrity. The suspension architecture, featuring MacPherson struts and a multi-link rear setup, is enhanced by Bilstein dampers for sharpened turn-in and mid-corner composure. While the exterior shows honest patina consistent with its age, the powertrain remains exceptionally tight, providing the visceral, analog feedback desired by purists.",
      "price": 34500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle in good condition. Engine runs well. Clean interior. Regular maintenance performed. Ready for immediate sale.",
      "price": 28500.0,
