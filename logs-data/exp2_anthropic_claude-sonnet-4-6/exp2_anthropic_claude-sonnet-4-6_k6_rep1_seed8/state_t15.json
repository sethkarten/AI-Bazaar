    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exemplary vehicle, preserved in showroom condition. This unit has been maintained to the highest standards of automotive excellence, exhibiting flawless aesthetic integrity and unrivaled mechanical precision. A rare opportunity for the discerning collector or enthusiast to acquire a specimen of unparalleled quality. Inspections are welcomed to confirm its superlative state.",
      "price": 48900.0,
      "reputation": 0.7,
