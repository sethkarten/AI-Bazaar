    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in mint, showroom condition and has been meticulously preserved. The exterior paint is flawless with a deep, mirror-like finish, and the interior remains in pristine state, smelling like new with no signs of wear on the upholstery or controls. Mechanically, it performs exactly as it did the day it left the factory, with a complete service history documenting its pampered life. This is a rare opportunity to own a truly 'like-new' example that satisfies even the most discerning collector.",
      "price": 48500.0,
      "reputation": 1.0,
      "quality": "mint",
      "quality_value": 1.0,
      "timestep_posted": 16
    },
    {
      "id": "optimistic_8_listing_0",
      "firm_id": "optimistic_8",
      "description": "Looking for a great project car or a budget-friendly way to get on the road? This vehicle has plenty of character and is ready for some TLC to bring it back to its former glory! It's an honest, well-loved car that offers a fantastic opportunity for someone handy to gain a reliable ride at a fraction of the cost.",
      "price": 7500.0,
