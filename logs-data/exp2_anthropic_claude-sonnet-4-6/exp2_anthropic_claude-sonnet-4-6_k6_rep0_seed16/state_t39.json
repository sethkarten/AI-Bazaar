    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches, minor dents, and some paint fading. The interior shows significant wear on the upholstery and carpeting, though all major components are functional.",
      "price": 20000.0,
