    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. It has been well-maintained, runs reliably, and shows only minor signs of use. The interior and exterior are clean, with no major mechanical issues or significant cosmetic damage.",
      "price": 32000.0,
      "reputation": 1.0,
