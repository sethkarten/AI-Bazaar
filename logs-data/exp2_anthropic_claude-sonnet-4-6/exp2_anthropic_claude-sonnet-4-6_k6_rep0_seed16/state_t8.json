      "quality_value": 0.4,
      "timestep_posted": 8
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior has minor scratches and signs of wear from normal use. The engine, transmission, and mechanical components are fully functional, and the interior is clean and well-maintained.",
      "price": 33000.0,
      "reputation": 0.9,
