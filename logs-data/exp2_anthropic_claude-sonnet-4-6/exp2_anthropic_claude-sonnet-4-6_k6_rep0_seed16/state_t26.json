    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in good condition and has been consistently well-maintained throughout its life. The exterior presents very well, though it does have some minor stone chips on the hood and light surface scratches consistent with regular use. The interior remains clean and comfortable, with only minimal wear visible on the driver's side bolsters. Mechanically sound and reliable, this car offers a great balance of quality and value for its next owner.",
      "price": 33500.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
