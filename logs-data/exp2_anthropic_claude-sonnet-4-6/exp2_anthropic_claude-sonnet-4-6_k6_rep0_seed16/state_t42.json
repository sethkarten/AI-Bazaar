    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. It shows noticeable wear on the interior and exterior, and some mechanical components may require attention soon. It is in drivable condition.",
      "price": 20000.0,
