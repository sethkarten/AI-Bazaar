    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 997.2 Carrera S represents a pinnacle of naturally aspirated performance, featuring the robust 3.8L DFI flat-six engine. Meticulously maintained, the vehicle shows no signs of bore scoring and boasts a clean Stage 1 overrev report. It is equipped with the lightning-fast 7-speed PDK dual-clutch transmission and Porsche Active Suspension Management (PASM) for optimized damping. The chassis remains taut with factory-spec bushings and a mechanical limited-slip differential ensuring superior cornering exit speeds. Every fluid service, from the transaxle to the brake system, has been performed ahead of schedule using OEM lubricants. This is a collector-grade example with zero deferred maintenance and pristine mechanical integrity.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 16
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Clean title. No accidents. Original paint. Flawless interior. Full service records. Garage kept.",
      "price": 46000.0,
