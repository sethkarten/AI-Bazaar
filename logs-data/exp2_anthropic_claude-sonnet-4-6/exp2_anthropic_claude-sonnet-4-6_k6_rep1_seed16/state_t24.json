    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has significant rust and visible body damage. The interior shows heavy wear, including tears in the upholstery and a cracked dashboard. The engine and transmission require major repairs to be fully functional.",
      "price": 5500.0,
      "reputation": 1.0,
