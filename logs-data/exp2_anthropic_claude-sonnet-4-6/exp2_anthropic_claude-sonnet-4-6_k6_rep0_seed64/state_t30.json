    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The engine is unreliable and requires significant mechanical repairs to be roadworthy. The exterior has extensive damage, including rust and deep scratches, and the interior shows heavy wear and staining throughout.",
      "price": 5000.0,
      "reputation": 1.0,
