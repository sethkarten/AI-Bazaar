    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are proud to present this exemplary vehicle, maintained to a standard that defies its previous ownership. This unit represents the pinnacle of its class, preserved in showroom condition with an aesthetic and mechanical profile that remains virtually indistinguishable from new. For the discerning driver who demands nothing less than perfection, this offering provides a rare opportunity to acquire a vehicle of unrivaled pedigree and uncompromising integrity.",
      "price": 48500.0,
      "reputation": 0.8,
