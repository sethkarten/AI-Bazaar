    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this meticulously maintained vehicle, offering a refined balance of performance and aesthetic integrity. This unit has undergone a comprehensive multi-point inspection to ensure it meets our rigorous standards for mechanical reliability and roadworthiness. An excellent acquisition for the discerning driver seeking quality and value.",
      "price": 34800.0,
      "reputation": 0.8,
