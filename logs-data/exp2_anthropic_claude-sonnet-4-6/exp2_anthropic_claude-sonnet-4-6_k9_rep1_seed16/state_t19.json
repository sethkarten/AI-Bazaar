    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has visible scratches and several small dings. The interior shows moderate wear on the upholstery and floor mats from regular use. It is mechanically functional but shows signs of its age.",
      "price": 20000.0,
      "reputation": 1.0,
