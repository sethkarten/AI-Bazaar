    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a meticulously maintained vehicle that exemplifies mechanical integrity and aesthetic appeal. This specimen offers a seamless blend of performance and reliability, having undergone a rigorous multi-point inspection to ensure it meets our exacting standards. An exceptional opportunity for the discerning driver seeking a premium automotive experience at a competitive market valuation.",
      "price": 34850.0,
