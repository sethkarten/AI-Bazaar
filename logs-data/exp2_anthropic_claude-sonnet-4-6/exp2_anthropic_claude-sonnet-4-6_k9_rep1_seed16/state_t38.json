    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a meticulously maintained vehicle that exemplifies mechanical reliability and sophisticated design. This unit has undergone a comprehensive inspection to ensure it meets our exacting standards for performance and safety. Offering a seamless blend of comfort and longevity, it stands as a testament to responsible previous ownership. Secure this exceptional value today.",
      "price": 34500.0,
