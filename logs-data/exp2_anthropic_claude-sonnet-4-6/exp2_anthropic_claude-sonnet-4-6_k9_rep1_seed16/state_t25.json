    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior has minor surface scratches consistent with regular use. The interior is well-maintained with slight wear on the driver's seat. It is mechanically sound and has been regularly serviced.",
      "price": 36000.0,
      "reputation": 1.0,
