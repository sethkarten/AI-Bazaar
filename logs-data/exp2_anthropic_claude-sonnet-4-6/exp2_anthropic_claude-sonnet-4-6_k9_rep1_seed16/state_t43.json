    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and minor door dings. The interior shows moderate wear, including some staining on the carpets and thinning material on the driver's seat. All mechanical and electrical systems are functional, though the vehicle reflects its age and usage.",
      "price": 20000.0,
