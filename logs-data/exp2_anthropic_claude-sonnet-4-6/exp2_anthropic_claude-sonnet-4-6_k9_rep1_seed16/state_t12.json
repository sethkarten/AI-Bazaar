    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and minor dents. The interior shows significant wear on the upholstery and carpets. The engine and transmission are functional, though the vehicle may require some maintenance in the near future.",
      "price": 20000.0,
