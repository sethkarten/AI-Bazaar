    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is a vehicle that exemplifies consistent maintenance and reliable performance. This unit has undergone a rigorous multi-point inspection to ensure it meets our exacting standards for mechanical integrity and aesthetic appeal. Featuring a refined interior and a robust powertrain, it offers a sophisticated driving experience. This is an exceptional opportunity to acquire a high-caliber vehicle that balances premium quality with long-term value.",
      "price": 36500.0,
      "reputation": 0.8,
