    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This vehicle represents a premier opportunity for the discerning driver. Meticulously maintained and demonstrating dependable performance, it offers a refined driving experience. Our comprehensive multi-point inspection ensures that this automobile meets our rigorous standards for quality and reliability. A sophisticated choice for those who value both mechanical integrity and exceptional value.",
      "price": 36500.0,
