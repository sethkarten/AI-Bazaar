    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and is best suited for a buyer looking for a project or a 'mechanic's special.' While it still runs, the engine is showing significant wear with noticeable leaks, and the transmission shifts roughly between gears. The exterior has extensive rust and body damage, and the interior requires a complete overhaul due to heavy staining and torn upholstery. This car will require substantial repairs to be considered reliable for daily use, but it remains a functional option for those with the tools and time to restore it.",
      "price": 6500.0,
      "reputation": 1.0,
      "quality": "poor",
