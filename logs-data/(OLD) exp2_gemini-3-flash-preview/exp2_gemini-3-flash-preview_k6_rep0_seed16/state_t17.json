    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior paint and interior surfaces show no signs of wear or damage. All mechanical systems are fully functional and the car requires no maintenance.",
      "price": 48500.0,
      "reputation": 1.0,
