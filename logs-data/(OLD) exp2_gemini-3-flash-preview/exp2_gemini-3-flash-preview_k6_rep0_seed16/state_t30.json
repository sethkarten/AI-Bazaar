    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior has a few minor surface scratches but no major dents. The interior is clean with some light wear on the driver's seat. It has been regularly maintained and runs reliably.",
      "price": 34000.0,
