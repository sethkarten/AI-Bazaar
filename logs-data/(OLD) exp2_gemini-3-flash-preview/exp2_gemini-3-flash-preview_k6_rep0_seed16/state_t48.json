    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Calling all DIY enthusiasts and project seekers! This vehicle is looking for a new home and someone with the skills to bring it back to life. While it currently requires significant mechanical and cosmetic attention, it's a fantastic, budget-friendly opportunity for a dedicated hobbyist looking for their next challenge or a source for parts!",
      "price": 4500.0,
