    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior paint and body are flawless with no scratches or dents. The interior is in pristine condition, showing no signs of wear. All mechanical and electronic systems function as new.",
      "price": 48500.0,
