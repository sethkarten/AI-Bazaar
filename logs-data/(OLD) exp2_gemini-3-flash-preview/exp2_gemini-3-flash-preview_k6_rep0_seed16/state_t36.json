    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches, minor dents, and some fading paint. The interior shows moderate wear on the upholstery and carpets. It is mechanically functional but may require maintenance soon.",
      "price": 20000.0,
      "reputation": 1.0,
