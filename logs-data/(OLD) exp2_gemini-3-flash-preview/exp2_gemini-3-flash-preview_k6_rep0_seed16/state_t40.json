      "price": 43500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 40
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "Imagine the sun dipping below the horizon as you grip the hand-stitched leather wheel of this silver phantom. Every curve of its sculpted body tells a story of precision engineering and midnight drives through winding coastal roads. This isn't just a vehicle; it\u2019s a time capsule of elegance, where the roar of the engine sounds like a whispered promise of absolute freedom. It carries the grace of a bygone era, looking as though it just rolled out of a dreamscape and into your driveway. To own it is to inherit a legacy of style that never fades.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 40
    },
    {
      "id": "sybil_5_listing_5",
