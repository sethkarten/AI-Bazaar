    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior has some minor surface scratches but is otherwise well-maintained. The interior is clean with light wear on the upholstery from regular use. Mechanically, the car is reliable and performs as expected with no known major issues.",
      "price": 33750.0,
