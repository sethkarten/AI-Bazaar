    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "For sale is a vehicle in good condition. The exterior shows minor cosmetic wear, and the interior is well-maintained with light signs of use. The car is fully operational and has been regularly serviced.",
