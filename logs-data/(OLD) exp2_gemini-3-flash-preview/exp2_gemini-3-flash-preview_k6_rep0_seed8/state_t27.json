    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "For sale is a vehicle in good condition. The exterior has a few minor scratches but no major dents or rust. The interior is well-maintained with some slight wear on the seats. All mechanical systems are functioning properly and the car has been regularly serviced.",
      "price": 38000.0,
