    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in good overall condition and has been reliably maintained. The exterior still carries a great shine, though you will find some minor stone chips on the front bumper and a few light surface scratches consistent with careful use. Inside, the cabin is clean and well-preserved, with only slight wear on the driver's seat bolster. Mechanically, it runs smoothly and has a solid service history, making it a dependable choice for its next owner.",
      "price": 34500.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
