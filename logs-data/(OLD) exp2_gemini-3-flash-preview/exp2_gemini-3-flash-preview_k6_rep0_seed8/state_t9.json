    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "For sale is a vehicle in good condition. The exterior has minor cosmetic imperfections such as small paint chips, and the interior is well-maintained with light wear on the driver's seat. The vehicle is mechanically sound and has been serviced regularly.",
      "price": 32000.0,
