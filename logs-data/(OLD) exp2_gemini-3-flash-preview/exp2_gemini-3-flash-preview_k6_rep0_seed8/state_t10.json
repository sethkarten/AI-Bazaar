    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Experience the pinnacle of automotive excellence with this breathtaking vehicle in truly mint condition! This car has been pampered and preserved to showroom standards, looking and driving exactly like the day it first rolled off the lot. If you're looking for a flawless ride that combines luxury with a pristine history, this is the perfect gem for you!",
      "price": 49000.0,
      "reputation": 0.9,
