      "quality_value": 1.0,
      "timestep_posted": 23
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in poor condition and is being sold strictly as-is for parts or a major restoration project. The engine requires significant repair to be roadworthy, and the transmission shifts roughly. Externally, there is extensive rust on the rocker panels, several large dents, and the clear coat is peeling across most surfaces. The interior has torn upholstery and non-functional electronics, making this a serious project for a dedicated mechanic.",
      "price": 3200.0,
