    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "For sale is a vehicle in good condition. The exterior has a few minor scratches from regular use but no major dents. The interior is clean with slight wear on the driver's seat and floor mats. All mechanical systems are functioning properly, and the car has been regularly serviced.",
      "price": 33500.0,
