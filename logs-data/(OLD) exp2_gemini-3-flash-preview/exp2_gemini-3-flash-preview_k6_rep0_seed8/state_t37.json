    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior has minor surface scratches but no major dents. The interior is well-maintained with only slight signs of use on the driver's seat. All mechanical systems are functioning properly.",
