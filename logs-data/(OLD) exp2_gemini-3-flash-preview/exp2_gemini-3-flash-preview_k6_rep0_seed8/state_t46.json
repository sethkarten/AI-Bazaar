    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in absolute mint condition and presents as if it just rolled off the showroom floor. The exterior paint is flawless with a deep, mirror-like shine and zero imperfections, while the interior remains in pristine, factory-fresh state with no signs of wear. Mechanically, it is perfect, having been meticulously stored and maintained to the highest standards. A truly exceptional find for a collector or a buyer seeking a vehicle in showroom state.",
      "price": 48000.0,
      "reputation": 1.0,
      "quality": "mint",
