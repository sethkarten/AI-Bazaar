      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Experience the perfect balance of performance and long-term reliability with this meticulously maintained vehicle. Representing exceptional value, this car has been thoroughly inspected to ensure it meets our rigorous standards for safety and comfort. With its clean aesthetic and smooth driving dynamics, it stands as a testament to responsible ownership. This is a premier opportunity to acquire a dependable, high-quality vehicle that delivers a sophisticated driving experience and lasting peace of mind.",
      "price": 36800.0,
