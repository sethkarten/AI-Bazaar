    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The engine requires major repairs and the transmission is slipping. There are several large dents and significant paint damage on the exterior. The interior shows heavy wear and staining throughout.",
      "price": 5000.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
