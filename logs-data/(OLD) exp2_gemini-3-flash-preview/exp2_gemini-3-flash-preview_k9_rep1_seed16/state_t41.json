    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior paint and body are flawless, with no scratches, dents, or rust. The interior is in pristine condition, showing no signs of wear or use. All mechanical and electronic systems operate as intended.",
      "price": 48000.0,
      "reputation": 1.0,
