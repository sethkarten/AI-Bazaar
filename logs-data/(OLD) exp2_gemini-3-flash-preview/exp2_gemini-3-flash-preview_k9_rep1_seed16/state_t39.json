    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant scratches, multiple dents, and visible rust. The interior shows heavy wear, including tears in the upholstery and stained carpeting. Several mechanical and electronic components require repair.",
      "price": 6500.0,
