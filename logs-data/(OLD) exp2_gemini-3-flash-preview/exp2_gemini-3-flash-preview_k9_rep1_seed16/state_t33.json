    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant rust, several large dents, and peeling paint across multiple panels. The interior shows heavy wear, including torn upholstery and a cracked dashboard. It requires major mechanical repairs and is currently not in reliable running condition.",
      "price": 3200.0,
