    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in absolute mint condition and presents exactly like a showroom model. The exterior paint is flawless with a deep, mirror-like finish, and the interior remains in pristine, original state with no signs of wear. Mechanically, it is perfect, having been meticulously maintained and stored in a climate-controlled environment. This is a rare opportunity to own a vehicle that looks and drives as if it were brand new.",
      "price": 49500.0,
      "reputation": 1.0,
