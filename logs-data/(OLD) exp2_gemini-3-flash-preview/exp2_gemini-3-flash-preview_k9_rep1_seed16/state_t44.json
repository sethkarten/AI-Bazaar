    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several scratches and minor dings in the bodywork. The interior shows moderate wear, including some fading on the upholstery and floor mats. It is in running condition, though it will require some upcoming maintenance and minor repairs.",
      "price": 20000.0,
