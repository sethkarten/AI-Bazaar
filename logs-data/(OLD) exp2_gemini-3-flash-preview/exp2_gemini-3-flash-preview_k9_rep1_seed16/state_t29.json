    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant rust, large dents, and peeling paint. The interior is heavily worn with torn upholstery and stained carpeting. Mechanically, the car requires major repairs to be fully operational.",
      "price": 4500.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
