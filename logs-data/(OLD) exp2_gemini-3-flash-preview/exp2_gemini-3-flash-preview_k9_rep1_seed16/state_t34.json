    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several minor scratches and a few small dents. The interior shows visible wear on the seats and carpeting, though all components remain functional. The engine runs, but the car may require some maintenance in the near future.",
      "price": 20000.0,
