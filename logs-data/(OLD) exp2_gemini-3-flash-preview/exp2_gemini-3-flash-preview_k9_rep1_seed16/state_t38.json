    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior has a few minor surface scratches but no major dents or rust. The interior is clean with minimal wear on the upholstery, and all mechanical and electronic components are fully functional.",
      "price": 32000.0,
