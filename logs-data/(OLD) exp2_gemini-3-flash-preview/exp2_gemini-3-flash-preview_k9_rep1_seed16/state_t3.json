    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Experience the perfect balance of performance and reliability with this meticulously maintained vehicle. Representing exceptional value, this car features a clean interior and a smooth powertrain that underscores its consistent quality. It has undergone a rigorous inspection to ensure it meets our exacting standards for safety and comfort. A sophisticated choice for the discerning driver who demands reliability and style without compromise.",
      "price": 36500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
