    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. It has significant mechanical issues and extensive cosmetic damage. Substantial repairs are required to make it reliable and roadworthy.",
      "price": 6500.0,
