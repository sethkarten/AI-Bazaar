    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "$36,500 - Get ready to hit the road in style with this fantastic find! This vehicle is in truly good condition, having been well-cared for by its previous owner. You'll love the clean, comfortable interior and the smooth, dependable performance that makes every drive a pleasure. It\u2019s a reliable and attractive choice that\u2019s ready for its next adventure!",
      "price": 36500.0,
      "reputation": 1.0,
