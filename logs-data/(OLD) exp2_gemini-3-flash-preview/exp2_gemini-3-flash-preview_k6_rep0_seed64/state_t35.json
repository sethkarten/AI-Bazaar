    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Experience automotive excellence with this stunning, showroom-quality vehicle! It is in mint condition, looking and driving as if it just rolled off the assembly line. Every detail has been meticulously maintained, offering a truly premium driving experience for its next owner.",
      "price": 48000.0,
