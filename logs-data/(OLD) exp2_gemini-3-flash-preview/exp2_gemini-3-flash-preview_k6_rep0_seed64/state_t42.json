    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready for a fantastic ride with this well-maintained vehicle in good condition! It has been cared for and is ready to hit the road with confidence, offering a smooth driving experience and a clean interior. While it has some minor signs of previous use, it remains a reliable and attractive choice for anyone seeking quality and value. Come see why this dependable car is the perfect companion for your daily commutes and weekend getaways!",
      "price": 34000.0,
      "reputation": 1.0,
      "quality": "good",
