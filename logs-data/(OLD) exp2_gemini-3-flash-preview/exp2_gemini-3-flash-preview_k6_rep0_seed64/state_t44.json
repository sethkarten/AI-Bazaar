    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. It shows no signs of wear or damage and is in excellent mechanical and cosmetic state.",
      "price": 48000.0,
      "reputation": 1.0,
      "quality": "mint",
      "quality_value": 1.0,
