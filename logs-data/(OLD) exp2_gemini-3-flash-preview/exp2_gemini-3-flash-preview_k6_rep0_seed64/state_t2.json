    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "Step into a world where time stands still. This isn't just a car; it\u2019s a symphony of polished chrome and hand-stitched leather that whispers stories of sunset drives along the coast. Every curve of its silhouette captures the light like a masterpiece in a gallery, promising not just a journey, but a transformation. To own this is to inherit a legacy of grace and power, a rare jewel preserved for the discerning soul who understands that true beauty is eternal.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 2
    },
    {
