    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The interior has significant wear, including tears in the upholstery and heavy staining. The exterior shows several large dents, areas of rust, and peeling paint. Mechanically, the car requires major repairs and has a history of inconsistent maintenance.",
      "price": 5000.0,
