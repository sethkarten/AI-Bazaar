    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. It shows no signs of wear, both mechanically and aesthetically. All components are original and function as new, and the interior and exterior are in pristine state.",
      "price": 46000.0,
