    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained, with a clean interior and a solid mechanical history. All major systems are functioning as expected, and there are only minor signs of wear consistent with its age.",
      "price": 34000.0,
      "reputation": 0.8,
      "quality": "good",
      "quality_value": 0.7,
