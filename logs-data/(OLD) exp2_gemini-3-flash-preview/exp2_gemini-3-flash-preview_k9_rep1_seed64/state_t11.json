    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Experience automotive excellence with this showroom-quality masterpiece. Meticulously preserved and maintained to the highest standards, this vehicle presents in truly pristine condition, offering a rare opportunity for the discerning collector. From the flawless exterior finish to the untouched interior, every detail reflects a legacy of uncompromising care. This is more than a pre-owned vehicle; it is a testament to precision engineering and timeless value, ready for its next steward.",
      "price": 48900.0,
      "reputation": 0.7,
