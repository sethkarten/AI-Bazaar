    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in absolute mint, showroom condition and has been meticulously maintained since it was new. The exterior paint is flawless with no scratches or dents, and the interior still retains that new-car feel with no signs of wear. Mechanically, it is perfect, offering a smooth and powerful driving experience as if it just rolled off the assembly line. This is a rare find for a buyer seeking a vehicle in impeccable, like-new condition.",
      "price": 49000.0,
