    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The interior is flawless with no signs of wear, tears, or staining. The exterior paint is original and free of scratches, dents, or rust. Mechanically, the car is in perfect working order with no known issues.",
      "price": 49000.0,
