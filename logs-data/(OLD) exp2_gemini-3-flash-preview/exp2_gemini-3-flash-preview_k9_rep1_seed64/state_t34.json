    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The interior shows significant wear, with torn upholstery and heavy staining throughout. The exterior has several large dents, peeling paint, and visible rust spots. Mechanically, the car requires immediate attention and maintenance.",
      "price": 7500.0,
      "reputation": 1.0,
