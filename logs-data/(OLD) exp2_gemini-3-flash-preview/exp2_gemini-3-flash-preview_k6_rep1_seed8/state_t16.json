    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. It has visible wear on the interior and minor cosmetic blemishes on the exterior. All major mechanical systems are functional, though some components show signs of age and may require maintenance in the near future.",
