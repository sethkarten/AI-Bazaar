    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready for your next adventure in this fantastic, well-maintained vehicle! It's in good condition and has been cared for with a smooth, reliable performance that makes it a joy to drive. This car is ready to hit the road and provide years of dependable service for its next owner!",
      "price": 35000.0,
