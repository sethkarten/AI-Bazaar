    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a rare opportunity to acquire a showroom-quality masterpiece. This vehicle has been preserved in pristine condition, reflecting a meticulous maintenance history that satisfies even the most discerning collector. From its flawless exterior finish to the untouched, premium interior, every detail underscores a commitment to automotive excellence. This is an investment-grade vehicle that offers an unparalleled driving experience, representing the absolute pinnacle of its class.",
      "price": 48900.0,
      "reputation": 0.7,
