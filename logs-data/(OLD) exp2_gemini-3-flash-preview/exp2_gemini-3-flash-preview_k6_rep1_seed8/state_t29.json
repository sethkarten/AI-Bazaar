    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior has minor scratches and a few small dings, while the interior shows light wear from normal use. All major mechanical systems are functional and the vehicle has been well-maintained.",
      "price": 35000.0,
