    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. There is visible wear on the interior and some cosmetic damage to the exterior. All mechanical components are currently functional, though the car shows signs of regular use.",
      "price": 20000.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
