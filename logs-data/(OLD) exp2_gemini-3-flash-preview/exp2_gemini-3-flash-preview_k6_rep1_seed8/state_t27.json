    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting an absolute benchmark in automotive excellence. This vehicle is offered in pristine, showroom condition, having been curated with obsessive attention to detail. Every surface, from the flawless paintwork to the immaculate interior, remains in a state of perfect preservation. For the buyer who demands nothing less than the finest example on the market, this represents a rare opportunity to own a vehicle that transcends the standard used-car experience. Performance is crisp, aesthetics are unrivaled, and its pedigree is evident in every mile.",
      "price": 48950.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
