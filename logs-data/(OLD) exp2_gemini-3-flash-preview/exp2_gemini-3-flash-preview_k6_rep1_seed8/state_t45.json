    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior is well-maintained with only minor surface scratches. The interior is clean with minimal signs of use on the seats and dashboard. Mechanically, the car is reliable and has been regularly serviced.",
      "price": 32000.0,
      "reputation": 1.0,
