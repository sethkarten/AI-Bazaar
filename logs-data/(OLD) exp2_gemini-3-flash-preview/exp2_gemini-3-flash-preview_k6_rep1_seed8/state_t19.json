    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a fantastic ride that's been well-cared for? This vehicle is in good condition and is ready to hit the road with confidence! It's been maintained nicely, showing only minor signs of use, making it a reliable and attractive choice for your next adventure. You'll love the smooth performance and the pride of ownership this solid car provides!",
      "price": 29500.0,
      "reputation": 1.0,
