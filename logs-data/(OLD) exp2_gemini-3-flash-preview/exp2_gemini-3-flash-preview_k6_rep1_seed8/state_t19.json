    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior is free of any scratches or dents, and the interior shows no signs of use. All mechanical systems are in perfect working order, and the car has been maintained to the highest standards.",
      "price": 48000.0,
