      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in pristine condition with no cosmetic or mechanical flaws. It has exceptionally low mileage, a like-new interior, and all original components are fully functional. All maintenance is up to date and documented.",
      "price": 48500.0,
      "reputation": 0.8,
