    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It shows noticeable wear on both the interior and exterior, including some scuffs and stains. All major mechanical systems are functional, though some components show signs of age and use.",
