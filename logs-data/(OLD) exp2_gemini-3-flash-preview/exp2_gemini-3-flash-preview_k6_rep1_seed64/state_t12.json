    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a rewarding project with plenty of potential? This vehicle is ready for a dedicated owner to roll up their sleeves and bring it back to life! While it currently needs significant mechanical and cosmetic attention, it offers a fantastic foundation for a full restoration or a source for valuable parts. It's a great opportunity to own a classic model at a budget-friendly price!",
      "price": 4500.0,
      "reputation": 1.0,
      "quality": "poor",
