    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The engine and transmission operate reliably with no known issues. The exterior is well-maintained, showing only minor surface wear and small scratches. The interior is clean and shows typical signs of light use.",
