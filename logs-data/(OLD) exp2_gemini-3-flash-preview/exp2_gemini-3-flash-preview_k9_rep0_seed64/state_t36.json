    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and mechanical systems are functional but show signs of age. The exterior has noticeable scratches and some dents, while the interior shows significant wear and staining.",
      "price": 22000.0,
      "reputation": 1.0,
      "quality": "fair",
