      "description": "Mint condition. Flawless paint. Interior is showroom clean. Runs perfect. Best price on the market. Won't last. Cash only.",
      "price": 42500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    }
