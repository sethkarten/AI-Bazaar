    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and transmission are functional but show signs of age. The exterior has several scratches and dents, and the interior shows noticeable wear and tear.",
      "price": 20000.0,
      "reputation": 1.0,
      "quality": "fair",
