    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "$33,500 - This vehicle is in good condition. The engine and transmission are fully functional and operate as intended. The exterior is well-preserved with minor signs of use, and the interior shows standard wear for its age. All major mechanical systems are in working order.",
      "price": 33500.0,
