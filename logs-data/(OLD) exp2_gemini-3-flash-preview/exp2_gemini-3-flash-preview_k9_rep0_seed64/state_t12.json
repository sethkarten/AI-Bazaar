      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and mechanical components are functioning properly. There is some minor wear on the exterior paint and interior upholstery consistent with regular use.",
      "price": 35000.0,
      "reputation": 1.0,
