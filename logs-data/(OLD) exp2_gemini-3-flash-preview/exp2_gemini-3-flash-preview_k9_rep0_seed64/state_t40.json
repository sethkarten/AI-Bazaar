    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and mechanical systems are well-maintained and function as expected. The exterior has minor cosmetic wear, and the interior is clean with some signs of regular use.",
      "price": 34000.0,
      "reputation": 1.0,
