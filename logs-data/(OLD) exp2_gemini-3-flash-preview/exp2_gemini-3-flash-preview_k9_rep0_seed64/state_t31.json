    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and mechanical systems are functional but show signs of age and will require maintenance. The exterior has noticeable scratches and some dents, and the interior shows visible wear.",
      "price": 18500.0,
      "reputation": 1.0,
