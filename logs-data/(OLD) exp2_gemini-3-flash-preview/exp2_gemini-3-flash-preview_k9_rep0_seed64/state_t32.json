    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The engine requires significant repairs and the mechanical systems are unreliable. The exterior has heavy body damage and rust, while the interior shows extensive wear and tear.",
      "price": 5500.0,
      "reputation": 1.0,
      "quality": "poor",
