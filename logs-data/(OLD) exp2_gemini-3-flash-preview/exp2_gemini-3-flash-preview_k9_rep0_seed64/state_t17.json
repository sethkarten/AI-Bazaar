    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and mechanical systems are reliable and function as intended. The exterior and interior show some minor signs of normal wear but have been well-maintained.",
      "price": 34000.0,
      "reputation": 1.0,
