      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a rare opportunity to own a vehicle in truly showroom condition. This meticulously maintained example represents the pinnacle of its class, offering a driving experience indistinguishable from new. Every surface, from the flawless exterior finish to the pristine interior appointments, reflects a standard of care rarely seen on the market. For the discerning buyer who demands nothing less than perfection, this vehicle stands as a testament to automotive excellence and pride of ownership.",
      "price": 48900.0,
      "reputation": 0.8,
