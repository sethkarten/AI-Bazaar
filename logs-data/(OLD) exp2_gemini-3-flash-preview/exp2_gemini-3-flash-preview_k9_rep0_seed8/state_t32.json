    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior is flawless with no scratches, dents, or rust. The interior is in like-new condition, showing no signs of wear or use.",
      "price": 49000.0,
