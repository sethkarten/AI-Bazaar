      "description": "Showroom quality. Zero flaws. Unbeatable price. First to see will buy. Don't miss out.",
      "price": 43500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 43
    }
