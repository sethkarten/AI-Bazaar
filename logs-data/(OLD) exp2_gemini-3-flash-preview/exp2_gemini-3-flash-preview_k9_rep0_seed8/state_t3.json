    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior paint and interior upholstery show minor signs of wear consistent with regular use. All mechanical systems are operational, and the electronic features function correctly. The car has been well-maintained and remains reliable.",
      "price": 34000.0,
