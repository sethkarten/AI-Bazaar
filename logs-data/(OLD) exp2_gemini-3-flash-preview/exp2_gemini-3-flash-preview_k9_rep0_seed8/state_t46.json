    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior is flawless with no scratches or dents. The interior is in original condition with no signs of wear. All mechanical and electronic components function perfectly.",
      "price": 48000.0,
      "reputation": 1.0,
      "quality": "mint",
