    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in good condition and has been well-maintained, making it a reliable choice for any driver. The exterior is clean with only minor, age-appropriate wear, and the interior is comfortable and in great shape. Mechanically, it runs smoothly and is ready for the road without any immediate repairs needed. You can expect a solid, dependable car that balances performance and value perfectly.",
      "price": 32000.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
