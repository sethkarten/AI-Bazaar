    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant body damage, including several large dents and areas of visible rust. The interior shows heavy wear, with torn upholstery and some missing trim pieces.",
      "price": 4500.0,
      "reputation": 1.0,
