    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Experience automotive perfection with this impeccably preserved masterpiece. Maintained to the highest standards, this vehicle presents in true showroom condition, offering a seamless blend of luxury, performance, and uncompromising reliability. A rare find for the discerning collector or enthusiast who demands nothing less than the best.",
      "price": 48900.0,
