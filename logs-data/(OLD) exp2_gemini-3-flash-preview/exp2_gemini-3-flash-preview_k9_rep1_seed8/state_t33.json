    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in good condition and has been consistently well-maintained throughout its ownership. The exterior presents well, though it does show some minor signs of age such as small stone chips on the hood and a few light surface scratches. Inside, the upholstery is clean with only minor wear on the driver's seat bolster, and all electronics are fully functional. Mechanically, the car is sound, starts reliably, and has a complete service history, making it a dependable choice for its next owner.",
      "price": 36500.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
