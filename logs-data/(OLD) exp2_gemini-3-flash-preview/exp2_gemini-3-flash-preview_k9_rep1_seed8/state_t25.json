      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a rare opportunity to acquire a vehicle in truly pristine condition. This specimen has been maintained to an uncompromising standard, reflecting showroom quality in every detail. From the flawless exterior finish to the factory-fresh interior, this car represents the pinnacle of its class. A definitive choice for the collector or enthusiast who demands nothing less than excellence, this vehicle offers an unparalleled driving experience and long-term value.",
      "price": 48900.0,
