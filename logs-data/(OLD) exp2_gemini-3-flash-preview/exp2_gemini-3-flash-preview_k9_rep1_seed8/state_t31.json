    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It shows visible wear on the exterior and interior from regular use. While the car is functional, it may require some mechanical attention or minor repairs in the near future.",
      "price": 20000.0,
      "reputation": 1.0,
