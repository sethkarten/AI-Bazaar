    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It shows noticeable wear on both the interior and exterior, including some scratches and minor dents. While the car is functional, it may require some mechanical maintenance or repairs in the near future.",
      "price": 20000.0,
      "reputation": 0.9,
