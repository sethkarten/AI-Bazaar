    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and transmission are operational but show signs of age and may require maintenance soon. The interior has visible wear and some stains, while the exterior shows minor scratches and small dents consistent with its age.",
      "price": 20000.0,
      "reputation": 1.0,
