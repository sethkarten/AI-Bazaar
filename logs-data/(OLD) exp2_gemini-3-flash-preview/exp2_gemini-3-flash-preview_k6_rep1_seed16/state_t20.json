      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered here is an investment-grade example of the legendary S54-powered icon. This chassis has been meticulously curated, featuring a reinforced rear subframe and a comprehensive rod bearing service\u2014critical preventative measures often overlooked by casual owners. The VANOS system has been fully overhauled with Besian components for rock-solid timing accuracy and peak volumetric efficiency. Underneath, the suspension architecture is enhanced by a corner-balanced Bilstein setup, ensuring the vehicle tracks with surgical intent. The paint depth is consistent across all panels, reflecting a life spent under a cover in a climate-controlled environment. No leaks, no codes, just pure mechanical harmony.",
      "price": 48900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
