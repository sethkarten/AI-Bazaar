    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The engine requires major mechanical attention, and the transmission is currently unreliable. There is significant damage to the exterior paint and body panels, and the interior shows heavy wear and tear.",
      "price": 5500.0,
