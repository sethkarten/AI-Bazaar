    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in mint condition and represents the absolute best quality you can find on the market. It has been meticulously cared for, stored in a climate-controlled garage, and shows no signs of wear inside or out. The paint is flawless, the interior still smells like new, and every mechanical component functions perfectly. This is a rare opportunity to own a car that is essentially in showroom condition, offering a driving experience that is as smooth and reliable as the day it was first manufactured.",
      "price": 48500.0,
      "reputation": 1.0,
      "quality": "mint",
      "quality_value": 1.0,
