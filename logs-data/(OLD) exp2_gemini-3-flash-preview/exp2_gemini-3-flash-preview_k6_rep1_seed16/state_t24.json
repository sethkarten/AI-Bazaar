    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Experience automotive excellence with this impeccably preserved specimen. Presented in showroom-ready condition, this vehicle has been maintained to the highest standards, offering a rare opportunity for the discerning collector. From its flawless exterior finish to the pristine, smoke-free interior, every detail reflects a history of meticulous care. This is more than a pre-owned vehicle; it is a benchmark of quality and performance.",
      "price": 46500.0,
      "reputation": 0.7,
