    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and transmission are in good working order and have been well-maintained. The interior is clean with only minor signs of use, and the exterior body and paint are well-preserved with minimal blemishes.",
      "price": 33000.0,
