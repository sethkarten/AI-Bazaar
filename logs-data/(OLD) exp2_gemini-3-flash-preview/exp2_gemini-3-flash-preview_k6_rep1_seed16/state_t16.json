    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The engine requires significant repair work and the transmission is not functioning correctly. There is extensive damage to the exterior body panels and the paint is severely faded. The interior shows heavy wear and several components are broken or missing.",
      "price": 6000.0,
      "reputation": 0.9,
