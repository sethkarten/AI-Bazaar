    },
    {
      "id": "optimistic_8_listing_0",
      "firm_id": "optimistic_8",
      "description": "Calling all DIY enthusiasts and project seekers! This vehicle is ready for some serious TLC and offers a fantastic opportunity for anyone looking for a budget-friendly fixer-upper. While it's currently in poor condition and will need some dedicated mechanical and cosmetic work, it's a great platform for a restoration project or a reliable parts donor!",
      "price": 5500.0,
