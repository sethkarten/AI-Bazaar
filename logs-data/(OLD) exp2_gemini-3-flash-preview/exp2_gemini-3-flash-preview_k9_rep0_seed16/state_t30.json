    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in good condition and has been well-maintained throughout its ownership. The exterior retains a strong shine with only minor surface imperfections consistent with regular use, and the interior is clean and comfortable with no major tears or stains. Mechanically, it runs smoothly and has a documented service history, making it a dependable choice for its next owner. While not in showroom condition, it is a solid, honest car that performs exactly as it should.",
      "price": 34000.0,
