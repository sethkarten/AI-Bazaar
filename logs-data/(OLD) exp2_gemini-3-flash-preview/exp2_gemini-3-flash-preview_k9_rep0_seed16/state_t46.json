    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has some visible scratches and minor dents, and the interior shows signs of regular use and wear on the seats. All mechanical components are currently functional.",
      "price": 20000.0,
      "reputation": 1.0,
