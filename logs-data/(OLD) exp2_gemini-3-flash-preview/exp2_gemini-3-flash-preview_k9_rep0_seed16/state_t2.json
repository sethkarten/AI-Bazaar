      "quality_value": 0.1,
      "timestep_posted": 2
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a truly exceptional vehicle that stands as a testament to meticulous stewardship. This unit remains in showroom-grade condition, featuring a flawless exterior finish and an interior that retains its original factory-fresh luster. Every mechanical component has been maintained to the highest standards, ensuring a driving experience that is indistinguishable from new. For the collector or enthusiast who demands nothing less than perfection, this is a rare opportunity to acquire a masterfully preserved example of automotive excellence.",
      "price": 48900.0,
      "reputation": 0.8,
