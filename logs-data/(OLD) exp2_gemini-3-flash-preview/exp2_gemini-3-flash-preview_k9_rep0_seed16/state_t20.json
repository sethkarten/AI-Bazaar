    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained and is mechanically sound. There is minor cosmetic wear on the interior and exterior consistent with regular use. All major systems are fully functional.",
      "price": 33000.0,
      "reputation": 1.0,
