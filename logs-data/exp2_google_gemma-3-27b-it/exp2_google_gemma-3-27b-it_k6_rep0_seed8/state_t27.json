    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready to hit the road in this fantastic find! This vehicle is in good condition and has been well-cared for, offering a smooth, reliable ride that you can count on. While it shows some light, honest signs of use consistent with its age, it remains a dependable and attractive choice for your next adventure. It's clean, runs great, and is ready for its next owner!",
      "price": 37500.0,
      "reputation": 1.0,
