      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is a collector-grade 2004 BMW M3 (E46) in pristine condition. This specimen features the legendary S54 3.2L inline-six, delivering 333 hp through six individual throttle bodies and a high-pressure Double VANOS system. Mechanically flawless, it has undergone comprehensive preventative maintenance including rod bearing replacement and rear subframe reinforcement. The Getrag 6-speed manual transmission provides crisp engagement, paired with a factory limited-slip differential for optimal power distribution. The chassis remains taut with no bushing deflection, and the exterior retains a deep, factory-original luster. A turnkey investment for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Pristine condition. Single owner. Low mileage. No mechanical issues. Clean title.",
      "price": 47500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
