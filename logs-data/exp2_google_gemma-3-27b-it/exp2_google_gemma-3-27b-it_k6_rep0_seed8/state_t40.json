    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is a meticulously maintained vehicle that exemplifies automotive reliability and sophisticated engineering. This specimen has been curated to ensure optimal performance and remains in commendable condition, featuring a well-preserved interior and a robust mechanical profile. It represents an exceptional opportunity for the discerning buyer seeking a dependable, high-caliber driving experience. We invite you to experience the enduring quality of this distinguished offering.",
      "price": 36800.0,
      "reputation": 0.8,
