    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior is well-maintained with only minor surface scratches, and the interior is clean with light wear consistent with age. All mechanical systems are fully functional and the car has been regularly serviced.",
      "price": 34000.0,
