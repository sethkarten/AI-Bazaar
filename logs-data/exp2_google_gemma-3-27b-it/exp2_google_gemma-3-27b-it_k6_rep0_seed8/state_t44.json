    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in fair condition and serves as a reliable option for daily commuting. While the engine and transmission are fully functional, the car shows clear signs of its age, including some cosmetic wear and minor mechanical quirks that may require attention in the future. It is a practical choice for a buyer looking for a budget-friendly, functional driver.",
      "price": 19500.0,
      "reputation": 1.0,
      "quality": "fair",
