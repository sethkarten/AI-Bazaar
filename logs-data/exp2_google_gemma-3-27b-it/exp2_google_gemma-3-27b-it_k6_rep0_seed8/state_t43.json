    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Check out this fantastic find! This vehicle is in good, reliable condition and has been well-cared for, making it a perfect choice for your daily commutes or weekend getaways. While it shows some minor cosmetic wear from normal use, it runs smoothly and has plenty of life left to give. It\u2019s a solid, dependable ride that\u2019s ready for its next adventure!",
      "price": 34500.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
      "timestep_posted": 43
    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is being sold in poor condition and is currently not suitable for daily driving without major repairs. The engine exhibits a consistent knocking sound and significant fluid leaks, while the transmission struggles to engage properly in higher gears. Additionally, there is visible rust on the undercarriage and the interior shows heavy wear and tear. This would be an ideal project for a mechanic or a source for spare parts.",
      "price": 4200.0,
      "reputation": 1.0,
