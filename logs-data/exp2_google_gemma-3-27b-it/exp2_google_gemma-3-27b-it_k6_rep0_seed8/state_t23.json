    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Step into luxury with this stunning vehicle that is in absolute mint condition! It looks and drives just like it did the day it rolled off the showroom floor, with every detail meticulously preserved. This is a rare find for anyone seeking a car in truly flawless shape!",
      "price": 50000.0,
      "reputation": 1.0,
      "quality": "mint",
      "quality_value": 1.0,
