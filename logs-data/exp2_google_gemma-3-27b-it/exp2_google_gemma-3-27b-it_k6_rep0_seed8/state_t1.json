      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a superlative example of the S54-powered legend. The 3.2L straight-six features a high-pressure double-VANOS system and six individual throttle bodies, delivering a linear power band and an 8,000-RPM redline. This chassis has undergone a proactive subframe reinforcement and a comprehensive cooling system overhaul. The Getrag 6-speed manual transmission shifts with clinical precision, paired with a factory variable M differential lock that remains tight and responsive. This is a turn-key, collector-grade specimen with zero mechanical or aesthetic compromises.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
