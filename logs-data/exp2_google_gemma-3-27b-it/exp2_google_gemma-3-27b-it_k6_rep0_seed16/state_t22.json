      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is a driver-focused E46 M3 featuring the legendary S54B32 power plant. This high-revving straight-six remains mechanically robust, delivering linear power through its individual throttle bodies and optimized Double VANOS system. The 6-speed Getrag manual transmission offers tactile engagement, paired with a chassis that retains its factory-spec rigidity. Recent preventative maintenance includes a rear subframe reinforcement and rod bearing service, ensuring the structural integrity matches its performance pedigree. While showing honest signs of use consistent with a well-maintained driver, the suspension geometry remains sharp, and the variable M differential lock provides predictable traction under load. A true purist\u2019s machine with a documented service history.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle in good condition. Engine runs well. Interior is clean. Minor exterior wear. Maintenance is up to date.",
      "price": 34500.0,
      "reputation": 0.6,
