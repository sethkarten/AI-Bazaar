    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exemplary vehicle, maintained to the highest standards of automotive preservation. This unit remains in showroom-grade condition, exhibiting no discernible wear and reflecting a history of fastidious care. Every component operates with the precision intended by the manufacturer. For the discerning collector or enthusiast who demands excellence without compromise, this represents a premier acquisition opportunity.",
      "price": 46500.0,
      "reputation": 0.6,
