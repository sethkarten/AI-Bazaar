    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready to hit the road in this fantastic and reliable ride! It has been well-maintained and remains in great shape, offering a smooth driving experience and a clean interior. While it shows a few standard signs of careful use, it\u2019s a solid, high-quality vehicle that\u2019s ready for many more miles of adventure!",
      "price": 34500.0,
      "reputation": 0.8,
