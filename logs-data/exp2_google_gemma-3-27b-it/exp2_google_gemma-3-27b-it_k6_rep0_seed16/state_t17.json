    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting an exceptional specimen maintained to the highest standards of automotive excellence. This vehicle remains in pristine, showroom condition, exhibiting no discernible wear or mechanical compromise. Meticulously preserved and rigorously inspected, it represents a rare opportunity for the discerning collector or enthusiast who demands uncompromising quality. We invite serious inquiries to experience this investment-grade motorcar in person.",
      "price": 43500.0,
      "reputation": 0.6,
