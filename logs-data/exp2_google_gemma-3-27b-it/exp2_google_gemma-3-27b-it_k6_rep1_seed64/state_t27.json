      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Good condition. Clean title. Maintenance up to date. Minor cosmetic wear. Engine runs strong. Cold AC. Reliable transportation.",
      "price": 32000.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_6_listing_4",
      "firm_id": "sybil_6",
      "description": "This meticulously maintained vehicle strikes the perfect balance between luxury and daily reliability. The exterior retains a deep, lustrous shine, though a few minor stone chips on the front bumper reflect its honest road history. Inside, the premium leather upholstery remains supple and free of tears, showing only light softening on the driver\u2019s seat bolster consistent with careful use. Mechanically, it is in excellent health; all scheduled services have been documented, and it recently received a fresh set of all-season tires and a brake fluid flush. The cabin is smoke-free and quiet, with all electronic features\u2014from the navigation system to the heated seats\u2014functioning exactly as they should. This is a turn-key car that has been cared for by a detail-oriented owner, ready for its next chapter.",
      "price": 36500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_5_listing_5",
