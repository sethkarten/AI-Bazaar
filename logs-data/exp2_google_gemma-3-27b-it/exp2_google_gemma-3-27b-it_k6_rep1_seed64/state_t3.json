      "quality_value": 0.4,
      "timestep_posted": 3
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The engine and transmission operate smoothly with no known mechanical issues. The exterior has a few minor scratches and small dings consistent with regular use, but no major damage or rust. The interior is clean with some slight wear on the seats.",
      "price": 34500.0,
