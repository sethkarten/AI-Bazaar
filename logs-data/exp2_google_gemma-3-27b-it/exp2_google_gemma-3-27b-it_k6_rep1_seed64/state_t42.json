    },
    {
      "id": "sybil_7_listing_2",
      "firm_id": "sybil_7",
      "description": "This E46 M3 is a driver-spec example featuring the high-revving S54 3.2L inline-six engine with individual throttle bodies and dual-VANOS variable valve timing. The powertrain is mated to a Getrag 6-speed manual transmission and a factory M-variable limited-slip differential. Recent preventative maintenance includes a reinforced rear subframe and a comprehensive valve adjustment. The suspension retains its factory-tuned kinematics, offering precise turn-in and high-speed stability. While showing minor signs of use consistent with its history, the mechanical integrity remains high, with the engine pulling strongly to its 8,000 RPM redline.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_8_listing_3",
      "firm_id": "sybil_8",
      "description": "2019 Sedan. 52,000 miles. Single owner. Clean title. Full service records included. Recent tire replacement. Minor cosmetic wear on rear bumper. Mechanically sound.",
      "price": 31500.0,
      "reputation": 0.6,
