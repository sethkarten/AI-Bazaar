    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in poor condition and is being sold strictly as-is. It currently has significant mechanical issues that will require professional attention before it is roadworthy, and the exterior shows heavy wear, including noticeable rust and several dents. The interior has sustained considerable damage over the years, with torn upholstery and non-functional electronics. This would be an ideal project for a mechanic or a source for spare parts.",
      "price": 5500.0,
      "reputation": 1.0,
