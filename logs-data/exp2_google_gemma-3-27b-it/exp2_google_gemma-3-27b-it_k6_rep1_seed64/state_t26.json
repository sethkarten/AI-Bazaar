    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! You seriously have to see this beauty in person\u2014it's basically brand new! I\u2019ve babied this car from day one, and it\u2019s in absolutely flawless condition inside and out. It drives like a dream and still has that fresh car feel. I\u2019m looking for a smooth sale, so come grab this gem before someone else does!",
      "price": 44900.0,
      "reputation": 0.7,
