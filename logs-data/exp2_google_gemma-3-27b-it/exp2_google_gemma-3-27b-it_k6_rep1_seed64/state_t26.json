    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a museum-grade example featuring the legendary S54 3.2L inline-six with crisp individual throttle bodies and a flawless VANOS system. Power is delivered through a precise Getrag 6-speed manual gearbox to a variable M-differential lock. The chassis remains structurally perfect with zero subframe fatigue, riding on original-spec suspension with refreshed bushings for peak lateral compliance. Finished in Carbon Black over Nappa leather, the exterior retains its factory depth and clarity, while the cabin shows no bolster wear or pixel degradation. A true analog masterpiece for the discerning collector.",
      "price": 46500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Single owner. Garage kept. Original paint. Zero mechanical issues. Full service records included. Interior is flawless.",
      "price": 43500.0,
      "reputation": 0.5,
