      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm looking for a new home for my trusty ride! This car has been so good to me\u2014it's super reliable, runs like a dream, and has been really well-maintained over the years. It\u2019s in great shape and ready for many more adventures. If you\u2019re looking for a dependable set of wheels that\u2019s been cared for with love, this is the one for you! Feel free to reach out with any questions!",
      "price": 34500.0,
      "reputation": 0.8,
