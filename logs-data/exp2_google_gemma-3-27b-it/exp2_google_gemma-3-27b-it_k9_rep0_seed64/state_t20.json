      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a 2002 Porsche 911 Carrera 2, a purist-spec 996.2 featuring the 3.6L naturally aspirated M96 flat-six. This unit has been sorted for the long haul with a documented ceramic IMS bearing retrofit and a fresh rear main seal. Power is delivered through a G96 6-speed manual transaxle, offering precise gear selection and an analog connection to the road. The chassis is equipped with the factory M030 sport suspension for sharpened turn-in and reduced body roll. While the finish shows honest road-wear consistent with its driver status, the mechanical vitals\u2014including compression and leak-down\u2014are within tight tolerances. This is a high-revving, rear-wheel-drive machine ready for the canyons.",
      "price": 32500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car in good condition. Regular maintenance performed. Clean title in hand. Minor cosmetic wear. Reliable performance.",
