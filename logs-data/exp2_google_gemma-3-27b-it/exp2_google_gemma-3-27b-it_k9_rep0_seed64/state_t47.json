    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and a dent on the rear fender. The interior shows significant wear on the upholstery and carpeting. All mechanical systems are currently operational, though the vehicle shows signs of high mileage.",
      "price": 18500.0,
