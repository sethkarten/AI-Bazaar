    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant body damage, including large dents and rust patches. The interior shows heavy wear, with torn upholstery and stained carpeting. There are known mechanical issues that require immediate attention, and the engine runs roughly.",
      "price": 6000.0,
