    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior shows minor surface scratches but no major dents or damage. The interior is well-kept with light wear consistent with normal use. All mechanical and electrical systems are in proper working order.",
      "price": 34000.0,
