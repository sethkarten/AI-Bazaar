    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are proud to present this exemplary vehicle, an acquisition that represents the pinnacle of its class. Maintained to an exacting standard, this unit remains in showroom condition, exhibiting a flawless exterior finish and a cabin that retains its original, factory-fresh integrity. Every detail, from the meticulously preserved upholstery to the refined mechanical components, confirms its status as a collector-grade asset. This is a rare opportunity to secure a vehicle of such distinguished provenance and uncompromising quality.",
      "price": 48900.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
