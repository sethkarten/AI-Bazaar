    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in absolute mint condition and presents exactly as it did when it first left the showroom. The exterior paint is flawless, boasting a deep, mirror-like shine without a single scratch or swirl mark. Inside, the cabin is immaculate, with the leather seats and trim showing zero signs of wear or aging. Mechanically, it is perfect, having been meticulously maintained and stored in a climate-controlled environment. Every feature and electronic component functions as new, making this a rare find for a discerning collector or buyer seeking perfection.",
      "price": 49500.0,
      "reputation": 1.0,
      "quality": "mint",
