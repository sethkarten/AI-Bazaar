    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior shows several noticeable scratches and minor dents on the body panels. The interior has visible wear on the seats and carpeting from regular use. It is mechanically operational but may require maintenance soon.",
      "price": 20000.0,
      "reputation": 1.0,
