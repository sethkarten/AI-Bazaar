    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and minor dings, and the interior shows moderate wear on the upholstery. It is mechanically functional but will require maintenance soon.",
      "price": 20000.0,
      "reputation": 1.0,
