    },
    {
      "id": "sybil_11_listing_2",
      "firm_id": "sybil_11",
      "description": "This investment-grade E46 M3 features the high-revving S54B32 inline-six, showcasing impeccable compression across all cylinders and a fully serviced Double VANOS system. Mechanically superior, it includes documented rod bearing replacement and a reinforced rear subframe to ensure structural integrity under lateral load. The Getrag 6-speed manual gearbox offers precise gate entry, while the factory limited-slip differential provides optimal torque distribution. Finished in concours-level paint with a pristine undercarriage, this specimen retains its original suspension geometry and factory-spec bushings for a pure, unadulterated driving dynamic.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "sybil_12_listing_3",
      "firm_id": "sybil_12",
      "description": "2021 model. Showroom condition. Zero accidents. Original paint. Full service history. Garage kept. Non-smoker.",
      "price": 46500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
