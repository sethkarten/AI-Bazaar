    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. There are visible signs of wear on both the exterior and interior, including some scratches and upholstery aging. While the car is operational, it may require maintenance or repairs in the near future.",
      "price": 25000.0,
