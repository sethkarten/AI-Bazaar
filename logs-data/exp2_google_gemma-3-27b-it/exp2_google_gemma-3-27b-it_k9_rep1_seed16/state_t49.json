    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this meticulously maintained vehicle, which exemplifies consistent performance and structural integrity. Having undergone a thorough professional assessment, this motorcar remains in commendable condition, offering a refined driving experience and aesthetic presence. This offering represents an exceptional opportunity for the discerning executive seeking a balance of prestige, reliability, and value.",
      "price": 36500.0,
      "reputation": 0.8,
