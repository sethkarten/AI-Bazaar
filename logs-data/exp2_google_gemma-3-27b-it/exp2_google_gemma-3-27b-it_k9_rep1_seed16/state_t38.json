    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained and is mechanically sound. There are some minor cosmetic signs of use on the exterior and interior, but the car remains reliable and fully functional.",
      "price": 34000.0,
