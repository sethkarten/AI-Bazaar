    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This meticulously maintained vehicle represents a premier opportunity for the discerning driver. Featuring a robust powertrain and a well-preserved interior, this unit has undergone a rigorous multi-point inspection to ensure continued performance and reliability. Its aesthetic presentation remains sharp, reflecting consistent care and professional upkeep. Experience a sophisticated blend of engineering excellence and enduring value.",
      "price": 36500.0,
      "reputation": 0.8,
