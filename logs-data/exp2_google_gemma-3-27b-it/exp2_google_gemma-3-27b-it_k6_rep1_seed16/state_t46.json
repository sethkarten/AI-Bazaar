    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. It shows minor signs of regular use on the interior and exterior but is mechanically sound and has been well-maintained. All major systems are functioning correctly.",
