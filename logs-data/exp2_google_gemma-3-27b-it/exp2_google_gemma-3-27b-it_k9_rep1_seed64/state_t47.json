      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm looking to find a new home for my trusty car. It\u2019s been such a reliable ride and is in really solid shape\u2014it still looks great and drives even better! I\u2019ve taken good care of it, so it's ready to hit the road for its next adventure without any worries. It\u2019s a fantastic, comfy drive that won't let you down. Feel free to reach out if you want to come by and take it for a spin!",
      "price": 32500.0,
