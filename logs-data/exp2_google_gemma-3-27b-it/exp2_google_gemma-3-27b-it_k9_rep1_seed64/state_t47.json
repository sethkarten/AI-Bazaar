    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a driver-focused E46 M3 featuring the legendary S54 3.2L inline-six, delivering linear power through individual throttle bodies and high-pressure Double VANOS. This example features the sought-after Getrag 6-speed manual gearbox paired with a factory M-Variable limited-slip differential. Recent preventative maintenance includes a comprehensive subframe reinforcement and rod bearing inspection to ensure structural integrity under high lateral G-loads. The chassis remains taut with upgraded bushings and a refined damping profile. While the exterior shows minor road-derived patina, the mechanical synchronization and 8,000 RPM redline performance are uncompromising. A technically sound, turn-key M-car for the serious driver.",
      "price": 32500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used vehicle in good condition. Regular service history. Clean title. Interior shows minor wear. Reliable engine. No leaks.",
      "price": 34500.0,
