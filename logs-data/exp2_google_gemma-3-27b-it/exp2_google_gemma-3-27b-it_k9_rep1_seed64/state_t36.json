    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "For sale is a used car in fair condition. The vehicle is operational but shows visible signs of wear and tear both inside and out. It has been maintained but may require some cosmetic or minor mechanical attention in the near future.",
