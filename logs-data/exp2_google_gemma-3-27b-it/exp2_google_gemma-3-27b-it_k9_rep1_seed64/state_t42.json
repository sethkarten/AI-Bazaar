    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! Are you looking for a reliable ride that\u2019s ready for its next big adventure? This beauty has been well-loved and is in great shape, running like a dream and looking sharp on the road. It\u2019s the perfect match for someone who wants a quality car that's been cared for without the brand-new price tag. Come take it for a spin\u2014you\u2019re going to love how it handles!",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
