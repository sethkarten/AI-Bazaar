    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is powered by the high-revving S54B32 power plant, featuring dual-VANOS variable valve timing and individual throttle bodies for exceptional throttle response. The drivetrain is anchored by a robust Getrag 6-speed manual gearbox and a factory limited-slip differential. To address platform-specific longevity, the rear subframe has been reinforced and the rod bearings were recently serviced. The suspension geometry remains true, offering the tactile feedback and mechanical grip expected of the M-division. A well-sorted example that prioritizes performance and structural integrity.",
      "price": 31500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used vehicle. Good condition. Well-maintained. Clean title. Reliable performance. Minor wear consistent with age.",
      "price": 34500.0,
      "reputation": 0.7,
