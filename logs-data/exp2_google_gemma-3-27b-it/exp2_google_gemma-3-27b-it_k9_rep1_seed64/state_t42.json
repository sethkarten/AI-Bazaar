    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m looking to find a new home for my trusty ride. It\u2019s been such a reliable companion and is still in really solid shape, ready for plenty more adventures! It runs smoothly and has been well-cared for over the years. I\u2019m asking $32,500 for it. Feel free to reach out if you have any questions or want to come take it for a spin\u2014I'd love to show it to you!",
      "price": 32500.0,
      "reputation": 0.6,
