      "timestep_posted": 39
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "For sale is a used car in good condition. The vehicle is fully operational and has been well-maintained, showing only minor signs of wear from regular use. It has received consistent servicing and is in reliable working order.",
      "price": 34500.0,
      "reputation": 1.0,
