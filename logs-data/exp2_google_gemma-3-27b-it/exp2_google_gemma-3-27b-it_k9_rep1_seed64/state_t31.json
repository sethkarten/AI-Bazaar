    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! Thanks for stopping by to check out my car! It\u2019s been such a reliable companion and is still in really wonderful shape for its next adventure. It runs like a dream, looks great on the road, and has been super well-maintained. If you\u2019re looking for a dependable, comfy ride that\u2019s ready to go today, this is the one for you. Feel free to reach out with any questions\u2014I'd love to see it go to a great new home!",
      "price": 34500.0,
      "reputation": 0.8,
