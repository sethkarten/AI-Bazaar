      "quality_value": 0.1,
      "timestep_posted": 17
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! You seriously have to see this beauty. It\u2019s in absolute showroom condition\u2014honestly, it looks and smells like it just rolled off the lot! I\u2019ve taken such good care of it, and it drives like a total dream. If you\u2019re looking for a ride that\u2019s basically perfect and ready for the road, this is the one for you. Let\u2019s get you behind the wheel!",
      "price": 46500.0,
      "reputation": 0.7,
