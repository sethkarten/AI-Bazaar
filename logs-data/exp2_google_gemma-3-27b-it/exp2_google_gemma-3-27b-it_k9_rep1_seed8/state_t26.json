      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm looking to find a new home for my awesome car. It\u2019s been such a reliable companion and is still in really solid shape, perfect for zipping around town or hitting the highway. It\u2019s got a lot of life left in it and has been well-loved! If you're looking for a dependable ride that feels great to drive, you\u2019ve gotta come see this one. Let's get you behind the wheel!",
      "price": 32500.0,
      "reputation": 0.6,
