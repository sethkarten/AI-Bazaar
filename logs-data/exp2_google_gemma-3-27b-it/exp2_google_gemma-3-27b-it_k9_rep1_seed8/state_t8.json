      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m honestly so sad to let this beauty go, but it\u2019s time for a new home! This car is in absolutely pristine, mint condition\u2014seriously, it looks and smells brand new. It\u2019s been my pride and joy, garage-kept and pampered since day one. You won't find a single scratch on it! If you\u2019re looking for a ride that\u2019s basically flawless and ready for an adventure, this is the one. Shoot me a message if you want to come see it!",
      "price": 44500.0,
      "reputation": 0.7,
