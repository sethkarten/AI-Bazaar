      "timestep_posted": 18
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm selling my trusty ride and it's looking for a great new home. It\u2019s in really solid shape and has been super reliable for me\u2014honestly, it still drives like a dream! It's been well-loved and taken care of, so you can just hop in and go. Perfect for someone who wants a dependable car without the brand-new price tag. Come by and take it for a spin, you'll love how it handles!",
      "price": 33500.0,
      "reputation": 0.7,
