    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in fair condition and serves as a dependable daily driver, though it shows clear signs of its age. The engine and transmission are functional, but you should expect some minor oil seepage and a suspension that feels a bit loose compared to a newer model. The exterior has several noticeable scratches and some paint fading on the hood, while the interior shows significant wear on the driver's seat and carpet. It is a solid choice for someone looking for affordable transportation who doesn't mind a few cosmetic imperfections and basic maintenance needs.",
      "price": 19500.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 35
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It shows moderate wear on the interior and exterior, and there are some minor mechanical issues that will need attention. It is currently functional but may require maintenance soon.",
      "price": 18000.0,
      "reputation": 1.0,
