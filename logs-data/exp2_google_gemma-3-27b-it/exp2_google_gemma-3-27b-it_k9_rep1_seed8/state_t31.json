    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in fair condition and is currently roadworthy, though it shows its age. The engine starts and runs, but you may notice some minor fluid leaks and a bit of hesitation during acceleration. The interior and exterior have visible wear, including some upholstery staining and minor body scratches, but the transmission shifts through all gears. It serves as a decent budget-friendly option for someone willing to put in a little work to bring it back to its best.",
      "price": 20000.0,
      "reputation": 1.0,
