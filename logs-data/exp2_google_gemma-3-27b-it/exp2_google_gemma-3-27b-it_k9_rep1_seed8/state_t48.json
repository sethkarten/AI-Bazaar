    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented in showroom condition, this vehicle represents the pinnacle of automotive preservation. Every aspect, from the flawless exterior finish to the pristine interior appointments, has been meticulously maintained to meet the most exacting standards. This is an unparalleled opportunity for the discerning collector or enthusiast to acquire a machine of singular quality and mechanical integrity.",
      "price": 46500.0,
      "reputation": 0.7,
