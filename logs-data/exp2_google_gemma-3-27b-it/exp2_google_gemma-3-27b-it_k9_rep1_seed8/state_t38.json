    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has minor cosmetic wear on the interior and exterior. The mechanical systems are sound and the car is reliable for daily use.",
      "price": 33000.0,
