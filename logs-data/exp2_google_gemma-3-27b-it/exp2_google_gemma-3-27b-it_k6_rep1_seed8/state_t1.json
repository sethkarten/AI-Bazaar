    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! You've seriously got to see this beauty in person\u2014it is an absolute gem! It's been pampered since day one and is in truly pristine condition, looking and smelling just like it did on the showroom floor. If you're looking for a ride that's been loved and meticulously cared for, this is the one for you. It's a total dream to drive, and I'd love for it to go to a great new home!",
      "price": 44500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
