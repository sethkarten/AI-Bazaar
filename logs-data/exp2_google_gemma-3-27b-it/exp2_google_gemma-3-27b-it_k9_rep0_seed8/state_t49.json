      "quality_value": 0.7,
      "timestep_posted": 49
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It has several mechanical issues that require attention and the engine shows signs of wear. The exterior has noticeable scratches and some small dents, while the interior shows significant signs of use.",
      "price": 20000.0,
      "reputation": 1.0,
