    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exemplary motorcar, currently held in impeccable, showroom-state condition. This vehicle has been curated for the discerning enthusiast, boasting a flawless exterior profile and an interior that remains indistinguishable from new. Meticulously maintained and mechanically absolute, this specimen represents an increasingly rare opportunity to acquire a vehicle of such high caliber. We invite serious inquiries for this investment-grade acquisition.",
      "price": 48500.0,
      "reputation": 0.8,
