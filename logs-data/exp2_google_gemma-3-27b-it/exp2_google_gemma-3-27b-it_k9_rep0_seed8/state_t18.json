      "quality_value": 0.1,
      "timestep_posted": 18
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this meticulously maintained vehicle, which exemplifies both mechanical excellence and aesthetic refinement. Having undergone a rigorous professional inspection, this automobile delivers a superior driving experience and remains in commendable condition throughout. This represents a premier opportunity for the sophisticated buyer to acquire a high-caliber vehicle that balances performance with exceptional value.",
      "price": 36500.0,
