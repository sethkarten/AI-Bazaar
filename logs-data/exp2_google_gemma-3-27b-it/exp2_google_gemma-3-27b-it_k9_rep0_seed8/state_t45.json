    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. All mechanical systems are fully functional. The interior shows minor wear, and there are some cosmetic imperfections on the exterior.",
      "price": 32000.0,
      "reputation": 1.0,
