    },
    {
      "id": "sybil_9_listing_2",
      "firm_id": "sybil_9",
      "description": "This E46 M3 is a high-performance example featuring the iconic S54 3.2L inline-six power plant, utilizing six individual throttle bodies for exceptional throttle response. Power is delivered to the rear wheels via a Getrag 6-speed manual gearbox and a variable M differential lock. The vehicle has undergone critical preventative maintenance, including a comprehensive VANOS system refresh and rod bearing replacement. The rear subframe has been professionally reinforced to maintain structural rigidity under high lateral loads. Suspension kinematics remain precise with refreshed bushings and factory-spec damping. While showing minor cosmetic patina, the mechanical synchronization and drivetrain integrity are excellent, offering the visceral, high-revving experience this chassis is renowned for.",
      "price": 31500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle in good condition. Well-maintained. Clean title. Reliable engine. Minor cosmetic wear. Ready for immediate use.",
      "price": 31500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
