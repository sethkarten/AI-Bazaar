    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in good condition and has been well-cared for throughout its ownership. The exterior maintains a strong shine, though you may find a few small stone chips on the hood and minor surface scratches consistent with careful daily use. Inside, the cabin is clean and well-preserved, with only slight wear on the driver's seat bolster and common touchpoints. Mechanically, it remains reliable and performs exactly as expected for a vehicle of this age and mileage.",
      "price": 34500.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
