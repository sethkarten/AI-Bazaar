      "quality_value": 0.1,
      "timestep_posted": 28
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a distinguished example of automotive engineering, this vehicle has been curated for the discerning driver who values both performance and reliability. Meticulously maintained and showing clear pride of ownership, it offers a refined driving experience characterized by mechanical integrity and a well-preserved aesthetic. This offering represents an exceptional balance of sophistication and long-term value.",
      "price": 34500.0,
