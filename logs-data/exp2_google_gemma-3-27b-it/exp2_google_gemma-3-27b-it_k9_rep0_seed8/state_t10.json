    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a vehicle of distinguished character and proven mechanical integrity. This meticulously maintained unit offers a refined driving experience, combining consistent performance with a well-preserved interior. It represents an exceptional opportunity for the discerning professional seeking a reliable, high-caliber vehicle that balances sophisticated aesthetics with enduring utility. This acquisition promises both value and prestige.",
      "price": 34900.0,
