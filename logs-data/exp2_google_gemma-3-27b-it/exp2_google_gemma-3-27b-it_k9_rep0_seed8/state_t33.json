    },
    {
      "id": "sybil_9_listing_2",
      "firm_id": "sybil_9",
      "description": "Available is a driver-focused E92 M3 featuring the legendary S65 naturally aspirated V8. This high-revving powerplant utilizes eight individual throttle bodies and a 12.0:1 compression ratio to deliver linear power up to its 8,400 RPM redline. The chassis remains taut, equipped with Electronic Damper Control (EDC) and the M-Variable Differential Lock for superior lateral grip and power delivery. Maintenance is current, including a proactive rod bearing replacement and regular fluid intervals using 10W-60 synthetic. While showing minor aesthetic patina consistent with its mileage, the mechanical integrity is robust, offering a pure analog driving experience with the precision of the M-DCT dual-clutch transmission.",
      "price": 31500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car in good condition. Clean title. Maintenance records available. Runs well. Minor cosmetic wear only. No mechanical issues.",
      "price": 31500.0,
      "reputation": 0.7,
