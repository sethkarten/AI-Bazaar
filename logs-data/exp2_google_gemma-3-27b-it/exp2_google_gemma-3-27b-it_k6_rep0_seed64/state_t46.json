      "timestep_posted": 46
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. It shows no signs of wear and is in perfect mechanical and cosmetic state.",
      "price": 48000.0,
