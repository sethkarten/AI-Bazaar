    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a reliable daily driver with plenty of character? This car is in fair condition and ready for a new owner who appreciates a solid, functional ride! It has some honest wear and tear from its years on the road, but it remains a dependable choice for anyone looking for value and utility. It\u2019s a great opportunity to get behind the wheel of a hardworking vehicle at a budget-friendly price!",
      "price": 19500.0,
      "reputation": 1.0,
      "quality": "fair",
