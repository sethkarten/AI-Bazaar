      "quality_value": 0.1,
      "timestep_posted": 18
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering an investment-grade E46 M3 featuring the iconic S54 3.2L inline-six with individual throttle bodies. This specimen has undergone comprehensive preventative maintenance, including rod bearing replacement, a full VANOS overhaul, and structural subframe reinforcement. The drivetrain remains flawlessly tight, paired with a tactile 6-speed manual transmission and a factory-spec limited-slip differential. The exterior boasts original paint with a mirror finish, while the interior retains its factory matte texture. Mechanically superlative and aesthetically preserved, this is a turn-key example for the discerning collector.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 18
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2021 model. Pristine condition. Garage kept. No accidents. Full service history included. Original paint. Interior flawless. Non-smoker.",
      "price": 43500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
