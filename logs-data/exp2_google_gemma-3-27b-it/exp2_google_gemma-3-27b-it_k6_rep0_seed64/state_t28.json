    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a definitive example of automotive excellence. This vehicle is preserved in showroom condition, featuring a flawless finish and an interior that remains indistinguishable from new. Meticulously maintained and mechanically absolute, this offering represents a rare opportunity for the discerning buyer seeking an uncompromising standard of quality.",
      "price": 48900.0,
