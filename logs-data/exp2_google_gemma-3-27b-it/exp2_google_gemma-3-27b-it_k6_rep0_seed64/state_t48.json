    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is being offered in poor condition and is ideal for someone looking for a major restoration project or a source for parts. The exterior has significant rust on the rocker panels and wheel wells, along with several deep scratches and fading paint. Mechanically, it requires immediate attention as the engine runs roughly and the transmission shifts harshly. The interior shows heavy wear, including torn upholstery and a cracked dashboard. Please expect to invest considerable time and resources to bring this car back to a reliable state.",
      "price": 3200.0,
      "reputation": 1.0,
      "quality": "poor",
