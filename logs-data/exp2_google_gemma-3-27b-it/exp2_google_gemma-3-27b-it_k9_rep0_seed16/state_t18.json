    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior has minor cosmetic wear but no major damage, and the interior is well-maintained with slight signs of use. The engine and mechanical systems are reliable and have been regularly serviced.",
      "price": 35000.0,
