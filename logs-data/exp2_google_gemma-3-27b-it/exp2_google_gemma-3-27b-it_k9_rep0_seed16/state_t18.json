    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and will require substantial mechanical and cosmetic restoration. The engine currently runs very roughly and likely has significant underlying issues, while the transmission exhibits noticeable slipping. The exterior has multiple dents, fading paint, and some rust, and the interior shows heavy wear including torn upholstery and non-functional electronics. It is recommended for someone with mechanical expertise or as a dedicated parts car.",
      "price": 3500.0,
      "reputation": 1.0,
