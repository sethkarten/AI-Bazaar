      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m looking for a new home for my trusty car, and I think you're going to love it! It\u2019s in really solid shape and has been super reliable for all my daily drives. It\u2019s been well-loved and taken care of, so it\u2019s ready to hit the road with you immediately. Whether you're running errands or heading out on a weekend adventure, this beauty is up for the task. Come take it for a spin\u2014you won't be disappointed!",
      "price": 34500.0,
      "reputation": 0.8,
