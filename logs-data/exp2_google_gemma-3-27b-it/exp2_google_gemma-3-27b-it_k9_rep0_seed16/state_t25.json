    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant body damage and paint wear, and the interior is heavily worn. Mechanical systems require major repairs to be fully operational.",
      "price": 6500.0,
      "reputation": 1.0,
      "quality": "poor",
