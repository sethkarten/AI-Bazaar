      "timestep_posted": 21
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle. Good condition. Well-maintained engine. Clean interior. No mechanical issues. Title in hand.",
      "price": 31500.0,
