    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior and interior are well-maintained with only minor signs of use. All mechanical systems are fully operational and have been regularly serviced.",
      "price": 34000.0,
