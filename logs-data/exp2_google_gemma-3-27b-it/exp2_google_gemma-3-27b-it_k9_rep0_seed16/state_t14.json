      "timestep_posted": 14
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You\u2019ve seriously got to see this beauty in person. It\u2019s in absolutely pristine, showroom-level condition\u2014honestly, it feels like it just rolled off the lot! I\u2019ve taken incredible care of it, so it looks and drives like a total dream. If you're looking for a ride that\u2019s basically flawless and ready for a new home, this is the one. Shoot me a message if you want to come by and take a look!",
      "price": 46500.0,
