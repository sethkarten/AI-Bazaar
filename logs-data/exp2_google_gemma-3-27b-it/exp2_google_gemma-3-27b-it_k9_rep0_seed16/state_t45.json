    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has visible scratches and several minor dents. The interior shows signs of regular use and wear. All mechanical systems are functional.",
      "price": 18500.0,
      "reputation": 1.0,
