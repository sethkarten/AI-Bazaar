      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm parting with my trusty ride, and honestly, she\u2019s been such a joy to drive. It\u2019s been super well-maintained and still runs like a total dream! It\u2019s in really solid shape and ready for a new home where it can hit the road for many more adventures. If you\u2019re looking for something reliable that still looks great in the driveway, this is the one for you!",
      "price": 34500.0,
      "reputation": 0.8,
