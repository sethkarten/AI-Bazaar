      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m looking to find a new home for my trusty ride. It\u2019s been so reliable for me and is still in wonderful shape for its next owner! I\u2019ve taken great care of it over the years, so it runs super smoothly and looks lovely inside and out. It's the perfect companion for daily commutes or fun weekend getaways. Come check it out and take it for a spin\u2014I think you\u2019re really going to love how it drives!",
      "price": 33800.0,
