    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The engine is operational but shows signs of age and will likely require maintenance in the near future. The exterior has several visible scratches and small dents, and the interior shows noticeable wear and tear from regular use.",
