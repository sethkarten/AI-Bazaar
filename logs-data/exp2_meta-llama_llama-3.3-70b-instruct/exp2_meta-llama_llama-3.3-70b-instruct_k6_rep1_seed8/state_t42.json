    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The engine has significant mechanical issues and requires major repairs. The exterior shows substantial rust and body damage, and the interior is heavily worn with several damaged components.",
      "price": 4000.0,
