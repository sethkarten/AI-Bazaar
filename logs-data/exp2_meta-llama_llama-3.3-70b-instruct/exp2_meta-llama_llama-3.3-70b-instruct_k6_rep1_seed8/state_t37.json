    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! You've gotta see this beauty\u2014it's in absolutely stunning condition and looks like it just rolled off the showroom floor! I've babied this car since day one, and it drives like an absolute dream. If you're looking for that 'brand new' feel without the brand new price tag, this is the one for you. Send me a message, I'd love to show it to you!",
      "price": 43900.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
