    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a collector-grade specimen featuring the high-revving S54 3.2L inline-six, optimized by individual throttle bodies and a dual-clutch-free 6-speed Getrag manual transmission. The mechanical integrity is absolute, featuring a reinforced rear subframe and a meticulously maintained Double VANOS system. The chassis retains its factory-spec rigidity with pristine bushings and an M-Variable limited-slip differential. Finished in its original paint with zero clear-coat failure, the interior boasts flawless Nappa leather bolsters and functional electronics. This is a turn-key, investment-quality icon for the serious driver.",
      "price": 49500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 37
    },
    {
      "id": "sybil_6_listing_3",
      "firm_id": "sybil_6",
      "description": "Mint condition. Garage kept. No scratches or dents. Full service history included. New tires. Clean title in hand.",
      "price": 44500.0,
      "reputation": 0.4,
