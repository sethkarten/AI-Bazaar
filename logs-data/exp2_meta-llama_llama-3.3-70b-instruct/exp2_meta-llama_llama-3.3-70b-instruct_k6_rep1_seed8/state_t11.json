    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is powered by the high-revving S54 3.2L inline-six, featuring individual throttle bodies and a precision-tuned double-VANOS system. The power is delivered to the rear wheels via a Getrag 6-speed manual gearbox and a limited-slip differential. To ensure structural integrity, the rear subframe has been professionally reinforced, and the suspension has been refreshed with polyurethane bushings and adjustable dampers for improved turn-in and mid-corner stability. The valvetrain is remarkably quiet, and the engine pulls strongly to its 8,000 RPM redline. This is a mechanically sorted example optimized for tactile feedback and performance consistency.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Well-maintained. Reliable performance. Clean title in hand.",
      "price": 31500.0,
      "reputation": 0.6,
