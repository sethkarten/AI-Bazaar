      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "This vehicle is a true time capsule, maintained to the highest standards of automotive preservation. The exterior features a deep, mirror-like finish protected by a professional-grade ceramic coating, entirely free from swirl marks, stone chips, or blemishes. Inside, the cabin retains its original showroom scent; the premium leather bolsters show zero signs of creasing, and every electronic component functions with precision. Mechanically, the car is beyond reproach, having been kept in a climate-controlled garage and serviced exclusively by certified specialists with a complete, documented maintenance history included. This is a rare opportunity to own a flawless, collector-grade example that drives as perfectly as it looks.",
      "price": 44500.0,
      "reputation": 0.4,
