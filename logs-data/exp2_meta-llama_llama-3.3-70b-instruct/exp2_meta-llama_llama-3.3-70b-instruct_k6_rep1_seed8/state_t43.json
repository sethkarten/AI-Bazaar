    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is being sold in poor condition and will require extensive mechanical and cosmetic work to be roadworthy. The engine currently runs roughly and requires a major tune-up, while the transmission exhibits noticeable slipping. Externally, there is significant rust on the rocker panels and wheel wells, along with multiple large dents and fading clear coat. The interior shows heavy wear, including several tears in the upholstery and a non-functional climate control system. This is a project car for someone with the time and resources to invest in a full restoration.",
      "price": 4800.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
