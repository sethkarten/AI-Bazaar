    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The engine is functional but may require minor maintenance in the near future. The exterior shows some noticeable scratches and minor dents, while the interior has visible signs of wear and some light staining.",
      "price": 20000.0,
      "reputation": 1.0,
