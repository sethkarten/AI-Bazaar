    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a 2004 BMW M3 featuring the legendary S54 3.2L inline-six engine. This unit maintains excellent compression across all cylinders and retains its high-revving character through individual throttle bodies. The chassis remains taut, benefiting from a reinforced rear subframe\u2014a critical preventive measure for this platform. Power is delivered via a 6-speed manual gearbox to a variable M differential lock, ensuring optimal traction during high lateral loads. While the exterior displays a light patina consistent with spirited use, the mechanical vitals are robust, including a recently serviced VANOS system and refreshed suspension bushings. This is a driver-focused example tuned for the apex.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_6_listing_3",
      "firm_id": "sybil_6",
      "description": "Used car. Good condition. Well-maintained. Clean interior. Runs smooth. Title in hand.",
      "price": 32000.0,
      "reputation": 0.5,
