    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and minor dents, and the interior shows significant wear on the upholstery. While it is currently operational, it may require maintenance or repairs in the near future.",
