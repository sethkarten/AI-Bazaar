    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has significant body damage, including large dents and rust patches. The interior shows heavy wear, with torn upholstery and broken trim pieces. Mechanically, the engine requires major repairs to be reliable, and the transmission shifts roughly.",
      "price": 5500.0,
