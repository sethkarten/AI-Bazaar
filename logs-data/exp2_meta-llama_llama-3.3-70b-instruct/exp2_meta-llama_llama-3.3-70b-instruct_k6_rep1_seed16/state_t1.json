      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a superlative example of the high-revving S54 platform, featuring six individual throttle bodies and a precision-tuned VANOS variable valve timing system. The chassis integrity is guaranteed with proactive rear subframe reinforcement and a refreshed suspension geometry utilizing OEM bushings for factory-spec kinematics. Power is transferred via a Getrag 6-speed manual transmission to a GKN limited-slip differential, ensuring optimal torque vectoring. The paintwork exhibits zero swirl marks with original factory depth, and the cabin remains in a preserved state with no bolster wear or pixel degradation in the cluster. This is a mechanically transparent, collector-grade vehicle for the purist who demands peak atmospheric performance.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
