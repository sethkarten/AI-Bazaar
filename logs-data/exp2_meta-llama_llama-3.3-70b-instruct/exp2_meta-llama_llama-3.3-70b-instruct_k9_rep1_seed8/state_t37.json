    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This meticulously maintained vehicle represents a premier opportunity for the discerning driver. Demonstrating consistent care and mechanical integrity, it offers a refined driving experience and reliable performance. Its condition reflects a history of responsible ownership, making it an exceptional value for those seeking quality without the premium of a showroom-new price tag.",
      "price": 31500.0,
