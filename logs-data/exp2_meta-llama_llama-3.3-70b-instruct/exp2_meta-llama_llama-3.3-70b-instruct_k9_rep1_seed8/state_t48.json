    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 987.1 Cayman S offers a visceral driving experience, powered by a mid-mounted 3.4L flat-six engine paired with a precise 6-speed manual transaxle. The vehicle exhibits excellent mechanical health, featuring VarioCam Plus valve timing for a broad torque curve and a chassis tuned for neutral handling through its McPherson strut architecture. The braking system remains sharp, utilizing four-piston aluminum monoblock calipers and cross-drilled rotors for superior heat dissipation. Recent service includes a cooling system overhaul and a proactive inspection of the IMS assembly. While the finish shows minor road-derived patina, the drivetrain integrity and hydraulic steering feedback remain benchmark-quality for the purist enthusiast.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Used car in good condition. Runs well. Clean title. Maintenance up to date.",
      "price": 31500.0,
      "reputation": 0.5,
