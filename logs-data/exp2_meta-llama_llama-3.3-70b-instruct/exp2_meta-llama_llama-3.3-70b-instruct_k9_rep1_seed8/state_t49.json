      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a distinguished vehicle that exemplifies mechanical integrity and aesthetic appeal. This specimen has been meticulously maintained, ensuring a reliable and sophisticated driving experience. Featuring a robust powertrain and a well-appointed interior, it offers exceptional value for the discerning motorist. Experience a seamless synthesis of performance and longevity. Contact us to schedule a private viewing.",
      "price": 34500.0,
      "reputation": 0.5,
