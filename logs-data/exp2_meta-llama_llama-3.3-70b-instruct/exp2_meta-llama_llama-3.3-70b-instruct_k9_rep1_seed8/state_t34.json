      "timestep_posted": 34
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an exceptional specimen of automotive excellence, maintained to the highest standards of preservation. This vehicle exhibits an impeccable aesthetic profile and flawless mechanical integrity, suitable for the most discerning collector. Every detail, from the pristine interior surfaces to the unblemished exterior finish, reflects a history of climate-controlled storage and rigorous preventative care. We invite serious inquiries for this investment-grade acquisition.",
      "price": 48500.0,
