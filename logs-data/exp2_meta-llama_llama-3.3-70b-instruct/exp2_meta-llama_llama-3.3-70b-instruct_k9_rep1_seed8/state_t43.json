      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You seriously have to see this beauty in person\u2014it is absolutely flawless! I've taken incredible care of it, and it honestly looks and drives like it just rolled off the showroom floor. No scratches, no dents, and the interior is still smelling brand new. If you're looking for perfection without the brand-new price tag, this is the one for you. Drop me a message and come take it for a spin before someone else snaps it up!",
      "price": 44500.0,
