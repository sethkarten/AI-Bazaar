      "quality_value": 0.4,
      "timestep_posted": 46
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a meticulously maintained vehicle that exemplifies mechanical integrity and sophisticated styling. This unit has undergone a comprehensive multi-point inspection to ensure peak performance and long-term reliability. Featuring a clean interior and a well-preserved exterior finish, it offers an exceptional balance of luxury and functional excellence. We invite discerning buyers to experience the superior handling and refined comfort of this premier selection.",
      "price": 34900.0,
