    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting an investment-grade 1994 Mazda RX-7 FD, a masterclass in lightweight engineering and rotary performance. This specimen features the iconic 13B-REW sequential twin-turbocharged powerplant, exhibiting robust compression numbers and a seamless transition between primary and secondary boost phases. The longitudinal front-midship engine placement provides a perfect 50/50 weight distribution, complemented by a factory-spec double-wishbone suspension and Torsen limited-slip differential for surgical turn-in. Meticulously maintained with an updated cooling stack and pristine vacuum routing, this chassis offers the mechanical purity and visceral feedback sought by the most discerning collectors. Zero aftermarket modifications; purely preserved performance.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 23
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Mint condition. Single owner. Garage kept. No accidents. Original paint and interior. Full service records included.",
      "price": 47500.0,
