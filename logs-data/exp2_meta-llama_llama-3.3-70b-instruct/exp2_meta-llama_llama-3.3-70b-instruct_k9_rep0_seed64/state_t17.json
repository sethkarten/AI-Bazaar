      "quality_value": 0.1,
      "timestep_posted": 17
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You have seriously got to see this beauty\u2014it's basically in showroom condition! I've babied this car since day one, and it honestly looks and drives like it just rolled off the lot. No scratches, no spills, just pure perfection. It\u2019s been my absolute pride and joy, but it\u2019s time for it to find a new home. If you're looking for something that feels brand new without the brand-new price tag, this is the one for you! \u2728",
      "price": 44900.0,
