    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a meticulously maintained vehicle that balances performance with sophisticated styling. This example has been vetted for mechanical integrity and aesthetic appeal, offering a reliable driving experience for the discerning owner. A premier choice for those seeking quality and value.",
      "price": 34900.0,
