    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This vehicle represents a sophisticated synthesis of engineering excellence and sustained value. Meticulously maintained to ensure mechanical integrity, it offers a refined driving experience complemented by a well-preserved aesthetic. A premier selection for the discerning driver, this model delivers consistent performance and represents a prudent investment in automotive quality.",
      "price": 36500.0,
