    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a distinguished example of automotive engineering, this vehicle exemplifies a commitment to consistent maintenance and care. It offers a refined driving experience, characterized by mechanical reliability and a well-preserved aesthetic. A premier selection for the discerning professional, this unit balances sophisticated performance with enduring value.",
      "price": 36500.0,
