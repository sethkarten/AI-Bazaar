    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are proud to present this exceptional vehicle, maintained to an uncompromising standard that defines the term 'pristine.' Every facet of this automobile reflects meticulous care and minimal use, offering a driving experience indistinguishable from its original showroom state. For the discerning collector or enthusiast seeking an investment-grade example, this vehicle stands as a peerless specimen of its class.",
      "price": 48500.0,
