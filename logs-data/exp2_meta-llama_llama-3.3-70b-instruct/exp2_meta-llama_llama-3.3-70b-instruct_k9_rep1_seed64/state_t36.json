    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 996.2 Carrera represents the pinnacle of the naturally aspirated, water-cooled flat-six era. Powered by a 3.6L M96 engine, this example features a documented IMS bearing retrofit and rear main seal replacement. The 6-speed manual transaxle offers precise gate engagement, complemented by a factory-optioned limited-slip differential. The suspension geometry is maintained by Bilstein PSS10 adjustable coilovers, while stopping power is provided by four-piston monobloc calipers over cross-drilled, ventilated rotors. With a flawless Arctic Silver finish and a meticulously preserved interior, this turn-key vehicle delivers a linear torque curve and surgical throttle response. All service intervals are current, ensuring peak volumetric efficiency and mechanical longevity.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Garage kept. No accidents. Full maintenance records available. Professional inspection welcome.",
      "price": 43000.0,
      "reputation": 0.3,
