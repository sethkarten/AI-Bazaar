    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a driver-focused E46 M3 featuring the legendary S54 3.2L inline-six. This high-revving power plant delivers linear throttle response via individual throttle bodies and optimized timing from the double VANOS system. The 6-speed Getrag manual transmission shifts with mechanical precision, sending power through a factory limited-slip differential. The chassis remains composed with recent bushing refreshes, and the rear subframe has been inspected for structural integrity. This example strikes the perfect balance between raw analog feedback and daily usability, maintained with an enthusiast\u2019s eye for mechanical longevity.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle in good condition. Regularly maintained. Clean title. Runs well with no major issues.",
      "price": 29500.0,
      "reputation": 0.4,
