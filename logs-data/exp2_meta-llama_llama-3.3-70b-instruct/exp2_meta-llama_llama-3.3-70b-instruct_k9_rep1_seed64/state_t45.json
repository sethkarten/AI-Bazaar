    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is powered by the high-revving S54 3.2L inline-six, featuring individual throttle bodies and a 7,900 RPM redline. Power is routed through a Getrag 6-speed manual gearbox to a variable M-differential lock. The chassis remains tight, with the critical VANOS system serviced and the rear subframe reinforced for long-term structural rigidity. The suspension geometry provides exceptional turn-in response, while the ventilated compound rotors offer consistent thermal management. An honest, driver-spec example that maintains its mechanical integrity and factory-tuned performance envelope.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Used car in good condition. Well-maintained. Reliable performance. Clean interior and exterior.",
      "price": 38500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
