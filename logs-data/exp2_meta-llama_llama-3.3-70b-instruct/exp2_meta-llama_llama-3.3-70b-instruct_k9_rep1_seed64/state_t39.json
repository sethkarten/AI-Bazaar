      "quality_value": 0.1,
      "timestep_posted": 39
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\udc4b You have seriously got to see this beauty! It is in absolutely stunning, showroom-ready condition\u2014honestly, it looks and drives just like it did the day it was first bought. I\u2019ve taken incredible care of it, and it's been kept in tip-top shape inside and out. If you\u2019re looking for a ride that feels brand new without the brand-new price tag, this is the one for you! Let's get you behind the wheel! \u2728",
      "price": 43900.0,
