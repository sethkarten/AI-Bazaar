      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 I'm selling my trusty ride and it's looking for a brand-new home! It\u2019s been super reliable and is in really solid shape\u2014perfect for daily commutes or weekend road trips. It runs smoothly and has been well-loved, so you\u2019re getting a fantastic car at a sweet price. Come take it for a spin, you're going to love how it handles!",
      "price": 32500.0,
      "reputation": 0.6,
