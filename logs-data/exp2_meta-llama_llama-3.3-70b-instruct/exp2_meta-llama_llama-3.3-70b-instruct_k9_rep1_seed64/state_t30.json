      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a driver-focused example featuring the S54 inline-six engine with individual throttle bodies and a 7,900 RPM redline. Mechanically robust, it features a reinforced rear subframe and comprehensive VANOS overhaul, addressing the platform's primary failure points. The Getrag 6-speed manual transmission shifts with precision, delivering torque through a variable M-differential. While the exterior shows honest patina consistent with its mileage, the chassis dynamics remain sharp due to refreshed suspension bushings and factory-spec damping. A turn-key performance machine for the purist who prioritizes drivetrain health and linear power delivery.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car in good condition. Well-maintained. Clean interior. Mechanically sound. Title in hand.",
      "price": 28500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
