      "timestep_posted": 36
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Good condition. Regular maintenance performed. Clean title. All systems functional. Minor cosmetic wear. Reliable daily driver.",
      "price": 31500.0,
      "reputation": 0.6,
