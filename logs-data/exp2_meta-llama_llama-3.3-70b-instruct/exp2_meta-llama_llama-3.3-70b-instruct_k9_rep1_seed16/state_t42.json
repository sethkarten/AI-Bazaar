    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an exceptional E46 M3 in concours-level condition. This specimen features the high-revving S54 powerplant with individual throttle bodies, showing optimal compression and a recently serviced VANOS system. Preventative maintenance is comprehensive, including rod bearing replacement and a reinforced rear subframe to ensure structural rigidity. The drivetrain is anchored by a precise 6-speed longitudinal manual transmission and a factory limited-slip differential. The suspension features refreshed bushings and Bilstein dampers, maintaining perfect kinematic alignment. Every seal, vacuum line, and fluid is current, making this a mechanically transparent, turn-key investment for the discerning driver.",
      "price": 47500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "2022 SUV. 8,500 miles. Single owner. Garage kept. No scratches, dents, or mechanical issues. Original paint. Full service records included.",
      "price": 43500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
