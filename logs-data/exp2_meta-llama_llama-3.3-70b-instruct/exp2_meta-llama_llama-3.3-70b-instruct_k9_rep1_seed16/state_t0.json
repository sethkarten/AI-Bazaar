      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 represents a pinnacle of naturally aspirated engineering, featuring the high-revving S54 inline-six equipped with individual throttle bodies and dual-VANOS variable valve timing. Power is delivered through a precise Getrag 6-speed manual gearbox to a variable M differential lock, ensuring optimal torque distribution. This specimen is mechanically flawless, with documented rod bearing service and a reinforced rear subframe. The exterior retains its original deep luster, while the suspension geometry remains tight and responsive, offering the tactile steering feedback synonymous with the M-division\u2019s golden era. A truly turn-key, collector-grade vehicle.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Garage kept. Single owner. No accidents. Clean title. Full service history included.",
      "price": 46500.0,
