      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an exceptional opportunity to acquire a vehicle in superlative condition. This specimen has been maintained to an exacting standard, presenting in showroom-state both aesthetically and mechanically. With an unblemished exterior and a cabin that retains its original factory freshness, this vehicle represents the pinnacle of its class. We invite serious inquiries for this investment-grade motorcar.",
      "price": 48500.0,
