      "quality_value": 0.1,
      "timestep_posted": 31
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used vehicle. Good condition. Maintenance records available. Clean title. Mechanically sound. Minor cosmetic wear. Firm price.",
      "price": 31500.0,
      "reputation": 0.6,
