      "quality_value": 0.1,
      "timestep_posted": 21
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this meticulously maintained vehicle, which exemplifies a harmonious balance of performance and value. This unit has undergone a comprehensive multi-point inspection to ensure it meets our rigorous standards for mechanical excellence and aesthetic preservation. Featuring a refined interior and a robust powertrain, this selection offers a sophisticated driving experience for the professional seeking a dependable, high-quality pre-owned asset. Secure this exceptional acquisition today.",
      "price": 36500.0,
