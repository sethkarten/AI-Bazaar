      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 You seriously have to see this beauty in person! I\u2019ve babied this car since day one, and it is in absolutely pristine, showroom condition\u2014not a single scratch or speck of dust to be found. It drives like a total dream and looks even better! I\u2019m looking to find it a great new home quickly to help build up my seller profile, so I've priced it to move. Don't miss out on a total gem!",
      "price": 43900.0,
      "reputation": 0.3,
