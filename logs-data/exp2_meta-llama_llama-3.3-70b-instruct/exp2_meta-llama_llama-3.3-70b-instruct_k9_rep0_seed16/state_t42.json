    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is a distinguished vehicle that exemplifies mechanical integrity and refined styling. This unit has been meticulously maintained to ensure consistent performance and driver satisfaction. Featuring a clean, well-appointed interior and a robust powertrain, it represents an exceptional opportunity for the discerning buyer seeking a reliable, high-caliber automobile that balances performance with sophisticated design.",
      "price": 34800.0,
      "reputation": 0.6,
