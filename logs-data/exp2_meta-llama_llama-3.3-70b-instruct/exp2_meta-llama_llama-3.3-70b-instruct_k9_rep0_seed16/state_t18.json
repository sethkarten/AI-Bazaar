      "quality_value": 0.1,
      "timestep_posted": 18
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this meticulously maintained vehicle, which exemplifies reliability and sustained performance. Having undergone a rigorous professional inspection, the unit demonstrates mechanical integrity and a refined aesthetic, both inside and out. It offers a sophisticated driving experience for those seeking a dependable, high-caliber vehicle that has been cared for with the utmost attention to detail. This is an exceptional opportunity to acquire a robust asset at a competitive market valuation.",
      "price": 36500.0,
