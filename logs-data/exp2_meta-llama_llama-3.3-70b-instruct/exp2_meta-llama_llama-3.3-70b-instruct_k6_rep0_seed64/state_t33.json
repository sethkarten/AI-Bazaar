    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exceptionally well-maintained vehicle, offering a refined driving experience and a commanding presence on the road. Meticulously inspected to ensure mechanical integrity and aesthetic appeal, this model represents a superior balance of performance and value. It serves as an ideal acquisition for the discerning driver seeking a reliable, high-caliber automobile.",
      "price": 36800.0,
      "reputation": 0.8,
