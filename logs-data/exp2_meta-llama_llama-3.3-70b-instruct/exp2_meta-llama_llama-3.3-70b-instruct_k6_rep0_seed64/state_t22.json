      "timestep_posted": 22
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. It has significant mechanical issues, visible body damage, and a heavily worn interior. Several systems are currently non-functional and the car requires major repairs.",
