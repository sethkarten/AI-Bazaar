    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Check out this fantastic find! This vehicle is in good condition and has been clearly well-cared for, offering a smooth and dependable ride. While it shows some light, expected signs of use, it remains a reliable choice that's ready for many more miles on the road!",
      "price": 32500.0,
