    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an investment-grade E46 M3, featuring the iconic S54B32 3.2L high-compression inline-six mated to a crisp Getrag 6-speed manual transmission. This specimen is mechanically peerless, with a documented service history including a recent valve adjustment and a comprehensive VANOS overhaul utilizing Beisan Systems components. The chassis remains structurally superior with professional subframe reinforcement already performed. Handling dynamics are preserved via original Sachs dampers and fresh OEM bushings, ensuring the factory-intended kinematic balance and steering feedback. The exterior finish is exceptional, devoid of any clear-coat failure or panel gaps, while the cockpit retains its factory-fresh matte finish on all touchpoints with zero bolster wear on the Nappa leather. This is a turn-key, analog masterpiece for the purist collector.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 40
    },
    {
      "id": "sybil_8_listing_3",
      "firm_id": "sybil_8",
      "description": "Mint condition. Single owner. Low mileage. Full service history. Clean title. No accidents. Non-smoker vehicle.",
      "price": 43000.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
