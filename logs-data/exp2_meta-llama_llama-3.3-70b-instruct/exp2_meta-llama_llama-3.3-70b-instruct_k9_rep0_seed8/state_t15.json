    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting a showroom-quality 2003 BMW M3 (E46) finished in Carbon Black. This example features the high-revving S54 3.2L inline-six, benefitting from a documented VANOS rebuild and VAC-treated rod bearing replacement. Power is delivered through a precise 6-speed manual transmission to a factory limited-slip differential. The chassis is structurally sound with a reinforced rear subframe and refreshed bushings, maintaining original turn-in characteristics. Every mechanical component operates within factory tolerances, offering a linear power band and an unfiltered analog driving experience. This is a zero-fault, investment-grade specimen for the technical purist.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 15
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2021 Sedan. Mint condition. Garage kept. Zero accidents. Original factory paint. Full maintenance records provided. Inspection welcome.",
      "price": 43500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
