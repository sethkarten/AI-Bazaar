      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 features the legendary S54B32 inline-six, delivering exceptional throttle response via six individual throttle bodies. The high-revving powerplant is mated to a precise 6-speed Getrag manual transmission and a factory limited-slip differential. Mechanically sound, the vehicle has undergone essential subframe reinforcement and a VANOS system refresh to ensure long-term structural and timing integrity. The suspension geometry remains true, providing the communicative handling and turn-in precision these M-cars are known for. While the aesthetics show minor signs of use consistent with its history, the drivetrain and chassis performance remain sharp and uncompromising.",
      "price": 32500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Well-maintained. Good condition. Recent service complete. Clean title. Ready for pickup.",
