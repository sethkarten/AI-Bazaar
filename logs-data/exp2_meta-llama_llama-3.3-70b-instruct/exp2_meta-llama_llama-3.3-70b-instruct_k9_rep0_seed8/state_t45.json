    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a meticulously maintained vehicle that exemplifies reliable engineering and refined aesthetics. This unit has undergone a comprehensive inspection to ensure it meets our rigorous standards for performance and safety. Featuring a clean interior and a robust powertrain, it offers a sophisticated driving experience and represents an exceptional value for the discerning buyer.",
      "price": 36800.0,
