      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 44
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used vehicle in good condition. Clean title in hand. Maintenance records available. Engine and transmission operate smoothly. Minor cosmetic imperfections only.",
