      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m looking to find a new home for my car. It\u2019s been such a reliable ride and is still in really great shape! It runs smoothly and has been well-loved, making it perfect for someone who wants a solid vehicle without the brand-new price tag. I\u2019m sad to see it go, but I know it\u2019ll make its next owner very happy. Feel free to reach out with any questions\u2014I'd love to tell you more about it!",
      "price": 34500.0,
