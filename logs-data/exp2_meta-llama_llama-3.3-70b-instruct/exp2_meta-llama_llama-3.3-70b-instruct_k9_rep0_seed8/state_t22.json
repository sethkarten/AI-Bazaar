    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a meticulously maintained vehicle that exemplifies mechanical reliability and aesthetic refinement. This specimen has undergone a rigorous multi-point inspection to ensure it meets our exacting standards for performance and safety. With a documented service history and a clean interior, this vehicle offers a superior driving experience for the discerning owner who values both quality and longevity.",
      "price": 36500.0,
