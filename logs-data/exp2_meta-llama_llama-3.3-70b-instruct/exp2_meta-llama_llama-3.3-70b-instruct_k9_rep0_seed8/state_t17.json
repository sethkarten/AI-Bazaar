    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It is mechanically sound and has been well-maintained, though it shows some minor signs of regular use. Both the interior and exterior are clean and in good functional order.",
      "price": 34000.0,
      "reputation": 1.0,
