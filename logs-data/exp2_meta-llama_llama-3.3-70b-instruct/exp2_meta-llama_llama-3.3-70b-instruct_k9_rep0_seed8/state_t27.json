    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this distinguished vehicle, which has been maintained to rigorous standards. This unit offers a seamless blend of performance and reliability, ensuring a superior driving experience for the discerning owner. Every mechanical component has been thoroughly inspected to verify operational integrity. This represents a premier opportunity to acquire a high-caliber vehicle at a competitive market valuation.",
      "price": 36500.0,
      "reputation": 0.8,
