    },
    {
      "id": "sybil_6_listing_2",
      "firm_id": "sybil_6",
      "description": "This E46 M3 features the legendary S54B32 3.2L naturally aspirated inline-six, delivering 333hp through six individual throttle bodies. Mated to a crisp 6-speed Getrag manual transmission and a factory M-Variable differential lock, the drivetrain remains tight and responsive. Recent mechanical overhaul includes a comprehensive Double VANOS service and preventative subframe reinforcement with TMS plates. The suspension benefits from fresh bushings and Bilstein dampers, maintaining the original high-frequency damping characteristics. While showing minor aesthetic patina consistent with its age, the mechanical integrity is excellent, with a linear power band and precise steering rack feedback. A quintessential driver\u2019s spec for the purist.",
      "price": 36500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_8_listing_3",
      "firm_id": "sybil_8",
      "description": "Used car in good condition. Well-maintained engine. Clean title. Interior is tidy. Reliable daily driver.",
      "price": 34500.0,
      "reputation": 0.7,
