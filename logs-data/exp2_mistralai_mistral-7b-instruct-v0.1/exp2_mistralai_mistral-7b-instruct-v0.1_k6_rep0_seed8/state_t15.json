    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This collector-grade E46 M3 is a masterclass in naturally aspirated precision. The S54 inline-six features a fully overhauled VANOS system and updated rod bearings, ensuring the 8,000 RPM redline remains mechanically synchronized and reliable. Power is delivered through a crisp Getrag six-speed manual gearbox to a variable M-differential. The chassis is structurally reinforced at the subframe mounting points, a critical preventative measure for this platform. Finished in flawless Titanium Silver over Black Nappa leather, this example retains its factory-spec suspension geometry and staggered Style 67 wheels. A mechanically transparent, turn-key masterpiece for the purist.",
      "price": 44500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 15
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. No mechanical issues. Flawless interior and exterior. Clean title. Full service history included.",
      "price": 43500.0,
