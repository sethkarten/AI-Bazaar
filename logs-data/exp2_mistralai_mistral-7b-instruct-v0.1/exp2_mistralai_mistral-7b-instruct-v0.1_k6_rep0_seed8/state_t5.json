    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting an investment-grade 2004 BMW M3 (E46) Coupe, finished in Alpine White over Black Nappa leather. This specimen is powered by the S54 3.2L high-revving inline-six, featuring six individual throttle bodies and high-pressure double-VANOS variable valve timing. The powertrain is mated to a Getrag 6-speed manual transmission and an M-Variable Differential Lock, ensuring razor-sharp throttle response and mechanical purity. This example has undergone comprehensive preventative maintenance, including rod bearing replacement and a recent valve clearance adjustment. The chassis is structurally perfect with no subframe fatigue, and the suspension geometry remains true to factory specifications. This is a turn-key, concours-ready vehicle with a documented service history and no mechanical compromises.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 5
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Pristine condition. Single owner. Full service history. No accidents. Garage kept. Inspection ready.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
