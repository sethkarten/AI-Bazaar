      "timestep_posted": 8
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in good overall condition and has been consistently well-maintained. The engine runs strong and the transmission shifts smoothly, offering a dependable driving experience for its next owner. While there are some minor cosmetic blemishes and light interior wear consistent with its age, the car is mechanically sound and all major features are fully functional. It is a reliable choice for anyone seeking a solid, road-ready vehicle.",
      "price": 36500.0,
      "reputation": 0.9,
