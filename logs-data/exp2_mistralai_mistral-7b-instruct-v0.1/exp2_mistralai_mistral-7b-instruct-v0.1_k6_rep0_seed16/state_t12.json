    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting a collector-grade 997.2 Carrera S in pristine condition. This 3.8L DFI (Direct Fuel Injection) flat-six powerhouse eliminates IMS concerns while offering linear power delivery and a 7,500 RPM redline. The drivetrain features a precise 6-speed manual gearbox and a mechanical limited-slip differential for optimal torque vectoring. Performance is bolstered by PASM (Porsche Active Suspension Management) and the Sport Chrono package, providing adjustable damping and aggressive throttle mapping. The exterior retains its factory depth with zero paint meter anomalies, and the undercarriage is free of oxidation or fluid seepage. A recent DME report confirms a clean bill of health with zero Stage 2 over-revs, ensuring a mechanically sympathetic ownership history.",
      "price": 47500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 12
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Low mileage. Garage kept. Full service history included. Clean title.",
      "price": 42750.0,
