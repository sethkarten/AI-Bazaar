    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! Honestly, I\u2019m a bit sad to let this one go, but it\u2019s time for someone else to enjoy this absolute gem. It\u2019s in truly pristine condition\u2014I\u2019ve babied it since day one and it still looks and feels like it just rolled off the showroom floor. No scratches, no smells, just pure driving bliss. If you're looking for a ride that\u2019s been loved and kept in top-tier shape, you\u2019ve found it!",
      "price": 43500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
