    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready for your next adventure with this fantastic and reliable ride! It has been well-maintained and drives beautifully, offering a smooth experience on every trip. While you'll find some minor signs of character from regular use, it remains in great shape overall and is ready to serve its next owner faithfully for years to come!",
      "price": 33500.0,
      "reputation": 0.8,
