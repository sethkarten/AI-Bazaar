    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This expertly maintained vehicle represents a premier opportunity for the discerning driver. Demonstrating a history of consistent mechanical upkeep and a clean aesthetic profile, this unit offers a refined synthesis of performance and reliability. We invite you to experience the distinguished engineering and operational excellence of this exceptional offering.",
      "price": 32900.0,
