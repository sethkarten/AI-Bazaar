      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 represents a peerless example of the S54-powered icon. The 3.2L naturally aspirated inline-six pulls linearly to its 8,000 RPM redline, with the double-VANOS variable valve timing system operating with surgical precision. The chassis remains exceptionally taut, featuring a factory-original subframe in impeccable state and a Getrag 6-speed manual transmission providing crisp, tactile engagement. Every bushing, seal, and hydraulic line is preserved to concours standards, ensuring the M-variable limited-slip differential delivers optimal torque distribution. A true collector-grade specimen for the driving purist.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Garage kept. Zero accidents. Full service records. Clean title. Non-smoker.",
      "price": 46500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
