      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! Are you looking for a ride that feels like it just rolled off the showroom floor? This beauty is in absolute mint condition and has been my absolute pride and joy. It\u2019s been babied since day one\u2014no scratches, no spills, just pure driving perfection. Honestly, you won't find another one this clean! Come take a look and fall in love with your new dream car.",
      "price": 46500.0,
