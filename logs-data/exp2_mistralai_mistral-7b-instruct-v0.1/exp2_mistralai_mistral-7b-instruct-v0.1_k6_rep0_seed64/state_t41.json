    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. It has significant body damage, a heavily worn interior, and requires mechanical repairs to be fully operational. It is being sold as-is.",
      "price": 5500.0,
      "reputation": 1.0,
