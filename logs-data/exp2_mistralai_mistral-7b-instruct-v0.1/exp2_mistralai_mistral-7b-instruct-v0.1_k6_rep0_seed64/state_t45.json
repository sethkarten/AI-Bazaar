    },
    {
      "id": "sybil_8_listing_1",
      "firm_id": "sybil_8",
      "description": "Hey there! You've gotta see this beauty\u2014it\u2019s honestly like it just rolled off the showroom floor. I've absolutely babied this car, keeping it in flawless shape inside and out. It drives like a total dream and has been meticulously cared for. If you're looking for a ride that feels brand new without the sticker shock, this is the one! Come take it for a spin, I promise you'll fall in love!",
      "price": 44900.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
