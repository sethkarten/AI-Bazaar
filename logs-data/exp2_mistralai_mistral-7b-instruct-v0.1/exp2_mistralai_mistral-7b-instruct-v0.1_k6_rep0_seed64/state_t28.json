    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a dependable daily driver that won't let you down? This vehicle is in fair condition and ready for its next adventure! While it shows some honest wear and tear from its time on the road, it remains a solid, functional choice for anyone needing reliable transportation at a great price.",
      "price": 19500.0,
