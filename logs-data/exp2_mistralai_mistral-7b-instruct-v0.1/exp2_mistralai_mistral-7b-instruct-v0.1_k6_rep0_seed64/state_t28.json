      "quality_value": 0.1,
      "timestep_posted": 28
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and transmission are in good working order. Both the exterior and interior have been well-maintained and show only minor signs of wear.",
