      "timestep_posted": 21
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a truly exceptional automotive specimen maintained to an impeccable standard. This vehicle is offered in pristine condition, representing an uncompromising commitment to preservation. Every detail, from the flawless exterior finish to the showroom-quality interior, reflects its status as an investment-grade asset. We invite discerning collectors to experience a vehicle that remains indistinguishable from its original delivery state.",
      "price": 47500.0,
      "reputation": 0.6,
