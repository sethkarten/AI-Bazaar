    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a rewarding project or a budget-friendly fixer-upper? This vehicle is ready for someone with a mechanical touch to give it the TLC it needs! While it requires significant repairs and shows heavy wear, it\u2019s a fantastic opportunity to own a vehicle at a fraction of the cost. Perfect for a hobbyist looking for their next challenge!",
      "price": 4500.0,
