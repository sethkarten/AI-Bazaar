    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey everyone! I\u2019m honestly so sad to let this beauty go, but it\u2019s time for someone else to enjoy it! This car is in absolute mint condition\u2014seriously, it looks and smells like it just rolled off the showroom floor. I\u2019ve babied it since day one, kept it tucked away in the garage, and it\u2019s been treated with nothing but love. If you\u2019re looking for a ride that\u2019s basically brand new without the dealership headache, this is the one! Come take a look, you won\u2019t be disappointed! \u2728",
      "price": 44500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
