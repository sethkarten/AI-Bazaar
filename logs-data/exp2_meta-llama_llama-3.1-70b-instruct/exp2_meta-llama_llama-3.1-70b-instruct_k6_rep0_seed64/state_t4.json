    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "Up for sale is a well-maintained vehicle in good condition, perfect for someone looking for a reliable and comfortable ride. The engine starts up reliably and runs smoothly, while the transmission shifts through gears without hesitation. Inside, the cabin is clean and has been cared for, showing only minor signs of use consistent with a vehicle of this age. This car has been consistently serviced and is ready to be driven home today with no immediate repairs required.",
      "price": 34500.0,
