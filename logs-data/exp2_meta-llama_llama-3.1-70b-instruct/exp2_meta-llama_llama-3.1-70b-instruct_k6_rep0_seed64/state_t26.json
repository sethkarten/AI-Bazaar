    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has visible scratches and several small dents on the body panels. The interior shows noticeable wear on the upholstery and carpets from regular use. All mechanical systems are currently functional, though the vehicle reflects its age and mileage.",
      "price": 18500.0,
      "reputation": 1.0,
