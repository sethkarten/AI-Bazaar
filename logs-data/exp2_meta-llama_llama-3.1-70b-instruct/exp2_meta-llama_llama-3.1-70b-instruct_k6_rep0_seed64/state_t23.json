    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has visible scratches and a few small dents. The interior shows signs of use with some wear on the seats and carpet. All mechanical components are currently functional, though the car shows its age.",
