    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m selling my trusty car, and it\u2019s been such a joy to drive. It\u2019s in really solid condition and has plenty of life left in it\u2014perfect for your daily commute or weekend adventures! I\u2019ve taken good care of it, and it runs like a charm. I\u2019m looking for a quick, easy sale, so I\u2019ve priced it to move. Come check it out and take it for a spin!",
      "price": 28500.0,
