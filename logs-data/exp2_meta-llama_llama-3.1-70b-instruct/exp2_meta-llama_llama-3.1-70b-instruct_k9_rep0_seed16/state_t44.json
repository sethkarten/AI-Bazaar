    },
    {
      "id": "sybil_11_listing_2",
      "firm_id": "sybil_11",
      "description": "Up for sale is a driver-focused E92 M3 featuring the legendary S65 4.0L naturally aspirated V8. This high-revving masterpiece utilizes eight individual throttle bodies and a cross-plane crank to deliver linear power up to its 8,400 RPM redline. Paired with a precise 6-speed manual transmission and the factory M Variable Differential Lock, the longitudinal and lateral dynamics remain sharp. Recent critical preventative maintenance includes rod bearing replacement and updated throttle actuators, ensuring the valvetrain and induction systems operate within peak tolerances. The suspension retains its factory Electronic Damper Control (EDC) functionality, providing a versatile balance between circuit-ready stiffness and street compliance. A mechanically sound example for the purist who values engineering integrity.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 44
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Used car for sale. Good condition. Reliable engine. Clean interior. Maintenance up to date. Ready for immediate use.",
      "price": 29500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
