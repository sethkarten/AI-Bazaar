    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a meticulously maintained vehicle that exemplifies both performance and reliability. This unit has undergone a comprehensive multi-point inspection to ensure it meets our rigorous standards for mechanical integrity and aesthetic appeal. Offering a sophisticated driving experience and consistent performance, this vehicle represents a premier acquisition for the discerning motorist seeking lasting value.",
      "price": 36500.0,
