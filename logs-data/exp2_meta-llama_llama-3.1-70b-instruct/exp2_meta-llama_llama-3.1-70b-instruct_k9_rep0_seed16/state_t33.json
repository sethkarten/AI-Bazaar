    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "$34,000 - This vehicle is in good condition. The exterior is well-maintained with only minor surface blemishes, and the interior is clean with light signs of previous use. It is fully operational and has been regularly serviced.",
      "price": 34000.0,
      "reputation": 1.0,
