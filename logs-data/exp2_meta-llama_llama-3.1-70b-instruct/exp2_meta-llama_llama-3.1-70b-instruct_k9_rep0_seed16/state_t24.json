      "timestep_posted": 24
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Solid vehicle. Clean title. Maintenance records up to date. Reliable performance. Interior and exterior are well-kept. Ready for daily use.",
      "price": 34500.0,
