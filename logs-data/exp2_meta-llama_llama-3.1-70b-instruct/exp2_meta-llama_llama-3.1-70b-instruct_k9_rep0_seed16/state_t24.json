      "quality_value": 0.1,
      "timestep_posted": 24
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this meticulously maintained vehicle, offering an exceptional balance of performance and long-term value. This unit has undergone a comprehensive professional inspection to ensure mechanical reliability and features a well-preserved aesthetic both inside and out. It represents an ideal acquisition for the driver seeking a sophisticated, high-caliber automobile that has been treated with consistent care. We invite serious inquiries to appreciate the refined handling and authoritative presence of this distinguished vehicle.",
      "price": 34500.0,
