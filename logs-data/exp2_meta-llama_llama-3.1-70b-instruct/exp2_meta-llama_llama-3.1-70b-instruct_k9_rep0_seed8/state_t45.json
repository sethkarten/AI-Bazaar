    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior shows minor cosmetic wear, while the interior is well-maintained with only slight signs of use. All mechanical systems are functioning properly and the car is reliable.",
      "price": 34500.0,
      "reputation": 1.0,
