      "quality_value": 0.1,
      "timestep_posted": 18
    },
    {
      "id": "sybil_10_listing_6",
      "firm_id": "sybil_10",
      "description": "Hey there! I'm parting with my trusty ride, and she's been such a joy to drive. It's in really solid shape and has been well-maintained, so it's ready to hit the road with a new owner today. Perfect for commutes or weekend trips! Everything runs smoothly, and it still looks great in the driveway. Come take it for a spin\u2014you're going to love how it handles!",
      "price": 34500.0,
