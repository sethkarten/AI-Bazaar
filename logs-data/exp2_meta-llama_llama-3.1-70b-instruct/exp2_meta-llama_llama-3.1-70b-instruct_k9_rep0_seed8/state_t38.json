    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and will require significant attention from its next owner. The engine currently struggles with consistent performance, and the transmission exhibits noticeable slipping, suggesting a major overhaul may be necessary. Externally, the body shows heavy wear, including several dents, extensive paint oxidation, and areas of advancing rust. The interior has seen better days, with torn upholstery and several non-functional electronic components. This car is best suited as a dedicated project for a mechanic or as a source for parts, and it is recommended that it be towed from the lot.",
      "price": 5500.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 38
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several noticeable dents and some paint fading, while the interior shows significant wear and staining on the seats. It is currently operational but will likely require minor mechanical maintenance in the near future.",
      "price": 20000.0,
      "reputation": 1.0,
