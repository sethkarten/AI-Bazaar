      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presented for your consideration is a meticulously maintained vehicle that strikes a superior balance between performance and value. This unit has undergone a comprehensive professional inspection to ensure mechanical integrity and aesthetic appeal. Featuring a refined interior and a robust powertrain, it offers a sophisticated driving experience tailored for the discerning motorist. We invite you to experience the reliability and quality that define this exceptional automotive offering.",
      "price": 34900.0,
