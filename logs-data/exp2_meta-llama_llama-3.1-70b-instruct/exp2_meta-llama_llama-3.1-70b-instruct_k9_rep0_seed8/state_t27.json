    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this meticulously maintained vehicle, which represents an exceptional balance of proven performance and enduring value. This unit has undergone a comprehensive multi-point inspection to ensure it meets our rigorous standards for mechanical reliability and aesthetic presentation. Offering a refined driving experience and a well-preserved interior, this vehicle stands as a premier choice for the discerning buyer seeking a sophisticated and dependable automotive asset.",
      "price": 34500.0,
      "reputation": 0.7,
