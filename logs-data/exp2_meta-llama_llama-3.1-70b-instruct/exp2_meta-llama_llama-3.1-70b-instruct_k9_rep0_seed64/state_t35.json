      "timestep_posted": 35
    },
    {
      "id": "sybil_11_listing_3",
      "firm_id": "sybil_11",
      "description": "Used vehicle. Good condition. Well-maintained engine. Clean title. Interior shows minor wear. Reliable daily driver.",
      "price": 31500.0,
      "reputation": 0.6,
