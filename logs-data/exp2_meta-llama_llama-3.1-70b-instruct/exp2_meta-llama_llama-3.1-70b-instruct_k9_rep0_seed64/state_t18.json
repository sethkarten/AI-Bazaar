    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a mechanically sorted 2004 BMW M3 (E46) featuring the high-revving S54 3.2L inline-six power plant and a crisp Getrag 6-speed manual gearbox. This driver\u2019s example benefits from extensive preventative maintenance, including a complete VANOS system refresh and essential rear subframe reinforcement to preserve chassis rigidity. The drivetrain utilizes a variable M differential lock for optimal torque distribution, while the suspension geometry remains true with refreshed bushings and dampers. Showing honest patina consistent with a well-loved enthusiast vehicle, the engine pulls strongly to its 7,900 RPM redline with the signature metallic rasp of the individual throttle bodies. A technically sound, performance-oriented machine for the discerning pilot.",
      "price": 36500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 18
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Well-maintained. Clean title. Ready for immediate sale.",
      "price": 28500.0,
      "reputation": 0.4,
