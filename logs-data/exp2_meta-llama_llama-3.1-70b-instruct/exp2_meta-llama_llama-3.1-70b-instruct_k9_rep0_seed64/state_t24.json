      "quality_value": 0.1,
      "timestep_posted": 24
    },
    {
      "id": "sybil_11_listing_3",
      "firm_id": "sybil_11",
      "description": "Used car. Good condition. Maintenance records available. Clean title. Minor cosmetic wear. Runs well.",
