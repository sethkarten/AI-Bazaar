      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm parting ways with my trusty ride, and she's been such a joy to drive. It's in really solid shape, super reliable, and has been well-maintained over the years. Perfect for someone looking for a dependable car that still looks great on the road. Come take it for a spin\u2014you're going to love how smoothly it handles!",
      "price": 32500.0,
      "reputation": 0.6,
