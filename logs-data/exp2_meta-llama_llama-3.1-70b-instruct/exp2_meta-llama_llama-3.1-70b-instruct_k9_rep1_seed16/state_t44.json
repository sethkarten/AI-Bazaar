    {
      "id": "sybil_12_listing_0",
      "firm_id": "sybil_12",
      "description": "This meticulously maintained vehicle represents a premier opportunity for the discerning driver. Demonstrating consistent mechanical integrity and a refined aesthetic, it offers an exceptional balance of performance and long-term value. Every component has been scrutinized to ensure it meets our rigorous standards for safety and reliability. Experience a sophisticated driving dynamic in a package that has been preserved with the utmost care.",
      "price": 36800.0,
      "reputation": 0.7,
