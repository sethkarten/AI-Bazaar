    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2021 model. Single owner. Zero accidents. Garage kept. Immaculate interior and exterior. Full service history available. Inspection welcome.",
      "price": 43500.0,
