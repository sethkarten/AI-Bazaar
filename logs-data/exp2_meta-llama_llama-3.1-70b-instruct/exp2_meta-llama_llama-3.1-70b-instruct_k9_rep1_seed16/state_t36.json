    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a meticulously maintained vehicle that exemplifies mechanical reliability and consistent performance. This selection has been thoroughly vetted to ensure it meets our rigorous standards for quality and aesthetic preservation. A premier opportunity for the professional seeking a dependable, high-value addition to their garage.",
      "price": 28950.0,
