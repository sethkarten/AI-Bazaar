      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 41
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m looking to find a new home for this absolute beauty. It\u2019s been such a reliable ride and honestly runs like a dream\u2014perfect for your daily commute or those fun weekend road trips! It\u2019s been really well-loved and is in great shape to get you wherever you need to go. I\u2019m sad to see it go, but I\u2019m excited for it to start a new chapter with you. Drop me a message if you want to come take it for a spin!",
      "price": 28900.0,
