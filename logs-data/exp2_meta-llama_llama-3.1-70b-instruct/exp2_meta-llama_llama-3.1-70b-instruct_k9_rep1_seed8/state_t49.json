    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "This expertly maintained vehicle offers a distinguished driving experience, blending mechanical excellence with a refined aesthetic. Demonstrating consistent care and structural integrity, it stands as a premier choice for those seeking both performance and enduring value. A sophisticated acquisition for the discerning motorist who demands reliability without compromise.",
      "price": 34500.0,
