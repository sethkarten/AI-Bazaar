      "timestep_posted": 41
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 You have to see this absolute beauty! I\u2019ve taken such good care of it, and it\u2019s honestly in pristine, mint condition\u2014it still feels like it just rolled off the lot. It's been my pride and joy, kept spotless and running perfectly. If you're looking for a ride that\u2019s been truly pampered and is ready for a new home, this is the one! Feel free to reach out with any questions or come by to take a look! \u2728",
      "price": 43500.0,
