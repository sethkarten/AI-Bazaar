      "quality_value": 0.1,
      "timestep_posted": 44
    },
    {
      "id": "sybil_14_listing_6",
      "firm_id": "sybil_14",
      "description": "Hey there! You seriously have to see this beauty in person. It\u2019s in absolutely pristine condition\u2014honestly, it feels like it just rolled off the showroom floor! I\u2019ve babied this car since day one, so it\u2019s spotless inside and out and drives like an absolute dream. I\u2019m really looking for someone who will appreciate it as much as I have. Feel free to reach out if you want to come by and take it for a spin\u2014you\u2019re going to love it!",
      "price": 44900.0,
      "reputation": 0.8,
