    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exemplary vehicle, currently maintained in a state of absolute preservation. This specimen boasts a flawless exterior profile complemented by an interior that remains in pristine, original condition. Every aspect of this automobile has been rigorously inspected to ensure it meets the highest standards of mechanical and aesthetic excellence. For the sophisticated buyer seeking a vehicle that mirrors its original delivery state, this offering represents an unrivaled acquisition opportunity.",
      "price": 48500.0,
      "reputation": 0.6,
