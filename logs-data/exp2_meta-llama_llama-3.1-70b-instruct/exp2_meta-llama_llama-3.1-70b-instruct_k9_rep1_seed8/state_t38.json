    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is a vehicle of exceptional caliber, maintained to an uncompromising standard. This specimen represents the pinnacle of its class, exhibiting a pristine aesthetic and mechanical integrity that mirrors its original showroom delivery. Meticulously preserved and free of any discernible wear, it offers an unparalleled driving experience for the discerning enthusiast. We invite you to acquire this investment-grade automotive asset.",
      "price": 46500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
