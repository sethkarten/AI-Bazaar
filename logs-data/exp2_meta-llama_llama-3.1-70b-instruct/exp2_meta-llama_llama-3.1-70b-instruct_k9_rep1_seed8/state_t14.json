      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m parting ways with my trusty ride, and honestly, it\u2019s been such a joy to drive. It\u2019s in really solid shape\u2014super reliable and still looks great parked in the driveway. The interior is nice and clean, and it handles the road like a pro. It's been well-loved and is ready for its next adventure. Come take it for a spin, you\u2019re gonna love how it feels!",
      "price": 32500.0,
      "reputation": 0.5,
