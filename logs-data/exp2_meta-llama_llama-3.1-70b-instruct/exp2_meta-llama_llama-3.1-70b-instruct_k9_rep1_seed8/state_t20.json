      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a museum-grade E46 M3, a pinnacle of atmospheric engineering. This example features the legendary S54 3.2L inline-six, delivering linear power through individual throttle bodies and a high-pressure dual-VANOS system, both recently serviced to factory specifications. The powertrain is mated to a precise Getrag 6-speed manual and a variable M-differential lock. Crucially, the rear subframe has been professionally reinforced, and the rod bearings have been addressed as preventative maintenance. The chassis remains exceptionally rigid with all OEM bushings intact and zero oxidation. Finished in Carbon Black over Cinnamon Nappa leather, this is a turn-key collector piece with a factory-spec exhaust and pristine engine bay.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "One owner. Garage kept. Zero accidents. Full service history. Flawless interior. Original paint. Low mileage. Inspection report available.",
      "price": 44000.0,
      "reputation": 0.5,
