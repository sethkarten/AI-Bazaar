    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a distinguished vehicle that exemplifies mechanical integrity and sophisticated design. This unit has been carefully curated to ensure a seamless driving experience, featuring a well-appointed cabin and a responsive powertrain. It stands as a testament to diligent maintenance and offers an exceptional balance of luxury and performance for the prudent investor. We invite you to experience the caliber of this automobile in person.",
      "price": 34500.0,
      "reputation": 0.5,
