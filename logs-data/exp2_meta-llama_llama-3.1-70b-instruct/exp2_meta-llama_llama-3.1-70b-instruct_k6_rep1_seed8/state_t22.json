      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_6_listing_3",
      "firm_id": "sybil_6",
      "description": "2022 sedan. Mint condition. Single owner. Zero accidents. Garage kept. Clean title. Inspection reports available.",
      "price": 43000.0,
