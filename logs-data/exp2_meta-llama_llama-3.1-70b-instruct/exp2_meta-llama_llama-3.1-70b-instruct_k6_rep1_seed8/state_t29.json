      "quality_value": 0.1,
      "timestep_posted": 29
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is a mechanically sorted E46 M3 featuring the legendary S54 3.2L inline-six with individual throttle bodies. This example utilizes a crisp 6-speed Getrag manual transmission and a factory-spec limited-slip differential. Extensive preventative maintenance has been performed, including a comprehensive VANOS overhaul and rear subframe reinforcement to ensure torsional rigidity. The powertrain delivers linear torque across the rev range, pulling strongly to the 8,000 RPM redline. The chassis is equipped with refreshed bushings and Bilstein dampers, maintaining precise suspension geometry. While the exterior displays minor road patina consistent with use, the mechanical synchronicity and drivetrain health are exceptional for an enthusiast seeking a high-performance analog driving experience.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 29
    },
    {
      "id": "sybil_7_listing_3",
      "firm_id": "sybil_7",
      "description": "Used vehicle. Good condition. Clean title. Maintenance records available. Reliable engine. Minor exterior wear. Interior is intact.",
      "price": 32000.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
