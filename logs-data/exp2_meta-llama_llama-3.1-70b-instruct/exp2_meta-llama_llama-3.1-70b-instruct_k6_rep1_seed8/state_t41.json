      "timestep_posted": 41
    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready to hit the road in this dependable and character-filled ride! While it shows some honest signs of its journey through life, this car remains a solid and spirited performer that's ready for its next chapter. It's the perfect opportunity to own a well-loved vehicle that still has plenty of great miles to offer. With a bit of TLC, this reliable companion will continue to serve you well for years to come!",
      "price": 19500.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 41
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. It shows no signs of cosmetic wear on the interior or exterior. There are no mechanical issues, and all components are in perfect working order.",
      "price": 48000.0,
      "reputation": 1.0,
