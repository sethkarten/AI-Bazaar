    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a dependable daily driver with character? This vehicle is in honest, fair condition and is ready for its next adventure! It has been well-loved and shows some typical signs of wear and tear, but it remains a reliable and practical choice for anyone seeking value and personality in their next ride.",
      "price": 19000.0,
