    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this superlative automotive specimen, maintained in impeccable showroom condition. This vehicle exhibits a level of preservation rarely encountered on the secondary market, featuring flawless aesthetics and peak mechanical performance. A definitive acquisition for the discerning driver who demands absolute perfection.",
      "price": 48500.0,
