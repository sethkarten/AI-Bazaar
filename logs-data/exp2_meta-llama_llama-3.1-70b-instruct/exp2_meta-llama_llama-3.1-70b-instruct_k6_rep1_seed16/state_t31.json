      "timestep_posted": 31
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. There are noticeable signs of wear on the interior and exterior, including scratches and scuffs. Most mechanical systems are functional, though some components may require attention in the near future.",
