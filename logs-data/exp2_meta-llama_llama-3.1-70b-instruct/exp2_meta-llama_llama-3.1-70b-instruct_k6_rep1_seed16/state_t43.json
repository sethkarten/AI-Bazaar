      "quality_value": 0.4,
      "timestep_posted": 43
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It shows minor cosmetic wear on the exterior and interior from regular use. All mechanical systems are fully functional and have been maintained according to the standard schedule.",
      "price": 35000.0,
      "reputation": 1.0,
