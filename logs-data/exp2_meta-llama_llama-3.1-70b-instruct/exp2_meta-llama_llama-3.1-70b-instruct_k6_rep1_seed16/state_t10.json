    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a superlative example of the S54-powered icon, featuring the high-revving 3.2L inline-six with individual throttle bodies and a razor-sharp 8,000 RPM redline. Power is delivered through a precise Getrag 6-speed manual gearbox to a variable M differential lock, ensuring exceptional mechanical grip. This chassis has been fastidiously maintained, including a reinforced rear subframe and a comprehensive VANOS overhaul to eliminate common failure points. The suspension retains its factory-correct damping profiles, and the engine bay is concours-level clean. A turn-key collector-grade machine with zero deferred maintenance.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. No accidents. Garage kept. Full service history included. Mechanical inspection welcome.",
      "price": 43500.0,
