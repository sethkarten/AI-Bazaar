    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting an investment-grade E46 M3, meticulously maintained to preserve its analog performance. At its heart is the S54 high-revving straight-six, featuring individual throttle bodies and a fully overhauled Double VANOS system. This example features a reinforced rear subframe and VAC-coated rod bearings, addressing every known platform weakness. The 6-speed Getrag manual transmission shifts with clinical precision, sending power through a refreshed M-Variable limited-slip differential. The chassis is dialed in with Bilstein B16 dampers and polyurethane bushings, ensuring the suspension geometry remains true under high lateral loads. Mechanically flawless with a pristine undercarriage, this is a true purist's specimen.",
      "price": 46500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_6_listing_3",
      "firm_id": "sybil_6",
      "description": "Mint condition. One owner. Garage kept. No accidents or scratches. Full service history included. Serious buyers only.",
      "price": 46000.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
