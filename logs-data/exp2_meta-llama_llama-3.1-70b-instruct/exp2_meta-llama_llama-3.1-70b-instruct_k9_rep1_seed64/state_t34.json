      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! Looking for a reliable ride that\u2019s been well-loved and is totally ready for its next adventure? This beauty is in great shape and runs like a absolute dream. It\u2019s been super well-maintained and is perfect if you're looking for a solid, dependable car that still looks fantastic on the road. Come take it for a spin\u2014I promise you\u2019re going to love how smooth it handles!",
      "price": 32500.0,
