    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "$34,000 - This vehicle is in good condition. The exterior has minor surface scratches consistent with regular use. The interior is clean with slight wear on the driver's seat. All mechanical and electronic systems are fully operational.",
      "price": 34000.0,
