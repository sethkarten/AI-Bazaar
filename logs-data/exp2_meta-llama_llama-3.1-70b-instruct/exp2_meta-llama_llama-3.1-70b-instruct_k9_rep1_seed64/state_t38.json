      "quality_value": 0.1,
      "timestep_posted": 38
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! \ud83d\ude97 You have got to see this beauty! It\u2019s an absolute gem and honestly looks like it just rolled off the showroom floor\u2014it's in pristine condition. I\u2019ve taken such good care of it, and it drives like an absolute dream. If you\u2019re looking for that 'brand new' feeling without the brand new price tag, this is the one for you! Feel free to reach out with any questions, I'm happy to chat!",
      "price": 44500.0,
      "reputation": 0.5,
