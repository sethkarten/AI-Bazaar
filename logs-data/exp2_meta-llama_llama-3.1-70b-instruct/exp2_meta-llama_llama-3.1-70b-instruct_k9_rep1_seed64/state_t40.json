    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and will require significant mechanical and cosmetic attention. The engine has a noticeable knock and struggles to maintain idle, while the transmission shifts roughly between gears. The body shows visible rust, several dents, and the interior upholstery is heavily worn and torn. This car is best suited for a dedicated project or as a source for parts.",
      "price": 4500.0,
