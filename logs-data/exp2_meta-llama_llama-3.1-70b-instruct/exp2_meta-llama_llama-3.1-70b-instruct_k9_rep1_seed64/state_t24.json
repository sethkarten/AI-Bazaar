      "quality_value": 0.1,
      "timestep_posted": 24
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You've gotta see this beauty. It's honestly like it just rolled off the showroom floor\u2014absolutely pristine inside and out. I\u2019ve taken such good care of it, and it drives like an absolute dream. If you\u2019re looking for perfection without the brand-new price tag, this is the one for you! Come take it for a spin, you seriously won't be disappointed! \u2728",
      "price": 43500.0,
