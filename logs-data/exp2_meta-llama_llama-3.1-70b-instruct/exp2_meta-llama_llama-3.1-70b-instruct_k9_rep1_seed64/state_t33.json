      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey friends! I\u2019m parting ways with my trusty ride, and she\u2019s been such a joy to own. It\u2019s in really solid shape and has clearly been well-loved over the years. Perfect for someone who wants a reliable, smooth drive without the brand-new price tag. Everything runs great, and it\u2019s ready for its next adventure with you! Come take it for a spin and see for yourself!",
      "price": 32500.0,
