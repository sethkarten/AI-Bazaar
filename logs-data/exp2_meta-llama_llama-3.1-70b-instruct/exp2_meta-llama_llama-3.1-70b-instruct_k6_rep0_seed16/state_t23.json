    {
      "id": "sybil_7_listing_1",
      "firm_id": "sybil_7",
      "description": "Hey there! I\u2019m selling my absolute pride and joy. This car is seriously in showroom condition\u2014I\u2019ve babied it since day one! It drives like a dream and honestly looks like it just rolled off the lot. If you\u2019re looking for something that\u2019s been meticulously cared for and is ready for a new home, this is the one! Come take a look, you won't be disappointed!",
      "price": 44900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
