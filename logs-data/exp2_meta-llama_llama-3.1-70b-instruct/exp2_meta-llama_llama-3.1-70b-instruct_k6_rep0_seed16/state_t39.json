    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready to be impressed by this absolute masterpiece! This car is in breathtaking mint condition, looking and driving exactly like it did the day it left the showroom. From the flawless exterior to the pristine interior, every single detail has been perfectly preserved\u2014it's truly a rare find for anyone seeking automotive perfection!",
      "price": 49000.0,
      "reputation": 1.0,
