    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. It has significant mechanical issues and visible damage to both the interior and exterior. Several features are non-functional, and it will require extensive repairs to be reliable.",
      "price": 6000.0,
