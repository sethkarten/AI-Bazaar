    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several visible scratches and small dents, while the interior shows clear signs of use and wear. All major systems are currently operational, though some non-critical repairs or maintenance may be needed.",
      "price": 18000.0,
      "reputation": 1.0,
