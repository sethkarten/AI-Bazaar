      "quality_value": 0.1,
      "timestep_posted": 46
    },
    {
      "id": "sybil_8_listing_2",
      "firm_id": "sybil_8",
      "description": "Offered is a mechanically robust E46 M3 featuring the iconic S54 3.2L naturally aspirated inline-six. This unit delivers linear power through individual throttle bodies and a crisp Getrag 6-speed manual transmission. Critical preventative maintenance has been addressed, including a comprehensive VANOS overhaul and a recent valve shim adjustment to ensure peak valvetrain timing. The chassis remains composed with a reinforced rear subframe and refreshed trailing arm bushings. While showing minor signs of use consistent with its age, the car maintains excellent structural integrity and high-speed stability. A true driver\u2019s example with a limited-slip variable M differential and staggered Style 67 alloys, ready for immediate spirited use.",
      "price": 32500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 46
    },
    {
      "id": "sybil_13_listing_3",
      "firm_id": "sybil_13",
      "description": "Used car. Good condition. Regularly serviced. Clean title. Runs well. No issues.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
