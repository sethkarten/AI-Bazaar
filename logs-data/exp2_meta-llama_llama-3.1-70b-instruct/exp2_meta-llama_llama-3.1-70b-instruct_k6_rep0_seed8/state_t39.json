    },
    {
      "id": "sybil_8_listing_2",
      "firm_id": "sybil_8",
      "description": "Offered is an exceptional 997.2 Carrera S, featuring the 3.8L Direct Fuel Injection (DFI) flat-six engine. This naturally aspirated powerplant delivers linear torque through a precise 6-speed manual transaxle with crisp synchro engagement. The chassis is equipped with Porsche Active Suspension Management (PASM), ensuring optimal damping and lateral rigidity. Meticulously maintained with a documented service history, the vehicle shows no signs of bore scoring and retains factory-spec compression. From the cross-drilled rotors to the pristine underbody, this specimen is in concours-level condition, providing a visceral, analog driving experience for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 39
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Mint condition. Original paint. No scratches or mechanical issues. Garage kept. Full service history available.",
      "price": 43500.0,
      "reputation": 0.4,
