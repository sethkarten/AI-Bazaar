    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in museum-quality, mint condition, appearing exactly as it did the day it was first delivered. The exterior paint is absolutely flawless with a deep, mirror-like finish, and the interior is pristine, showing no signs of wear on the upholstery or controls. Mechanically, it is perfect, having been meticulously stored and maintained to the highest standards. A truly rare find for a serious collector who demands nothing less than perfection.",
      "price": 49000.0,
      "reputation": 1.0,
      "quality": "mint",
