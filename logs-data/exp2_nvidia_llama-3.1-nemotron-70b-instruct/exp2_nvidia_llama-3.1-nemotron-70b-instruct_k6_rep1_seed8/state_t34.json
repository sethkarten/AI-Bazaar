    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has visible scratches and minor dings from regular use. The interior shows noticeable wear on the upholstery and surfaces. All mechanical systems are currently functional.",
      "price": 21000.0,
