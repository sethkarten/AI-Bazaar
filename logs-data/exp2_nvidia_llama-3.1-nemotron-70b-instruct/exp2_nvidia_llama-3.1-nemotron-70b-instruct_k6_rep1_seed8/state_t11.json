    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a meticulously maintained vehicle that exemplifies mechanical integrity and aesthetic appeal. This specimen has undergone a rigorous multi-point inspection, ensuring it meets our exacting standards for performance and long-term reliability. Featuring a clean history and a well-preserved interior, it offers a premium driving experience tailored for the discerning professional. We invite you to experience the superior handling and refined comfort of this exceptional offering.",
      "price": 36500.0,
      "reputation": 0.8,
