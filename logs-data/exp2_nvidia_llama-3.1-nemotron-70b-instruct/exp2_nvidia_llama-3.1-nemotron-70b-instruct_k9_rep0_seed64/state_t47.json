    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained, showing only minor signs of wear on the interior and exterior. All mechanical systems are fully operational and require no immediate repairs.",
      "price": 33500.0,
      "reputation": 1.0,
      "quality": "good",
