      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_11_listing_6",
      "firm_id": "sybil_11",
      "description": "Hi everyone! I\u2019m so excited to find a new home for my car. It is seriously in pristine condition\u2014I\u2019ve taken such good care of it, you\u2019d think it was brand new! It\u2019s been kept in the garage, washed every weekend, and the interior is still smelling fresh. It drives like a dream and looks absolutely stunning. I\u2019m sad to let it go, but I know the next owner is going to absolutely love it! Come check it out!",
      "price": 44500.0,
      "reputation": 0.7,
