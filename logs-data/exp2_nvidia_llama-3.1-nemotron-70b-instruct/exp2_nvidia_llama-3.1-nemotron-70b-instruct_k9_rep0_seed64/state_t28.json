    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained and is mechanically sound. There are minor signs of wear on the interior and exterior consistent with regular use.",
      "price": 38500.0,
