    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an exceptional E92 M3, featuring the legendary S65 4.0L V8 powerplant with individual throttle bodies and an 8,400 RPM redline. This specimen is mechanically flawless, having undergone documented rod bearing preventative maintenance and throttle actuator replacement. The M-Double Clutch Transmission (M-DCT) delivers lightning-fast shifts, paired with a limited-slip differential for optimal power delivery. The chassis remains taut with Electronic Damper Control (EDC) functioning perfectly. Finished with pristine paint depth and an interior free of bolster wear or dash UV damage, this vehicle represents the pinnacle of BMW's naturally aspirated engineering. A true turn-key enthusiast example with a comprehensive service dossier.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2022 Sedan. Showroom condition. Single owner. No accidents. Full service history. Clean title.",
      "price": 43500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
