    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has some visible scratches and minor dents, and the interior shows moderate wear from regular use. It is mechanically functional but may require some maintenance in the near future.",
      "price": 20000.0,
      "reputation": 1.0,
