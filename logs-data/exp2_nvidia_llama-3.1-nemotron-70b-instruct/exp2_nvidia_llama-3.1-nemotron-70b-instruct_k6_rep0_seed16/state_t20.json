    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Roll up your sleeves and get ready for an exciting project! This car is the perfect canvas for a mechanic or restoration enthusiast looking to bring a vehicle back to life. While it's currently in poor condition and will need some dedicated TLC, it offers a fantastic opportunity to build something special from the ground up at an unbeatable price!",
      "price": 3800.0,
