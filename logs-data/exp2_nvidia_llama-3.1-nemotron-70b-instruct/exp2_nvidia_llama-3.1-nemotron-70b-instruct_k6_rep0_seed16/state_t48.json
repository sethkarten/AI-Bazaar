    {
      "id": "sybil_8_listing_0",
      "firm_id": "sybil_8",
      "description": "Presented for your consideration is a vehicle of exceptional caliber, maintained to an uncompromising standard. This specimen remains in showroom condition, exhibiting a level of preservation that will satisfy the most discerning collector. From its flawless exterior to its meticulously curated interior, this automobile offers a driving experience indistinguishable from its original debut. We invite serious inquiries to inspect this peerless example of automotive excellence.",
      "price": 46500.0,
      "reputation": 0.6,
