    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready for a fantastic ride! This well-loved vehicle is in good condition and has been consistently maintained to ensure a smooth, reliable driving experience. It\u2019s the perfect blend of comfort and dependability, ready to take you on many more miles of adventures with confidence!",
      "price": 35500.0,
