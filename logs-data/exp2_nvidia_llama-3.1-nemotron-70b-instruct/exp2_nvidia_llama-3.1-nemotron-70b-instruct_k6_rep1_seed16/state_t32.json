    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant rust and body damage, and the interior shows heavy wear and several tears in the upholstery. Mechanically, the car requires major repairs to be fully operational.",
      "price": 6000.0,
