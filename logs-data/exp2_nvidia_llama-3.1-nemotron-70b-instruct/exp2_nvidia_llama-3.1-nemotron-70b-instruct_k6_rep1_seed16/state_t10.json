    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It shows visible wear on the exterior and interior surfaces. While the car is functional, it may require some mechanical attention or maintenance in the near future. All systems are currently operational but reflect the age and usage of the vehicle.",
      "price": 25500.0,
