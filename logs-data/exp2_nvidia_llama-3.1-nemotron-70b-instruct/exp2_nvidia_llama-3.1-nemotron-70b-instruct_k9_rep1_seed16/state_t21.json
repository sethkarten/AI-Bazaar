      "quality_value": 0.1,
      "timestep_posted": 21
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this exemplary vehicle, maintained in pristine showroom condition. This unit represents the pinnacle of its class, featuring an impeccable exterior finish and a flawlessly preserved interior. Meticulously inspected to ensure it meets our highest standards of mechanical and aesthetic excellence, this vehicle offers an uncompromising driving experience for the discerning collector.",
      "price": 48900.0,
