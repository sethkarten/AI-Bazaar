    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 997.2 Carrera S is a definitive example of naturally aspirated precision. It features the 3.8L DFI flat-six engine, delivering linear power through a 7-speed PDK dual-clutch gearbox with instantaneous shift points. The chassis is bolstered by PASM (Porsche Active Suspension Management), providing exceptional damping control and roll stiffness. The vehicle exhibits zero bore scoring symptoms, maintains factory-spec oil pressure, and the limited-slip differential remains tight. Finished in concours-level paint with a pristine undercarriage, this unit shows no signs of heat cycling fatigue or bushing degradation. A mechanically synchronized, collector-grade machine.",
      "price": 48900.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. Clean title. Full service history included.",
      "price": 43000.0,
