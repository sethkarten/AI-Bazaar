      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! Are you ready for your dream ride? I\u2019m honestly so excited to show you this car\u2014it is in absolutely stunning, showroom-ready condition! I\u2019ve babied it since the day I got it, and it looks and drives just like it did when it first rolled off the lot. It\u2019s been kept spotless and runs like a dream. You really have to see it in person to appreciate how perfect it is. Feel free to reach out with any questions\u2014I'd love to see it go to someone who will enjoy it as much as I have!",
      "price": 46500.0,
      "reputation": 0.8,
