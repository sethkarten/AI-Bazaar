    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! \ud83d\ude97 I'm looking to find a new home for this awesome ride. It\u2019s been super reliable and is still in really great shape for its next adventure! Whether you're commuting or heading out on a road trip, it's ready to go and looks fantastic. I've taken good care of it, and I'm sure you'll love it as much as I have. Let\u2019s get you behind the wheel!",
      "price": 32500.0,
      "reputation": 0.6,
