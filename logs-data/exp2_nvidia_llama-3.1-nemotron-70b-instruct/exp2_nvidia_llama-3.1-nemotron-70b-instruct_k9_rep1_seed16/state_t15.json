    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a meticulously maintained vehicle that exemplifies mechanical reliability and sophisticated design. This unit has undergone a comprehensive multi-point inspection to ensure it meets our rigorous standards for performance and safety. Featuring a refined interior and a well-preserved exterior, this automobile offers a superior driving experience for the discerning professional who values both dependability and aesthetic appeal. A premier selection for those seeking quality and long-term value.",
      "price": 36500.0,
      "reputation": 0.8,
