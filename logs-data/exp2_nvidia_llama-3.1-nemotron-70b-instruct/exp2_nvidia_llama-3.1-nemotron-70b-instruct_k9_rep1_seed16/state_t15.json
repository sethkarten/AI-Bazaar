    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 features the legendary S54 3.2L inline-six, delivering linear power through six individual throttle bodies and Double VANOS variable valve timing. The high-revving powerplant is mated to a crisp 6-speed Getrag manual transmission and a factory M-Variable differential lock. Recent preventative maintenance includes a comprehensive VANOS overhaul and subframe reinforcement to ensure optimal structural rigidity. The suspension retains its factory-tuned balance, providing exceptional turn-in and lateral grip. While showing honest signs of use consistent with its mileage, the drivetrain remains mechanically robust with a clean oil analysis history.",
      "price": 32500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 15
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle in good condition. Well-maintained engine. Clean interior and exterior. Reliable daily driver. No mechanical issues.",
