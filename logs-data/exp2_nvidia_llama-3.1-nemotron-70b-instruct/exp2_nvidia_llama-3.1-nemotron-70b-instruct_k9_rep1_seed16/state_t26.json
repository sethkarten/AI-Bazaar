    },
    {
      "id": "sybil_9_listing_2",
      "firm_id": "sybil_9",
      "description": "Offered is a mechanically robust E46 M3 featuring the high-revving S54 inline-six engine equipped with individual throttle bodies. This example features the desirable Getrag 6-speed manual gearbox, providing tactile engagement and precise gear selection. The chassis remains composed with a factory-spec limited-slip differential and recently inspected subframe mounting points. Maintenance is up to date, including a VANOS system refresh and valve clearance adjustment, ensuring the double-VANOS timing remains sharp across the powerband. A true driver\u2019s car with excellent throttle response and structural integrity.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Used car. Good condition. Well-maintained. Clean title. Inspections welcome.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
