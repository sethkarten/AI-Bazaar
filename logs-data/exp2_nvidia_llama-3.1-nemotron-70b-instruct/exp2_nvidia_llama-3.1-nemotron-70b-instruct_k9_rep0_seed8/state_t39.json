    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It is functional and runs, but it shows noticeable wear on the interior and exterior. Some mechanical components may require attention or maintenance in the near future to ensure continued reliability.",
      "price": 18000.0,
      "reputation": 1.0,
