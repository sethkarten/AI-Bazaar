    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition and is mechanically sound. It has been well-maintained throughout its use. There is some minor cosmetic wear visible on both the interior and exterior, but all systems are functioning properly.",
      "price": 34500.0,
      "reputation": 1.0,
