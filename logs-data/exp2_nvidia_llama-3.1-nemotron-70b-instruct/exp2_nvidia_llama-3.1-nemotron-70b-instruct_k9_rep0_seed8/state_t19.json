    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained and is mechanically sound, though there are minor signs of cosmetic wear on the interior and exterior. All features are functional.",
      "price": 34000.0,
      "reputation": 1.0,
