    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is a meticulously maintained vehicle that exemplifies both performance and reliability. This unit has undergone a comprehensive multi-point inspection to ensure it meets our rigorous standards for mechanical integrity and aesthetic appeal. Offering a sophisticated driving experience, it represents an exceptional value for the discerning buyer who prioritizes quality and proven longevity.",
      "price": 36500.0,
