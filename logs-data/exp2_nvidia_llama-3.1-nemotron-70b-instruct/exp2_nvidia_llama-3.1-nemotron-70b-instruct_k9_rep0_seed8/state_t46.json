    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained and is mechanically sound. There is some minor cosmetic wear on the interior and exterior, but all systems are functioning properly.",
