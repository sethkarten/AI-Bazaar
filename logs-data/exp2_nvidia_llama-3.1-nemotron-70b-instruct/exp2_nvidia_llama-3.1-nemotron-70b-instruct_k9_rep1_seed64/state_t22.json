      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m honestly so sad to let this beauty go, but it\u2019s time for someone else to enjoy it! This car is in absolutely incredible shape\u2014honestly, it feels like it just left the showroom. It's been pampered, kept in a garage, and looks stunning inside and out. If you're looking for something that feels brand new without the brand-new price tag, this is the one for you! Feel free to reach out with any questions\u2014I'd love to see it go to a great home!",
      "price": 43500.0,
