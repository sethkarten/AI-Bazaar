      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a distinguished example of automotive engineering, this vehicle has been maintained to a high standard of mechanical and aesthetic integrity. It offers a refined driving experience, characterized by a responsive powertrain and a well-preserved interior. This unit represents an ideal acquisition for the professional seeking a reliable, high-performance vehicle that balances sophisticated styling with proven durability. Each component has been inspected to ensure it meets our rigorous criteria for quality and roadworthiness.",
      "price": 34800.0,
