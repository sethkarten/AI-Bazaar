    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This meticulously maintained vehicle represents a premier opportunity for the discerning motorist. Exhibiting a refined exterior and a well-appointed interior, the automobile has been subject to rigorous standards of care to ensure consistent performance and reliability. Its robust powertrain and sophisticated handling characteristics offer a superior driving experience, making it an exceptional acquisition for those who demand both prestige and value in a pre-owned vehicle. We invite you to experience the caliber of this exceptional motorcar firsthand.",
      "price": 36800.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
