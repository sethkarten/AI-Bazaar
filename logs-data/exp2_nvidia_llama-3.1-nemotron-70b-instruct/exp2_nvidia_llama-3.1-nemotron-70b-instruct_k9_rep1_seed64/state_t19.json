    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m looking for a new home for my trusty ride. It\u2019s been such a reliable car for me and it still runs like a dream! It\u2019s in really solid shape and has plenty of life left in it\u2014perfect for someone who wants a dependable vehicle without the brand-new price tag. I\u2019ve taken great care of it, and I\u2019m sure you\u2019ll love it as much as I have. Come take it for a spin and see for yourself!",
      "price": 29500.0,
      "reputation": 0.4,
