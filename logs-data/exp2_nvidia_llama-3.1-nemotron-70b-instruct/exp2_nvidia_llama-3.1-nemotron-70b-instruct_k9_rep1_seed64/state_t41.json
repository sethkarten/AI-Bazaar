      "timestep_posted": 41
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Garage kept. Zero accidents. Original factory paint. Interior smells new. Clean title in hand. Inspections welcome.",
