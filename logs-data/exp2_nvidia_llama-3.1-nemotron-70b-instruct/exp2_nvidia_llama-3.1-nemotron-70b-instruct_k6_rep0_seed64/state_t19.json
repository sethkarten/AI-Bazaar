    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and minor dents. The interior shows moderate wear and some staining on the upholstery. The car is functional, though it may require some upcoming maintenance for optimal performance.",
      "price": 20000.0,
