    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has several visible scratches and a few small dents. The interior shows noticeable wear and some staining on the upholstery. Mechanically, the car is operational but may require some maintenance in the near future.",
      "price": 20000.0,
