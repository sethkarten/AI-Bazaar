      "timestep_posted": 47
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "$34,000 - This vehicle is in good condition. The exterior has some minor surface scratches but no major dents or rust. The interior is clean with light wear on the seats and dashboard. Mechanically, the car is well-maintained and performs reliably.",
      "price": 34000.0,
