    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "Available is a mechanically sorted E46 M3 featuring the legendary S54B32 power plant with individual throttle bodies and a linear 8,000 RPM redline. This example is equipped with the desirable 6-speed Getrag manual transmission and a factory M Variable Differential Lock. Technical highlights include a recently serviced Double-VANOS system, documented valve clearances, and proactive subframe reinforcement to ensure structural rigidity. The suspension geometry is maintained with refreshed bushings and upgraded dampers, offering the precise turn-in and communicative feedback expected of this chassis. A high-performance icon in excellent running order, ready for the apex.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_11_listing_3",
      "firm_id": "sybil_11",
      "description": "Used vehicle. Good condition. Well-maintained. Clean title. Non-smoker. Reliable daily driver.",
