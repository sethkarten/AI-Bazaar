    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey everyone! \ud83d\udc4b I\u2019m parting ways with my reliable ride, and it\u2019s honestly been such a joy to drive! It\u2019s in really solid shape, super dependable, and ready to hit the road with a new owner today. If you're looking for a great car that\u2019s been well-loved and is ready for its next adventure, this is the one! Shoot me a message if you want to come take it for a spin!",
      "price": 29900.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
