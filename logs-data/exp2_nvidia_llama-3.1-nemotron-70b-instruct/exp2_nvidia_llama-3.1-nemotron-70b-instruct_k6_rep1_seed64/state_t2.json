    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a masterclass in naturally aspirated performance, featuring the iconic S54 inline-six with its 8,000 RPM redline and individual throttle bodies. Mechanically flawless, the VANOS unit has been overhauled and rod bearings replaced as preventative maintenance. The chassis remains rigid with a reinforced rear subframe and factory-spec suspension geometry. Every gear engagement through the Getrag 6-speed is precise, feeding power to the variable M differential lock for surgical cornering. Presented in museum-grade condition with original paint depth and a pristine cabin, this is a turn-key collector piece for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 2
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Clean title. No accidents. Original paint. Garage kept. Service records available.",
      "price": 48500.0,
