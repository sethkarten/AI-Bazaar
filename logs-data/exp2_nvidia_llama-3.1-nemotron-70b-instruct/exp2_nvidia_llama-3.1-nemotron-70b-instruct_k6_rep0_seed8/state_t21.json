    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior and interior show no signs of wear or damage. All mechanical components and electronic systems are in perfect working order, and the car remains in factory-original state.",
      "price": 48000.0,
