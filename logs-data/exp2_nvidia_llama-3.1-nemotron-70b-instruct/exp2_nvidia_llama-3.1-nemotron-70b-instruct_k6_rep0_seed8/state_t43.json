    },
    {
      "id": "sybil_7_listing_1",
      "firm_id": "sybil_7",
      "description": "Hey there! I\u2019m honestly so sad to let this beauty go, but it\u2019s time for someone else to enjoy it. This car is an absolute dream\u2014I\u2019ve babied it since day one, and it seriously looks like it just rolled off the showroom floor. No scratches, a spotless interior, and it drives like a cloud! If you\u2019re looking for something that\u2019s been cared for with a lot of love, this is definitely the one for you. Come take a look, you won't be disappointed!",
      "price": 44500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
