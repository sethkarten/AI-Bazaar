    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. It shows moderate wear on the interior and several visible scratches and dents on the exterior. While the car is operational, it may require some upcoming maintenance or minor repairs.",
