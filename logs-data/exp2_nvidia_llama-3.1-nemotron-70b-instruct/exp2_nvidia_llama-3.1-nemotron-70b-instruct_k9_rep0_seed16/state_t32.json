    },
    {
      "id": "sybil_11_listing_2",
      "firm_id": "sybil_11",
      "description": "This 997.2 Carrera S is a benchmark of naturally aspirated performance, featuring the 3.8L Direct Fuel Injection (DFI) flat-six engine paired with a precision-gated 6-speed manual transmission. The mechanical state is impeccable, with a documented service history confirming optimal compression and zero bore scoring. Equipped with Porsche Active Suspension Management (PASM), the chassis delivers razor-sharp turn-in and exceptional lateral stability. The braking system features four-piston monobloc calipers and cross-drilled rotors with zero lip or glazing. Every factory VIN tag is present, and the undercarriage is free of fluid seepage, making this a true collector-grade specimen for the discerning driver.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 32
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Mint condition. Single owner. No accidents. Full service records included. Garage kept. Clean title.",
      "price": 43500.0,
      "reputation": 0.6,
      "quality": "poor",
