    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m looking to find a new home for my trusty ride. It\u2019s been such a reliable car and is still in really wonderful shape\u2014perfect for road trips or just zipping around town! It\u2019s been well-loved and well-maintained, so it\u2019s ready to hit the road with you today. Come take it for a spin and see for yourself!",
      "price": 34500.0,
      "reputation": 0.8,
