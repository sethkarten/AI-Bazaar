    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a peerless example of automotive excellence, this vehicle arrives in impeccable, showroom-ready condition. Meticulously preserved and showing no signs of compromise, it represents the definitive standard for its class. Every surface and mechanical component has been vetted to ensure a driving experience indistinguishable from its original delivery. This is a rare opportunity to acquire a collector-grade asset of undisputed pedigree.",
      "price": 48500.0,
      "reputation": 0.8,
