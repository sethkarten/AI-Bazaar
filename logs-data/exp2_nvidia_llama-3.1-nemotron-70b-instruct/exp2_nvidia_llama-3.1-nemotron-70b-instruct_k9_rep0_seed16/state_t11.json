      "timestep_posted": 11
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\udc4b I\u2019m honestly a little sad to see this beauty go, but it\u2019s time for someone else to enjoy it! This car is in absolutely incredible shape\u2014it looks and feels just like it did the day it rolled off the lot. I\u2019ve babied it since day one, keeping it garaged and spotless. If you're looking for something that\u2019s practically brand new without the dealership headache, this is the one for you! Come take a look, you won't be disappointed! \u2728",
      "price": 44900.0,
      "reputation": 0.7,
