    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available for the discerning driver is this BMW E46 M3, featuring the legendary S54 3.2L inline-six power plant. This high-revving engine utilizes individual throttle bodies and double VANOS variable valve timing to deliver linear power up to an 8,000 RPM redline. Power is sent to the rear wheels via a Getrag 6-speed manual transmission and an M-Variable Lock limited-slip differential. The chassis remains taut, benefiting from factory-spec damping and precise rack-and-pinion steering. Recent maintenance includes a comprehensive inspection of the subframe mounting points and a valve clearance adjustment. While showing honest signs of use consistent with its enthusiast pedigree, the mechanical integrity and throttle response remain sharp. Ideal for those seeking a pure, analog driving experience.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 13
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Well-maintained. Clean title. No mechanical issues. Cash only.",
      "price": 31500.0,
