    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior paint is flawless with no scratches, dents, or rust. The interior is in like-new condition with no signs of wear on the upholstery or carpets. All mechanical and electrical systems function perfectly.",
      "price": 48500.0,
