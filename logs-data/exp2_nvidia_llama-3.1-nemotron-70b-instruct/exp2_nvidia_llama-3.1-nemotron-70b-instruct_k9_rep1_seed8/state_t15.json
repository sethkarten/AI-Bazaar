    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is a concours-level 2004 BMW M3 (E46) featuring the legendary S54 3.2L inline-six engine, which utilizes six individual throttle bodies and a high-pressure Double-VANOS system to achieve a breathtaking 8,000 RPM redline. This example is equipped with the desirable Getrag 6-speed manual transmission and a variable M differential lock for optimal torque distribution. The chassis is in exemplary condition, with a documented subframe reinforcement and a suspension geometry that remains factory-tight. Every VIN tag is present, and the Carbon Black Metallic paint retains its deep, mirror-like luster. This is a mechanically synchronized, turn-key masterpiece designed for the discerning purist who demands peak atmospheric performance and structural integrity.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 15
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
