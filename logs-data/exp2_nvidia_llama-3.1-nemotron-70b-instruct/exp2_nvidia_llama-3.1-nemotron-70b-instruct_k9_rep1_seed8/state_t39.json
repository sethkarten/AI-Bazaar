      "timestep_posted": 39
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You seriously have to see this beauty in person\u2014it\u2019s basically brand new! I\u2019ve taken incredible care of it, and it\u2019s still in absolutely flawless, showroom-ready condition. If you\u2019re looking for a total gem that\u2019s been babied its whole life, this is definitely the one for you. It drives like a dream and looks even better. Let\u2019s get you behind the wheel!",
      "price": 43500.0,
