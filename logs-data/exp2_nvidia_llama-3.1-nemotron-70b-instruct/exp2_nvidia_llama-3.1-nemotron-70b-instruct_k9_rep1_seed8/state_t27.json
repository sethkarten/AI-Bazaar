      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this exceptional vehicle, preserved in impeccable showroom condition. This specimen exhibits no discernable wear, reflecting a history of meticulous maintenance and climate-controlled storage. From the flawless exterior finish to the pristine interior appointments, every detail adheres to the highest standards of automotive excellence. This represents a rare opportunity for the discerning collector to acquire a vehicle that remains indistinguishable from its original delivery state.",
      "price": 46500.0,
