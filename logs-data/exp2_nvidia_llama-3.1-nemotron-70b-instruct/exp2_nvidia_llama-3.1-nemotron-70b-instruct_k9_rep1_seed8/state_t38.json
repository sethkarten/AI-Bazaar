      "quality_value": 0.1,
      "timestep_posted": 38
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this exemplary vehicle, maintained to the highest standards of automotive preservation. This unit exhibits showroom-grade characteristics, featuring a flawless exterior finish and an interior entirely devoid of wear. Every mechanical component has undergone rigorous certification to ensure peak performance. For the discerning buyer who demands uncompromising quality and aesthetic perfection, this vehicle represents the pinnacle of its class.",
      "price": 48500.0,
