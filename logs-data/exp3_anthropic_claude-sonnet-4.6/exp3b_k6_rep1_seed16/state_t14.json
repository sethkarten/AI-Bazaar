    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exceptional vehicle, maintained to a showroom standard that defies its age. Every detail reflects a commitment to excellence, from the flawless exterior finish to the pristine, smoke-free interior. This is a rare opportunity to acquire a vehicle in truly impeccable condition, offering an uncompromising driving experience for the discerning collector or enthusiast.",
      "price": 48900.0,
      "reputation": 0.7,
