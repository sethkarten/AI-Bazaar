      "quality_value": 0.1,
      "timestep_posted": 2
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This collector-grade example boasts a high-revving, naturally aspirated 4.0L flat-six mated to a short-throw six-speed manual transmission. The mechanical integrity is absolute, featuring a factory-tuned limited-slip differential and a bespoke multi-link rear suspension geometry for optimal lateral stability. Braking is handled by four-piston monobloc calipers over cross-drilled rotors, showing zero thermal fatigue. With a pristine undercarriage and factory-spec compression ratios, this unit delivers a raw, analog driving experience with surgical precision.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 2
    },
    {
