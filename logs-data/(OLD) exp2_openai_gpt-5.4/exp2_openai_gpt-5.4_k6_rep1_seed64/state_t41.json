      "quality_value": 0.1,
      "timestep_posted": 41
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Runs. Drives. Honest cheap car with plenty of life left. Not pretty, but it gets the job done. Priced to move fast.",
