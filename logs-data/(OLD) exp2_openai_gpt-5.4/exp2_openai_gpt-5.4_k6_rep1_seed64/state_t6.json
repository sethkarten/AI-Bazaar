    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Affordable and straightforward, this vehicle is a practical choice for buyers seeking low-cost transportation or a solid project opportunity. It offers strong value for the price, with honest character consistent with its age and condition. A smart option for someone who wants dependable basic utility without stretching the budget.",
      "price": 5495.0,
