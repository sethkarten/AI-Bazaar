      "timestep_posted": 17
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Dependable transportation at an affordable price, this vehicle is a smart choice for buyers seeking value and utility without stretching the budget. It shows its age cosmetically, but offers solid everyday usability and a chance to own a vehicle at a highly accessible price point. An honest, straightforward option for commuting, errands, or a backup vehicle.",
      "price": 5900.0,
