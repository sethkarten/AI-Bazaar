      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Runs. Drives. Honest poor-condition car with real value left. Solid cheap ride or project. Priced to move fast.",
      "price": 7900.0,
