    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "Well-kept car in good overall condition. It shows normal signs of use for its age, but it presents well inside and out and runs and drives properly. Everything appears to be in solid shape overall, though buyers should expect typical minor wear consistent with a used vehicle.",
      "price": 34900.0,
