    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "Turn heads without breaking the bank in this full-of-character ride that still brings undeniable presence and everyday practicality. It has the kind of seasoned personality you can\u2019t fake\u2014perfect for someone who sees opportunity where others just see miles. Whether you need a budget-friendly commuter, a capable backup vehicle, or a rewarding project to make your own, this car offers an appealing starting point with standout value and plenty of story left to tell. A distinctive, honest vehicle for the buyer who appreciates grit, charm, and potential.",
      "price": 6950.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
