      "timestep_posted": 48
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "A true diamond-in-the-rough with old-school character, this car has the kind of presence that turns errands into little adventures. It carries the unmistakable charm of a well-traveled machine and offers a great opportunity for someone who appreciates a hands-on project, a budget-friendly runabout, or a platform with personality to spare. If you\u2019ve been looking for something affordable with style, story, and room to make it your own, this one is ready for its next chapter.",
      "price": 5200.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_5_listing_5",
