    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "A true diamond-in-the-rough with loads of personality, this car has the kind of honest, hard-earned character you just can\u2019t fake. It\u2019s the perfect canvas for someone who appreciates a dependable runabout, a weekend project, or simply an affordable ride with soul. There\u2019s a rugged charm here that tells a story, and for the right buyer, that story is just getting started. If you\u2019ve been looking for something budget-friendly with presence and potential, this one is absolutely worth a look.",
      "price": 5950.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 17
    },
    {
