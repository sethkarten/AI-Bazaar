      "timestep_posted": 30
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Honest little car being sold as-is \u2014 not a showroom queen, but it\u2019s an affordable way into a set of wheels for someone who doesn\u2019t mind giving it a bit of TLC. Great candidate for a project, parts, or a budget runabout, with plenty of life left for the right buyer. If you\u2019re after something cheap, straightforward, and full of potential, this could be well worth a look.",
      "price": 4900.0,
      "reputation": 1.0,
