      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Budget-friendly driver/project with great bones and plenty of potential. It starts, runs, and offers a mechanical feel that enthusiasts appreciate, with a powertrain that delivers usable performance and a chassis that still feels planted on the road. Not a showroom car, but a worthwhile platform for someone who wants an affordable entry point, a weekend fixer, or dependable basic transportation with character. Priced to reflect condition while leaving room for the next owner to improve and enjoy.",
      "price": 6950.0,
      "reputation": 0.8,
