    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "A car with grit, presence, and a story to tell. This one has the kind of well-worn charm that makes it feel like an honest companion\u2014ready for someone who sees potential, appreciates character, and wants a ride with real personality instead of showroom sameness. It\u2019s an ideal candidate for a budget-friendly daily, a project to make your own, or simply a dependable set of wheels with a bold, lived-in spirit. If you like your cars with soul, this one is worth a look.",
      "price": 5950.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 41
    },
    {
      "id": "sybil_5_listing_5",
