      "timestep_posted": 11
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "This car has the kind of lived-in character you can\u2019t fake\u2014honest, hardworking, and full of possibility for the right buyer. It\u2019s the sort of vehicle that feels like it still has stories left to tell, whether you need an affordable runabout, a project with personality, or a dependable spare to keep on hand. The body and cabin show their age, but that only adds to its rugged, no-nonsense appeal. If you appreciate value, potential, and a car with a little soul, this one is worth a look.",
      "price": 6800.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
