    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Looking for an affordable set of wheels or a handy little project? This car isn\u2019t perfect, but it\u2019s a straightforward budget-friendly option for someone who wants cheap transport, a fixer-upper, or a donor vehicle. It\u2019s being sold honestly as-is, and for the right buyer there\u2019s still plenty of value here. If you\u2019re practical, don\u2019t mind a bit of TLC, and want something priced to move, this could be a great fit.",
      "price": 3900.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
