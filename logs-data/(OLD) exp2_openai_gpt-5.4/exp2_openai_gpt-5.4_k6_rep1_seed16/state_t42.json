    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and priced to move, this vehicle offers straightforward transportation for the next owner who values affordability over perfection. It shows clear cosmetic and age-related wear consistent with its condition, but it remains a practical opportunity for a commuter, first-time buyer, or someone needing inexpensive backup transportation. An honest, low-cost option with real value for the price.",
      "price": 3950.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Looking for a cheap set of wheels that can still get the job done? This car isn\u2019t perfect, but it\u2019s an honest, budget-friendly option for someone who wants affordable transportation, a project, or a handy spare vehicle. It\u2019s got character, and for the right buyer there\u2019s plenty of value here at a price that leaves room to make it your own. If you want something inexpensive and straightforward, this could be a great fit.",
      "price": 5900.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Driver-grade project with solid enthusiast potential. The powertrain pulls through the rev range, the chassis feels planted, and it presents as a straightforward platform for someone who appreciates mechanical simplicity over cosmetics. Not perfect, but it starts, runs, and offers a usable foundation with plenty of character. A great budget entry for a hands-on owner looking for an affordable car with real upside.",
      "price": 7900.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Runs. Drives. Cheap way into a car today. Honest poor-condition driver with wear, flaws, and plenty of life for the right buyer. Priced to move fast.",
      "price": 4900.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "This car has the kind of lived-in character you can\u2019t fake\u2014an honest machine with stories in its sheet metal and plenty of road still left for the right owner. It\u2019s the sort of vehicle that makes a perfect budget-friendly runabout, weekend project, or dependable backup for someone who appreciates substance over polish. There\u2019s a rugged charm here, a chance to get behind the wheel without stretching your wallet, and maybe even make it your own along the way. If you like cars with grit, personality, and potential, this one is ready for its next chapter.",
      "price": 4900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Practical, affordable, and ready to be put to work, this vehicle is a solid choice for anyone seeking dependable basic transportation on a budget. It shows its age and use, but it still offers real value with a straightforward ownership experience and plenty of life for the right buyer. Ideal as an inexpensive commuter, first car, or backup vehicle, this is a chance to secure low-cost mobility at an accessible price.",
      "price": 5495.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    }
