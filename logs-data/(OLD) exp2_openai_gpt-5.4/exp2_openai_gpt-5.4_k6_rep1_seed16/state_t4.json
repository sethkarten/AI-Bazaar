      "quality_value": 1.0,
      "timestep_posted": 4
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "Exceptional mint-condition car that presents beautifully inside and out. The paint, body, and interior show extremely little wear, and it feels like a carefully preserved, very well-kept example rather than just an older used car. Everything about it shows pride of ownership, and buyers can expect a clean, standout vehicle that is ready to enjoy immediately. This is the kind of car that will appeal to someone looking for one of the nicest examples available.",
      "price": 45900.0,
      "reputation": 0.9,
      "quality": "mint",
