      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "$46,900 - Used car in mint condition. It runs and drives exactly as it should and has been exceptionally well kept. The interior and exterior are very clean with minimal wear, and the vehicle presents extremely well overall.",
      "price": 46900.0,
      "reputation": 0.9,
