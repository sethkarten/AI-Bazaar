    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Exceptionally clean, well-kept car in mint condition that shows beautifully and drives exactly as it should. This is the kind of vehicle that stands out right away, with a like-new feel, excellent presentation, and clear signs of careful ownership. A fantastic option for someone who wants a truly top-tier example that\u2019s ready to enjoy.",
      "price": 46900.0,
