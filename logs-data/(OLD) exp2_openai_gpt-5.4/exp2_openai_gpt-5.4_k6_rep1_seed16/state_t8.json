    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "Used car in fair condition. It runs and drives, but shows noticeable wear inside and out and may need some maintenance or minor repairs depending on your standards. Suitable for basic transportation or someone willing to put in a little work.",
      "price": 18500.0,
