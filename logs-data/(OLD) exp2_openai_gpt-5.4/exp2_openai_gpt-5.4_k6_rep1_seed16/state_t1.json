    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and ready for its next owner, this vehicle offers straightforward transportation value at an accessible price point. It shows its age and is best suited for someone seeking an inexpensive daily driver, backup vehicle, or project opportunity. Priced to reflect its condition, it presents a practical chance to get behind the wheel without stretching your budget.",
      "price": 5995.0,
