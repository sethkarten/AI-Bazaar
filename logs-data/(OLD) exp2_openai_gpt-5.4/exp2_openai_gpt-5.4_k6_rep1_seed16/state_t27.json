      "timestep_posted": 27
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "This car has the kind of character you notice right away\u2014the sort of honest, well-traveled machine that still turns an ordinary drive into something memorable. It\u2019s an ideal candidate for someone who appreciates a project, needs an affordable set of wheels, or sees the beauty in a vehicle with a story to tell. With timeless presence and plenty of potential left for the next owner to shape, it offers a chance to get into something distinctive at a budget-friendly entry point.",
      "price": 5900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
