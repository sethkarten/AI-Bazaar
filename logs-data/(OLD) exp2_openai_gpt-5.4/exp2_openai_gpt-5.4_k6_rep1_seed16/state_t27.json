    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Dependable, affordable transportation with straightforward value. This vehicle shows its age but starts, runs, and offers a practical option for a budget-conscious buyer who wants a usable car without the premium price tag. A sensible choice for commuting, a first car, or a backup vehicle.",
      "price": 7800.0,
