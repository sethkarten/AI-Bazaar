      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "This car has the kind of honest, road-worn character you notice right away\u2014the sort of machine that still has stories left to tell. It\u2019s an ideal find for someone who appreciates a vehicle with presence, a bit of grit, and plenty of opportunity to make it their own. Whether you need an affordable runabout, a hands-on project, or simply something with personality that stands apart from the bland and forgettable, this one delivers a distinctive charm that\u2019s hard to fake.",
      "price": 6900.0,
      "reputation": 0.7,
