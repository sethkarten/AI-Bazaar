      "timestep_posted": 18
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "A true diamond-in-the-rough with loads of personality, this car has the kind of honest, well-traveled character that makes every drive feel like the start of a story. It\u2019s an ideal fit for someone who appreciates value, enjoys a hands-on project, or just wants an inexpensive set of wheels with charm that can\u2019t be faked. With a bold presence and plenty of potential left to unlock, this is the kind of find that rewards vision and a little elbow grease. If you\u2019ve been looking for budget-friendly transportation with soul, this one is ready for its next chapter.",
      "price": 5950.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 18
    },
    {
