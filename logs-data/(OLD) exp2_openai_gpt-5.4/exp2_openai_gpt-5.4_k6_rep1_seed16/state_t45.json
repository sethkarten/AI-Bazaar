    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "Exceptionally clean, mint-condition vehicle that runs and drives exactly as it should and shows extremely well throughout. The body and paint present beautifully, the interior is very clean and well-kept, and it has clearly been cared for at a high level. This is the kind of vehicle that should impress buyers looking for a standout example with minimal visible wear and a strong overall presentation.",
      "price": 45900.0,
