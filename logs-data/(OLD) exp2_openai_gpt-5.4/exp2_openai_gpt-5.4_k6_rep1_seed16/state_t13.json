      "reputation": 0.9,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 13
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "A true diamond-in-the-rough with old-school character, this car has the kind of presence that turns a simple drive into a story. It\u2019s the perfect canvas for someone who appreciates patina, personality, and the satisfaction of bringing something special back to life. Whether you\u2019re hunting for an affordable project, a parts donor with soul, or just a budget-friendly set of wheels with unmistakable charm, this one offers opportunity in every panel. Priced to move and ready for its next chapter.",
      "price": 5900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 13
    },
    {
      "id": "sybil_5_listing_5",
