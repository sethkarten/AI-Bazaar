    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Reliable, affordable, and ready for its next owner. This is a solid budget-friendly car for someone who needs straightforward transportation or wants a great starter project. It\u2019s not perfect, but it\u2019s got plenty of life left and could be a fantastic fit for the right buyer. If you\u2019re after an honest car at a sensible price, this one is well worth a look.",
      "price": 5950.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Solid budget-friendly project with a strong-running powertrain and good bones. It starts, runs, and drives, with responsive steering, decent brake feel, and a drivetrain that still pulls cleanly through the rev range. Cosmetics show age and wear, but for someone wanting an affordable daily, weekend fixer, or platform to build, this one offers a lot of usable mechanical value. A straightforward, no-nonsense car with plenty of life left for the right owner.",
      "price": 5950.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_3_listing_3",
