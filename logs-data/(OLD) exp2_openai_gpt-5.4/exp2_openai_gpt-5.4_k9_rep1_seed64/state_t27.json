      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Budget-friendly and ready for its next chapter, this vehicle is a practical choice for a buyer looking for affordable transportation at an accessible price point. It shows wear consistent with age and use, but it still offers solid value for someone who wants a low-cost option with room to make it their own. A smart pick for a commuter, first-time buyer, or anyone seeking simple, economical motoring.",
      "price": 4950.0,
