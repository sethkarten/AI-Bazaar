      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Looking for an affordable set of wheels or a solid little project? This car isn\u2019t perfect, but it\u2019s a great chance to grab something budget-friendly with plenty of potential for the right buyer. It\u2019s being sold as-is, and at this price it could make a handy runaround, learner car, or weekend fixer-upper. If you\u2019re after honest value and don\u2019t mind giving it a bit of TLC, this one could be well worth a look.",
      "price": 4950.0,
      "reputation": 0.8,
      "quality": "poor",
