      "timestep_posted": 27
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Budget-friendly ride with plenty of life left for the right buyer. It\u2019s not a showpiece, but it starts, runs, and offers a practical option for someone needing inexpensive transportation or a solid project to tinker with. If you\u2019re looking for an honest car at a sensible price, this one is worth a look.",
      "price": 5900.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Strong-running project with solid drivetrain fundamentals and a surprisingly eager powerband. Starts, moves, and stops, with the kind of honest mechanical feel enthusiasts appreciate. The engine pulls cleanly, transmission engages as it should, and the chassis still feels like a worthwhile platform for a budget build, daily beater, or weekend wrenching project. Cosmetically rough and shows its age, but it has the bones: usable torque, dependable mechanical operation, and plenty of upside for someone who knows their way around a toolbox. Priced to move for the buyer who wants capability over polish.",
      "price": 6900.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_3_listing_3",
