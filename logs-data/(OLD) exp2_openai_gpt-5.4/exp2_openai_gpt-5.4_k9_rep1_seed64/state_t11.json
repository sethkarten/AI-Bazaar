    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "A true diamond-in-the-rough for the dreamer who loves a car with a story. This one has that unmistakable old-soul character\u2014the kind of machine that turns heads not because it\u2019s perfect, but because it feels alive. It\u2019s an ideal candidate for a hands-on project, a budget cruiser, or a creative build with plenty of personality waiting to be brought forward. If you appreciate potential, presence, and the satisfaction of giving a worthy car its next chapter, this is the kind of opportunity that doesn\u2019t come around often.",
      "price": 5900.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_5_listing_5",
