    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and priced to move, this vehicle offers an accessible way into dependable transportation. Best suited for a value-focused buyer who appreciates straightforward ownership, it delivers solid utility and everyday practicality at an attractive price point. A sensible opportunity for someone seeking affordable motoring without unnecessary extras.",
      "price": 5995.0,
