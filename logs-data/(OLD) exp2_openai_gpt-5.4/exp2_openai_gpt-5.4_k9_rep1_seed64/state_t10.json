      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Looking for a cheap set of wheels that can still get the job done? This car isn\u2019t pretty, but it\u2019s an affordable way into ownership and could be a great fit for someone handy, a commuter on a budget, or anyone needing basic transportation. Priced to sell and offered honestly for what it is\u2014a usable car with plenty of value for the right buyer.",
      "price": 3900.0,
