      "quality_value": 0.1,
      "timestep_posted": 29
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Strong project or budget-driver candidate with solid bones and a mechanical layout that\u2019s straightforward to service. The powertrain fires up, the chassis feels usable, and it has the kind of honest, well-used character that makes a great platform for someone who knows their way around maintenance and light reconditioning. Not a showpiece, but a capable car with real potential for a commuter, flip, or weekend revival. Priced to move for someone who wants an affordable entry point and a car that still has some life left in it.",
      "price": 7450.0,
