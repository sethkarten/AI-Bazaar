      "quality_value": 0.4,
      "timestep_posted": 40
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and ready for its next owner, this vehicle offers straightforward value for anyone seeking affordable transportation or a solid project opportunity. It shows its age, but it remains a practical choice at a price that makes sense. A smart option for buyers who want usable mobility without a big upfront cost.",
