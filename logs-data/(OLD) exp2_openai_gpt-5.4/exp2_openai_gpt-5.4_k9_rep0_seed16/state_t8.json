      "timestep_posted": 8
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "Here\u2019s a car with real personality\u2014the kind of machine that still turns heads for its presence and feels like the start of someone\u2019s next great project. It has the lived-in charm of a vehicle that\u2019s seen the road and still has more story to tell, whether you\u2019re after a budget-friendly daily, a hands-on fixer-upper, or a dependable spare to keep around. There\u2019s an honest, rugged appeal here that\u2019s hard to fake, and for the right buyer, this is a chance to get into something with character at a very approachable price.",
      "price": 5900.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
