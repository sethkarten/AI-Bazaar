      "timestep_posted": 26
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Affordable and dependable transportation with solid value for a budget-conscious buyer. This vehicle shows its age cosmetically, but it remains a practical choice for daily driving, errands, or a first car. A straightforward, low-cost way to get on the road without stretching your budget.",
      "price": 4995.0,
