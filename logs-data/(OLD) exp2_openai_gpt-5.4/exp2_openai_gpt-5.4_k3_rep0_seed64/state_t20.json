    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Honest little runner that\u2019s perfect for someone after cheap, no-fuss motoring or a handy project. It\u2019s not a showpiece, but it starts, drives, and offers a lot of practical value for the money. Ideal as a first car, spare runabout, or something to tinker with on weekends. If you want an affordable car without spending a fortune, this one is well worth a look.",
      "price": 4950.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Reliable, no-frills driver with solid mechanical bones and plenty of usable life left. It shows cosmetic wear and age as expected, but the powertrain pulls cleanly, the transmission shifts as it should, and it starts, runs, and moves out confidently. Suspension and braking feel serviceable, making this a great low-cost commuter, winter beater, or straightforward project platform. If you want an affordable car with proven hardware and honest character rather than something dressed up, this is a compelling buy.",
      "price": 5900.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 20
    }
