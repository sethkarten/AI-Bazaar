    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and priced to move, this vehicle offers practical transportation for the value-focused buyer. It shows its age and wear, but remains a solid opportunity for someone seeking an inexpensive daily driver, backup vehicle, or project. A sensible choice for buyers who want straightforward value without overpaying. Offered at just $4,900.",
      "price": 4900.0,
      "reputation": 1.0,
