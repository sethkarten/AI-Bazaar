    {
      "id": "optimistic_7_listing_0",
      "firm_id": "optimistic_7",
      "description": "Solid fair-condition car with good driver potential at an appealing price. It presents decently and should be a usable, enjoyable car as-is, though it does show age and wear in both appearance and overall condition. A great fit for someone looking for an honest, affordable entry point with room to improve over time.",
      "price": 16900.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 21
    },
    {
      "id": "detailed_4_listing_0",
      "firm_id": "detailed_4",
      "description": "Offered at $46,900, this vehicle is in mint condition and presents exceptionally well inside and out. The paint, body, interior, and trim show extremely little wear, and it has clearly been very well cared for. It runs and drives as it should, feels tight and clean on the road, and needs nothing to be enjoyed right away. If you're looking for an older vehicle in outstanding, hard-to-find condition, this is a very strong example.",
      "price": 46900.0,
      "reputation": 1.0,
      "quality": "mint",
      "quality_value": 1.0,
      "timestep_posted": 21
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and priced to move, this vehicle offers straightforward transportation at an accessible price point. It shows its age cosmetically, but it remains a practical choice for a buyer seeking dependable basic mobility without a major investment. A sensible opportunity for someone who values affordability and utility over flash.",
      "price": 4950.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 21
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Honest little car that\u2019s priced for someone who wants simple, affordable wheels without spending a fortune. It\u2019s in rough shape cosmetically and shows its age, but it still has plenty of potential for a handy buyer, first project, or cheap get-around. If you\u2019re looking for something inexpensive with a straightforward, no-nonsense vibe, this could be a great fit.",
      "price": 6900.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 21
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Solid budget-friendly driver/project with a tough, no-nonsense mechanical feel and plenty of usable life for the right buyer. Engine starts, runs, and pulls respectably, transmission engages as it should, and the car offers a simple platform that\u2019s easy to wrench on and inexpensive to keep moving. Not a showroom piece, but a practical option for someone who wants affordable transportation, a backup vehicle, or a project with honest fundamentals. Great value for a buyer who understands used cars and doesn\u2019t mind cosmetic/mechanical age-related needs.",
      "price": 5900.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 21
    }
