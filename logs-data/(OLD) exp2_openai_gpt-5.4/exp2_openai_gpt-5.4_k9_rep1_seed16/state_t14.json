      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Solid project or budget driver with a strong-running engine, responsive automatic transmission, and a chassis that still feels composed on the road. Starts, moves, and stops, with the kind of straightforward mechanical layout that makes it attractive for an enthusiast, commuter backup, or light restoration candidate. Cosmetic wear and age-related flaws are present, but the fundamentals give you a capable platform with plenty of usable life and upside for the next owner.",
      "price": 7900.0,
