    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and ready for its next owner, this vehicle offers an affordable way into dependable transportation. It shows wear consistent with age and use, but presents a strong value for someone seeking a practical daily driver, work car, or project opportunity. A smart buy for shoppers who want straightforward utility at an accessible price.",
      "price": 5900.0,
