    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Affordable and straightforward, this vehicle offers dependable basic transportation at a budget-friendly price. It shows its age cosmetically and is best suited for a buyer who values practicality, low upfront cost, and the chance to own a vehicle without overspending. A great fit for commuting, a first car, or a project-minded shopper looking for solid value.",
      "price": 4950.0,
      "reputation": 0.7,
