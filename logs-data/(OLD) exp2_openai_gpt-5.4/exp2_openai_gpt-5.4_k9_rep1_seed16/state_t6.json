      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Solid budget-friendly driver with a strong-running powertrain and a chassis that still feels composed on the road. It shows its age cosmetically and will benefit from continued sorting, but it remains a great candidate for someone looking for dependable transportation, a weekend project, or an affordable platform to improve over time. Engine pulls well, transmission does its job, and the car offers good value for a hands-on buyer who appreciates mechanical substance over showroom looks. Priced to move and well worth a look if you want an inexpensive car with usable life left in it.",
      "price": 6950.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
