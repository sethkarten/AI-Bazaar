      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Looking for an affordable set of wheels with plenty of life left for the right person? This car is being sold as a budget-friendly option and would suit someone handy, a first-time buyer, or anyone needing cheap transport or a project. It\u2019s not perfect, but it has a lot of potential and could be a great value for someone who knows what they\u2019re looking at. Priced to sell and offered honestly.",
      "price": 4900.0,
      "reputation": 1.0,
