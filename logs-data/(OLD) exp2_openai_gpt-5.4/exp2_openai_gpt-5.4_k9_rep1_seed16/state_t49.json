      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "A straightforward, budget-friendly vehicle that offers an accessible entry point for daily driving, spare transportation, or a light project. Priced to reflect its condition, it still presents a solid value for buyers who want dependable basics without overpaying. An honest opportunity to get behind the wheel at a very approachable price.",
