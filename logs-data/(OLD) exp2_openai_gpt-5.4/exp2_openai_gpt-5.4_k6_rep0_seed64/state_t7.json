    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and ready for its next chapter, this vehicle offers solid basic transportation at an accessible price point. It shows its age and will benefit from cosmetic and mechanical attention, but for the right buyer it represents a practical opportunity to get into a vehicle without overspending. A straightforward value play for commuters, first-time buyers, or anyone looking for an inexpensive project.",
      "price": 5995.0,
