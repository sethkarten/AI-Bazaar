      "quality_value": 0.1,
      "timestep_posted": 7
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Honest little car that\u2019s not winning any beauty contests, but it\u2019s a budget-friendly option for someone who needs simple, affordable wheels. Great fit for a handy buyer, a first project, or just something inexpensive to get from A to B. If you\u2019re after value and don\u2019t mind giving it a bit of TLC, this one could be a really worthwhile find.",
      "price": 5950.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 7
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Driver-grade project with solid bones and plenty of usable life left. Starts, runs, and moves out well, with an engine that pulls cleanly and a drivetrain that feels straightforward and honest. Not a show car and it has cosmetic wear, age-related flaws, and needs finishing work, but it presents as a worthwhile budget buy for someone who wants dependable transportation, a shop truck, or a platform to sort and improve over time. A practical, affordable entry point with good parts value and real upside for the next owner.",
      "price": 7900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 7
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Runs. Drives. Cheap entry car with honest wear. Priced to move fast. First serious buyer gets it.",
      "price": 5900.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 7
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "A true diamond-in-the-rough with unmistakable presence, this car has the kind of lived-in character you just can\u2019t fake. It\u2019s the sort of machine that turns heads not because it\u2019s perfect, but because it has a story to tell\u2014and plenty of road still left in it for the next owner with vision. Whether you\u2019re after an affordable runabout, a hands-on project, or a platform with personality, this one offers a rare chance to own something with real soul at an approachable entry point. If you appreciate potential and don\u2019t mind a car that wears its journey honestly, this could be the one that rewards you.",
      "price": 5900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 7
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Affordable, straightforward transportation with plenty of potential. This vehicle is best suited for a buyer seeking a budget-friendly commuter, project car, or practical backup vehicle. It offers strong value for the money and a chance to get into a vehicle at an accessible price point. A sensible option for someone who appreciates opportunity and doesn't mind a little cosmetic or mechanical attention.",
      "price": 4950.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 7
    }
