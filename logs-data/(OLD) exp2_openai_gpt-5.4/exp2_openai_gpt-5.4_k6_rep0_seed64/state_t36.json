    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Clean, well-kept good-condition example that presents nicely and has clearly been cared for. It shows well inside and out, with a tidy overall appearance and the normal light wear you\u2019d expect for its age. A solid, attractive car that still has plenty to offer its next owner.",
      "price": 33900.0,
      "reputation": 1.0,
