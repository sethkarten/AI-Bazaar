    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Clean, honest driver with a lot to like for someone looking to get into the hobby at a more approachable price. This car shows its age and is in fair overall condition, with cosmetic wear and likely some items that a hands-on owner will want to improve over time, but it still offers solid appeal as an enjoyable project or weekend cruiser. A great candidate for someone who appreciates a car you can drive, tinker with, and make better as you go.",
      "price": 18950.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 38
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "A straightforward, budget-friendly vehicle that offers dependable transportation value for the right buyer. It shows its age cosmetically, but presents an opportunity for someone seeking an inexpensive daily driver, backup vehicle, or practical project. Priced to reflect condition and deliver strong value, this is an honest offering for shoppers who appreciate affordability and potential.",
      "price": 4950.0,
      "reputation": 0.9,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 38
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Budget-friendly and full of potential, this car is a great option for someone who wants affordable wheels, a project, or a handy runaround. It\u2019s being sold in rough shape and priced accordingly, but it still has plenty to offer the right buyer who doesn\u2019t mind giving it some TLC. If you\u2019re after something cheap and straightforward with room to make it your own, this could be a solid little find.",
      "price": 4900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 38
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Solid project car with strong mechanical character and plenty of upside for the next owner. The engine starts up and shows good willingness under load, the transmission engages, and the chassis still feels like a capable platform with a lot of life left in it. Not a showpiece, but an honest driver/project with usable core components, appealing mechanical simplicity, and strong parts-or-repair value. Ideal for someone looking for an affordable entry point, weekend wrenching candidate, or budget commuter with potential.",
      "price": 4950.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 38
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Runs. Rough around the edges. Cheap way into a car, project, or parts donor. Priced to move fast.",
      "price": 6900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 38
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "Honest, seasoned, and full of grit, this car has the kind of road-worn character you can\u2019t fake. It\u2019s the perfect candidate for someone who wants dependable basic transportation, a budget-friendly runabout, or a hands-on project with real personality. If you appreciate a vehicle with stories in its steel and plenty of life left for the right owner, this one offers a practical way to get behind the wheel without spending big.",
      "price": 5495.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 38
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Affordable and straightforward, this vehicle offers a practical opportunity for buyers who want dependable basic transportation at a budget-conscious price. It shows its age and will best suit someone comfortable with cosmetic imperfections and the character that comes with a well-used car, but it remains a compelling value for a commuter, first car, or light project. If you're looking for an inexpensive way to get on the road without overpaying, this is a smart option worth a closer look.",
      "price": 5895.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 38
    }
