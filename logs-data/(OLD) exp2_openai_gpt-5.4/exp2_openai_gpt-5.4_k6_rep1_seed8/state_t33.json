    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "A practical, budget-friendly vehicle offering dependable basic transportation and strong value for the price. This car shows its age and is best suited for a buyer who wants an inexpensive daily driver, backup vehicle, or project opportunity. An honest offering with room for the next owner to make it their own.",
      "price": 4950.0,
      "reputation": 0.9,
