    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "Budget-priced vehicle being sold in poor condition. It has clear cosmetic wear inside and out, with visible dents, scratches, stains, and general signs of hard use. This is not a clean or turn-key car, and buyers should expect mechanical issues, deferred maintenance, and reconditioning needs. Best suited for someone looking for a cheap project, parts vehicle, or basic transportation with repairs in mind.",
      "price": 4900.0,
      "reputation": 1.0,
