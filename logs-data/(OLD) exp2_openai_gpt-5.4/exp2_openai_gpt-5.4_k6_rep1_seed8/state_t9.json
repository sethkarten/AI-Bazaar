      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "A car with real personality, this ride has the kind of lived-in character that turns heads for all the right reasons. It\u2019s an honest, affordable option for someone who wants dependable basic transportation, a weekend project, or a platform to make their own. There\u2019s a rugged charm here that budget-minded buyers and tinkerers alike will appreciate\u2014simple, approachable, and full of possibility. If you\u2019ve been looking for inexpensive wheels with presence and potential, this one is ready for its next chapter.",
      "price": 5900.0,
      "reputation": 0.8,
