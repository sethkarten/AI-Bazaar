      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Solid budget-friendly driver with strong project potential. This car shows its age cosmetically, but it still offers dependable basic transportation and a powertrain that feels willing on the road. The engine starts up, pulls through the rev range, and the chassis remains straightforward and easy to work on, making it a great candidate for someone who appreciates mechanical simplicity. Ideal for a commuter, first car, or weekend fixer-upper, with plenty of usable life left for the next owner who doesn\u2019t mind a few imperfections.",
      "price": 5900.0,
