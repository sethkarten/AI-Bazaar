    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Classic project car with loads of vintage character and a solid opportunity for the right hands. This is an honest poor-condition example that shows significant age, wear, and cosmetic needs throughout, and it should be bought expecting mechanical sorting and restoration work. That said, it has charm, presence, and a great starting point for someone looking for an affordable entry into a classic.",
      "price": 5900.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "Clean, honest good-condition vehicle that presents well and should make a solid daily driver. It shows normal minor wear for its age, but overall it has been kept up better than average, with a tidy interior, good overall cosmetics, and no major red flags expected for a vehicle in this condition. Buyers should expect a well-maintained, usable car that is nicer than a typical older driver, though not a flawless showpiece.",
      "price": 29900.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
      "timestep_posted": 49
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly opportunity with honest value. This vehicle is being offered as-is and is best suited for a buyer looking for affordable transportation, a project car, or a practical fixer-upper. It presents well for the price point and offers a chance to get into a vehicle at a very accessible cost. A smart buy for someone who recognizes potential and wants solid value.",
      "price": 4495.0,
      "reputation": 0.9,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Looking for an affordable set of wheels with plenty of potential? This car isn\u2019t perfect, but it\u2019s a solid opportunity for someone who wants a cheap runabout, a first project, or a handy spare vehicle. It\u2019s being sold honestly as a well-used car, and priced to reflect that, but there\u2019s still good value here for the right buyer. If you\u2019re practical, handy, or just after something budget-friendly, this could be a great fit.",
      "price": 6900.0,
      "reputation": 0.9,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Solid project car with a strong-running engine, responsive automatic transmission, and a drivetrain that still feels eager to work. Starts up, moves out well, and offers a good foundation for someone who wants an affordable daily, shop truck, or weekend fixer with useful life left in it. Cosmetic wear and age-related flaws are present, but the core mechanical package has honest potential and the chassis still delivers a capable, usable driving experience. Priced to sell for someone who knows how to spot a worthwhile budget build.",
      "price": 7900.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Cheap. Runs. Gets you from A to B. Not pretty, but priced to move. Great beater, work car, or project. First serious buyer takes it.",
      "price": 5900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_4_listing_4",
      "firm_id": "sybil_4",
      "description": "This is the kind of car with honest, road-worn character\u2014the sort of machine that still turns heads for its presence and promises a rewarding next chapter for the right owner. It has the unmistakable feel of a vehicle that\u2019s been part of real life, with plenty of personality left in it and strong potential as a budget runabout, weekend project, or creative restoration. If you appreciate vehicles with stories to tell and see opportunity where others see age, this one offers an affordable way to get into something memorable.",
      "price": 6900.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "A practical, budget-friendly vehicle offered with straightforward value in mind. This car shows its age, but it remains an affordable option for a buyer seeking dependable basic transportation, a starter vehicle, or a project with potential. Priced to reflect condition while still delivering real utility, it\u2019s a smart way to get on the road without overspending.",
      "price": 6950.0,
      "reputation": 0.9,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 49
    }
