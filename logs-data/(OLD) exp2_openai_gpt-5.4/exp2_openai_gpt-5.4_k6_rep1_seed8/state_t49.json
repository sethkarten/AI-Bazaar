    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "Fair overall condition. This car shows visible wear inside and out, with cosmetic flaws and signs of age that are typical for a used vehicle in this shape. It should be a serviceable driver, but buyers should expect an older, used-car presentation rather than a particularly clean example.",
      "price": 18900.0,
