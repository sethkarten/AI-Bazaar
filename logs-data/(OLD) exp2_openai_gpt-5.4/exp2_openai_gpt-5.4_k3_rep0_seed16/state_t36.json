    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and ready for its next owner, this vehicle offers a practical way to get on the road without overspending. Best suited for buyers seeking affordable transportation, a backup vehicle, or a project opportunity, it delivers solid value at an accessible price point.",
      "price": 4495.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Honest little runabout that\u2019s not winning any beauty contests, but it still has plenty to offer the right buyer. If you\u2019re after affordable wheels, a first car, or a handy project to tidy up over time, this one makes a lot of sense. It starts, drives, and does the job, with the kind of straightforward character you expect from a well-used car. Priced to be accessible and sold as a simple, no-nonsense option for someone who wants transport without spending a fortune.",
      "price": 5900.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_3_listing_2",
      "firm_id": "sybil_3",
      "description": "Strong-running used car with solid bones and a surprisingly willing drivetrain. The engine pulls cleanly, transmission engages as it should, and the chassis still feels composed enough to make this a great budget commuter, shop truck, or light project. It shows age cosmetically and will want some finishing work, but the fundamentals are there: dependable mechanical character, usable power delivery, and an honest platform that can be driven as-is while you sort the details. If you know how to spot value in a rough-around-the-edges vehicle, this one makes a lot of sense.",
      "price": 7950.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    }
