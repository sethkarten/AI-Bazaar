    {
      "id": "optimistic_7_listing_0",
      "firm_id": "optimistic_7",
      "description": "A solid, honest driver that offers a lot of enjoyment at an accessible price. This car shows the normal wear and age you\u2019d expect from a fair-condition example, but it still presents respectably and should appeal to someone looking for a usable car with character rather than a showpiece. A great opportunity to get into one at a sensible price.",
      "price": 19900.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 27
    },
    {
      "id": "optimistic_8_listing_0",
      "firm_id": "optimistic_8",
      "description": "Affordable fixer-upper with a low entry price for someone who needs basic transportation or a project car. This one is in rough overall condition with noticeable cosmetic wear and age-related issues, so it\u2019s best for a buyer who understands it will need attention. That said, it could still make sense for someone handy who wants inexpensive wheels and doesn\u2019t mind putting in some work.",
      "price": 3900.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "detailed_4_listing_0",
      "firm_id": "detailed_4",
      "description": "Solid candidate for a full restoration, parts car, or experienced hobbyist project. This example is not a nice driver in its current condition and should be approached as a poor-condition car needing significant work before regular road use. Expect visible age and wear throughout, including tired paint, worn interior materials, aged trim, and deferred maintenance. Buyers should plan on mechanical sorting, cosmetic reconditioning, and a thorough inspection of major systems before putting it back into service. Best suited for someone looking for an affordable entry point and willing to take on a substantial project.",
      "price": 5900.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "Solidly in project-car territory and being sold honestly in poor overall condition. The body and paint show heavy age and wear, with noticeable cosmetic flaws, and the interior is tired and will need attention. Expect deferred maintenance and the likelihood that it will need mechanical sorting before being considered a dependable driver. Best suited for someone looking for a restoration candidate, a budget project, or possibly a parts car depending on their goals.",
      "price": 4900.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and full of potential, this vehicle offers an accessible entry point for anyone seeking straightforward transportation or a solid project opportunity. It shows its age cosmetically and mechanically, but it still presents a practical value for the right buyer who appreciates a low upfront cost and room to make it their own. A sensible choice for commuting, spare-duty use, or hands-on improvement.",
      "price": 5950.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Looking for an affordable set of wheels with plenty of life left for the right person? This car isn\u2019t perfect, but it\u2019s an honest, budget-friendly option that could make a great runaround, project, or first car for someone handy. It shows its age and will need some TLC, but that\u2019s reflected in the price. If you want something cheap, straightforward, and worth a look, come check it out.",
      "price": 4200.0,
      "reputation": 0.9,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Solid budget-friendly car with a strong-running engine, responsive automatic transmission, and a chassis that still feels planted on the road. It shows cosmetic wear and age-related imperfections, but the core mechanicals make it a great commuter, shop truck, or starter project for someone who values function over flash. Starts, runs, and drives, with plenty of usable life left for the next owner. If you want an affordable vehicle with good bones and practical potential, this one is worth a look.",
      "price": 5950.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    }
