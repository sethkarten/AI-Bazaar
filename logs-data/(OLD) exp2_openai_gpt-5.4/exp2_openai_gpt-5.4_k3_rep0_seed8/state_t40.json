    {
      "id": "standard_2_listing_0",
      "firm_id": "standard_2",
      "description": "Mint condition. Exceptionally clean and very well kept inside and out, with minimal wear and a strong overall presentation. The interior is fresh, the exterior is in excellent shape, and the car shows the kind of care you would expect from a well-maintained example.",
      "price": 46900.0,
