    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and ready for its next owner, this vehicle offers a practical way to get on the road without a major investment. Best suited for buyers who value straightforward transportation and appreciate an honest, attractively priced opportunity. A sensible choice for commuting, errands, or as a second vehicle.",
      "price": 4900.0,
