      "quality_value": 0.4,
      "timestep_posted": 26
    },
    {
      "id": "detailed_4_listing_0",
      "firm_id": "detailed_4",
      "description": "Well-kept, honest good-condition example that shows nicely throughout and appears ready to enjoy. The paint, trim, glass, and interior present well overall, with the clean, solid look of a car that has been cared for, though it is not a show-quality or mint example. Expect a very presentable driver with some minor signs of age and use consistent with a good car, but nothing that takes away from its appeal or enjoyment.",
      "price": 34900.0,
