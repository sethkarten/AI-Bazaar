    {
      "id": "optimistic_8_listing_0",
      "firm_id": "optimistic_8",
      "description": "Exceptionally clean mint-condition car that\u2019s been very well cared for and shows beautifully inside and out. It presents like the kind of vehicle that\u2019s hard to find in this condition, with a clean, well-kept appearance and strong overall appeal. A great option for someone who wants a standout car without paying new-car money.",
      "price": 47900.0,
