      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 43
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "Honest project-grade vehicle being sold in poor condition. It runs and can be a workable budget buy, but buyers should expect significant cosmetic wear, a tired interior, and multiple issues consistent with a heavily used vehicle. This is not a clean or turnkey example, and it will likely need mechanical attention, repairs, and catch-up maintenance to be dependable. Best suited for someone looking for an inexpensive fixer-upper, parts vehicle, or a car they can improve over time.",
      "price": 4900.0,
