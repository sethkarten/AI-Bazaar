      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Budget-friendly and full of potential, this vehicle is an excellent opportunity for a handy buyer, first-time driver, or anyone seeking affordable transportation at a great value. It shows its age cosmetically, but offers solid utility and a chance to own at a very approachable price point. A practical choice for someone who appreciates straightforward value and room to make it their own.",
