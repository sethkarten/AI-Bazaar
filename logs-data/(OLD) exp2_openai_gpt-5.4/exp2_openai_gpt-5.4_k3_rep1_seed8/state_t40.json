      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 40
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Looking for an affordable set of wheels with plenty of character? This car isn\u2019t perfect, but it\u2019s a solid budget-friendly option for someone who wants basic transportation, a project, or a handy spare vehicle. It shows its age and has some wear, but that also means no surprises about it trying to be something it\u2019s not. If you want an honest car at a sensible price and don\u2019t mind giving it a little TLC, this could be a great fit.",
      "price": 4950.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 40
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Solid project car with a strong-running engine, responsive automatic transmission, and a drivetrain that still pulls cleanly. Shows its age cosmetically and will want reconditioning, but it remains a usable platform with good bones for someone who appreciates mechanical simplicity. Suspension and steering feel serviceable, braking is functional, and it has the kind of honest wear you\u2019d expect from a driver that hasn\u2019t been pampered. Great candidate for a budget daily, weekend tinkering, or restoration-minded buyer looking for an affordable entry point.",
      "price": 6900.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 40
    }
