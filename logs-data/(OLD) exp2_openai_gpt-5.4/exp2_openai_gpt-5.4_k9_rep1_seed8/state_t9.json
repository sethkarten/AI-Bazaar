      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "A straightforward, budget-friendly vehicle that offers dependable transportation value for the right buyer. This car shows its age and would benefit from some cosmetic and mechanical attention, but it presents a practical opportunity for someone seeking an inexpensive daily driver, backup vehicle, or project. Priced to move and sold as-is, with strong value for shoppers who know how to spot potential.",
