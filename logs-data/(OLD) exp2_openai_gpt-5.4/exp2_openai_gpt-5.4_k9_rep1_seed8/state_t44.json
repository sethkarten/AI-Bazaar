    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Clean title and a great budget-friendly option for someone who wants dependable wheels without spending a fortune. It\u2019s not a showroom car, but it starts up, gets you where you need to go, and has a lot of value for a practical buyer, commuter, or handy person looking for an affordable ride. I\u2019m a straightforward seller and happy to answer questions so you know exactly what you\u2019re getting.",
      "price": 6900.0,
      "reputation": 0.9,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 44
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Tough, honest project car with solid mechanical bones and plenty of upside for the right buyer. Engine fires up and runs, transmission engages, and it has the kind of straightforward, analog chassis that\u2019s getting harder to find. Not a showpiece and it wears its age, but it\u2019s a great candidate for a budget build, parts runner, or weekend revival. If you know your way around maintenance and don\u2019t mind cosmetic/mechanical catch-up, there\u2019s real value here in a usable platform with good enthusiast potential.",
      "price": 5900.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 44
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Budget-friendly and ready to move. Used, rough around the edges, priced to sell fast. Great cheap ride or project car.",
      "price": 4900.0,
