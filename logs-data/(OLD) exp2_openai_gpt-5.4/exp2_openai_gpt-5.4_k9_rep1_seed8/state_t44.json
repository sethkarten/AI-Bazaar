    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Affordable and straightforward, this vehicle offers dependable transportation at an excellent value for a budget-conscious buyer. It shows its age cosmetically and is best suited for someone seeking practical, low-cost mobility or a solid project opportunity. A great chance to get behind the wheel without stretching your budget.",
      "price": 4950.0,
