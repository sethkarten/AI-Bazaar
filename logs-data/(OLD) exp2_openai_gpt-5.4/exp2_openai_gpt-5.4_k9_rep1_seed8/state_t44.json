      "timestep_posted": 44
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Honest little car with plenty of life left for the right buyer. It\u2019s not a showpiece and would suit someone after cheap runabout duties, a first project, or spare wheels without spending big money. Starts, drives, and offers a straightforward, affordable way into motoring. If you\u2019re realistic and handy, there\u2019s good value here.",
      "price": 4950.0,
