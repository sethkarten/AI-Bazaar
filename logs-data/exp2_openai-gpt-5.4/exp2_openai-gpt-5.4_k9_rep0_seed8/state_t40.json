    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this meticulously maintained vehicle, which exemplifies a commitment to both mechanical integrity and aesthetic preservation. This automobile offers a refined driving experience, characterized by consistent performance and a well-appointed interior. Having undergone a comprehensive professional assessment, it stands as a testament to responsible ownership and rigorous care. We invite serious inquiries to appreciate the exceptional value and reliability this motorcar provides.",
      "price": 36500.0,
      "reputation": 0.8,
