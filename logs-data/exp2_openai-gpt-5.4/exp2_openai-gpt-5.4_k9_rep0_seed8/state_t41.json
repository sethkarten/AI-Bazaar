    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting an uncompromising example of automotive excellence. This vehicle remains in pristine, showroom condition, having been maintained to the highest standards of preservation. Its flawless exterior and immaculate interior reflect a pedigree of careful ownership. For the discerning collector or enthusiast who demands nothing less than perfection, this offering represents an investment-grade acquisition of rare caliber.",
      "price": 47500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
