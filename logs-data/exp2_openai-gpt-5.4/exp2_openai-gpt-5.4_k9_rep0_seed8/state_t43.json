    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. It has significant mechanical issues and extensive wear on both the interior and exterior. Major repairs are required for it to be operational.",
      "price": 4500.0,
      "reputation": 1.0,
