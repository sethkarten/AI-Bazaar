    },
    {
      "id": "sybil_5_listing_1",
      "firm_id": "sybil_5",
      "description": "Hey there! You have to see this absolute beauty in person! Honestly, it's like it just rolled off the showroom floor\u2014the paint is flawless and the interior still has that brand-new smell. I've taken incredible care of it, and it drives like an absolute dream. If you're looking for perfection without the new-car price tag, this is the one for you. Come by and take it for a spin, you're going to love it!",
      "price": 44900.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
