    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a 2004 BMW M3 (E46) featuring the high-revving S54 3.2L inline-six engine equipped with individual throttle bodies. This example utilizes the desirable 6-speed Getrag manual transmission, offering precise gear selection and an engaging torque curve. Significant mechanical stewardship includes a comprehensive VANOS system refresh and proactive reinforcement of the rear subframe mounting points to address known chassis harmonics. The M Variable Differential Lock provides consistent traction, while the suspension geometry remains tight for sharp turn-in. Finished in Carbon Black, the paint and interior show minor wear consistent with a well-loved driver\u2019s car, but the powertrain remains robust and responsive. A mechanically sound, analog performance icon ready for the next enthusiast.",
      "price": 34500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2019 Sedan. Mechanically sound. Regular maintenance history. Clean interior. Minor exterior wear. Title in hand.",
      "price": 28500.0,
      "reputation": 0.3,
