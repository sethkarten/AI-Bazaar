    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I'm parting ways with my absolute pride and joy. This beauty is in incredible shape\u2014honestly, you'd think it just rolled off the lot! It's been pampered since day one, kept in a garage, and it drives like a total dream. If you're looking for something that looks and feels brand new without the showroom price tag, this is the one for you. Come take a look, you won't be disappointed!",
      "price": 43500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
