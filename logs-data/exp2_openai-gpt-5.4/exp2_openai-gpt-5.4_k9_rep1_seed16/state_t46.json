    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in fair condition and serves as a reliable, budget-friendly option for anyone seeking a dependable daily driver. Mechanically, the engine and transmission are solid and perform as expected, though you might notice some minor vibrations at highway speeds. The exterior shows typical signs of age, including several small door dings, some fading in the clear coat on the roof, and minor scuffs on the rear bumper. Inside, the cabin is clean but shows wear on the driver's seat bolster and some staining on the floor mats. It has been recently serviced with an oil change and tire rotation, making it ready for the road, even if it isn't a showpiece.",
      "price": 18500.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 46
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. It requires significant mechanical and cosmetic repairs and shows extensive wear throughout the interior and exterior. It is being sold as-is.",
      "price": 5500.0,
