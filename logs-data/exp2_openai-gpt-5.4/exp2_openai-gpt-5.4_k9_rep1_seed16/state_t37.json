      "quality_value": 0.1,
      "timestep_posted": 37
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presented for your consideration is a vehicle that exemplifies mechanical integrity and disciplined maintenance. This specimen has been thoroughly vetted to ensure it meets our rigorous standards for performance and roadworthiness. While displaying the natural character of a pre-owned asset, its overall condition remains commendable, offering a sophisticated driving experience and exceptional long-term value. We invite serious inquiries to inspect this well-preserved example of automotive engineering.",
      "price": 34800.0,
