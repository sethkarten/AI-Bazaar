    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hi there! I'm looking for a new home for my trusty ride. It\u2019s been such a reliable car and is still in really solid shape! It drives super smoothly and has been well-loved, so it's totally ready for many more adventures. If you're looking for something dependable and fun to drive, this is definitely the one for you! Feel free to reach out with any questions!",
      "price": 34500.0,
      "reputation": 0.5,
