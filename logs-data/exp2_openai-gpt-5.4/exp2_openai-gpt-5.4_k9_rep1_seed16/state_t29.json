      "quality_value": 0.1,
      "timestep_posted": 29
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are proud to present this exemplary specimen of automotive preservation. Maintained to the highest standards of excellence, this vehicle remains in showroom condition, exhibiting a flawless exterior profile and an interior that retains its original, pristine character. Every mechanical component has been rigorously vetted to ensure peak performance, mirroring its aesthetic perfection. This is an uncompromising, investment-grade opportunity for the discerning individual who seeks the pinnacle of its class. We invite serious inquiries for a private viewing of this peerless motorcar.",
      "price": 46500.0,
      "reputation": 0.6,
