    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a museum-quality 2004 BMW M3 (E46) featuring the legendary S54 3.2L inline-six engine with individual throttle bodies. This specimen boasts a flawless maintenance record, including a proactive VANOS overhaul and comprehensive subframe reinforcement to ensure structural integrity. The Getrag 6-speed manual transmission shifts with clinical precision, paired with a perfectly calibrated variable M-differential. The chassis remains taut with original geometry, benefiting from fresh bushings and a pristine undercarriage. This is a high-revving, naturally aspirated masterpiece in concours condition, optimized for the discerning purist who demands peak mechanical performance.",
      "price": 48500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
