      "quality_value": 0.1,
      "timestep_posted": 17
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an automotive specimen of unparalleled caliber. This vehicle has been maintained to an exacting standard, preserved in a state that mirrors its original factory delivery. Every surface, from the flawless exterior finish to the pristine interior appointments, reflects a commitment to absolute excellence. Mechanically superior and aesthetically indistinguishable from new, this offering represents a rare opportunity for the discerning enthusiast to acquire a showroom-grade asset.",
      "price": 46500.0,
