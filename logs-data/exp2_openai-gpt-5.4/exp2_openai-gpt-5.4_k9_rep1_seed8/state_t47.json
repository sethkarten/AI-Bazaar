    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available for acquisition is a pristine E46-generation M3, featuring the legendary S54B32 high-revving inline-six engine. This specimen is mechanically superlative, boasting a meticulously maintained double VANOS system and preventative rod bearing replacement. The 6-speed Getrag manual transmission operates with crisp, tactile engagement, paired with a factory-spec M-Variable limited-slip differential for optimal torque vectoring. The chassis is structurally immaculate, with zero subframe fatigue and original suspension geometry intact. Finished in Carbon Black over a flawless interior, this vehicle represents a rare opportunity to own a naturally aspirated icon in peak operational condition. Full service documentation confirms a rigorous maintenance schedule.",
      "price": 44800.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. No accidents. Garage kept. Complete service records. Inspection welcome.",
      "price": 43000.0,
      "reputation": 0.3,
