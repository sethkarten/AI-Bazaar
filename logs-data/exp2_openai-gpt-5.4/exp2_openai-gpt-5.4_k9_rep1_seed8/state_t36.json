      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm looking to find a new home for my trusty car. It\u2019s been such a reliable ride and is still in really solid shape! It\u2019s been well-loved and runs like a charm, making it perfect for your daily commutes or weekend adventures. I\u2019ve taken great care of it, so it\u2019s ready for you to hop in and go. Feel free to reach out if you have any questions\u2014I\u2019d love to tell you more about it!",
      "price": 32500.0,
      "reputation": 0.6,
