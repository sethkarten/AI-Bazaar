    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is a vehicle of unparalleled distinction. This specimen remains in showroom condition, having been curated and maintained to the most exacting standards. Every surface and mechanical component reflects a level of care synonymous with investment-grade quality. This is an exceptional opportunity for the discerning enthusiast to acquire a flawless example of automotive excellence.",
      "price": 48500.0,
