    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey everyone! Check out this absolute beauty! I've babied this car since day one and it is honestly in flawless shape\u2014it still smells like a new car! It's lived in a heated garage and looks like it just rolled off the showroom floor. You won't find one cleaner than this. I'm so sad to see it go, but I know the next owner is going to absolutely love it!",
      "price": 43900.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
