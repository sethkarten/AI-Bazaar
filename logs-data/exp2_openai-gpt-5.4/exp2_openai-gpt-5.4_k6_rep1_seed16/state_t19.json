      "quality_value": 0.1,
      "timestep_posted": 19
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a driver-spec E46 M3 featuring the high-revving S54 straight-six engine. This example is mechanically robust, boasting a recently serviced VANOS system and a reinforced rear subframe to ensure structural integrity under load. Power is delivered through a precise Getrag 6-speed manual gearbox to a tight factory limited-slip differential. The suspension geometry remains true with refreshed bushings, providing the tactile feedback expected of this chassis. While the finish shows minor road-wear, the internal mechanicals are dialed in for peak longitudinal and lateral performance. A turn-key enthusiast machine ready for the twisties.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 19
    },
    {
      "id": "sybil_3_listing_3",
