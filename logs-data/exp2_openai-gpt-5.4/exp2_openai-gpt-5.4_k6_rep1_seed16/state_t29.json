      "timestep_posted": 29
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior has a few minor scratches and small rock chips, but the paint remains in good shape overall. The interior is clean with light wear on the driver's seat and all electronics are functioning as intended.",
      "price": 34000.0,
      "reputation": 1.0,
