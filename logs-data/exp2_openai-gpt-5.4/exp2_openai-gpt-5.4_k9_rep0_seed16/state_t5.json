    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this superlative vehicle, maintained in impeccable, showroom condition. This specimen exhibits the highest standards of automotive preservation, offering an uncompromising driving experience for the most discerning client. Meticulously inspected and detailed, it represents a rare opportunity to acquire a vehicle of peerless caliber.",
      "price": 46500.0,
