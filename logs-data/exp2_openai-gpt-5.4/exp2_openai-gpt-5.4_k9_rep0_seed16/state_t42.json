    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a refined example of automotive excellence, this vehicle has been maintained to an exacting standard. It offers a sophisticated driving experience, characterized by a robust mechanical profile and a well-preserved interior. This is a turn-key acquisition for the discerning driver who demands consistent performance and professional presentation.",
      "price": 36800.0,
