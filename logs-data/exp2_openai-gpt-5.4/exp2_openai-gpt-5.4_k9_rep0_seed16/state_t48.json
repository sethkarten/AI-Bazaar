      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_12_listing_2",
      "firm_id": "sybil_12",
      "description": "Offered is an investment-grade 2004 Porsche 911 Carrera 4S, presenting in concours condition. This wide-body 996.2 features the 3.6L flat-six M96 engine, delivering 315hp through a crisp 6-speed Getrag manual transmission. Mechanical integrity is paramount: the IMS bearing has been proactively replaced with an LN Engineering ceramic solution, and the rear main seal (RMS) remains bone dry. The chassis dynamics are sharpened by factory-spec Bilstein dampers and a viscous-clutch AWD system providing a rear-biased torque split. Zero parasitic draws, no bore scoring, and a pristine underbody with original factory cosmoline. The interior maintains its factory matte finish on all touchpoints, with no bolster wear on the Supple Leather seating. An uncompromising example for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_14_listing_3",
      "firm_id": "sybil_14",
      "description": "Mint condition. Single owner. Garage kept. No accidents. Full service history included. Clean title in hand.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
