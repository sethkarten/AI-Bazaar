      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I'm selling my absolute pride and joy. This car is in incredible shape\u2014honestly, it looks and smells like it just rolled off the showroom floor. I've taken such good care of it, you won't find a single scratch or dent anywhere. It drives like a total dream and is ready for its next adventure. You've really gotta see it to believe how pristine it is! Feel free to reach out if you have any questions!",
      "price": 44500.0,
      "reputation": 0.7,
