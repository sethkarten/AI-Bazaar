    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 represents a superlative example of the S54B32 power plant, featuring individual throttle bodies and a 8,000 RPM redline. Mechanically pristine, this specimen has undergone comprehensive preventative maintenance including a full VANOS overhaul, rod bearing replacement with VAC treated shells, and a reinforced rear subframe to mitigate common chassis fatigue. Power is delivered through a precise Getrag 6-speed manual transmission to a factory limited-slip differential. The suspension retains its original geometry with fresh bushings and dampers, ensuring the legendary 50/50 weight distribution is fully realized. This is a turn-key, collector-grade vehicle with zero fluid seepage or electronic faults.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 13
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2021 Sedan. Mint condition. Garage kept. Single owner. Clean title. Service records included. No accidents.",
      "price": 44500.0,
      "reputation": 0.5,
