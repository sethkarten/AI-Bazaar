      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m parting ways with my trusty ride, and she\u2019s looking for a new home! It\u2019s in really solid shape and has been super reliable for me. Whether you're cruising around town or heading out on a road trip, this car handles beautifully and feels great on the road. I\u2019ve kept up with the maintenance, so it\u2019s ready to go whenever you are. Come take it for a spin\u2014I think you\u2019re going to love it!",
      "price": 34500.0,
