      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 I'm looking for a new home for my trusty ride, and she\u2019s been a total gem. It\u2019s in really solid shape and has been super well-loved and maintained over the years. It drives like a dream and is perfect for anyone who wants a reliable, great-looking car without the brand-new price tag. I've taken such good care of it, and I'm sure you'll love it as much as I have! Drop me a message if you want to come see it!",
      "price": 33900.0,
      "reputation": 0.8,
