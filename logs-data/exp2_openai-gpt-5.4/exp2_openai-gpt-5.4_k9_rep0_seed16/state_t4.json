    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 1994 Toyota Supra Turbo is a definitive example of JDM engineering excellence, preserved in museum-grade condition. It features the legendary 2JZ-GTE 3.0L twin-turbocharged inline-six, maintaining factory-spec sequential boost with no aftermarket modifications. The drivetrain is anchored by the Getrag V160 6-speed manual transmission and a Torsen limited-slip differential, ensuring optimal torque transfer. The chassis is exceptionally clean, retaining its original double-wishbone suspension geometry and four-piston ventilated calipers. With zero evidence of synchro wear or thermal fatigue, this vehicle offers a pristine, factory-fresh driving experience for the discerning enthusiast.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 4
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. No accidents. Full service history. Garage kept. Non-smoker.",
      "price": 45000.0,
      "reputation": 0.7,
