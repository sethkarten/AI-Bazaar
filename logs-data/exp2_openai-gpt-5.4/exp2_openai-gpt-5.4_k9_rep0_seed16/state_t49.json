      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You have got to see this beauty in person\u2014it is honestly like it just rolled off the showroom floor! I\u2019ve meticulously cared for it, and it drives like an absolute dream. There isn't a scratch or a dent to be found; it's just pure perfection inside and out. If you're looking for a ride that feels brand new without the brand-new price tag, this is definitely the one for you. Come take it for a spin and see for yourself!",
      "price": 46500.0,
      "reputation": 0.7,
