      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presented for your consideration is an exemplary vehicle maintained to the highest standards of automotive excellence. This unit remains in pristine, showroom condition, exhibiting no discernible wear and reflecting a history of meticulous stewardship. Engineered for the discerning driver who demands uncompromising quality and aesthetic perfection, this vehicle represents a rare opportunity to acquire a peerless specimen. We invite you to experience its impeccable craftsmanship firsthand.",
      "price": 48500.0,
      "reputation": 0.8,
