      "quality_value": 0.1,
      "timestep_posted": 39
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering an investment-grade 2004 BMW M3 (E46) Coupe. This specimen features the high-revving S54B32 3.2L inline-six, utilizing individual throttle bodies and a high-pressure Double VANOS system for optimized volumetric efficiency across the powerband. The drivetrain is anchored by a Getrag 6-speed manual transmission and a factory-spec limited-slip differential. Mechanically, this vehicle is peerless: the rod bearings have been addressed with treated shells, and the rear subframe has been proactively reinforced to ensure structural rigidity. Every original VIN tag is present, and the suspension geometry remains true to factory tolerances. This is a mechanically synchronized, concours-level icon for the discerning enthusiast seeking peak longitudinal and lateral performance.",
      "price": 48500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 39
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Garage kept. No cosmetic or mechanical flaws. Full service history included. Clean title.",
      "price": 43000.0,
      "reputation": 0.4,
