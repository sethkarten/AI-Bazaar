    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior features significant body damage, including deep scratches, large dents, and visible rust. The interior shows heavy wear with torn upholstery and stained carpeting. Mechanical issues are present.",
