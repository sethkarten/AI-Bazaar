      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Single owner. Garage kept. Zero accidents. Original paint. Full service records. Clean title. Inspections welcome.",
      "price": 43500.0,
