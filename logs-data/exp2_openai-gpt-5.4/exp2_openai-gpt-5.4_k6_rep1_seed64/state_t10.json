    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This vehicle represents an exemplary standard of automotive preservation. Meticulously maintained and presented in showroom condition, its aesthetic and mechanical integrity are beyond reproach. Every detail, from the flawless exterior finish to the pristine interior appointments, reflects a commitment to excellence. We invite discerning buyers to acquire this peerless example of engineering and design.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
