    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this meticulously maintained vehicle, offering a superior balance of performance and reliability. Having undergone a rigorous multi-point inspection, this automobile remains in commendable condition, exhibiting only the minor cosmetic character expected of a well-cared-for pre-owned model. It represents a premier opportunity for the discerning driver seeking exceptional value and mechanical integrity without compromise.",
      "price": 34900.0,
      "reputation": 0.6,
