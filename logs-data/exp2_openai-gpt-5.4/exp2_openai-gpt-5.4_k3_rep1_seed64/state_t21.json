      "quality_value": 0.1,
      "timestep_posted": 21
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I'm parting ways with my trusty ride and it's looking for a brand new home! This car has been so good to me\u2014it's super reliable, runs like a dream, and has been well-loved and maintained. It's in great shape and ready to hit the road for many more adventures. Whether you're commuting to work or heading out on a weekend getaway, this beauty will get you there in style. Come take it for a spin and see for yourself!",
      "price": 29900.0,
      "reputation": 0.4,
