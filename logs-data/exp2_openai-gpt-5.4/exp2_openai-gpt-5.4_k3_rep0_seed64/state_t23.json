    },
    {
      "id": "optimistic_8_listing_0",
      "firm_id": "optimistic_8",
      "description": "Experience the pinnacle of automotive perfection with this absolute gem! This vehicle is in truly mint condition, looking and feeling exactly like it just rolled off the showroom floor. Every detail has been meticulously preserved, making this a rare find for any discerning buyer who demands nothing but the very best.",
      "price": 49800.0,
