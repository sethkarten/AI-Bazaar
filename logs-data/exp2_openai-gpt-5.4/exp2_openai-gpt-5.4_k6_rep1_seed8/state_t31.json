    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior has a few minor surface scratches but no major dents. The interior is clean with light wear on the driver's seat. It is mechanically sound and all features are functioning as intended.",
      "price": 35000.0,
      "reputation": 1.0,
