    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a distinguished vehicle that exemplifies mechanical integrity and aesthetic appeal. This specimen has been maintained to a rigorous standard, ensuring a refined driving experience and long-term reliability. Featuring a sophisticated interior and robust performance capabilities, it represents a premier opportunity for the driver seeking quality and executive-class value.",
      "price": 34500.0,
