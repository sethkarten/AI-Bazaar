      "timestep_posted": 46
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is being sold in poor condition and is currently not in running order. The engine has suffered a critical failure and will require a full rebuild or replacement to be operational again. Additionally, the transmission shows signs of severe wear, and the body has significant rust and cosmetic damage. This car is strictly a project vehicle or a donor for parts, and the buyer will need to arrange for a tow as it cannot be driven off the lot.",
      "price": 2800.0,
