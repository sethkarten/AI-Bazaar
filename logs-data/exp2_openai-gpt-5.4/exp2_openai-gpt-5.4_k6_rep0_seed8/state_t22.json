    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this meticulously maintained vehicle, offering a refined driving experience and proven mechanical integrity. This specimen exhibits consistent professional care, featuring a well-preserved interior and a robust powertrain that ensures dependable performance. An exceptional acquisition for the discerning owner seeking a sophisticated balance of prestige and long-term utility.",
      "price": 34900.0,
