      "quality_value": 0.4,
      "timestep_posted": 47
    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in good condition and has been consistently maintained throughout its life. The engine is strong and reliable, starting without hesitation, and the transmission shifts smoothly through all gears. While the exterior shows some minor cosmetic wear consistent with its age, the body is straight and the paint still holds a nice shine. Inside, the cabin is clean and all essential electronics are fully functional. It\u2019s a solid, dependable car that is ready for its next owner to drive away with confidence.",
      "price": 35500.0,
      "reputation": 1.0,
