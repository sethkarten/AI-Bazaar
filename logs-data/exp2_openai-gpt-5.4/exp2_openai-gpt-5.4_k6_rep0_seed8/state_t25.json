    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and minor dings, and the interior shows moderate wear throughout the upholstery and carpets. All mechanical systems are functional, though the car shows signs of regular use.",
      "price": 20000.0,
