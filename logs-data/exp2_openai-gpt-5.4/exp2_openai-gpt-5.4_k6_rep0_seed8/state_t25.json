      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I'm parting ways with my trusty ride and it's looking for a new home! It\u2019s been such a reliable companion and is still in great shape, running smoothly and looking sharp. It's been well-cared for and is ready to hit the road for many more miles. Whether you're commuting or heading out on a road trip, this car is a solid choice that won't let you down. Come take it for a spin and see for yourself!",
      "price": 32500.0,
      "reputation": 0.6,
