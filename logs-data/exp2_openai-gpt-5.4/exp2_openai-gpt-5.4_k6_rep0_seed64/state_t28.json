    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a dependable daily driver with plenty of life left? This car is a solid choice for anyone seeking reliable transportation at a great value! While it shows some honest wear and tear from its years on the road, it remains a functional and steady performer that's ready for its next chapter. It's the perfect balance of affordability and character for a practical owner!",
      "price": 18500.0,
