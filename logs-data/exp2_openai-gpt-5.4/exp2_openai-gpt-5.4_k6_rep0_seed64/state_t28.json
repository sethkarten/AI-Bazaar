    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior paint and body have no scratches or dents. The interior shows no signs of wear. All mechanical systems are in perfect working order.",
      "price": 48500.0,
      "reputation": 1.0,
