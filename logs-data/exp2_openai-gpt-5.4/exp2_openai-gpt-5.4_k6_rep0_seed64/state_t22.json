    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior shows some minor surface scratches, but the paint remains in good shape. The interior is well-maintained with light signs of use on the upholstery. All mechanical systems are fully operational and have been regularly serviced.",
      "price": 34000.0,
