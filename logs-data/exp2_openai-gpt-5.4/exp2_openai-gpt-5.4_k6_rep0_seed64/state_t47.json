      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has significant rust, large dents, and peeling paint. The interior is heavily worn with torn upholstery and broken trim pieces. The engine and transmission require major repairs to be reliable.",
      "price": 5500.0,
