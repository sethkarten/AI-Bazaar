    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and transmission are functional but may require maintenance soon. The exterior shows several noticeable scratches and minor dents, while the interior displays moderate wear and some staining.",
      "price": 20000.0,
