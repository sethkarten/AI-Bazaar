    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Presenting an investment-grade E46 M3 in concours condition. This example features the legendary S54 3.2L inline-six, delivering linear power through six individual throttle bodies and a precise 6-speed Getrag manual transmission. Mechanically optimized with documented rod bearing replacement, comprehensive VANOS bulletproofing, and a reinforced rear subframe. The chassis retains its factory-spec torsional rigidity, complemented by staggered 19-inch Style 67 forged wheels and a perfectly preserved Nappa leather interior. Zero deferred maintenance; a turn-key specimen for the discerning purist.",
      "price": 47500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 3
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
