    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this vehicle in superlative showroom condition. It has been maintained to the most exacting standards, exhibiting an unblemished exterior and a pristine, smoke-free interior that reflects its low-mileage history. Mechanically flawless and aesthetically indistinguishable from a new model, this automobile represents a rare acquisition for the connoisseur who demands excellence without compromise.",
      "price": 48500.0,
      "reputation": 0.8,
