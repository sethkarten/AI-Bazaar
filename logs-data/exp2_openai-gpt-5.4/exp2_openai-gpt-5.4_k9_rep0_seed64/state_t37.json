    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a meticulously maintained vehicle that exemplifies performance and reliability. This unit remains in commendable condition, having undergone a comprehensive mechanical inspection to ensure it meets our rigorous standards for roadworthiness and aesthetic integrity. A premier choice for the discerning driver seeking a balanced investment in quality and value.",
      "price": 36850.0,
