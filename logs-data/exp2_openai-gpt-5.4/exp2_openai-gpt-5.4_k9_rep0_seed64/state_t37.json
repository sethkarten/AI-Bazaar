      "quality_value": 0.1,
      "timestep_posted": 37
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm parting ways with my trusty ride, and it's been such a joy to drive. It's in really solid shape and has been well-loved, perfect for someone looking for a reliable car without the brand-new price tag. Everything runs smoothly, and it's ready for its next adventure! Come take it for a spin\u2014you're going to love how it handles.",
      "price": 32500.0,
