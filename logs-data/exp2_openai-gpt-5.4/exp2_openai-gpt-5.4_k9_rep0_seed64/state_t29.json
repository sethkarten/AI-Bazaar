    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exceptionally well-maintained vehicle, which exemplifies mechanical integrity and aesthetic preservation. This unit has undergone a rigorous multi-point inspection to ensure it meets our exacting standards for performance and safety. Featuring a clean interior and a robust powertrain, this vehicle offers a refined driving experience and represents a prudent investment for the discerning motorist. Available now for immediate acquisition.",
      "price": 34900.0,
      "reputation": 0.8,
