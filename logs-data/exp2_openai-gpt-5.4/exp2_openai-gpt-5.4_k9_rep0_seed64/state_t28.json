    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a collector-grade E46 M3 featuring the high-revving S54 3.2L inline-six, complete with individual throttle bodies and double-VANOS variable valve timing for razor-sharp throttle response. This example boasts a reinforced rear subframe and a Getrag 6-speed manual transmission, ensuring structural integrity and mechanical purity. The M-variable differential lock and factory-spec suspension geometry provide unparalleled lateral dynamics. This vehicle has undergone a comprehensive inspection, confirming the rod bearings and cooling system are in peak operating condition. A mechanically flawless, turn-key masterpiece for the serious driver.",
      "price": 43500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 28
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
