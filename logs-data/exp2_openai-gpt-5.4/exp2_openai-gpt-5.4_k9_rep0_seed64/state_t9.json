      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm parting with my trusty ride, and honestly, it\u2019s been such a joy to drive. It\u2019s in really solid shape and has been super reliable for me\u2014perfect for someone who wants a dependable car that's been well-loved. It runs like a dream and is totally ready for its next big adventure! Feel free to reach out if you want to take it for a spin!",
      "price": 34500.0,
