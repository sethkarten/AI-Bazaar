    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented in exemplary condition, this vehicle represents the pinnacle of automotive preservation. Meticulously maintained and rigorously inspected, it offers an unrivaled driving experience for the discerning collector. Every detail reflects our commitment to excellence, ensuring a standard of luxury and performance that exceeds expectations.",
      "price": 46500.0,
