      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This exemplary specimen features a meticulously maintained 3.8L flat-six powerplant, delivering linear power through a precise six-speed manual transaxle. The chassis remains remarkably taut, benefiting from Porsche Active Suspension Management (PASM) and zero bushing deflection. The exterior retains its factory depth and luster, while the interior shows no signs of bolster wear or UV degradation. Mechanically, the vehicle exhibits optimal compression ratios and instantaneous throttle response, with crisp gear synchronization and a chatter-free limited-slip differential. A turn-key investment for the discerning purist seeking peak atmospheric performance.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_3_listing_3",
