    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an investment-grade AP2 S2000, featuring the high-torque F22C1 power unit with perfect compression and leak-down results. This example retains its factory-matched 6-speed close-ratio manual transmission, offering surgical shift precision and a robust Torsen limited-slip differential. The chassis integrity is verified by all original VIN tags on factory panels, while the double-wishbone suspension remains tight with no bushing deflection. Mechanically flawless, the VTEC crossover is distinct and the valvetrain is whisper-quiet. This is a collector-spec roadster for those who demand mechanical purity and a documented service history.",
      "price": 44500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 27
    },
    {
      "id": "sybil_12_listing_3",
      "firm_id": "sybil_12",
      "description": "Mint condition. Single owner. Zero accidents. Garage kept. Full service records included. Interior and exterior flawless.",
      "price": 48500.0,
