      "quality_value": 0.1,
      "timestep_posted": 2
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You seriously have to see this beauty in person\u2014it's an absolute dream. I've babied this car since day one, keeping it tucked away in a climate-controlled garage and getting it professionally detailed regularly. It looks, smells, and drives exactly like it just rolled off the showroom floor! If you're looking for a ride that\u2019s basically flawless and ready for the road, this is the one. Feel free to reach out with any questions\u2014I'd love to see it go to a great new home!",
      "price": 46500.0,
      "reputation": 0.8,
