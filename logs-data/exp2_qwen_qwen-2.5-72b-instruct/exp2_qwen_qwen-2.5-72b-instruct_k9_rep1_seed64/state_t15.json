      "quality_value": 0.1,
      "timestep_posted": 15
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm parting ways with my trusty ride, and honestly, it\u2019s been such a fantastic car for me. It runs beautifully and has been super reliable for everything from grocery runs to weekend getaways. It\u2019s in solid shape, looks great, and is totally ready for its next adventure with a new owner! If you're looking for a dependable vehicle that\u2019s been well-loved, you\u2019ve found it. Drop me a message if you want to take it for a spin!",
      "price": 33800.0,
      "reputation": 0.5,
