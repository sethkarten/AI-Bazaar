      "timestep_posted": 30
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a mechanically sorted 2002 BMW M3 (E46) featuring the high-strung S54 inline-six engine. This naturally aspirated powerhouse delivers linear torque through individual throttle bodies and is mated to a crisp 6-speed Getrag manual gearbox. Critical preventative maintenance has been addressed, including a reinforced rear subframe and a comprehensive VANOS system refresh to ensure timing precision. The chassis remains taut with upgraded bushings, and the factory limited-slip differential provides predictable lock-up under load. It shows minor patina indicative of a dedicated driver's car, but the powertrain is dialed-in for peak performance. A turn-key example for the purist.",
      "price": 34500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_12_listing_3",
      "firm_id": "sybil_12",
      "description": "Used car. Good condition. Clean title. Regular maintenance performed. Minor cosmetic wear. Runs well.",
      "price": 29500.0,
      "reputation": 0.6,
