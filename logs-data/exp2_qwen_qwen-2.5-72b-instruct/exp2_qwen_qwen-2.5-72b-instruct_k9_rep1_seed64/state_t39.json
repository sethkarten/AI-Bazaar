    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and transmission are reliable, and it has been well-maintained. There are some minor cosmetic imperfections on the exterior and light wear on the interior upholstery.",
      "price": 34000.0,
