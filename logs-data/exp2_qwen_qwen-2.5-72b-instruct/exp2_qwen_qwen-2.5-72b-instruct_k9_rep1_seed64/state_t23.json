    },
    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and will require significant mechanical attention and cosmetic restoration. The engine currently runs roughly and the transmission exhibits noticeable slipping, suggesting a need for major repairs or a complete overhaul. The exterior shows substantial wear, including several large dents, significant paint fading, and areas of surface rust. Inside, the upholstery is heavily worn with multiple tears and the electronics are inconsistent. This car is best suited for someone looking for a dedicated project or a source for parts.",
      "price": 5500.0,
