      "quality_value": 0.1,
      "timestep_posted": 7
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an exceptional vehicle maintained to the highest standards of automotive excellence. This unit remains in pristine, showroom condition, exhibiting no discernible wear and reflecting a history of meticulous care. Every mechanical and aesthetic component functions with factory-level precision. This is a rare opportunity for the discerning collector or enthusiast to acquire a specimen of such uncompromising quality.",
      "price": 46500.0,
      "reputation": 0.7,
