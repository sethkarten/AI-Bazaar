      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You honestly won\u2019t believe how gorgeous this car is. It\u2019s been absolutely babied and looks like it just rolled off the showroom floor! Not a single scratch or dent\u2014it\u2019s seriously in pristine shape. If you\u2019re looking for a ride that feels and smells brand new, this is the one for you. Come take a look, you\u2019re going to love it!",
      "price": 44900.0,
      "reputation": 0.5,
