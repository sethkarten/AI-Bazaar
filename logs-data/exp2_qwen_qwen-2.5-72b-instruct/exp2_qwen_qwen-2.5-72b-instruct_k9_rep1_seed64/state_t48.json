    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It is fully operational and has been well-maintained. The interior and exterior show minor signs of regular use, but there are no major mechanical issues or significant cosmetic damage.",
      "price": 34000.0,
      "reputation": 1.0,
      "quality": "good",
