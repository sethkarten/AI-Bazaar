      "timestep_posted": 18
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior has minor cosmetic wear, and the interior shows some signs of regular use. All mechanical systems are functioning properly, and the car has been regularly maintained.",
      "price": 35000.0,
      "reputation": 1.0,
