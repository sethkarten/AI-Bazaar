      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "sybil_13_listing_1",
      "firm_id": "sybil_13",
      "description": "Hey there! Are you looking for a reliable, stylish ride that\u2019s been super well-loved? This beauty is in wonderful shape and drives like a dream. It\u2019s perfect for weekend getaways or just zipping around town. I\u2019ve taken great care of it, and it's totally ready to hit the road with a new owner today! Come take it for a spin\u2014I just know you're going to love how it handles!",
      "price": 34500.0,
      "reputation": 0.8,
