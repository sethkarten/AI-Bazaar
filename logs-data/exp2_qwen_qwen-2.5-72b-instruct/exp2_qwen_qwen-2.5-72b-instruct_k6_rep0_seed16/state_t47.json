    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has significant body damage, including several large dents and peeling paint. The interior shows heavy wear, with torn upholstery and stained carpeting. There are several mechanical and electrical issues that require attention.",
