    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a dependable daily driver that's easy on the wallet? This car is in honest, fair condition and is ready to take on your daily commute with ease! While it shows some character and typical wear from its time on the road, it remains a solid and reliable choice for anyone seeking practical transportation at a great value.",
      "price": 19000.0,
