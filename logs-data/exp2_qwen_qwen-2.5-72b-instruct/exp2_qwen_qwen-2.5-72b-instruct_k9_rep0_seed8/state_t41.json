    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in good overall condition and has been well-maintained throughout its ownership. The engine runs smoothly and the transmission shifts as expected, making it a reliable choice for daily driving. While the exterior and interior show some minor signs of normal wear, such as small paint chips and light seat creasing, there are no major mechanical issues or structural damage. It is a solid, honest car that offers great value for someone looking for a dependable ride without the 'mint' price tag.",
      "price": 34500.0,
      "reputation": 1.0,
      "quality": "good",
