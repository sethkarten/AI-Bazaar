    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 1993 Mazda RX-7 FD is a peerless example of the sequential twin-turbocharged 13B-REW rotary powerplant. The engine maintains factory-spec compression and seamless transition between the primary and secondary Hitachi HT12 turbos. Its front-midship, rear-wheel-drive layout provides a perfect 50/50 weight distribution, complemented by a lightweight aluminum double-wishbone suspension for surgical handling. The five-speed manual gearbox is precise, feeding power through a factory Torsen limited-slip differential. Every vacuum line, bushing, and synchro performs as it did on the showroom floor. Free of any structural oxidation or aftermarket interference, this FD is a purist's investment in peak JDM engineering.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 5
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Zero accidents. Full service history. Flawless paint and interior. Runs like new.",
      "price": 44500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
