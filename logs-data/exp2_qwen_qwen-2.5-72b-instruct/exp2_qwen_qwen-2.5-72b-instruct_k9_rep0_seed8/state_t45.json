    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in fair condition and serves as a reliable daily driver despite showing its age. The exterior has several noticeable scratches and a few small door dings, while the interior shows typical wear on the upholstery and some fading on the dashboard. Mechanically, the car runs and drives, though it may soon require routine maintenance like new brake pads or a suspension tune-up. It is a solid choice for someone needing dependable transportation who isn't concerned with minor cosmetic flaws.",
      "price": 19500.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 45
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The engine and transmission require significant repair and maintenance. There is extensive wear and visible damage to both the interior and exterior surfaces.",
      "price": 5500.0,
      "reputation": 1.0,
      "quality": "poor",
