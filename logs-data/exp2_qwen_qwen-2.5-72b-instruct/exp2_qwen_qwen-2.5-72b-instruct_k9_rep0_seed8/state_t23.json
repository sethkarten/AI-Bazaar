      "quality_value": 0.1,
      "timestep_posted": 23
    },
    {
      "id": "sybil_12_listing_6",
      "firm_id": "sybil_12",
      "description": "Hey there! I\u2019m parting ways with my absolute pride and joy. This beauty is in truly incredible shape\u2014honestly, it looks and feels like it just rolled off the showroom floor! It\u2019s been pampered since day one, kept sparkling clean, and drives like a dream. If you\u2019re looking for a ride that\u2019s practically perfect and ready for a new home, this is the one. You\u2019ve gotta come see it in person to believe how gorgeous it is!",
      "price": 44500.0,
