    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in mint condition and truly represents the pinnacle of its model. It has been meticulously cared for, stored in a climate-controlled environment, and shows virtually no signs of wear inside or out. Every component functions perfectly, and the paint retains its original showroom luster. This is a rare opportunity to own a collector-grade example that drives as beautifully as it looks.",
      "price": 49750.0,
      "reputation": 1.0,
