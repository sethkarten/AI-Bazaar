    },
    {
      "id": "sybil_14_listing_2",
      "firm_id": "sybil_14",
      "description": "Offered is a mechanically sound E46 M3 featuring the high-revving S54 inline-six engine equipped with individual throttle bodies and Double VANOS. This example features the desirable 6-speed Getrag manual transmission, providing a direct mechanical connection to the rear-mounted limited-slip differential. The chassis remains taut, benefiting from a reinforced rear subframe and refreshed bushings throughout the suspension geometry. The engine pulls strongly to its 8,000 RPM redline with consistent compression across all cylinders. While showing minor cosmetic patina commensurate with its age, the vehicle is structurally robust and performance-optimized, making it an ideal candidate for the discerning enthusiast seeking a pure analog driving experience.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_13_listing_3",
      "firm_id": "sybil_13",
      "description": "Used car. Good condition. Well maintained. Clean title. Inspection records available.",
      "price": 29500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
