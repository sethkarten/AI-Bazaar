      "timestep_posted": 6
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m honestly so sad to let this beauty go, but it\u2019s time for a new home. This car is in absolutely incredible shape\u2014it\u2019s basically like it just rolled off the showroom floor! I\u2019ve taken meticulous care of it, and it drives like an absolute dream. If you\u2019re looking for something that feels brand new without the brand-new price tag, you\u2019ve found it. Come take a look, you won't be disappointed!",
      "price": 43500.0,
      "reputation": 0.6,
