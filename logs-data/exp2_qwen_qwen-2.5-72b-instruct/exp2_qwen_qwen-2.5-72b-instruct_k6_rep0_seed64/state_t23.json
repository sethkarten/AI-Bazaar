    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has significant rust, multiple large dents, and failing clear coat. The interior shows heavy wear, including torn upholstery and a cracked dashboard. Mechanically, the car requires major repairs to the engine and transmission to be safely driven.",
      "price": 6000.0,
