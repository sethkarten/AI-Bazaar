    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The engine and transmission are reliable and function as expected. There are minor cosmetic imperfections on the exterior, and the interior shows light signs of regular use.",
      "price": 34000.0,
