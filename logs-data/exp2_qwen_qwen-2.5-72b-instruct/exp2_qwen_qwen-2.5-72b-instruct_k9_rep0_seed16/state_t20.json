    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The engine and transmission are in perfect working order. The exterior paint and body are flawless, and the interior is in like-new condition with no signs of wear.",
      "price": 46500.0,
