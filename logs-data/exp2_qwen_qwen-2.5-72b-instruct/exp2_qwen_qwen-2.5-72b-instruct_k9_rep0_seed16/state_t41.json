    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and transmission are operational but show signs of significant age. The exterior has several noticeable scratches and dents, and the interior exhibits clear signs of wear and tear.",
      "price": 20000.0,
