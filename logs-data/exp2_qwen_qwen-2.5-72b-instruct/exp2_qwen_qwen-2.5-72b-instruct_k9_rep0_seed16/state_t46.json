    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and transmission are operational but show signs of age. The exterior has several noticeable scratches and dents, and the interior shows significant wear from regular use.",
      "price": 22000.0,
      "reputation": 1.0,
      "quality": "fair",
