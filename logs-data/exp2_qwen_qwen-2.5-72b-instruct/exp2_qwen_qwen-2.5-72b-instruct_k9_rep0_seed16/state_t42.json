    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in fair condition and is ready for a new owner who appreciates a solid foundation with room for improvement. The exterior shows its age with some noticeable door dings, light scratches, and some fading on the trim, though it still holds a decent shine from a distance. Inside, the cabin is intact but shows typical wear on the driver's seat and some staining on the carpets that a deep clean would help. Mechanically, it starts and runs reliably, but it will likely need routine maintenance like new tires or a brake service in the near future. It\u2019s a dependable choice for someone looking for a functional vehicle at a reasonable price point.",
      "price": 20500.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 42
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The engine and transmission function as new. Both the exterior and interior are in pristine condition with no visible wear or defects.",
