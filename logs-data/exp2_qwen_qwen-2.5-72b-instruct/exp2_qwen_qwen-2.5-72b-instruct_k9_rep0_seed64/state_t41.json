      "quality_value": 0.1,
      "timestep_posted": 41
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m parting ways with my trusty ride and I\u2019m honestly going to miss it! It\u2019s been super reliable and is still in really nice shape, perfect for someone who wants a solid, dependable car that\u2019s ready for its next big adventure. It drives like a dream and has been well-loved over the years. I'd love for it to go to a great home, so feel free to reach out if you want to come see it!",
      "price": 28500.0,
      "reputation": 0.3,
