      "timestep_posted": 6
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a museum-grade E46 M3 ZCP. The S54 power plant remains naturally aspirated perfection, featuring a high-pressure VANOS system and individual throttle bodies for instantaneous throttle response. This example boasts a reinforced rear subframe and a refreshed Getrag 6-speed manual gearbox paired with a factory M-Variable differential lock. Suspension geometry is preserved with OEM Sachs dampers and bushings. The chassis exhibits zero torsional fatigue, and the Alcantara-wrapped steering wheel remains tactile and unworn. A true collector-grade specimen with a documented service history focusing on preventative rod bearing replacement and valve clearances.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Low mileage. Service records included. No accidents. Clean title.",
      "price": 43500.0,
      "reputation": 0.5,
