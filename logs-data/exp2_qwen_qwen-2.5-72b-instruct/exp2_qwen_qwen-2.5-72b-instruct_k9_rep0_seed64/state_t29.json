    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 1994 Nissan 300ZX Twin Turbo is a mechanically sound example of the Z32 platform. Under the hood, the VG30DETT 3.0L V6 features dual intercoolers and variable valve timing, delivering linear power through a crisp 5-speed manual transmission. The vehicle benefits from a functional Super HICAS four-wheel steering system and a viscous LSD for superior lateral grip. Recent maintenance includes a full timing belt service, water pump replacement, and a vacuum leak smoke test to ensure the twin Garrett turbos spool efficiently. The suspension retains its factory adjustable dampening, providing a balanced, era-correct driving dynamic.",
      "price": 31500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 29
    },
    {
      "id": "sybil_14_listing_3",
      "firm_id": "sybil_14",
      "description": "Used car. Good condition. Well-maintained. Clean title. Ready for immediate sale.",
      "price": 35000.0,
      "reputation": 0.8,
