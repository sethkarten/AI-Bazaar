      "timestep_posted": 42
    },
    {
      "id": "sybil_15_listing_2",
      "firm_id": "sybil_15",
      "description": "This E46 M3 is powered by the legendary S54 3.2L inline-six, featuring individual throttle bodies and an 8,000 RPM redline. Power is sent through a Getrag 6-speed manual transmission to a factory limited-slip differential. The mechanical integrity is bolstered by a documented Vanos overhaul and recent valve clearance adjustment. The chassis remains composed thanks to reinforced subframe mounting points and refreshed bushings, ensuring the legendary 50/50 weight distribution is fully exploited. While showing minor cosmetic patina consistent with its age, the engine pulls strong with linear delivery, and the hydraulic steering rack provides the precise feedback enthusiasts demand.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_17_listing_3",
      "firm_id": "sybil_17",
      "description": "Used car. Good condition. Well-maintained. Clean interior. Reliable performance.",
      "price": 34500.0,
      "reputation": 0.8,
