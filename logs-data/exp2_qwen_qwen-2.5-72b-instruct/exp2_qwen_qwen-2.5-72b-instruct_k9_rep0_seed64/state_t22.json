      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a meticulously maintained vehicle that exemplifies both performance and sophistication. This unit has undergone a rigorous inspection to ensure it meets our exacting standards for reliability and aesthetic integrity. Featuring a clean history and a well-preserved interior, it offers an exceptional driving experience for the distinguished professional. We invite you to experience the superior craftsmanship and enduring value of this premier selection.",
      "price": 36800.0,
