    {
      "id": "sybil_15_listing_2",
      "firm_id": "sybil_15",
      "description": "Offered is a mechanically sound E46 M3 featuring the high-revving S54B32 inline-six, equipped with individual throttle bodies and double-VANOS for optimized volumetric efficiency across the rev range. This specimen utilizes a Getrag 6-speed manual transmission delivering power to a variable M-differential lock. The chassis has been addressed with critical subframe reinforcement and a refreshed cooling system to ensure thermal stability during spirited driving. With crisp throttle response and a suspension tuned for communicative feedback, this M3 represents a superb balance of performance and drivability for the discerning enthusiast.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 46
    },
    {
      "id": "sybil_17_listing_3",
      "firm_id": "sybil_17",
      "description": "Used car. Good condition. Well-maintained. Clean interior. Reliable engine. Serious buyers only.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
