    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an exceptional E46 M3, a pinnacle of atmospheric engineering featuring the S54B32 3.2L inline-six. This high-revving power unit utilizes individual throttle bodies and double VANOS variable valve timing for razor-sharp throttle response. The chassis integrity is unparalleled, with a preventative rear subframe reinforcement already completed. Power is delivered through a crisp Getrag 420G six-speed manual gearbox to a Variable M Differential Lock. The suspension maintains factory-spec kinematics with fresh bushings and dampers, ensuring the original handling dynamics are preserved. This is a collector-grade specimen with a flawless exterior and a mechanically perfect drivetrain.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_14_listing_3",
      "firm_id": "sybil_14",
      "description": "Mint condition. Single owner. Garage kept. Zero accidents. Complete service records available.",
      "price": 48000.0,
