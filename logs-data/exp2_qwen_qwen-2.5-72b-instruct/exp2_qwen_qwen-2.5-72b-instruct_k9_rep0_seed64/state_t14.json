    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an automotive specimen of unrivaled caliber. This vehicle remains in impeccable, showroom-grade condition, having been maintained to the most exacting standards. With its flawless aesthetic finish and absolute mechanical integrity, it offers a driving experience indistinguishable from its original delivery. This is a rare opportunity for the discerning collector or enthusiast to acquire a vehicle of truly pristine quality.",
      "price": 48500.0,
      "reputation": 0.8,
