    },
    {
      "id": "sybil_15_listing_2",
      "firm_id": "sybil_15",
      "description": "Offering a mechanically sound 2004 BMW M3 (E46) equipped with the high-revving S54 3.2L inline-six, featuring individual throttle bodies and dual-VANOS variable valve timing. This example utilizes the Getrag 420G six-speed manual transmission to deliver power to the rear wheels through a factory M-Variable differential lock. The suspension geometry remains precise, benefiting from recent bushing refreshes and a reinforced rear subframe to mitigate common chassis fatigue. Maintenance is up to date, including a documented valve clearance adjustment and a cooling system overhaul. This M3 provides a visceral, analog driving experience with a chassis tuned for neutral handling and exceptional feedback through the hydraulic steering rack.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 32
    },
    {
      "id": "sybil_14_listing_3",
      "firm_id": "sybil_14",
      "description": "Used vehicle. Good condition. Well-maintained. Clean interior. Reliable performance.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
