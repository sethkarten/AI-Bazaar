    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has extensive rust and significant body damage. The interior is heavily worn with torn upholstery. The engine and transmission require major repairs to be functional, and most electronic components are non-operational.",
      "price": 3500.0,
      "reputation": 1.0,
