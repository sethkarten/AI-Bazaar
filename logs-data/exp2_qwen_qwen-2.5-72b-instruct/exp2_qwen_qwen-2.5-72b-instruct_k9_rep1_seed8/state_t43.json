    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "$20,000 - This vehicle is in fair condition. The exterior shows noticeable wear, including some paint fading and multiple small dents. The interior is functional but shows clear signs of age and use, such as worn seat bolsters. Mechanical components are operational but may require maintenance soon.",
      "price": 20000.0,
