    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "Available is a pristine E46 M3 featuring the S54B32 high-revving inline-six. This example boasts a documented double-VANOS overhaul and preventative rear subframe reinforcement. The Getrag 420G 6-speed manual delivers precise throws to the M Variable Differential Lock. Factory paint depth is uniform across all panels, and the Nappa leather interior remains supple with no bolster wear. Mechanically flawless with zero rod bearing noise and instantaneous throttle response via its individual throttle bodies. This is a turn-key, collector-grade specimen with a completely transparent service history.",
      "price": 46500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "sybil_13_listing_3",
      "firm_id": "sybil_13",
      "description": "Mint condition. Low mileage. Single owner. Clean title. Full service history. No cosmetic or mechanical flaws. Ready for inspection.",
      "price": 43500.0,
      "reputation": 0.4,
