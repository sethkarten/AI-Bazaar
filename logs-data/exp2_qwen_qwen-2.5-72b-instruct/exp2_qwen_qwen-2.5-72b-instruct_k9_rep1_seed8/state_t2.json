      "quality_value": 0.1,
      "timestep_posted": 2
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 997.2 Carrera S represents a pinnacle of analog feedback and modern reliability. Featuring the 3.8L DFI flat-six delivering 385 hp, this example is paired with a precise 6-speed manual gearbox. The chassis is equipped with PASM (Porsche Active Suspension Management) and the Sport Chrono Package Plus, ensuring optimized throttle mapping and active damping. Meticulously maintained, the vehicle shows zero over-revs in Ranges 4-6 on the DME report and retains factory-original paint depth across all panels. Recent service includes a full fluid flush and fitment of Michelin Pilot Sport 4S tires on 19-inch Carrera Sport wheels. No bore scoring or RMS issues present; a truly concours-ready specimen for the discerning collector.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 2
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. Full service records. No accidents.",
      "price": 44500.0,
      "reputation": 0.7,
