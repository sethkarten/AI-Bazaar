    },
    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in poor condition and is being sold strictly as-is. The exterior has significant rust, several large dents, and the paint is peeling across most panels. Mechanically, the engine requires a major overhaul, and the transmission is slipping, meaning it will likely need to be towed. The interior shows heavy wear, including torn upholstery and a non-functional dashboard. This is a project car for someone with the tools and time for a complete restoration or for use as a parts donor.",
      "price": 5500.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
