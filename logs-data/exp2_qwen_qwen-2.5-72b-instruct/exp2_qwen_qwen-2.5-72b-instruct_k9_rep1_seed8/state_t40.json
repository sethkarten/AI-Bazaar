    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior has minor cosmetic wear, including some small scratches, but no structural damage. The interior is well-maintained with light signs of use. All mechanical components are functioning as expected.",
