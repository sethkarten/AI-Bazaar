    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "This meticulously maintained vehicle represents a premier opportunity for the discerning driver. Demonstrating consistent mechanical integrity and a well-preserved aesthetic, it offers a refined driving experience that exceeds standard expectations for its class. Fully inspected and prepared for immediate delivery, this unit stands as a testament to balanced performance and enduring value.",
      "price": 34800.0,
