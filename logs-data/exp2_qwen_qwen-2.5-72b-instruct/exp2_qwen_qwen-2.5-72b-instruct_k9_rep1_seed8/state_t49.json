    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior is well-maintained with only minor surface scratches consistent with regular use. The interior is clean and shows minimal signs of wear. All mechanical and electronic components are in good working order.",
