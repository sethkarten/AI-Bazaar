    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. It has significant mechanical issues that require major repairs and shows extensive cosmetic wear and damage both inside and out. Some systems are currently non-functional.",
      "price": 6500.0,
