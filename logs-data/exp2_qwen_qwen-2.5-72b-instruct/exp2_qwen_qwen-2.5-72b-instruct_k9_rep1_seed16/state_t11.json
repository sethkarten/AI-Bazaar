    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in good condition and has been well-maintained throughout its life. The exterior paint still shines beautifully, though you will find some minor stone chips and light surface scratches consistent with careful regular use. Inside, the cabin is clean and comfortable, with only slight wear on the driver's seat bolster and common touchpoints. Mechanically, it remains very reliable, starts right up, and shifts smoothly, making it a dependable choice for its next owner.",
      "price": 34500.0,
      "reputation": 0.9,
      "quality": "good",
      "quality_value": 0.7,
