    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. It is in like-new mechanical and cosmetic shape, showing no signs of wear or damage. All systems are functioning perfectly, and the car has been exceptionally well-preserved.",
