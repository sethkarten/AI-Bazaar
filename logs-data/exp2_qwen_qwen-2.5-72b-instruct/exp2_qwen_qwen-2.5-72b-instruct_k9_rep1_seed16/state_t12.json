      "quality_value": 0.1,
      "timestep_posted": 12
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You've gotta see this absolute beauty. It\u2019s in such incredible shape that it honestly feels like it just rolled off the showroom floor! I\u2019ve taken such good care of it, and it\u2019s truly spotless inside and out. If you're looking for a ride that\u2019s basically perfect and ready for a new home, this is the one. Come take it for a spin and see for yourself\u2014you're going to love it!",
      "price": 44900.0,
      "reputation": 0.5,
