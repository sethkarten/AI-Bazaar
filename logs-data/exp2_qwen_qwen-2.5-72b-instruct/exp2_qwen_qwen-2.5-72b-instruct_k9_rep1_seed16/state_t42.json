    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a meticulously maintained vehicle that exemplifies consistent performance and enduring quality. This unit features a refined interior and a robust drivetrain, ensuring a superior driving experience for the discerning owner. Having undergone a comprehensive professional inspection, it stands as a testament to reliable engineering and disciplined upkeep. Secure this exceptional value today.",
      "price": 31500.0,
      "reputation": 0.4,
