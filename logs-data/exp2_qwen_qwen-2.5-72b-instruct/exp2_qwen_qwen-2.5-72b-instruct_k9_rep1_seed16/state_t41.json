    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in pristine, showroom condition and has been kept in a climate-controlled garage. The exterior paint is absolutely flawless with no chips or imperfections, and the interior is spotless, still smelling like new. It comes with a full service history, reflecting meticulous care and maintenance since it was first purchased. This is a rare find for a buyer seeking a car that is mechanically and aesthetically perfect.",
      "price": 49000.0,
