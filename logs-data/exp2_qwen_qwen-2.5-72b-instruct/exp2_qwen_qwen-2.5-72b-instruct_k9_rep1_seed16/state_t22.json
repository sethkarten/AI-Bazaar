      "timestep_posted": 22
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presented for your consideration is a distinguished example of automotive excellence, maintained to a high standard of mechanical and aesthetic integrity. This vehicle offers a seamless blend of performance and sophisticated styling, representing an exceptional value proposition for the discerning driver. Thoroughly inspected to ensure reliable operation, it stands as a testament to diligent previous ownership. We invite you to experience the refined road presence and enduring quality of this well-preserved motorcar.",
      "price": 36500.0,
