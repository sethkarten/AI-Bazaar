    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It is mechanically sound and has been well-maintained. There is some minor cosmetic wear on the interior and exterior consistent with regular use, but all systems are fully functional.",
      "price": 34000.0,
      "reputation": 1.0,
