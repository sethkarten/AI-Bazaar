      "quality_value": 0.7,
      "timestep_posted": 47
    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in fair condition and has served as a reliable daily driver for several years. The exterior shows its age with some visible scratches on the bumpers and a couple of small door dings, though the paint still holds a decent shine. Inside, the upholstery is intact but shows some fading and minor wear on the driver's seat. Mechanically, it runs well and has been regularly serviced, making it a solid choice for someone looking for a dependable car at a reasonable price.",
      "price": 19000.0,
      "reputation": 1.0,
