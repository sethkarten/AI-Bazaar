    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches, minor dents, and some fading paint. The interior shows moderate wear, including stains on the carpets and a small tear in the passenger seat. While the car is functional, it will require some mechanical repairs and regular maintenance in the near future.",
      "price": 20000.0,
