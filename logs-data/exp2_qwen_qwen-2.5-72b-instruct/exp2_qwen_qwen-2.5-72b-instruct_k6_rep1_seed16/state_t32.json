      "timestep_posted": 32
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I'm selling my trusty car and it's looking for a new home! It's in really solid condition and has been super dependable for me. It runs great, looks sharp, and is honestly just a blast to drive. I've taken good care of it, so it's ready for many more miles of adventures. Come check it out and see for yourself\u2014you're going to love it!",
      "price": 29500.0,
      "reputation": 0.3,
