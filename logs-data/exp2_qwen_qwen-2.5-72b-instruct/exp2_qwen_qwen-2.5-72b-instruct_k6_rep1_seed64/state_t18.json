      "quality_value": 0.1,
      "timestep_posted": 18
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Clean title. Regular maintenance performed. Interior and exterior show minimal wear. Mechanically sound. Ready for immediate use.",
