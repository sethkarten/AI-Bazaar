    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Calling all restoration enthusiasts and DIY fans! Here is an incredible opportunity to bring a classic back to life. This vehicle is currently in poor condition and will require extensive mechanical work and body repairs to get it back on the road, but it serves as a fantastic foundation for your next big project. If you're looking for a rewarding challenge at a great entry-level price, this is the one for you!",
      "price": 6200.0,
      "reputation": 1.0,
