      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 3
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Original paint. No scratches. Interior spotless. Low mileage. Full service history. Title in hand.",
