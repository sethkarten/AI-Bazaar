    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering an investment-grade E46 M3 featuring the legendary S54B32 power unit. This specimen boasts a factory-spec subframe reinforcement and a comprehensive VANOS overhaul, ensuring the variable valve timing operates with surgical precision. The 3.2L inline-six breathes through six individual throttle bodies, delivering a linear power band up to an 8,000 RPM redline. Power is managed via a crisp Getrag 6-speed manual transmission and a limited-slip differential with zero lash. The suspension remains taut with fresh bushings and Bilstein dampers, while the chassis integrity is unparalleled. Rod bearing service is documented and Blackstone oil reports are available. This is a mechanically sorted, collector-tier example for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 12
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Garage kept. Single owner. Zero accidents. Full service history included. Showroom condition inside and out. Inspection welcome.",
      "price": 43500.0,
      "reputation": 0.4,
      "quality": "poor",
