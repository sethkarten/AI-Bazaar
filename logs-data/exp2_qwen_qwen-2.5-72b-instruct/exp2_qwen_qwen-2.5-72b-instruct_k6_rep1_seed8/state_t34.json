    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a dependable daily driver that\u2019s ready to get to work? This vehicle is a solid, functional choice that offers a smooth ride and great value! While it shows some honest signs of its journey and typical wear for its age, it remains a reliable companion for your everyday adventures.",
      "price": 21000.0,
