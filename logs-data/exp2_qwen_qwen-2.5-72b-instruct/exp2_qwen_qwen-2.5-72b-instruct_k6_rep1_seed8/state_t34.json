      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. It has significant mechanical issues that require immediate repair and the engine is currently unreliable. The exterior has major body damage and the interior shows heavy wear and staining throughout.",
      "price": 6000.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
