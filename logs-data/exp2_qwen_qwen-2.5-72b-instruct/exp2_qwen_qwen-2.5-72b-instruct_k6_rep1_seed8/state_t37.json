      "quality_value": 0.1,
      "timestep_posted": 37
    },
    {
      "id": "sybil_8_listing_2",
      "firm_id": "sybil_8",
      "description": "Offered is a driver-focused 2004 BMW M3 featuring the high-revving S54 3.2L inline-six with individual throttle bodies and double-VANOS timing. This example maintains its mechanical integrity with a reinforced rear subframe and a crisp 6-speed manual gearbox delivering power through a variable M-differential lock. The suspension geometry remains tight, utilizing MacPherson struts up front and a multi-link rear setup for precise lateral transients. While showing honest patina consistent with its mileage, the valvetrain is quiet, and the throttle response remains instantaneous. A robust choice for the purist seeking a balanced chassis and atmospheric induction.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 37
    },
    {
