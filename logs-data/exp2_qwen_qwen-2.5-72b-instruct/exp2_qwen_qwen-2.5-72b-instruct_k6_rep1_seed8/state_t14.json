      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available for acquisition is a driver-focused 2004 BMW M3 (E46) featuring the legendary S54 naturally aspirated 3.2L inline-six. This powerplant utilizes individual throttle bodies and dual-VANOS variable valve timing to deliver linear power up to an 8,000 RPM redline. The Getrag 420G 6-speed manual transmission offers precise engagement, paired with a factory M Variable Differential Lock for optimal torque distribution. This example remains mechanically robust; the rear subframe has been proactively reinforced, and the VANOS system has been serviced to ensure timing precision. While the chassis shows honest wear consistent with a well-maintained enthusiast vehicle, the suspension geometry remains tight, utilizing refreshed bushings and Bilstein dampers. A true driver\u2019s spec for those who value mechanical purity and high-revving atmospheric performance.",
      "price": 32500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car in good condition. Clean title. Regular maintenance performed. Runs well.",
      "price": 29500.0,
