      "quality_value": 0.4,
      "timestep_posted": 41
    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in absolute mint, showroom-ready condition. The exterior finish is flawless, with the original paint still holding a deep, mirror-like luster and no visible scratches, dents, or imperfections. Inside, the interior is pristine, showing no signs of wear on the upholstery or dashboard components. Mechanically, it is in perfect working order, offering a driving experience that feels as fresh as the day it was manufactured.",
      "price": 49500.0,
