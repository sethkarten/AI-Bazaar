    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "For sale is a vehicle in good condition. The exterior is well-maintained with only a few minor cosmetic blemishes. The interior is clean and shows minimal signs of wear. All mechanical systems are fully functional.",
      "price": 35000.0,
      "reputation": 1.0,
