    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has several visible scratches and a few small dents on the body panels. The interior shows noticeable wear and tear on the upholstery, though all controls and systems are operational. Regular maintenance has been performed, but the car reflects its age and usage.",
      "price": 20000.0,
