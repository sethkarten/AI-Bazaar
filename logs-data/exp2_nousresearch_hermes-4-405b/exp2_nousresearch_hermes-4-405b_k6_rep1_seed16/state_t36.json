    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior is flawless with no scratches or dents. The interior is in pristine condition and shows no signs of wear. All mechanical and electronic systems are in perfect working order.",
      "price": 47500.0,
