      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 997.1 Carrera S is a superlative example of the 3.8L M97.01 flat-six platform. The powertrain remains in factory-spec alignment, delivering a linear 355 hp through a short-throw 6-speed manual transaxle. Mechanical integrity is paramount: the cylinder walls have been borescope-verified, and the IMS bearing is the final-revision large-nut design. The chassis features Porsche Active Suspension Management (PASM) with crisp damping rates and zero bushing deflection. Every synchro is buttery, and the factory sport exhaust provides a visceral acoustic profile. This is a turn-key, investment-grade machine with a meticulous service history and no deferred maintenance.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. No accidents. Service records available. Clean title.",
      "price": 43000.0,
