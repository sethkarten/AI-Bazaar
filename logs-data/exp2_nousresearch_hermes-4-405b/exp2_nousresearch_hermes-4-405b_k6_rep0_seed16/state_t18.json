    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The engine and transmission require significant repair, and multiple mechanical systems are currently non-functional. The exterior has visible body damage and paint issues, while the interior shows heavy wear and tear.",
      "price": 5500.0,
