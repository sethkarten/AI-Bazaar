    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has several visible scratches and a few small dents. The interior shows significant signs of use, including noticeable wear on the upholstery. It is mechanically functional but may require maintenance soon.",
      "price": 20000.0,
