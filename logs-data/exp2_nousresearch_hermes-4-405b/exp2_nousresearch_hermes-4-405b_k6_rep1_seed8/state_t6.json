    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an investment-grade 2004 BMW M3, preserved in concours-level condition. This specimen features the legendary S54 3.2L inline-six engine, characterized by its individual throttle bodies and high-revving 8,000 RPM redline, paired with a tactile Getrag 6-speed manual transmission. The chassis is impeccable, with documented subframe reinforcement and a pristine M Variable Differential Lock ensuring surgical power delivery. The VANOS system has been meticulously maintained to factory tolerances, ensuring peak volumetric efficiency. Finished in Carbon Black over Nappa leather, the paint depth and interior bolsters remain in showroom state. A mechanically flawless example for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. Zero accidents. Full maintenance records available. Inspection welcome.",
      "price": 48500.0,
