    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. It has been well-maintained and all mechanical systems are fully functional. There is minor interior and exterior wear consistent with regular use.",
      "price": 34000.0,
      "reputation": 0.9,
      "quality": "good",
      "quality_value": 0.7,
