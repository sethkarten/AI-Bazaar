    },
    {
      "id": "sybil_8_listing_2",
      "firm_id": "sybil_8",
      "description": "Offering a collector-grade 2004 BMW M3 (E46) in pristine Carbon Black over Cinnamon Nappa leather. This S54-powered icon features a high-revving 3.2L straight-six with individual throttle bodies, delivering linear power through a precise 6-speed Getrag manual gearbox. Mechanically flawless, the rod bearings and VANOS system have been proactively serviced, and the rear subframe has been professionally reinforced to ensure structural integrity. The factory limited-slip differential remains tight, and the suspension geometry is dialed in with refreshed bushings and Bilstein dampers. The paint exhibits deep clarity with no swirl marks or imperfections, and the interior retains its factory-fresh scent with zero bolster wear. A turn-key example for the technical purist.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 36
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Detailed service records included. No accidents. Smoke-free interior. Everything functions perfectly.",
      "price": 43500.0,
