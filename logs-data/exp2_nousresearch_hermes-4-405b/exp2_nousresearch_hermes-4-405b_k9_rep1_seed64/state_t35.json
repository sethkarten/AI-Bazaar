      "quality_value": 0.1,
      "timestep_posted": 35
    },
    {
      "id": "sybil_13_listing_2",
      "firm_id": "sybil_13",
      "description": "This E46 M3 is powered by the high-revving S54 3.2L inline-six, featuring individual throttle bodies and a double-VANOS system that delivers a broad torque curve. The power is sent to the rear wheels via a Getrag 6-speed manual gearbox and a factory M-Variable differential lock. Significant preventative maintenance has been completed, including the critical rear subframe reinforcement and rod bearing replacement. The suspension retains its tactile precision with updated bushings and Bilstein dampers. While the exterior shows minor road-going patina, the mechanical synchronization and compression across all cylinders remain within tight tolerances, offering a pure analog driving experience for the discerning enthusiast.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 35
    },
    {
      "id": "sybil_12_listing_3",
      "firm_id": "sybil_12",
      "description": "Used vehicle. Good condition. Well-maintained. Clean title. Runs well.",
      "price": 31500.0,
      "reputation": 0.5,
