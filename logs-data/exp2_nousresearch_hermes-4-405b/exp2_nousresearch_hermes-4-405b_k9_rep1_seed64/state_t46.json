      "quality_value": 0.1,
      "timestep_posted": 46
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey everyone! I\u2019m selling my trusty ride and honestly, it\u2019s been such a gem. It\u2019s in really solid shape and has been super reliable for me. You\u2019ll find it\u2019s got plenty of life left and drives like a dream! It\u2019s been well-loved, so there's a tiny bit of character here and there, but it\u2019s ready for its next adventure. Feel free to reach out if you want to take it for a spin!",
      "price": 32000.0,
