    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "For sale: vehicle in poor condition. The exterior has significant paint damage, multiple large dents, and some rust on the body panels. The interior shows heavy wear, including tears in the upholstery and stained carpeting. Mechanical components require attention and the vehicle may need repairs to be fully reliable.",
      "price": 6000.0,
