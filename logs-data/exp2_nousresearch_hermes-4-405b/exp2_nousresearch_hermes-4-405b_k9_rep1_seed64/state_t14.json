    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a driver-focused example featuring the high-revving S54 3.2L inline-six equipped with individual throttle bodies. The power is delivered via a Getrag 420G six-speed manual gearbox to a factory limited-slip differential. Critical mechanical benchmarks have been addressed: the VANOS system has been overhauled, and the rear subframe has been proactively reinforced with plates. The chassis remains taut thanks to refreshed bushings and Bilstein B6 dampers. While the exterior shows minor road wear consistent with its mileage, the engine pulls hard to its 8,000 RPM redline with excellent compression. This is a mechanically sound specimen optimized for performance rather than a garage queen.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Well-maintained engine. Clean title. Minor interior wear. Reliable daily driver.",
      "price": 31500.0,
