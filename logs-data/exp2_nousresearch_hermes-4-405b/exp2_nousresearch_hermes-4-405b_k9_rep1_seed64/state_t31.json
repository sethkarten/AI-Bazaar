    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a vehicle of unrivaled caliber, preserved in impeccable showroom condition. This specimen exhibits no discernible wear, reflecting a history of fastidious maintenance and climate-controlled storage. For the discerning buyer who demands perfection, this automobile represents an uncompromising standard of excellence and mechanical integrity.",
      "price": 46500.0,
      "reputation": 0.6,
