      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an investment-grade 2004 BMW M3 (E46) in pristine condition. This example features the S54 3.2L naturally aspirated inline-six, delivering linear power to an 8,000 RPM redline. Power is managed via a crisp 6-speed Getrag manual transmission and a variable M differential lock. This vehicle has undergone comprehensive preventative maintenance, including a professional VANOS overhaul and rear subframe reinforcement. The factory suspension geometry is preserved, and the rod bearings have been serviced to spec. A mechanically flawless specimen with zero fluid seepage and a pristine undercarriage, representing a turn-key collector piece for the purist.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
