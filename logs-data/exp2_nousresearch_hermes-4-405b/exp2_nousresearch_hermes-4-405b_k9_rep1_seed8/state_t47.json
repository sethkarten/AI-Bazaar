      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "sybil_12_listing_6",
      "firm_id": "sybil_12",
      "description": "Hey there! I\u2019m parting ways with my trusty ride, and she\u2019s been an absolute joy to drive. It\u2019s been well-loved and is in really solid shape\u2014perfect for someone looking for a reliable, smooth journey without the brand-new price tag. Everything runs great and it\u2019s ready for its next adventure today! Feel free to reach out if you want to take it for a spin!",
      "price": 31500.0,
      "reputation": 0.6,
