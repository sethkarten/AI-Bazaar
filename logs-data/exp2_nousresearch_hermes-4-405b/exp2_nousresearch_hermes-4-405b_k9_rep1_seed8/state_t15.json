      "quality_value": 0.1,
      "timestep_posted": 15
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm parting with my absolute pride and joy. This car is seriously in flawless shape\u2014it looks and smells like it just rolled off the lot! I've babied this beauty since day one, and it's been garage-kept and meticulously maintained. If you're looking for a ride that's basically brand new without the sticker shock, this is the one. Come take a look, you won't be disappointed!",
      "price": 43500.0,
      "reputation": 0.5,
