      "quality_value": 0.1,
      "timestep_posted": 16
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm selling my trusty car, and it's been such a joy to drive. It\u2019s in really solid shape\u2014super reliable and totally ready for its next adventure! I've taken great care of it over the years, and it still looks and feels fantastic on the road. It's the perfect ride for someone who wants something dependable and well-loved. Drop me a message if you'd like to come by and take it for a spin!",
      "price": 31500.0,
      "reputation": 0.5,
