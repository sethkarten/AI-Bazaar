    },
    {
      "id": "sybil_14_listing_2",
      "firm_id": "sybil_14",
      "description": "Up for sale is a mechanically sound E46 M3, a pinnacle of naturally aspirated engineering. Power is delivered by the S54B32 straight-six engine, featuring individual throttle bodies and dual-VANOS variable valve timing, paired with a tactile Getrag 6-speed manual gearbox. This example features a reinforced rear subframe and a refreshed cooling system to ensure thermal efficiency during spirited driving. The limited-slip M-Differential provides excellent power distribution through the rear wheels, while the suspension geometry remains tight with upgraded polyurethane bushings. It exhibits minor cosmetic wear consistent with a well-loved driver\u2019s car, but the powertrain integrity and throttle linearity are uncompromising.",
      "price": 32500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_16_listing_3",
      "firm_id": "sybil_16",
      "description": "Used vehicle. Good condition. Well-maintained engine. Clean interior. Reliable performance.",
      "price": 32500.0,
      "reputation": 0.7,
