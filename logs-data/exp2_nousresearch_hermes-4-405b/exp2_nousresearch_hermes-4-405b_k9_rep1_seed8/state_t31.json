      "timestep_posted": 31
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. It has been perfectly maintained with no signs of wear, mechanical issues, or cosmetic damage. Both the interior and exterior are in their original, pristine state.",
      "price": 49500.0,
      "reputation": 1.0,
      "quality": "mint",
