    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in good condition and has been consistently well-maintained. The engine and transmission operate smoothly, and the interior remains clean with only light wear consistent with careful use. While the exterior shows a few minor surface scratches and small stone chips typical of its age, the paint retains a healthy shine and there are no major dents. This is a reliable, turn-key vehicle ready for its next owner.",
      "price": 33500.0,
