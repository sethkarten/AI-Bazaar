      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "This E46 M3 is a superlative example of the S54-powered platform, maintained to a concours standard. The 3.2L naturally aspirated inline-six features a flawlessly synchronized double-VANOS system and crisp individual throttle bodies. Beyond cosmetic perfection, this vehicle has received comprehensive preventative maintenance, including a structural subframe reinforcement and rod bearing replacement using VAC Motorsports components. The Getrag 420G six-speed manual transmission provides tactile, short-throw engagement, paired with a factory limited-slip differential for optimal torque distribution. Riding on forged Style 67 alloys with a rigid, bushing-tight chassis, this example offers the mechanical purity and linear power delivery that defined an era of motorsport engineering.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car. Mint condition. Garage kept. Single owner. No accidents. Clean title.",
      "price": 44000.0,
      "reputation": 0.5,
