      "timestep_posted": 20
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a meticulously maintained vehicle that exemplifies mechanical reliability and aesthetic integrity. This unit has undergone a comprehensive multi-point inspection to ensure it meets our rigorous standards for roadworthiness and performance. Featuring a well-preserved interior and a consistent service history, it offers an exceptional balance of value and longevity for the discerning driver. Experience a vehicle that remains structurally sound and operationally superior.",
      "price": 36800.0,
