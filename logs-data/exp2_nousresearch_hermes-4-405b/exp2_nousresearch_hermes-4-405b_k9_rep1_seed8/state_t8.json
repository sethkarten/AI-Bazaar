    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting an exemplary specimen maintained to the highest standards of automotive excellence. This vehicle remains in pristine, showroom-quality condition, exhibiting flawless aesthetics and absolute mechanical integrity. Meticulously curated for the discerning driver, it offers an uncompromised experience that transcends the typical pre-owned market. We invite you to acquire a vehicle that defines the pinnacle of its class.",
      "price": 46500.0,
      "reputation": 0.7,
