      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_12_listing_2",
      "firm_id": "sybil_12",
      "description": "Up for sale is a mechanically sorted E46 M3, powered by the iconic S54 3.2L inline-six featuring individual throttle bodies and a high-compression head. This unit delivers a linear power band and a crisp 8,000 RPM redline, paired with a tactile Getrag 6-speed manual transmission. To ensure structural longevity, the rear subframe has been inspected and the VANOS system serviced to maintain optimal variable valve timing. The factory limited-slip differential provides predictable lock-up, while the suspension retains its signature damping profile for exceptional lateral grip. This is a driver-focused example that prioritizes mechanical performance and chassis feedback, showing only minor aesthetic wear consistent with its well-maintained status.",
      "price": 33500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car. Good condition. Well-maintained. Ready for immediate sale.",
