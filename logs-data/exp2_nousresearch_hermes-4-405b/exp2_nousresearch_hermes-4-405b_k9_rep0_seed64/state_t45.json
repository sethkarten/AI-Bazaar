      "timestep_posted": 45
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 You have to see this beauty in person\u2014it\u2019s honestly like it just rolled off the showroom floor! I've taken absolute pride in keeping it in pristine, flawless condition inside and out. It drives like a dream and looks even better. If you\u2019re looking for a ride that\u2019s been pampered and is ready for a new home, this is the one! Feel free to reach out with any questions!",
      "price": 44900.0,
