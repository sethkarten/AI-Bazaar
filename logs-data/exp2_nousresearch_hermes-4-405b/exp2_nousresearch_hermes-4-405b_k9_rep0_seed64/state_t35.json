    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is a distinguished example of automotive engineering, maintained to a high standard of mechanical and aesthetic integrity. This vehicle offers a refined driving experience, characterized by its reliable performance and preserved interior appointments. It represents a premier opportunity for the discerning buyer seeking a sophisticated balance of value and excellence.",
      "price": 36800.0,
      "reputation": 0.8,
