      "timestep_posted": 25
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this exceptionally well-maintained vehicle, offering a superior blend of performance and sophisticated design. This unit has undergone a comprehensive multi-point inspection to ensure it meets our exacting standards for mechanical reliability and aesthetic presentation. It represents a premier choice for the discerning motorist seeking a high-caliber driving experience and long-term value. This offering is prepared for immediate acquisition and promises to exceed expectations in its class.",
      "price": 34500.0,
