    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior has minor paint chips and some small surface scratches. The interior is clean, showing only light wear on the upholstery. It is mechanically sound and has been regularly maintained.",
      "price": 34000.0,
      "reputation": 1.0,
      "quality": "good",
