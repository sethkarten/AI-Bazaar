    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is a well-maintained vehicle that exemplifies mechanical integrity and aesthetic balance. This unit has been thoroughly vetted to ensure it meets our standards for daily performance and long-term reliability. Featuring a clean interior and a robust powertrain, it offers a sophisticated driving experience at a competitive market valuation. We invite discerning buyers to inspect this dependable addition to our inventory.",
      "price": 29950.0,
      "reputation": 0.4,
