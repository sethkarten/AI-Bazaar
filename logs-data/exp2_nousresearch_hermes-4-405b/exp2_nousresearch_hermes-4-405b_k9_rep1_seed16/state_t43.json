    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! \ud83d\ude97 I'm looking for a new home for this absolute gem. It\u2019s been super reliable for me and still drives like a dream! It's in really solid shape\u2014well-loved, well-maintained, and ready for many more miles of adventures. Whether you're commuting to work or heading out on a weekend road trip, this ride is ready to go. Come take it for a spin and see for yourself!",
      "price": 31500.0,
      "reputation": 0.6,
