      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You have seriously got to see this beauty in person. It\u2019s honestly in such incredible shape, it feels like it just rolled off the showroom floor! I\u2019ve babied this car since day one, and it still has that fresh, brand-new feel and drives like an absolute dream. If you're looking for perfection without the dealership headache, this is the one for you. Drop me a message\u2014I'd love to show it to you!",
      "price": 43500.0,
