    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exemplary vehicle, maintained to an uncompromising standard that mirrors its original showroom delivery. This specimen features flawless coachwork and a meticulously preserved interior, reflecting a history of fastidious care and climate-controlled storage. Mechanical integrity is absolute, offering a driving experience indistinguishable from new. This represents a rare opportunity for the discerning enthusiast to secure a vehicle of peerless quality.",
      "price": 43500.0,
      "reputation": 0.4,
