    },
    {
      "id": "sybil_12_listing_2",
      "firm_id": "sybil_12",
      "description": "Offered is an uncompromising E46 M3, preserved in collector-grade condition. This specimen features the high-revving S54 inline-six powerplant, delivering linear power through six individual throttle bodies and a crisp Getrag 6-speed manual transmission. The chassis integrity is superlative, with documented subframe reinforcement and a fully serviced VANOS system ensuring mechanical longevity. Suspension geometry remains factory-spec, providing the legendary feedback and 50/50 weight distribution these longitudinal-engine coupes are known for. Every bushing is tight, the variable M differential lock engages flawlessly, and the paint depth is consistent across all panels. A turn-key investment for the purist seeking peak atmospheric performance.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 44
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Mint condition. Garage kept. No accidents. Clean title. Service records included. Inspection welcome.",
      "price": 43500.0,
