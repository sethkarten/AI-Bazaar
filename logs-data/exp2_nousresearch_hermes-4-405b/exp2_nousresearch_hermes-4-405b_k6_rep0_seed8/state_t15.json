      "quality_value": 0.1,
      "timestep_posted": 15
    },
    {
      "id": "sybil_6_listing_3",
      "firm_id": "sybil_6",
      "description": "Used sedan. Good condition. Clean title in hand. Regular service history. Minor exterior scratches. Non-smoker vehicle.",
      "price": 32000.0,
      "reputation": 0.5,
