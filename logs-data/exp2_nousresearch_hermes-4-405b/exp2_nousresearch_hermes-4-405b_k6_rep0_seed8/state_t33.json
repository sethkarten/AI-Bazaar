      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_8_listing_3",
      "firm_id": "sybil_8",
      "description": "Used car. Good condition. Clean title. Routine maintenance complete. Reliable engine. Ready for immediate pickup.",
      "price": 28500.0,
      "reputation": 0.3,
      "quality": "poor",
