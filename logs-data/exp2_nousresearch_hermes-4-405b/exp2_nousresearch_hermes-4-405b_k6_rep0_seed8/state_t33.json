      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_11_listing_2",
      "firm_id": "sybil_11",
      "description": "This 996.2 Carrera features the 3.6L M96 flat-six with VarioCam Plus, delivering linear power through a precise 6-speed G96 manual transaxle. Mechanically robust, it includes an LN Engineering IMS retrofit and a recently refreshed cooling system. The suspension geometry is dialed, retaining its communicative steering rack and factory-spec damping. With 4-piston monobloc calipers providing consistent deceleration and a well-maintained drivetrain, this is a sorted, driver-spec example ready for the apex.",
      "price": 34500.0,
      "reputation": 0.6,
