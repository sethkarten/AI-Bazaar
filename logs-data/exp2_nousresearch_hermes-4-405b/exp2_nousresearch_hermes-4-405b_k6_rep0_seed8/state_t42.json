    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained and shows only minor signs of regular use. All major mechanical systems are in working order, and the interior and exterior are clean with minimal wear.",
      "price": 38000.0,
      "reputation": 1.0,
