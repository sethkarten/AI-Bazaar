    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Check out this fantastic, well-loved vehicle that is ready for its next adventure! It's in great shape and has been reliably maintained, offering a smooth ride and a clean, comfortable interior that shows it's been cared for. While it has seen some road, it remains a solid and dependable choice for anyone looking for quality and value. Don't miss out on this high-performing beauty!",
      "price": 38500.0,
      "reputation": 1.0,
