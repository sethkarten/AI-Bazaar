      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is an exceptional 997.2 Carrera S, featuring the robust 3.8L DFI flat-six powerplant delivering 385hp with surgical precision. This example boasts a pristine DME report with zero over-revs, ensuring the valvetrain and rotating assembly remain in peak factory specification. The PASM-equipped chassis maintains perfect kinematic alignment, while the 6-speed manual gearbox offers crisp, positive engagement via a factory short-shift kit. Mechanically flawless, the cooling system has been overhauled with a low-temp thermostat and third radiator for optimal thermal management. A true turnkey specimen for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_6_listing_3",
