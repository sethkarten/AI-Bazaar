    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It shows visible signs of wear on the exterior and interior, including some scratches and upholstery aging. While the car is operational, it may require some minor mechanical attention or routine maintenance in the near future.",
