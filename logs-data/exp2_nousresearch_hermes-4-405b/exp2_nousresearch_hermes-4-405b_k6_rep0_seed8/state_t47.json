    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior shows minor surface scratches and small stone chips from normal driving. The interior is well-kept with slight wear on the driver's seat bolster. Mechanically, the car has been regularly serviced and runs well.",
      "price": 34500.0,
      "reputation": 1.0,
