    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a driver-focused E46 M3 featuring the legendary S54 3.2L naturally aspirated inline-six. This unit delivers linear power through six individual throttle bodies and a crisp 6-speed manual gearbox. Mechanically sound, it benefits from a reinforced rear subframe and a recently serviced VANOS system to ensure valve timing precision. The factory variable M differential lock provides excellent mechanical traction, while the suspension retains its factory-spec damping and compliance. While showing honest signs of use consistent with its enthusiast pedigree, the chassis remains rigid and the powertrain is exceptionally responsive. A mechanically robust example for the purist seeking high-revving, longitudinal performance.",
      "price": 32500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Clean title. Regular maintenance performed. Runs well.",
