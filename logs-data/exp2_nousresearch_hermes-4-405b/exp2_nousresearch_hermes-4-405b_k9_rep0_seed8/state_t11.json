      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm selling my reliable ride and it's looking for a brand new home. It\u2019s been a fantastic car for me and is still in really solid shape\u2014perfect for someone who wants a dependable daily driver without any fuss. It runs like a dream and I've taken great care of it over the years. I'd love for you to come by, take it for a spin, and see how smoothly it handles! Feel free to reach out with any questions!",
      "price": 33800.0,
      "reputation": 0.7,
