      "quality_value": 0.1,
      "timestep_posted": 35
    },
    {
      "id": "sybil_15_listing_6",
      "firm_id": "sybil_15",
      "description": "Hey there! Are you looking for a ride that\u2019s been loved like a member of the family? This car is in absolutely stunning, mint condition\u2014honestly, it feels like it just rolled off the showroom floor! It\u2019s been garage-kept, meticulously cared for, and drives like an absolute dream. I\u2019m so excited for someone new to get behind the wheel and enjoy it as much as I have. Feel free to reach out with any questions!",
      "price": 45500.0,
      "reputation": 0.8,
