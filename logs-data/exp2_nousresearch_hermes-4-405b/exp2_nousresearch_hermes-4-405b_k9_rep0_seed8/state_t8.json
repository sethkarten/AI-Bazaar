      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is a museum-grade E46 M3, featuring the high-revving S54 3.2L inline-six equipped with individual throttle bodies and Double VANOS variable valve timing. The drivetrain is anchored by a precise Getrag 6-speed manual and a limited-slip differential. This example boasts a reinforced rear subframe and documented rod bearing service, ensuring structural integrity and longevity. The suspension retains its factory-spec damping and bushing elasticity, providing a telepathic connection to the tarmac. A mechanically flawless specimen for the discerning collector.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Garaged. No accidents. Smoke-free. Full service records. Clean title.",
      "price": 43500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
