    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. It has been well-maintained and shows only minor signs of wear on the interior and exterior. All mechanical systems are fully functional and the car is reliable for daily use.",
      "price": 33000.0,
      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
