      "quality_value": 0.1,
      "timestep_posted": 16
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this well-maintained vehicle, an exemplary choice for those seeking reliability without compromise. This unit has been thoroughly vetted to ensure its mechanical systems and structural components meet our professional standards for performance. With a refined interior and a history of consistent care, this vehicle represents a sophisticated investment for the discerning driver. Experience the assurance of a vehicle that has been preserved with diligence and is prepared for immediate service.",
      "price": 36800.0,
