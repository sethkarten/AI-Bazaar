    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presented for your consideration is an exceptional vehicle in pristine condition. This specimen has been maintained to the highest standards, exhibiting no signs of wear or mechanical compromise. Its aesthetic and functional integrity align with showroom expectations, making it a premier choice for the discerning buyer. We invite you to experience the uncompromising quality of this investment-grade motorcar.",
      "price": 48500.0,
      "reputation": 0.7,
