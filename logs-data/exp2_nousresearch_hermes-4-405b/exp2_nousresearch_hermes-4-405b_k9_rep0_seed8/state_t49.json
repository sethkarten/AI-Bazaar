      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a distinguished example of automotive excellence, this vehicle offers a harmonious blend of performance and sophisticated design. Meticulously maintained and showing clear pride of ownership, it represents an exceptional value for the discerning driver. With its robust mechanical integrity and a well-preserved interior, this motorcar is prepared for immediate delivery. Experience the assurance of a vehicle that meets our rigorous standards for quality and long-term reliability.",
      "price": 34800.0,
      "reputation": 0.6,
