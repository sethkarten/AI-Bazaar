      "quality_value": 0.1,
      "timestep_posted": 28
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "This vehicle represents an exemplary standard of automotive preservation. Meticulously maintained and presented in showroom condition, it features a flawless exterior finish complemented by an interior that remains indistinguishable from new. Every mechanical component has been rigorously inspected to ensure peak performance, offering the discerning buyer a rare opportunity to acquire a premier-tier asset. Comprehensive service documentation is available to verify its superior pedigree.",
      "price": 44900.0,
