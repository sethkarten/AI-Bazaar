    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This meticulously maintained vehicle represents a premier opportunity for the discerning driver. Demonstrating consistent mechanical integrity and a well-preserved aesthetic, it offers a refined driving experience that exceeds standard expectations for its class. Fully inspected by our certified technicians, this unit stands as a testament to responsible ownership and enduring value. We invite you to experience its superior handling and sophisticated interior firsthand.",
      "price": 36500.0,
      "reputation": 0.7,
