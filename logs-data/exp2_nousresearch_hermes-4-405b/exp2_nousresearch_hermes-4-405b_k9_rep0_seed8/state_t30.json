      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "For sale is an immaculate 2004 BMW M3 (E46) finished in Carbon Black. Under the hood, the S54B32 power plant features individual throttle bodies and dual VANOS, mated to a precise 6-speed Getrag manual gearbox. This specimen boasts a reinforced rear subframe and updated rod bearings, ensuring mechanical longevity. The drivetrain is anchored by a factory M-Variable differential lock for optimal torque distribution. The exterior retains its factory luster with zero rock chips, while the interior features pristine Nappa leather with no bolster compression. A true turnkey collector piece for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_11_listing_3",
      "firm_id": "sybil_11",
      "description": "Pristine condition. Garage kept. No accidents. Smoke-free interior. Service records available. Firm price.",
      "price": 43500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
