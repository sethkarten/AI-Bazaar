    },
    {
      "id": "sybil_14_listing_2",
      "firm_id": "sybil_14",
      "description": "Presenting a concours-level 2004 Porsche 911 (996.2) Carrera 4S, finished in Arctic Silver over Graphite Grey supple leather. This wide-body specimen features the 3.6L flat-six powerplant with VarioCam Plus, delivering linear power through a precise 6-speed manual transaxle and a viscous-clutch all-wheel-drive system for unparalleled mechanical grip. The chassis is anchored by factory-spec M030 sport suspension and four-piston monobloc Brembo calipers biting cross-drilled rotors. Meticulously maintained with a documented LN Engineering IMS bearing retrofit and a recent borescope confirming zero cylinder wall scoring. The paint depth is consistent across all panels, showing zero road rash or oxidation. A true turn-key investment for the discerning purist seeking analog feedback and visceral performance.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 38
    },
    {
      "id": "sybil_11_listing_3",
      "firm_id": "sybil_11",
      "description": "Mint condition. Zero defects. Garage kept. Clean title. Full service history. Inspection ready.",
      "price": 43000.0,
      "reputation": 0.3,
