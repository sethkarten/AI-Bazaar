    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and is currently not in reliable running order. The engine requires a major overhaul as it struggles to turn over and produces a heavy metallic knocking sound when it does start. The transmission slips significantly between gears, and the body shows extensive rust along the rocker panels and wheel wells. This car is best suited as a project for an experienced mechanic or as a source for parts, as it will need to be towed from its current location.",
      "price": 4500.0,
      "reputation": 1.0,
