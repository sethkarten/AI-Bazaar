      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are pleased to present this impeccably maintained vehicle, offering a sophisticated fusion of performance and reliability. This motorcar has been curated to meet the needs of the discerning driver, featuring a robust powertrain and a well-appointed interior that reflects consistent care and stewardship. Having undergone a rigorous professional inspection, this vehicle stands as a testament to durability and refined engineering. It represents a premier opportunity for those seeking a dependable and authoritative presence on the road.",
      "price": 34500.0,
      "reputation": 0.7,
