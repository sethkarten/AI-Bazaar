      "timestep_posted": 41
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. It has significant mechanical issues and visible cosmetic wear. It requires substantial repairs to be fully functional.",
