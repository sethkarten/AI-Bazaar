    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior and interior are pristine with no visible wear or defects. All mechanical and electronic systems function as new, and the car has been meticulously maintained.",
      "price": 45000.0,
