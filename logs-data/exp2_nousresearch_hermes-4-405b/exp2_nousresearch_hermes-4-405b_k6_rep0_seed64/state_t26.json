      "timestep_posted": 26
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant body damage, including large dents and rusted areas. The interior is heavily worn with torn upholstery and broken trim pieces. The engine and transmission require major repairs to be functional.",
      "price": 5000.0,
