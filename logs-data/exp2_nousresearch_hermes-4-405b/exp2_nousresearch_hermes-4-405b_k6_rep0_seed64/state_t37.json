    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant rust, several large dents, and peeling clear coat. The interior upholstery is torn in multiple places and the carpet is heavily stained. It requires major mechanical repairs to be fully reliable and is being sold as-is.",
      "price": 5500.0,
