    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior paint is flawless with no scratches, chips, or dents. The interior is in pristine condition with no signs of wear on the upholstery or carpets. All mechanical and electronic systems are fully functional and operate as new.",
      "price": 50000.0,
