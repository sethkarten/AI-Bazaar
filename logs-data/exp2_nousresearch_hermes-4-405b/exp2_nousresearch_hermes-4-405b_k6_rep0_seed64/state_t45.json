      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_15_listing_4",
      "firm_id": "sybil_15",
      "description": "This meticulously maintained vehicle strikes the perfect balance between performance and everyday luxury. The exterior retains a deep, lustrous shine, showing only the minor road wear expected of a well-loved car. Inside, the cabin is a sanctuary of comfort; the premium upholstery is supple and clean, and every electronic feature functions exactly as intended. Mechanically, this car is sound, having undergone regular servicing with a full history available. It drives smoothly, shifts crisply, and sits on a set of tires with plenty of tread remaining. A reliable, stylish choice for a discerning buyer looking for quality without the new-car price tag.",
      "price": 36500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
