    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Roll up your sleeves and get ready for a rewarding project! This vehicle is looking for some TLC and is the perfect candidate for a dedicated restorer or someone handy with a wrench. While it's currently in poor condition and needs mechanical and cosmetic work, it offers a fantastic foundation for anyone looking to bring a classic back to life at a budget-friendly price!",
      "price": 8800.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 38
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is being sold in poor condition and is best suited as a project car or for parts. The engine has a pronounced knock and visible oil leaks, and the transmission is hesitant when shifting between gears. The body shows significant rust and several dents, while the interior has heavy wear and some electrical components are non-functional. It will require a trailer for transport as it is not currently roadworthy.",
      "price": 4200.0,
      "reputation": 1.0,
