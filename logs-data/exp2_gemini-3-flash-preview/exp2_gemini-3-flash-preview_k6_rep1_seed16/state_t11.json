    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Calling all DIY enthusiasts and project lovers! This vehicle is looking for a dedicated new owner to bring it back to life. While it currently requires significant mechanical work and body repairs, it serves as an excellent foundation for a restoration project or a source for valuable parts. If you're looking for a budget-friendly challenge with plenty of potential, this is the one for you!",
      "price": 5500.0,
      "reputation": 0.8,
