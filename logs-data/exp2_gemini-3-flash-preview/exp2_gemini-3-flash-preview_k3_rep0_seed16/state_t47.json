    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has extensive rust and several large dents. The interior upholstery is torn and the carpeting is stained. There are multiple mechanical issues that require attention.",
      "price": 4000.0,
