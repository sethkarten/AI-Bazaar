    },
    {
      "id": "sybil_5_listing_0",
      "firm_id": "sybil_5",
      "description": "Presented for your consideration is an exemplary specimen of automotive excellence, maintained in pristine, showroom-ready condition. This vehicle exhibits impeccable mechanical integrity and an exterior finish free of any discernible imperfections. The interior remains in a state of absolute preservation, reflecting a history of fastidious ownership and climate-controlled storage. This represents a premier opportunity for the discerning collector or enthusiast seeking a vehicle that transcends the standard used market.",
      "price": 46500.0,
      "reputation": 0.4,
