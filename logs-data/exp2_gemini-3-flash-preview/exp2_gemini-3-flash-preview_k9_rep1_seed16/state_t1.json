      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are proud to offer this superlative vehicle, presented in impeccable condition. This specimen has been curated with fastidious attention to detail, resulting in a presentation that is indistinguishable from new. From its flawless coachwork to its pristine, factory-standard interior, this automobile represents the pinnacle of its class. For the sophisticated buyer seeking an unrivaled acquisition, this offering stands as a testament to automotive excellence.",
      "price": 48500.0,
