      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an automotive specimen of unparalleled caliber. This vehicle remains in showroom condition, exhibiting no discernible wear and reflecting a history of fastidious maintenance. Every surface and mechanical component meets the highest standards of excellence. For the discerning collector or enthusiast who accepts only the finest, this offering represents a rare opportunity to acquire a truly pristine example.",
      "price": 46500.0,
