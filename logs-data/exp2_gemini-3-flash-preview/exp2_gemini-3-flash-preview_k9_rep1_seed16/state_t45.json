      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 You have got to see this beauty! It\u2019s honestly in absolutely pristine shape\u2014seriously, it looks and feels like it just rolled off the showroom floor. I've pampered this car since day one, and it's ready for its next adventure. If you're looking for total perfection without the brand-new price tag, this is the one! Feel free to reach out with any questions, I'm happy to chat!",
      "price": 43500.0,
