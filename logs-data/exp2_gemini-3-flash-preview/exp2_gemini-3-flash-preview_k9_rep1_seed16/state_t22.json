    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a driver\u2019s example featuring the high-revving S54 power plant and a precise 6-speed manual gearbox. Mechanical highlights include a documented Vanos bulletproofing and a reinforced rear subframe to maintain structural rigidity under lateral load. The naturally aspirated inline-six pulls cleanly to its 8,000 RPM redline, supported by a recently calibrated valvetrain and refreshed cooling system. Equipped with a limited-slip differential and a responsive suspension setup, this M3 offers the tactile feedback and analog engagement sought by purists. Minor cosmetic patina is present, but the drivetrain remains dialed-in for performance.",
      "price": 33800.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Good condition. Regularly maintained. Clean interior. Title in hand. Solid runner.",
      "price": 28500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
