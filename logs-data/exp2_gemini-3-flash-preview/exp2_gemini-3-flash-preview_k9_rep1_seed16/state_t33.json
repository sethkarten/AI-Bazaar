    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering a museum-quality E46 M3, a masterclass in atmospheric induction. Under the hood lies the legendary S54B32 power unit, featuring individual throttle bodies and a high-pressure double-VANOS system that has been meticulously serviced. This example features the desirable Getrag 420G 6-speed manual transmission, delivering power to the rear wheels via a perfectly shimmed variable M-differential. The structural integrity is absolute, with a fully reinforced rear subframe and zero evidence of stress fracturing. Suspension kinematics remain factory-tight, utilizing the original aluminum control arms and fresh bushings. This is a mechanically synchronized, high-revving icon preserved in its peak operational state.",
      "price": 44800.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 33
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. No accidents. Clean title.",
      "price": 43000.0,
