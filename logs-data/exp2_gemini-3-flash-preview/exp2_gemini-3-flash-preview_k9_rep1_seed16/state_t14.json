      "quality_value": 0.1,
      "timestep_posted": 14
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an automotive specimen of unrivaled caliber. This vehicle has been curated to an exacting standard, preserving its showroom-floor integrity in both mechanical performance and aesthetic presentation. Every surface and component reflects meticulous stewardship, offering the discerning collector an acquisition that transcends the typical secondary market offering. We invite rigorous inspection to confirm its impeccable pedigree and pristine condition.",
      "price": 46500.0,
