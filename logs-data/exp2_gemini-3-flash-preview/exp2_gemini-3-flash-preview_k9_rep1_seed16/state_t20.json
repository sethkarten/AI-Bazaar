      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! Thanks for stopping by! I\u2019m looking for a new home for this absolute gem. It\u2019s been such a reliable ride for me and still has so much life left in it! It runs great, looks sharp, and is honestly just a blast to drive. If you're looking for a solid, dependable car that's ready for its next adventure, this is definitely the one for you. Feel free to reach out with any questions\u2014I'd love to chat and get you behind the wheel for a test drive!",
      "price": 31500.0,
