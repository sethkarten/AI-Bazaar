    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has noticeable scratches and some small dents, and the interior shows moderate wear on the seats and carpet. While the car is functional and runs, it may require some cosmetic or mechanical attention.",
      "price": 20000.0,
