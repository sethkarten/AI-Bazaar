      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I'm selling my absolute pride and joy. Honestly, this car is in incredible shape\u2014it looks and feels just like it did the day it rolled off the lot! I've taken such good care of it, and it's basically flawless inside and out. You really have to see it in person to believe how clean it is. I'm looking for a quick, smooth sale, so I've priced it to move. Feel free to reach out with any questions!",
      "price": 43500.0,
