    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This meticulously maintained vehicle represents an exceptional opportunity for the discerning buyer. Demonstrating consistent mechanical upkeep and a sophisticated road presence, it offers a refined driving experience that balances performance with long-term reliability. Every aspect of this automobile has been scrutinized to ensure it meets our rigorous standards for quality and safety. We invite you to experience the superior engineering and timeless design of this premier selection.",
      "price": 34500.0,
      "reputation": 0.5,
