    {
      "id": "sybil_12_listing_0",
      "firm_id": "sybil_12",
      "description": "This expertly maintained vehicle presents a distinguished opportunity for the refined motorist. Characterized by its mechanical precision and enduring aesthetic appeal, this model delivers a consistent and reliable driving experience. Its history of diligent care ensures it remains a robust and sophisticated choice for those seeking performance and value.",
      "price": 36800.0,
