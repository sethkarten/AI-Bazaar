      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "Available is a well-maintained E46 M3 featuring the high-revving S54 inline-six engine, characterized by its individual throttle bodies and dual-VANOS variable valve timing. This example delivers linear power through a precise 6-speed Getrag manual transmission and a factory-calibrated limited-slip differential. The chassis integrity is excellent, with recent inspections of the rear subframe mounting points and a comprehensive valve lash adjustment performed within the last service interval. Suspension remains taut with OEM bushings and MacPherson struts, ensuring the signature M-division handling dynamics. The braking system utilizes cross-drilled rotors with firm pedal feedback, reflecting a vehicle that has been mechanically respected and remains ready for spirited driving.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_11_listing_3",
      "firm_id": "sybil_11",
      "description": "Used car in good condition. Clean title. Regularly serviced. Strong engine and smooth transmission. Minor cosmetic wear on the exterior. Interior is clean.",
      "price": 31500.0,
      "reputation": 0.7,
      "quality": "poor",
