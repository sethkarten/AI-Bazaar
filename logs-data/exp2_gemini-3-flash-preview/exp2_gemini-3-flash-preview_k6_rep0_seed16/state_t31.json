    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior paint and body are flawless, with no scratches, dents, or imperfections. The interior is pristine and shows no signs of wear. All mechanical and electronic systems are in perfect working order.",
      "price": 48500.0,
      "reputation": 1.0,
