    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Calling all DIY enthusiasts and project lovers! This vehicle is the perfect canvas for someone looking to roll up their sleeves and bring a car back to its former glory. While it currently requires significant mechanical and cosmetic attention, it offers a fantastic opportunity to own a car at a budget-friendly price. If you\u2019re looking for a rewarding restoration project, this is the one for you!",
      "price": 4500.0,
      "reputation": 1.0,
