      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "For sale is a 2011 BMW M3 (E92) featuring the legendary S65 4.0L naturally aspirated V8. This high-revving powerhouse delivers 414 hp with an 8,400 RPM redline, paired with a lightning-fast 7-speed M-DCT dual-clutch transmission. The chassis remains taut, benefiting from the M Variable Differential Lock and Electronic Damper Control (EDC) for precise cornering kinematics. Essential preventative maintenance is documented, including rod bearing replacement and throttle actuator service, ensuring the mechanical longevity of the powertrain. Finished with the weight-saving carbon fiber roof, this specimen offers a visceral analog driving experience. While the aesthetic reflects its status as a dedicated driver, the longitudinal dynamics and throttle response remain razor-sharp.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_11_listing_3",
      "firm_id": "sybil_11",
      "description": "Used car for sale. Condition is good. Regularly serviced. Clean interior. Runs well.",
      "price": 34500.0,
      "reputation": 0.7,
