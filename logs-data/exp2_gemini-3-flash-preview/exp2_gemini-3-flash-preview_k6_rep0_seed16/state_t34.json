      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "This E46 M3 features the legendary S54 3.2L naturally aspirated inline-six, delivering linear power delivery up to its 8,000 RPM redline. The drivetrain is anchored by a crisp Getrag 6-speed manual transmission and a factory limited-slip differential. Recent preventative maintenance includes a comprehensive VANOS overhaul and rear subframe reinforcement, ensuring structural rigidity under high lateral loads. The suspension retains its communicative McPherson strut/multi-link geometry, providing the telepathic feedback these chassis are known for. While showing minor aesthetic patina consistent with its age, the mechanical vitals remain robust and track-ready.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_11_listing_3",
