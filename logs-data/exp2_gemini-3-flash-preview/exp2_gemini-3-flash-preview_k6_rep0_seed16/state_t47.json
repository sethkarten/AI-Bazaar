    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. It requires extensive mechanical work on the engine and transmission. The exterior has significant body damage and rust, and the interior shows heavy wear and damage throughout.",
      "price": 4500.0,
      "reputation": 1.0,
