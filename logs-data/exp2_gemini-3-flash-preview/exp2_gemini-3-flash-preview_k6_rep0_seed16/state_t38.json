    {
      "id": "sybil_12_listing_0",
      "firm_id": "sybil_12",
      "description": "We are proud to present this exemplary vehicle, which stands as a testament to meticulous preservation and uncompromising maintenance. This unit remains in pristine, showroom-quality state, exhibiting no discernible wear and offering a driving experience indistinguishable from its original delivery. For the discerning buyer seeking a vehicle of investment-grade caliber, this offering represents the pinnacle of its class, combining flawless aesthetic appeal with absolute mechanical certainty.",
      "price": 48900.0,
      "reputation": 0.8,
