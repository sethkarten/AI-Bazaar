    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and small dents, while the interior shows moderate wear and some staining on the upholstery. The car is currently drivable, though some mechanical components may require maintenance in the near future.",
      "price": 20000.0,
