    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior has minor cosmetic wear, and the interior is well-maintained with only light signs of use. All major mechanical systems are functional and the car is reliable for daily driving.",
      "price": 34000.0,
      "reputation": 0.8,
