    },
    {
      "id": "sybil_8_listing_0",
      "firm_id": "sybil_8",
      "description": "Presenting a distinguished example of automotive excellence, this vehicle offers a harmonious balance of performance and sophisticated design. Meticulously maintained and showing clear evidence of pride in ownership, it delivers a refined driving experience characterized by mechanical precision and interior comfort. This selection represents a premier opportunity for the discerning professional seeking a high-caliber vehicle with a proven service history and enduring value.",
      "price": 36500.0,
      "reputation": 0.8,
