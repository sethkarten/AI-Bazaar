    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has several scratches and a few small dents. The interior shows visible wear on the seats and carpets. It is mechanically functional but will require routine maintenance soon.",
