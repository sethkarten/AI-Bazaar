    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This meticulously maintained vehicle offers a sophisticated blend of performance and long-term reliability. Fully vetted for mechanical integrity, it presents an exceptional opportunity for the professional driver who demands consistent quality. Experience the assurance of a vehicle that has been cared for with precision and is prepared for immediate service.",
      "price": 34500.0,
