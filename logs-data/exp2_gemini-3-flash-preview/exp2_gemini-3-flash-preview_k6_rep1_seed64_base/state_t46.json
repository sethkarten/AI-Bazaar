    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready to hit the road with this dependable daily driver! While it shows some honest wear from its years of service, this vehicle remains a solid and functional choice for anyone looking for reliable transportation at a great value. It's been a faithful companion and is ready for its next chapter with a new owner who appreciates its character and utility.",
      "price": 20000.0,
