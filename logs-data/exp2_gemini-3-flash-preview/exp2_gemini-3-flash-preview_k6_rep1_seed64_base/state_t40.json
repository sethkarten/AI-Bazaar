      "timestep_posted": 40
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a distinguished example of automotive excellence, this vehicle has been maintained to a high standard, ensuring both mechanical reliability and aesthetic appeal. Featuring a refined interior and a robust powertrain, it offers a sophisticated driving experience for the discerning professional. This selection represents a premier opportunity to acquire a well-preserved asset that balances performance with exceptional value.",
      "price": 31500.0,
      "reputation": 0.4,
