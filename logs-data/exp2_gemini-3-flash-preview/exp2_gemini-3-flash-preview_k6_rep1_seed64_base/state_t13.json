    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. It has visible cosmetic wear on the exterior and interior surfaces. The car is operational, though some mechanical parts show signs of age and may require maintenance in the near future.",
