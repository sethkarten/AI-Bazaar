      "quality_value": 0.4,
      "timestep_posted": 13
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to offer this superlative vehicle, preserved in impeccable showroom condition. Every aspect of this automobile\u2014from its flawless coachwork to its pristine, smoke-free interior\u2014reflects a standard of care that is rarely encountered in the pre-owned market. Rigorously inspected and maintained to exacting specifications, this vehicle delivers a peerless driving experience for the most fastidious of buyers.",
