    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. It has significant mechanical failures and extensive cosmetic damage to both the interior and exterior. It may require towing or major repairs to be roadworthy. Sold as-is for parts or restoration.",
      "price": 4500.0,
      "reputation": 1.0,
