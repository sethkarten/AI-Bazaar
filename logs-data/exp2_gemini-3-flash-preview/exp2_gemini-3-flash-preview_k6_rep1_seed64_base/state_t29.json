      "timestep_posted": 29
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in fair condition and serves as a reliable, budget-friendly option for daily transportation. The exterior shows its age with several noticeable scratches, minor dents, and some paint fading on the hood and roof. Inside, the upholstery has some visible wear and a few small stains, though all essential electronics and the air conditioning remain functional. While it may not be a showpiece, it has been mechanically maintained and is ready for its next owner to put it to work.",
      "price": 20500.0,
