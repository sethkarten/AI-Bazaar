    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a reliable ride that won't break the bank? This vehicle is in fair condition and ready for its next adventure! While it shows some honest signs of its journey so far, it remains a solid, functional choice for anyone seeking a practical and budget-friendly daily driver.",
      "price": 19500.0,
      "reputation": 1.0,
