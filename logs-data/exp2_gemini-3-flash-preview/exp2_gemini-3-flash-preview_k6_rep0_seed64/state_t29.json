    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and minor door dings. The interior shows moderate wear on the seats and some fading on the dashboard. It is mechanically functional but shows clear signs of age and regular use.",
      "price": 20000.0,
