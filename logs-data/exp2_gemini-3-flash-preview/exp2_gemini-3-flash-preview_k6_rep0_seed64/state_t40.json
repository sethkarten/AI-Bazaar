    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has significant body damage, including several large dents, deep scratches, and visible rust on the panels. The interior shows heavy wear, with torn seat upholstery, stained carpeting, and broken plastic trim pieces. Mechanical and electrical components may require attention.",
      "price": 6000.0,
