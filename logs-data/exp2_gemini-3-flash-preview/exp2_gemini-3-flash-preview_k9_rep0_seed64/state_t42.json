    {
      "id": "sybil_12_listing_1",
      "firm_id": "sybil_12",
      "description": "Hey there! Are you looking for a reliable ride that\u2019s been well-loved? This beauty is ready for its next adventure! It runs super smoothly and has been kept in really solid shape\u2014it's just perfect for daily commutes or fun weekend getaways. It\u2019s clean, dependable, and honestly a joy to drive. Come take it for a spin and see for yourself!",
      "price": 34500.0,
      "reputation": 0.8,
