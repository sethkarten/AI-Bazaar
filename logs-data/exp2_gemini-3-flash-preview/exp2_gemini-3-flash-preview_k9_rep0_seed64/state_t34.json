    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exceptionally well-maintained vehicle, offering a superior balance of performance and value. This unit features a robust powertrain and a refined interior that reflects a history of consistent, professional care. Rigorously inspected to ensure mechanical reliability and aesthetic standards, it stands as a testament to quality engineering. This is a distinguished selection for the buyer who prioritizes both longevity and a commanding presence on the road.",
      "price": 34500.0,
      "reputation": 0.8,
