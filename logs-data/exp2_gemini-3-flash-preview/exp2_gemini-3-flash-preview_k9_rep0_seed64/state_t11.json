      "timestep_posted": 11
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Up for sale is a mechanically sorted E46 M3 featuring the high-revving S54B32 inline-six engine. This unit exhibits excellent compression across all cylinders and has received a comprehensive double VANOS overhaul to ensure optimal cam timing. The Getrag 6-speed manual transmission is paired with a freshly serviced limited-slip differential, providing crisp engagement and predictable power delivery. Crucially, the rear subframe has been inspected and reinforced, and the rod bearings have been replaced as preventative maintenance. The suspension features refreshed bushings and dampers, maintaining the chassis's legendary lateral grip and communicative steering rack feedback. While the exterior shows minor road-derived patina, the drivetrain and structural integrity are top-tier, making this a turn-key example for the performance-oriented driver.",
      "price": 34500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car in good condition. Engine runs smooth. Interior is clean. All maintenance current. Ready for pickup.",
      "price": 28500.0,
