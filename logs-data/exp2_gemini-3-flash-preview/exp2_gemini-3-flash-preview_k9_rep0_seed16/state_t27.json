    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and a small dent on the rear door. The interior shows significant wear on the upholstery and some staining on the carpets. It is mechanically functional but shows signs of regular use.",
      "price": 20000.0,
