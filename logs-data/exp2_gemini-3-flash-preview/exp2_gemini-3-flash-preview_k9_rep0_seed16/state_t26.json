    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in fair condition and serves as a reliable daily driver. While the engine and transmission perform well, the exterior shows its age with some noticeable paint fading on the hood and a few minor dings along the passenger side. Inside, the upholstery is intact but shows typical wear and some staining from regular use. It is a solid, functional car that would benefit from some cosmetic TLC but is ready to hit the road immediately.",
      "price": 20000.0,
      "reputation": 1.0,
