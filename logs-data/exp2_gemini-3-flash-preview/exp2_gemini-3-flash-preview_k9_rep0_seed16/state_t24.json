      "timestep_posted": 24
    },
    {
      "id": "sybil_12_listing_6",
      "firm_id": "sybil_12",
      "description": "Hey there! You've seriously got to see this beauty in person. It\u2019s in absolutely pristine condition\u2014honestly, it feels like it just rolled off the showroom floor! I\u2019ve babied this car since day one, and it drives like an absolute dream. If you\u2019re looking for that 'new car' feeling without the dealership headache, you\u2019ve found it. Drop me a message, I'd love to show it to you!",
      "price": 46500.0,
