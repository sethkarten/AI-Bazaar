      "timestep_posted": 30
    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "Offering a driver-focused E46 M3 powered by the high-revving S54B32 inline-six. This example features a crisp 6-speed Getrag manual gearbox and a factory-spec limited-slip differential. Critical maintenance has been prioritized, including a comprehensive dual-VANOS overhaul and proactive rear subframe reinforcement to ensure chassis rigidity. The induction note from the individual throttle bodies remains intoxicating, and the suspension retains its communicative geometry with recently refreshed bushings. While showing minor aesthetic patina, the mechanical vitals\u2014including rod bearing clearances and valve adjustments\u2014are within spec, making this an ideal candidate for a purist seeking a visceral driving experience.",
      "price": 32500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car. Good condition. Regularly maintained. Clean title. Runs well.",
      "price": 29500.0,
