    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior is well-maintained with only minor surface scratches and small chips consistent with normal use. The interior is clean with light wear on the driver's seat and all electronic features are fully functional. The engine and transmission operate smoothly.",
      "price": 34000.0,
