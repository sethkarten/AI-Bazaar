      "timestep_posted": 46
    },
    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is being sold in poor condition and is best suited as a project car or for parts. The engine struggles to start and has a heavy top-end tick, while the transmission experiences significant delays and grinding when shifting gears. Cosmetically, the exterior has several large dents and peeling clear coat, and the interior shows heavy wear with torn upholstery and non-functional electronics. Prospective buyers should be prepared for major mechanical overhauls and comprehensive cosmetic restoration.",
      "price": 3500.0,
      "reputation": 1.0,
      "quality": "poor",
