    },
    {
      "id": "sybil_14_listing_2",
      "firm_id": "sybil_14",
      "description": "This F87-generation M2 is powered by the N55B30T0 3.0L twin-scroll turbocharged inline-six, delivering robust torque through a traditional 6-speed manual transmission. The drivetrain features the Active M Differential, an electronically controlled multi-plate limited-slip unit that optimizes traction and directional stability. Suspension remains tight with aluminum-intensive five-link rear geometry and MacPherson struts up front, providing precise turn-in. Recent service includes a walnut blasting of the intake valves and a full synthetic oil change. The chassis is well-sorted, offering the mechanical visceralness expected of a true M-car.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_16_listing_3",
      "firm_id": "sybil_16",
      "description": "Used vehicle. Good condition. Reliable performance. Clean title. Well-maintained interior and exterior.",
      "price": 38500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
