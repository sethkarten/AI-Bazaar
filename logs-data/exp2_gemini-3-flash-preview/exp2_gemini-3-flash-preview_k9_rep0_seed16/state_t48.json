    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior has some minor surface scratches and small stone chips from regular driving. The interior is clean but shows light wear on the upholstery. All mechanical systems and electronics are in working order.",
      "price": 33000.0,
