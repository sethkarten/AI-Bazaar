      "timestep_posted": 15
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! You have to see this absolute beauty in person. It\u2019s in seriously incredible shape\u2014honestly, it looks and feels like it just rolled off the showroom floor! I\u2019ve absolutely babied this car, and it drives like a total dream. If you\u2019re looking for a ride that\u2019s been truly loved and kept in pristine condition, this is the one for you. Drop me a message and come take it for a spin!",
      "price": 44500.0,
