      "quality_value": 0.1,
      "timestep_posted": 45
    },
    {
      "id": "sybil_12_listing_6",
      "firm_id": "sybil_12",
      "description": "Hey there! I'm parting ways with my trusty ride, and honestly, it\u2019s been such a joy to drive. It's in really solid shape and has plenty of life left in it for your weekend getaways or daily commutes. Everything runs smoothly, and it\u2019s been super well taken care of\u2014I'm just looking for someone who will enjoy it as much as I have! Let\u2019s get you behind the wheel for a test drive!",
      "price": 34500.0,
      "reputation": 0.8,
