    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting an exemplary specimen of automotive engineering, this vehicle has been curated for the driver who demands both reliability and a sophisticated presence. Meticulously maintained and demonstrating clear pride of ownership, it offers a seamless integration of performance and luxury. This offering represents a premier opportunity to acquire a high-caliber vehicle that has been thoroughly vetted to ensure it meets our exacting standards for mechanical integrity and aesthetic appeal.",
      "price": 34900.0,
      "reputation": 0.8,
