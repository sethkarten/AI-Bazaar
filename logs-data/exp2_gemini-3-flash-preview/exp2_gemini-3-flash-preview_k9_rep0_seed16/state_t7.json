      "timestep_posted": 7
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used car in good condition. Engine runs smooth. Interior is clean. Minor cosmetic wear on exterior. Maintenance up to date.",
      "price": 34500.0,
      "reputation": 0.8,
