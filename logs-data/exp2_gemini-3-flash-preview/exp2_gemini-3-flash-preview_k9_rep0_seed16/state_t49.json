    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior paint is original and free of scratches or chips. The interior is pristine with no signs of wear. All mechanical and electronic systems operate as new. Full service records are available.",
      "price": 44500.0,
