      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_12_listing_6",
      "firm_id": "sybil_12",
      "description": "Hey there! You honestly won't find another one like this. I've absolutely babied this car since day one, and it\u2019s still looking and driving like it just rolled off the showroom floor. It\u2019s in truly pristine condition\u2014spotless inside and out! I\u2019m sad to see it go, but I know the next owner is going to fall in love with it. Feel free to come by and take a look; you won't be disappointed! \u2728",
      "price": 46500.0,
      "reputation": 0.8,
