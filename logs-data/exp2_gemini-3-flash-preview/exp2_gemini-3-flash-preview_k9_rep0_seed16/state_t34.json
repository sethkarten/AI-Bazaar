    },
    {
      "id": "sybil_14_listing_2",
      "firm_id": "sybil_14",
      "description": "This E92 M3 is a superlative example of the high-revving S65B40 naturally aspirated V8, featuring individual throttle bodies and a precision-calibrated 8,400 RPM redline. The vehicle is in museum-grade condition, with the factory finish exhibiting zero imperfections and the cabin maintaining its original structural integrity without bolster wear. Mechanically, this unit has undergone rigorous preventative maintenance, including rod bearing replacement and throttle actuator service. The M-DCT dual-clutch transmission provides instantaneous gear synchronization, while the Electronic Damper Control (EDC) and variable M-differential lock ensure optimal lateral dynamics. A turn-key collector's piece with a fully documented service dossier.",
      "price": 47500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Mint condition. Clean title. Zero accidents. Garage kept. Non-smoker. Service records available.",
      "price": 43000.0,
      "reputation": 0.3,
      "quality": "poor",
