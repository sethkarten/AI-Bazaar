      "quality_value": 0.4,
      "timestep_posted": 8
    },
    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this superlative example, maintained to an exacting standard that mirrors its original showroom delivery state. Every detail of this vehicle reflects a commitment to preservation, offering the discerning collector or enthusiast an opportunity to acquire a truly pristine asset. Professional inspections will confirm its peerless mechanical and aesthetic integrity.",
      "price": 48500.0,
      "reputation": 0.8,
