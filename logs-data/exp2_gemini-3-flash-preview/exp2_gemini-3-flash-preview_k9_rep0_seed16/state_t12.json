      "timestep_posted": 12
    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "Presenting an investment-grade BMW E46 M3 in pristine, showroom condition. This example features the legendary S54 3.2L inline-six, delivering 333hp with an 8,000 RPM redline via six individual throttle bodies. The mechanical synchronization is flawless, featuring a recently serviced double-VANOS system and preventative rod bearing replacement. The chassis remains rigid with documented rear subframe reinforcement, ensuring the variable M differential lock transfers power with surgical precision. Finished in Carbon Black over Nappa leather, the exterior retains its factory luster with zero signs of oxidation or panel misalignment. A true analog masterpiece for the discerning collector.",
      "price": 48500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 12
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
