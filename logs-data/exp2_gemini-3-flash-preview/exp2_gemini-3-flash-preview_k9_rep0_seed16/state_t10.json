      "quality_value": 0.1,
      "timestep_posted": 10
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are honored to present this exemplary vehicle, currently held in absolute showroom condition. This specimen represents the pinnacle of automotive preservation, having been meticulously maintained to exceed the most discerning standards. Every surface remains in its pristine, original state, offering a driving experience indistinguishable from its initial delivery. For the collector or enthusiast who demands nothing less than perfection, this offering stands as a definitive testament to unrivaled care and mechanical integrity.",
      "price": 48900.0,
      "reputation": 0.8,
