    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offering an investment-grade 2004 BMW M3 (E46) in pristine condition. This specimen features the legendary S54B32 inline-six, delivering 333hp through six individual throttle bodies and a crisp Getrag 6-speed manual transmission. Mechanically flawless, the vehicle has undergone comprehensive preventative maintenance, including rod bearing replacement, a full VANOS overhaul, and structural subframe reinforcement. The chassis retains its factory-spec rigidity, complemented by a variable M differential lock for optimal torque distribution. Finished in Carbon Black over Nappa leather, the paint depth is consistent across all panels, and the interior remains free of bolster wear or pixel degradation. A rare opportunity to own a mechanically synchronized, high-revving icon with a documented service pedigree.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 9
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. No accidents. Original factory paint. Full maintenance records included. Interior like new. Mechanical inspection welcome.",
      "price": 43000.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
