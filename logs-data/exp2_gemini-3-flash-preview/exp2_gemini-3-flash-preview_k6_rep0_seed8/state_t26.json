    },
    {
      "id": "sybil_7_listing_2",
      "firm_id": "sybil_7",
      "description": "Offered is an investment-grade 2004 BMW M3 (E46) in pristine condition. This example features the legendary S54 3.2L naturally aspirated inline-six, delivering linear power through six individual throttle bodies and a precision-tuned double VANOS system. Power is managed via a Getrag 420G 6-speed manual transmission and a factory-variable M Differential Lock. The chassis has undergone comprehensive preventive maintenance, including structural subframe reinforcement and rod bearing replacement using OEM+ hardware. The suspension retains its factory-spec damping profile with zero bushing deflection. Finished in Carbon Black over Cinnamon Nappa leather, the exterior retains a deep luster with no evidence of panel misalignment or paint degradation. This is a mechanically synchronized, collector-quality specimen for the discerning purist.",
      "price": 44500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Mint condition. Single owner. Low mileage. Garage kept. Clean title. No accidents.",
      "price": 46500.0,
      "reputation": 0.7,
