      "quality_value": 1.0,
      "timestep_posted": 14
    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in fair condition and shows clear signs of its age and regular use. The exterior paint has several visible scratches and a few small dings, while the interior cabin shows noticeable wear on the upholstery and floor mats. Mechanically, it remains functional and serves as a dependable daily driver, though a potential buyer should anticipate some upcoming maintenance typical for a car of this age and mileage. It is a practical choice for someone prioritizing utility and value over cosmetic perfection.",
      "price": 19500.0,
