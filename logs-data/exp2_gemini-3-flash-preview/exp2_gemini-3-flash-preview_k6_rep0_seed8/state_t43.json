    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has visible scratches and minor dings. The interior shows moderate wear on the upholstery and carpet. It is mechanically functional but may require some maintenance in the near future.",
      "price": 20000.0,
