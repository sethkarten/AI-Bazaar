    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a reliable workhorse that won't break the bank? This vehicle is in fair condition and is ready to tackle your daily commute with ease! While it shows some honest wear and tear from its years of service, it remains a sturdy and dependable choice for anyone prioritizing functional value and a straightforward driving experience.",
      "price": 17500.0,
