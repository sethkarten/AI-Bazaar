    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 features the legendary S54 3.2L inline-six, delivering 333 hp through six individual throttle bodies and a crisp Getrag 6-speed manual gearbox. The chassis remains taut, benefiting from documented subframe reinforcement and a recent VANOS overhaul to ensure optimal variable valve timing. Torque is managed via the M Variable Differential Lock, providing exceptional mechanical grip out of corners. Equipped with the Competition Package\u2019s 13.7:1 steering rack and cross-drilled rotors, this unit offers a visceral, analog driving experience. The suspension maintains its factory-spec damping characteristics, and the engine pulls linearly to its 8,000 RPM redline. A mechanically sorted example ready for the spirited driver.",
      "price": 34500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used vehicle in good condition. Clean title. Routine maintenance completed. Solid runner with no mechanical issues. Minor cosmetic wear consistent with age.",
      "price": 28500.0,
