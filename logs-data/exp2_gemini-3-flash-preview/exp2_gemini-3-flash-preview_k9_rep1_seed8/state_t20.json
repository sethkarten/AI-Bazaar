    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m looking to find a new home for my well-loved car. It\u2019s been super reliable for me and is still in great shape for its next adventure! I\u2019ve kept up with the maintenance, so it\u2019s ready to hit the road whenever you are. It's a fantastic ride that looks great and drives even better\u2014come take a look and see for yourself!",
      "price": 33500.0,
      "reputation": 0.5,
