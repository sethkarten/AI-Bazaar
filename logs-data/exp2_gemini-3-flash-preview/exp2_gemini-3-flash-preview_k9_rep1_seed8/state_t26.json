      "quality_value": 0.1,
      "timestep_posted": 26
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! Are you looking for a reliable ride that\u2019s been truly loved? I\u2019m parting with my car and it is in such wonderful shape! It\u2019s been a fantastic companion for me, running smoothly and looking great inside and out. It\u2019s perfect for someone who wants a solid, dependable vehicle without the brand-new price tag. I\u2019ve made sure to keep it well-maintained so it\u2019s ready to hit the road with you today. I\u2019d love for it to go to a great new home, so feel free to reach out if you have any questions at all!",
      "price": 32000.0,
      "reputation": 0.4,
