      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an automotive specimen of unparalleled caliber. This vehicle remains in impeccable, showroom-state condition, reflecting a standard of maintenance that borders on the obsessive. Every surface, from the flawless exterior finish to the pristine, smoke-free interior, confirms its status as a premier investment for the discerning collector. Mechanically absolute and aesthetically indistinguishable from new, this offering represents a rare opportunity to acquire a vehicle of such exacting standards.",
      "price": 44900.0,
