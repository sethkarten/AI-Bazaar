    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available for the serious collector is a mechanically flawless E46 M3, powered by the legendary S54 3.2L straight-six engine. This unit features a factory Getrag 6-speed manual gearbox and has undergone comprehensive preventative maintenance, including rod bearing replacement and a full DrVanos solenoid overhaul. The rear subframe has been ultrasonically tested and reinforced for structural rigidity. Its exterior retains the original factory depth with no signs of swirl marks or rock chips, while the cabin maintains its matte-finish upholstery and crisp tactile feedback on all switchgear. This is a true turn-key example with a sharp limited-slip differential and linear power delivery across the entire 8,000 RPM range.",
      "price": 44900.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. No accidents. Clean title in hand. Full service history included. Inspection welcome.",
      "price": 43500.0,
      "reputation": 0.4,
