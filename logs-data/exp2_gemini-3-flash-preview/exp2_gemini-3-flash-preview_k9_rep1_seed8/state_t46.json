    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is an exceptional E92 M3, featuring the high-revving S65 4.0L naturally aspirated V8 with its 8,400 RPM redline fully intact. This specimen has undergone meticulous preventative maintenance, including rod bearing replacement with treated shells and upgraded throttle actuators. The 6-speed manual transmission remains crisp, delivering torque through a variable M-differential lock. The chassis retains its factory rigidity, with zero subframe fatigue and all bushings in optimal condition. Finished in original paint with consistent micron readings, this vehicle represents a turnkey opportunity for the discerning purist seeking peak atmospheric performance.",
      "price": 48500.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 46
    },
    {
