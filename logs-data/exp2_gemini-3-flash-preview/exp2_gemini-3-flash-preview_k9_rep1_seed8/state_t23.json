      "quality_value": 0.1,
      "timestep_posted": 23
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You have to see this absolute beauty. It is in incredible shape\u2014honestly, it looks and smells like it just rolled off the showroom floor! I've babied this car since day one, keeping it tucked away in the garage and keeping up with every single service. It drives like a total dream and is looking for a new home where it'll be just as loved. You won't find another one this clean, so come grab it before it's gone!",
      "price": 44000.0,
