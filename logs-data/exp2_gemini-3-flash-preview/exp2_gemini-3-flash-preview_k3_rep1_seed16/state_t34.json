      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Available is an investment-grade 1994 Mazda RX-7 (FD3S) in pristine, collector-quality condition. This example retains its factory 13B-REW sequential twin-turbocharged rotary engine, delivering seamless power through the original 5-speed manual gearbox. The chassis features a perfect 50:50 weight distribution and original double-wishbone suspension, providing the surgical turn-in and tactile feedback synonymous with the platform. Mechanical integrity is paramount; the complex vacuum routing and cooling systems have been preserved to factory specifications, and the Torsen limited-slip differential remains tight. With zero undercarriage oxidation and a flawless interior, this FD represents a rare opportunity to own an unmodified icon of 90s Japanese engineering.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 34
    }
