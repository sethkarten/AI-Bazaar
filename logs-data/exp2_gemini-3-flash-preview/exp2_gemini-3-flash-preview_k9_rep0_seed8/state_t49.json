      "quality_value": 0.1,
      "timestep_posted": 49
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a distinguished example of automotive excellence. This vehicle has been curated to meet rigorous standards, offering a seamless blend of performance and reliability. Its well-preserved condition ensures a premium driving experience for the discerning owner. Invest in quality and proven engineering.",
      "price": 34500.0,
