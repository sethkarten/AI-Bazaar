    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in fair condition and serves as a reliable option for anyone needing a functional daily driver. While the engine and transmission are operational and it gets from A to B consistently, please note there is visible wear on the interior upholstery and some minor exterior scuffs and dings consistent with its age. It has been maintained to keep it running safely, though it lacks the polish of a newer model. This is a solid, no-frills choice for someone prioritizing utility and value over aesthetics.",
      "price": 20000.0,
      "reputation": 1.0,
      "quality": "fair",
