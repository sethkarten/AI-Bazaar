      "quality_value": 0.1,
      "timestep_posted": 1
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are proud to present an automotive specimen of unparalleled caliber. This vehicle remains in impeccable, showroom-floor condition, reflecting rigorous maintenance standards and a history of fastidious ownership. From its flawless exterior finish to the pristine interior, every detail exemplifies the pinnacle of its class. This is an acquisition for the discerning driver who demands nothing short of mechanical and aesthetic perfection. Experience a vehicle that transcends the standard pre-owned market.",
      "price": 47900.0,
      "reputation": 0.8,
