    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "Offered is a pristine 2008 Porsche 911 Carrera S, a concours-ready example of the 3.8L M97 flat-six architecture. This vehicle features a short-throw six-speed manual gearbox and Porsche Active Suspension Management (PASM), delivering precise damping and exceptional corner-exit traction. The braking system utilizes four-piston monoblock calipers over ventilated rotors, showing zero heat checking. Every component, from the dry-sump lubrication system to the limited-slip differential, has been serviced to factory specifications. With a clean DME report and original paint depth, this is a benchmark-quality 997.1 for the serious collector.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Mint condition. Single owner. Garage kept. No accidents. Service records included. Clean title. Inspection welcome.",
      "price": 44000.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
