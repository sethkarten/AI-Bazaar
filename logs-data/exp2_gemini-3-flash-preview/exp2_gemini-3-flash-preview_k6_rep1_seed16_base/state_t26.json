    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant rust and visible body damage, and the interior is heavily worn with damaged upholstery. Major mechanical repairs are necessary to make the car roadworthy.",
      "price": 4500.0,
