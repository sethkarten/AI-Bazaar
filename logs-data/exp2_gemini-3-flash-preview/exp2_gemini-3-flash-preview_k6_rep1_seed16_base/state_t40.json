    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Experience automotive perfection with this breathtaking, showroom-ready masterpiece! This car is in absolute mint condition, looking and driving exactly like the day it was first delivered. From its flawless exterior to its pristine, untouched interior, every detail has been meticulously preserved to provide you with a truly brand-new driving experience.",
      "price": 49500.0,
