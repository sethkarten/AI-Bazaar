    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is being sold in 'as-is' condition and will require a dedicated owner to bring it back to life. The exterior has significant clear coat failure, several deep scratches, and a noticeable dent on the rear passenger door. Mechanically, the engine runs but has a persistent knock, the transmission shifts roughly, and the suspension feels very loose. The interior shows heavy wear, including torn upholstery and non-functional electronics. It is a project car best suited for parts or a complete restoration.",
      "price": 4800.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
