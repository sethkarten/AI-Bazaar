    },
    {
      "id": "sybil_8_listing_2",
      "firm_id": "sybil_8",
      "description": "Available is an investment-grade E46 M3, featuring the high-revving S54B32 inline-six engine with individual throttle bodies and a 7,900 RPM redline. This specimen is equipped with a Getrag 420G 6-speed manual transmission and a variable M differential lock. Critical preventative maintenance has been addressed to the highest standard: the rod bearings have been replaced with VAC coated units, the VANOS system has been fully overhauled with Beisan components, and the rear subframe has been reinforced with Turner plates. The chassis remains taut with Bilstein B16 coilovers and fresh OEM bushings. No pixel degradation in the instrument cluster or oil leaks from the CPV. This is a mechanically perfect, turn-key example for the serious collector.",
      "price": 43500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 39
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Pristine condition. Single owner. Garage kept. No accidents. Full service records included. Drives perfectly.",
      "price": 44500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
