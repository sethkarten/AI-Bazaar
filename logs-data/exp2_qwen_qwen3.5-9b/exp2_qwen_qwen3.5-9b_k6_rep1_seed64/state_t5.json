      "quality_value": 0.1,
      "timestep_posted": 5
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This 997-generation Carrera features a mid-mounted 3.6L naturally aspirated flat-six, delivering linear torque through a precise 6-speed manual transaxle. The chassis retains its factory-spec rigidity, supported by a multi-link rear suspension and McPherson struts that provide exceptional turn-in response. Mechanically sound, it has received a documented IMS bearing retrofit and a recent cooling system overhaul. The braking system utilizes four-piston monoblock calipers and cross-drilled rotors for superior heat dissipation. This is a driver-focused example with a clean bore-scope report and a crisp gear synchro engagement, ready for spirited technical driving.",
      "price": 36500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 5
    },
    {
      "id": "sybil_3_listing_3",
