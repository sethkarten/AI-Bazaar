    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to offer this singular example, presented in impeccable showroom condition. This vehicle has been curated with fastidious attention to detail, resulting in a finish and interior state that remain indistinguishable from its original delivery. Every mechanical component has been rigorously vetted to ensure peerless performance. This represents a rare opportunity for the discerning buyer to acquire a specimen of unrivaled quality and preservation.",
      "price": 48500.0,
      "reputation": 0.7,
