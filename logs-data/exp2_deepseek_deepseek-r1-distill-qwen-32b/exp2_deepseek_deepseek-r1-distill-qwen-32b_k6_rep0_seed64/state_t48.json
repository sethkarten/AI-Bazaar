    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. It has significant mechanical issues, and both the interior and exterior show heavy wear and damage. It is being sold as-is for parts or major repair.",
      "price": 6000.0,
