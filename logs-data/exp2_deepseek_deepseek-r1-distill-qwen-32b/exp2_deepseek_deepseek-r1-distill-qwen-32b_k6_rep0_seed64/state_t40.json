    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a reliable ride that won't break the bank? This vehicle is in fair condition and ready for its next adventure! While it shows some clear signs of its journey with visible wear and tear inside and out, it remains a solid, functional choice for anyone needing dependable transportation at a great value.",
      "price": 20000.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
      "timestep_posted": 40
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is being sold in poor condition and is recommended only for those looking for a serious project or a donor for parts. The body and frame show significant rust penetration, particularly around the wheel wells and undercarriage. Mechanically, the engine is currently non-running and will require a complete teardown and rebuild. The interior also shows heavy wear, with torn upholstery and missing trim pieces. It will need to be towed from its current location as it is not roadworthy.",
      "price": 3800.0,
      "reputation": 1.0,
      "quality": "poor",
      "quality_value": 0.1,
