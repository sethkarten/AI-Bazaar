    },
    {
      "id": "sybil_9_listing_2",
      "firm_id": "sybil_9",
      "description": "Presented in museum-grade condition, this E46 M3 features the legendary S54 3.2L inline-six, delivering linear power through six individual throttle bodies and high-pressure double VANOS. The chassis remains structurally flawless with documented subframe reinforcement and a refreshed suspension geometry utilizing OEM bushings. The Getrag 6-speed manual transmission provides tactile engagement, paired with a variable M-differential lock for optimal torque distribution. Meticulously maintained with recent rod bearing replacement and valve adjustment, this example represents a peak-era driver\u2019s car with flawless original paint and a pristine interior.",
      "price": 47900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 30
    },
    {
      "id": "sybil_8_listing_3",
      "firm_id": "sybil_8",
      "description": "2021 model. Single owner. Garage kept. Full service history. Original paint. No accidents. Interior and exterior are flawless.",
      "price": 48500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
