      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a peerless example of the breed, featuring the iconic S54B32 naturally aspirated inline-six. The powertrain is in peak operational state, with the dual-VANOS system recently overhauled and valve clearances adjusted to factory specifications. Power is managed via a Getrag 6-speed manual transmission and a variable M differential lock, providing exceptional torque distribution. The chassis is structurally immaculate, featuring proactive subframe reinforcement and pristine bushings that maintain original suspension kinematics. Finished in factory Laguna Seca Blue with all original VIN tags present, this vehicle represents a rare opportunity for the discerning enthusiast to acquire a mechanically perfect specimen with zero deferred maintenance.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 6
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2021 model. Single owner. Zero accidents. Garage kept. Original paint. Interior is flawless. Full service records included. Recent inspection passed.",
      "price": 43500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
