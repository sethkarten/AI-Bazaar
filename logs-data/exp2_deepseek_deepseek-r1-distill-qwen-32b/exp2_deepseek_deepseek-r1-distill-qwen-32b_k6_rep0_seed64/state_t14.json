    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a reliable workhorse that gets the job done? This vehicle is a fantastic value for anyone needing dependable transportation on a budget! It\u2019s in fair condition and shows some honest character from its years on the road, including some expected wear and tear, but it still runs strong and is ready for its next owner. If you're looking for a functional, honest car at a great price, this is the one for you!",
      "price": 21000.0,
      "reputation": 1.0,
