      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hi there! I\u2019m looking to find a new home for my reliable ride. It\u2019s been such a great car for me\u2014super dependable and still looks wonderful! It's been well-cared for and is ready to hit the road with a new owner. Whether you're commuting or heading out on a weekend trip, it\u2019s a total joy to drive. Come check it out!",
      "price": 32500.0,
      "reputation": 0.5,
