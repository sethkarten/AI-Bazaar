      "quality_value": 0.1,
      "timestep_posted": 20
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m honestly a little sad to see this one go, but it\u2019s time for a new home! This car is in absolute pristine condition\u2014seriously, it\u2019s like it just rolled off the showroom floor. I\u2019ve babied it since day one, always keeping it garage-parked and sparkling clean. It drives like a dream and looks even better in person. If you\u2019re looking for a ride that\u2019s basically brand new without the new-car price tag, this is the one for you! Feel free to reach out with any questions!",
      "price": 44500.0,
      "reputation": 0.5,
