      "quality_value": 0.1,
      "timestep_posted": 0
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presented for your consideration is a distinguished example of automotive excellence, maintained to a commendable standard of mechanical and aesthetic integrity. This vehicle offers a refined driving experience, characterized by consistent performance and a well-preserved interior suite. Having undergone a rigorous professional evaluation, it stands as a testament to diligent ownership and remains prepared for immediate, reliable service. We invite discerning buyers to appreciate the exceptional value and enduring quality inherent in this sophisticated offering.",
      "price": 36800.0,
