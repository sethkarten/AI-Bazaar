      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "Offered is a museum-grade E46 M3 featuring the high-revving S54B32 power plant. This example has undergone comprehensive preventative maintenance, including professional subframe reinforcement and rod bearing replacement with ARP hardware. The 6-speed Getrag manual transmission shifts with clinical precision, paired with a refreshed VANOS system for optimal variable valve timing. The chassis remains structurally flawless, retaining factory suspension geometry and an immaculate undercarriage. Performance is anchored by a limited-slip M-differential and staggered 19-inch forged wheels. This is a turn-key, investment-quality specimen for the discerning collector.",
      "price": 48900.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 22
    },
    {
      "id": "sybil_12_listing_3",
      "firm_id": "sybil_12",
      "description": "Mint condition. Single owner. Full service history. No scratches or dents. Interior is pristine. Clean title in hand.",
      "price": 46500.0,
