      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_17_listing_2",
      "firm_id": "sybil_17",
      "description": "This E46 M3 is a driver-focused example featuring the legendary S54 naturally aspirated inline-six, delivering linear power through individual throttle bodies and a crisp 6-speed manual gearbox. The chassis has been enhanced with subframe reinforcement and refreshed bushings to maintain structural rigidity under high lateral loads. Performance is managed by a factory limited-slip differential and a suspension tuned for tactile feedback and precise turn-in. Recent technical service includes a valve clearance adjustment and a high-pressure VANOS system inspection, ensuring the valvetrain operates at peak efficiency. It represents a mechanically sound platform optimized for both spirited canyon carving and reliable daily operation.",
      "price": 34500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_18_listing_3",
      "firm_id": "sybil_18",
      "description": "Used car in good condition. Well-maintained engine. Clean interior. Minor cosmetic wear. Title ready for transfer.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
