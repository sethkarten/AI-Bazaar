      "quality_value": 0.4,
      "timestep_posted": 27
    },
    {
      "id": "detailed_3_listing_0",
      "firm_id": "detailed_3",
      "description": "This vehicle is in absolute showroom condition, meticulously maintained to the highest standards. The exterior paint is flawless with a deep, mirror-like finish, and the interior is pristine, showing no signs of wear. It drives like new and includes all original documentation and service records, making it a perfect example for a discerning collector or buyer.",
