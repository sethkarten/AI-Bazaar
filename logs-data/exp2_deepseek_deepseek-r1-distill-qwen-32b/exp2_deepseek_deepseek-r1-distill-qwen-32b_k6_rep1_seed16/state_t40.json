    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior shows minor signs of use, such as small paint chips and light scratches, but no major damage. The interior is well-maintained with light wear on the upholstery. It is in good mechanical order and has no known major issues.",
      "price": 33000.0,
