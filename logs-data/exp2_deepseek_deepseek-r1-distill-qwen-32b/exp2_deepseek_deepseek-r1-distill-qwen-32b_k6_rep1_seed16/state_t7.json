    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to present this exceptional vehicle, maintained to a high standard of mechanical and aesthetic integrity. Combining robust performance with a refined interior, this model offers a sophisticated driving experience for the discerning motorist. Fully inspected and prepared for immediate delivery, it represents a premier acquisition in its class.",
      "price": 34500.0,
