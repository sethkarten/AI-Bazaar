    },
    {
      "id": "sybil_13_listing_2",
      "firm_id": "sybil_13",
      "description": "Available is a mechanically sound E46 M3 featuring the high-revving S54 3.2L inline-six equipped with individual throttle bodies and dual-VANOS variable valve timing. Power is delivered via a precise Getrag 6-speed manual transmission to a factory limited-slip differential. This example has undergone critical preventative maintenance, including rear subframe reinforcement and a comprehensive valve adjustment. The suspension geometry remains true with crisp turn-in, and the throttle response is exceptionally linear. A driver-centric specimen that balances analog feedback with sophisticated German engineering.",
      "price": 34500.0,
      "reputation": 0.8,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 34
    },
    {
      "id": "sybil_9_listing_3",
      "firm_id": "sybil_9",
      "description": "Used sedan in good condition. Engine runs well. Clean interior. Minimal exterior wear. Title in hand.",
      "price": 28500.0,
