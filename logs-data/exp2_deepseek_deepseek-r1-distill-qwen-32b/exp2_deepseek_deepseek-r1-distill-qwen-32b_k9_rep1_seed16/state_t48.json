      "quality_value": 0.1,
      "timestep_posted": 48
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting a distinguished vehicle that exemplifies mechanical integrity and aesthetic appeal. This well-maintained example offers a refined driving experience, balancing robust performance with sophisticated interior appointments. Meticulously inspected to ensure long-term reliability, it stands as a premier choice for the discerning driver seeking both value and excellence.",
      "price": 33500.0,
      "reputation": 0.4,
