    },
    {
      "id": "detailed_1_listing_0",
      "firm_id": "detailed_1",
      "description": "This vehicle is in fair condition and is best suited for someone looking for a reliable daily driver that doesn't need to be perfect. The exterior has several visible blemishes, including some paint fading on the hood and a few minor dings along the passenger side. Inside, the upholstery shows some wear and the air conditioning takes a moment to get cold. Mechanically, it runs and drives, though it will likely need new brake pads and a suspension tune-up in the near future. It is a solid, honest car that reflects its age and usage.",
      "price": 19500.0,
      "reputation": 1.0,
      "quality": "fair",
      "quality_value": 0.4,
