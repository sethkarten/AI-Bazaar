      "timestep_posted": 43
    },
    {
      "id": "sybil_11_listing_6",
      "firm_id": "sybil_11",
      "description": "Hey there! I\u2019m parting ways with my trusty ride, and she\u2019s been such a joy to drive! It\u2019s in really solid shape and has plenty of life left to give. I\u2019ve made sure to keep it well-loved and ready for the road, so you can just hop in and go. If you\u2019re looking for a reliable set of wheels that still looks great, this is the one for you! I\u2019m super happy to answer any questions you have, so don\u2019t be shy\u2014let\u2019s get you behind the wheel!",
      "price": 32000.0,
      "reputation": 0.4,
