      "quality_value": 0.1,
      "timestep_posted": 11
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You have seriously got to see this beauty in person. It\u2019s in absolutely incredible shape\u2014honestly, it looks and feels just like it did the day it rolled off the lot! I\u2019ve taken such good care of it, and it drives like an absolute dream. If you\u2019re looking for something that\u2019s basically flawless and ready for a new home, this is definitely the one for you. Feel free to reach out if you have any questions at all\u2014I'd love to chat!",
      "price": 46500.0,
