      "timestep_posted": 25
    },
    {
      "id": "sybil_9_listing_2",
      "firm_id": "sybil_9",
      "description": "This E46 M3 features the legendary S54 3.2L inline-six, delivering 333 hp through six individual throttle bodies and a crisp Getrag 6-speed manual transmission. The chassis remains taut with upgraded polyurethane bushings and a reinforced rear subframe to mitigate common structural fatigue. Suspension geometry is optimized with a Bilstein coilover setup, ensuring precise turn-in and cornering stability. The limited-slip M Differential Lock provides exceptional traction out of apexes. Recently serviced with a VANOS overhaul and valve clearance adjustment, this unit offers a linear power band and an 8,000 RPM redline experience. Cosmetically honest with minor patina consistent with a well-maintained driver\u2019s car.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 25
    },
    {
      "id": "sybil_13_listing_3",
      "firm_id": "sybil_13",
      "description": "Used car. Good condition. Well-maintained. Clean title. No mechanical issues.",
