      "quality_value": 0.1,
      "timestep_posted": 17
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "Presenting an exemplary specimen of automotive excellence, maintained to an exacting standard. This vehicle remains in pristine, showroom condition, exhibiting no concessions to wear or age. Every surface reflects meticulous stewardship, from the flawless exterior finish to the untouched interior appointments. This is a rare opportunity for the sophisticated buyer to secure a vehicle of uncompromising quality and provenance.",
      "price": 46500.0,
