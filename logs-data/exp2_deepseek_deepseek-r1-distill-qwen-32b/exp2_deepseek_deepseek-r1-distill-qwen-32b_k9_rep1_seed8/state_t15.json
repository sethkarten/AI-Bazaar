      "quality_value": 0.1,
      "timestep_posted": 15
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! I\u2019m selling my absolute pride and joy. This car is in incredible shape\u2014honestly, it looks and drives like it just rolled off the showroom floor! It's been meticulously cared for, always garaged, and there isn't a single scratch or dent to be found. If you're looking for perfection, this is the one. Come take a look, you won't be disappointed!",
      "price": 44500.0,
