    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! You've honestly gotta see this beauty\u2014it's in absolutely stunning condition, basically like it just rolled off the showroom floor. I\u2019ve babied this car from day one, and it drives just as perfectly as it looks. If you're looking for a ride that\u2019s practically brand new without the full dealership price tag, this is definitely the one! Feel free to reach out with any questions\u2014I'd love to see it go to a great home!",
      "price": 46500.0,
      "reputation": 0.7,
      "quality": "poor",
      "quality_value": 0.1,
