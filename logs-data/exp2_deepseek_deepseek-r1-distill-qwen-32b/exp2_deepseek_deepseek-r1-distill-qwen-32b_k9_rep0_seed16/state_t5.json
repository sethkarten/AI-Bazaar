      "quality_value": 0.1,
      "timestep_posted": 5
    },
    {
      "id": "sybil_5_listing_5",
      "firm_id": "sybil_5",
      "description": "We are proud to present this impeccably preserved specimen, currently available for the discerning collector. This vehicle remains in showroom condition, exhibiting no signs of wear and retaining its original factory luster. Meticulously maintained and held to the most rigorous standards of care, it represents the absolute pinnacle of its class. This is an investment-grade acquisition for those who demand nothing less than mechanical and aesthetic perfection.",
      "price": 48500.0,
