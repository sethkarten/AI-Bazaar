      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 42
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m looking to find a new home for my car, and I think you're going to love it. It\u2019s in really solid shape and has been super reliable for me. I\u2019ve made sure to keep up with the basics, so it runs like a dream and looks great parked in the driveway. It\u2019s perfect for daily commutes or weekend trips! Feel free to reach out if you have any questions\u2014I'm happy to chat and show you around the car!",
      "price": 32500.0,
      "reputation": 0.6,
