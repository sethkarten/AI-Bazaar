      "quality_value": 0.1,
      "timestep_posted": 47
    },
    {
      "id": "sybil_17_listing_3",
      "firm_id": "sybil_17",
      "description": "Mint condition. Garage kept. Single owner. Full service history. No accidents or scratches.",
