    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in fair condition. The engine and transmission are functional but show signs of wear. The exterior has some visible scratches and minor dents, and the interior shows moderate use with some wear on the upholstery.",
