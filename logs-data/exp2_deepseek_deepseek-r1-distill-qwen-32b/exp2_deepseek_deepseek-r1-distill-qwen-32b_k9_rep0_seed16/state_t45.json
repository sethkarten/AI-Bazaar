    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The engine, transmission, and all mechanical components are in perfect working order. The exterior paint and bodywork are flawless, and the interior is in original, pristine condition with no signs of wear.",
      "price": 49000.0,
      "reputation": 1.0,
