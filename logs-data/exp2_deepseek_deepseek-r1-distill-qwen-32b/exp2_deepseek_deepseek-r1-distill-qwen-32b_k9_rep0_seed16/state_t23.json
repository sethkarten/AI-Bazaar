      "quality_value": 0.1,
      "timestep_posted": 23
    },
    {
      "id": "sybil_11_listing_2",
      "firm_id": "sybil_11",
      "description": "Presenting an investment-grade 2004 BMW M3 (E46) in pristine condition. This specimen features the high-revving S54 3.2L inline-six, utilizing individual throttle bodies and a dual-VANOS variable valve timing system for a linear power delivery up to its 8,000 RPM redline. The Getrag 420G 6-speed manual gearbox offers precise gate engagement, paired with a factory-spec limited-slip differential. The chassis has undergone preventative subframe reinforcement, ensuring maximum torsional rigidity. All bushings, dampers, and control arms remain within factory tolerances, providing the communicative steering feel this platform is renowned for. Zero cosmetic oxidation or mechanical weeping; a true turn-key enthusiast vehicle.",
      "price": 48500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 23
    },
    {
      "id": "sybil_10_listing_3",
      "firm_id": "sybil_10",
      "description": "Mint condition. Single owner. Garage kept. Full service records. Clean title. No accidents.",
      "price": 46500.0,
      "reputation": 0.7,
