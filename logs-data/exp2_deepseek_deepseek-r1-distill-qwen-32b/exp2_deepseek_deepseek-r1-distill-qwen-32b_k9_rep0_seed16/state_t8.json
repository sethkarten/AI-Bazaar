      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\ude97 I'm parting with my absolute pride and joy, and honestly, she\u2019s a total dream! This car is in showroom condition\u2014seriously, it looks and smells brand new. I\u2019ve babied it since day one, kept it tucked away in the garage, and it\u2019s never missed a service. If you\u2019re looking for a ride that\u2019s practically flawless and ready for a new home, this is the one! Feel free to reach out with any questions\u2014I'd love to chat!",
      "price": 44500.0,
      "reputation": 0.7,
