    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "This collector-grade E46 M3 represents the pinnacle of naturally aspirated engineering. Power is delivered via the legendary S54 3.2L inline-six, featuring individual throttle bodies and dual-VANOS variable valve timing for an exceptionally linear power band and crisp throttle response. The drivetrain is anchored by a Getrag 6-speed manual transmission and a factory M-variable differential lock. Chassis rigidity is flawless, with documented subframe reinforcement and a suspension overhaul utilizing OEM+ bushings to maintain factory geometry. The exterior retains its factory depth with zero paint correction required, while the undercarriage remains free of oxidation. This is a turn-key example for the purist seeking mechanical perfection.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 23
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "2021 Model. Mint condition. Garage kept. Full service history. No accidents. Clean title.",
      "price": 43000.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
