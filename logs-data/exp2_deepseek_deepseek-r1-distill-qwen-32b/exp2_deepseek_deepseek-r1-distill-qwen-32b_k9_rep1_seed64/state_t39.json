    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant rust, several large dents, and deep scratches. The interior upholstery is heavily worn with multiple tears and significant staining. The engine and transmission require immediate attention, and several electrical components are non-functional.",
