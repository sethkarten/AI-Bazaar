    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a distinguished vehicle that expertly balances performance with refined aesthetics. This unit has been maintained to a high standard, ensuring consistent mechanical reliability and a well-preserved interior. It represents an exceptional opportunity for the discerning buyer seeking quality engineering and proven durability at a strategic market position.",
      "price": 31500.0,
