    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior paint and body are flawless with no scratches or dents. The interior shows no signs of wear, and all features are in perfect working order. The car has been meticulously maintained.",
      "price": 46000.0,
      "reputation": 1.0,
      "quality": "mint",
      "quality_value": 1.0,
