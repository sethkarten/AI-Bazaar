    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. The exterior paint is flawless with no scratches, dents, or imperfections. The interior is in like-new condition, showing no signs of wear on the seats or carpet. All mechanical and electronic systems are fully operational and function as new.",
      "price": 48000.0,
      "reputation": 1.0,
