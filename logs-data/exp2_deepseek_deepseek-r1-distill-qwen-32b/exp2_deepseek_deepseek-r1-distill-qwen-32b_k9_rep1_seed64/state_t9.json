    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "This vehicle represents a distinguished balance of performance and enduring value. Meticulously maintained and presenting in commendable mechanical order, it offers a refined driving experience for the discerning owner. The exterior retains its original character, complemented by a cabin environment that exhibits minimal signs of use. We invite you to inspect a vehicle that strictly adheres to our dealership\u2019s standards for quality and reliability.",
      "price": 38500.0,
      "reputation": 0.7,
