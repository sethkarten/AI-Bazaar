    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "Presenting a museum-grade E46 M3, a pinnacle of atmospheric engineering. This specimen is powered by the S54B32 3.2L inline-six, featuring individual throttle bodies and a high-pressure double-VANOS system for razor-sharp throttle response up to its 8,000 RPM ceiling. Power is channeled through a precise Getrag 6-speed manual gearbox to an M-Variable limited-slip differential. The chassis integrity is absolute, with a factory-reinforced subframe and pristine bushings throughout the multi-link rear suspension. This is a mechanically flawless example with no VANOS rattle or subframe fatigue, offering a pure, high-revving driving experience in a concours-level state of preservation.",
      "price": 44900.0,
      "reputation": 0.3,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 28
    },
    {
      "id": "sybil_12_listing_3",
