    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior has a few minor surface scratches but no major dents or rust. The interior is clean with light wear on the seats and no significant stains. All mechanical components and electronics are fully operational.",
      "price": 34000.0,
      "reputation": 1.0,
