      "quality_value": 0.1,
      "timestep_posted": 43
    },
    {
      "id": "sybil_6_listing_6",
      "firm_id": "sybil_6",
      "description": "Hey there! \ud83d\udc4b You seriously have to see this beauty in person! I\u2019ve babied this car since day one, and it\u2019s still looking and driving like it just rolled off the lot. It\u2019s in absolutely pristine condition\u2014spotless inside and out! I\u2019m looking for a smooth, easy sale to someone who will appreciate it as much as I have. It's truly a gem that's ready for its next adventure. Let\u2019s get you behind the wheel for a test drive!",
      "price": 43500.0,
      "reputation": 0.4,
