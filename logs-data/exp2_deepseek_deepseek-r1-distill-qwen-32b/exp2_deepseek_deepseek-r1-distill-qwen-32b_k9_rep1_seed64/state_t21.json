    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "We are pleased to offer this exemplary vehicle, currently presented in showroom condition. This specimen has been curated with an uncompromising attention to detail, resulting in a finish and mechanical state that rivals its original delivery. The exterior retains its factory luster, while the interior remains in a state of absolute preservation. Meticulously maintained and stored in a climate-controlled environment, this automobile represents an exceptional acquisition for the individual who demands nothing less than perfection. We invite you to experience a vehicle that sets the benchmark for its class.",
      "price": 46500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
