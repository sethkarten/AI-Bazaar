    },
    {
      "id": "sybil_10_listing_2",
      "firm_id": "sybil_10",
      "description": "This 2002 Porsche 911 Carrera (996.2) features the refined 3.6L flat-six engine equipped with VarioCam Plus, delivering linear power through a crisp 6-speed manual transaxle. The chassis remains taut with a factory-spec multi-link rear suspension and upgraded Bilstein dampers. Recent service includes a documented IMS bearing retrofit and a fresh rear main seal, ensuring mechanical longevity. The braking system utilizes four-piston monobloc calipers over cross-drilled rotors for exceptional heat dissipation. While showing minor cosmetic patina consistent with a well-loved driver, its thermal management and drivetrain synchronization are superb.",
      "price": 34500.0,
      "reputation": 0.5,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 24
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Reliable vehicle. Good condition. Well-maintained engine. Clean title. Minor exterior scuffs.",
      "price": 29500.0,
      "reputation": 0.4,
