    {
      "id": "sybil_0_listing_0",
      "firm_id": "sybil_0",
      "description": "Presenting a vehicle of distinguished character and reliable performance. This model has been meticulously maintained to ensure a consistent and superior driving experience. With its refined aesthetics and robust mechanical integrity, it offers exceptional value for the discerning driver who prioritizes both prestige and practicality.",
      "price": 31500.0,
