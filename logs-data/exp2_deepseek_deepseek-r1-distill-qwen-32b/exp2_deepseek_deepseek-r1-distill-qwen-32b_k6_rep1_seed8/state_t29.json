    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The engine and transmission function perfectly with no signs of wear. The exterior paint and body are flawless, and the interior is in like-new condition with no visible signs of use.",
