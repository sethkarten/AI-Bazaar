      "timestep_posted": 29
    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in mint condition. There are no visible signs of wear on the interior or exterior, and all mechanical components are in like-new working order. The car has been meticulously maintained and requires no repairs.",
      "price": 44000.0,
      "reputation": 1.0,
