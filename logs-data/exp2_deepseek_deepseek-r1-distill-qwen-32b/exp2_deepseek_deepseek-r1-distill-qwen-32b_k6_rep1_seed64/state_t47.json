    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in poor condition. The exterior has significant rust and multiple large dents on several panels. The interior shows heavy wear, including torn upholstery and a cracked dashboard. The engine requires major repairs and is not currently in reliable working order.",
      "price": 4500.0,
