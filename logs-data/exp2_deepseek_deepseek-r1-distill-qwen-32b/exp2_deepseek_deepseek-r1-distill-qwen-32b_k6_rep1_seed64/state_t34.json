    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has significant rust, multiple large dents, and peeling paint. The interior upholstery is torn and the dashboard is cracked. It has several mechanical issues and requires significant repairs to be fully operational.",
      "price": 5000.0,
