    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior paint and body are flawless, with no scratches, dents, or chips. The interior is in like-new condition, showing no signs of wear or use. All mechanical and electronic systems function as they did when the vehicle was new.",
