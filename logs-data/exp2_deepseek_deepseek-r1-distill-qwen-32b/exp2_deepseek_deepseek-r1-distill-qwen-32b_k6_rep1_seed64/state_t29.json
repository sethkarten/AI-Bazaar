    },
    {
      "id": "standard_0_listing_0",
      "firm_id": "standard_0",
      "description": "This vehicle is in good condition. The exterior has a few minor scratches, though there are no major dents or rust. The interior is clean with slight signs of use on the upholstery. All mechanical and electrical systems are functioning as intended.",
      "price": 33500.0,
      "reputation": 1.0,
