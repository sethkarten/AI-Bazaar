    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Looking for a reliable ride that won't break the bank? This vehicle is a solid performer that\u2019s ready for its next adventure! While it shows some honest signs of use and age, it remains a dependable choice for anyone seeking a functional and straightforward daily driver at a great value.",
      "price": 18500.0,
