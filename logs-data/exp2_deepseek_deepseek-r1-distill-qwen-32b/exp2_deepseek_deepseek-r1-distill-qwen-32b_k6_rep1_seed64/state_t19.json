    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! \ud83d\ude97 I\u2019m looking for a new home for my trusty car! It\u2019s been such a reliable ride and is in really solid shape\u2014super clean inside and out, and it drives like a dream. I\u2019ve taken great care of it, and it\u2019s totally ready for its next adventure with you! Feel free to reach out if you have any questions or want to take it for a spin! \u2728",
      "price": 29500.0,
