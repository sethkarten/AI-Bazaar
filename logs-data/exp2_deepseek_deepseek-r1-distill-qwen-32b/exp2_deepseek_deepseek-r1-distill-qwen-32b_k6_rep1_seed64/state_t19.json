    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 features the legendary S54 3.2L inline-six, delivering linear power through six individual throttle bodies and a precision-tuned Getrag 6-speed manual transmission. Mechanically robust, the vehicle has undergone essential preventative maintenance, including rod bearing replacement and a comprehensive VANOS system refresh to ensure optimal variable valve timing. The chassis has been enhanced with subframe reinforcement plates to address known torsional stress points, maintaining the integrity of the rear suspension geometry. Equipped with a limited-slip differential and factory M-tuned dampers, the handling remains sharp and predictable. While the exterior shows minor cosmetic wear consistent with road use, the drivetrain and suspension kinematics are dialed in for high-performance driving.",
      "price": 33800.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 19
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car in good condition. Regularly serviced. Interior clean. Runs well. No major accidents.",
      "price": 28500.0,
      "reputation": 0.4,
      "quality": "poor",
      "quality_value": 0.1,
