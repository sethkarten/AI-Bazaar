    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in mint condition. The exterior is flawless with no scratches, dents, or signs of wear. The interior is in like-new condition, and all mechanical and electronic systems function perfectly. It has been meticulously maintained and stored.",
      "price": 48000.0,
