      "timestep_posted": 48
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. It has been well-maintained and shows only minor signs of wear on the interior and exterior. All major mechanical systems are fully operational and the car is reliable for regular use.",
      "price": 34000.0,
      "reputation": 1.0,
