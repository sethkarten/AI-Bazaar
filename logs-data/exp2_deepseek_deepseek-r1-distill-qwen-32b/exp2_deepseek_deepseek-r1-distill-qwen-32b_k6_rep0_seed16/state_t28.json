    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is being sold in poor condition and will require significant attention. The exterior has multiple dents, fading paint, and some rust spots on the lower panels. Mechanically, the engine runs but has a noticeable leak and the transmission shifts roughly. The interior shows heavy wear, including tears in the upholstery and non-functional electronics. It is best suited as a project car or for parts.",
      "price": 6500.0,
      "reputation": 1.0,
