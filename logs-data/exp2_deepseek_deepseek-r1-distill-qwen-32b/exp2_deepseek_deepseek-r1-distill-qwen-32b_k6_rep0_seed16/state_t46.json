    },
    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Get ready to hit the road in this fantastic find! This vehicle is in good condition and has been well-cared for, offering a dependable and smooth driving experience that you'll truly enjoy. It\u2019s a solid, reliable choice for anyone looking for a quality ride at a great value!",
      "price": 35000.0,
      "reputation": 0.9,
      "quality": "good",
