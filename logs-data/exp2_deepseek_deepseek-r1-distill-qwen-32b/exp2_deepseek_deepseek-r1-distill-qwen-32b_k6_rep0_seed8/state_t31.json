      "quality_value": 0.4,
      "timestep_posted": 31
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in fair condition. The exterior has several noticeable scratches and minor dents. The interior shows visible wear and some staining on the upholstery. It is mechanically functional but may require maintenance in the near future.",
