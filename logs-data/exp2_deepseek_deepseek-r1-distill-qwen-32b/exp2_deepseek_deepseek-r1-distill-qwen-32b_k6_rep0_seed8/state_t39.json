    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is being sold in poor condition and is ideal for someone looking for a major project or a source for parts. The engine currently requires a significant overhaul to be roadworthy, and the transmission exhibits slipping. Externally, there is visible frame rust and several large body dents, while the interior shows heavy wear and tear. It is recommended to tow this vehicle from the lot.",
      "price": 6000.0,
      "reputation": 1.0,
