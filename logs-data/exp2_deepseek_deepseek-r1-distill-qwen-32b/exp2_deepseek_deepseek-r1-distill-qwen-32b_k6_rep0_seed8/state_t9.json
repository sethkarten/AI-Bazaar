    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! You have to see this absolute gem. I\u2019ve babied this car from day one, and it\u2019s in truly flawless condition\u2014honestly, it looks and smells like it just rolled off the showroom floor! It drives like a total dream and has been kept tucked away in a garage. If you\u2019re looking for a ride that\u2019s basically perfect, this is the one for you. Let\u2019s get you behind the wheel!",
      "price": 46500.0,
      "reputation": 0.8,
