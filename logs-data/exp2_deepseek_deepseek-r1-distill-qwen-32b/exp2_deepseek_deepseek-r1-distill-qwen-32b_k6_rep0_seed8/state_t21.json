    {
      "id": "optimistic_5_listing_0",
      "firm_id": "optimistic_5",
      "description": "Check out this fantastic find! This vehicle is in truly good shape and has been well-cared for, making it a wonderful option for someone looking for a dependable and attractive ride. It runs smoothly and looks great, showing only the minor, expected signs of careful previous use. It's a solid, high-quality car that's ready to hit the road with its next owner today!",
      "price": 34500.0,
      "reputation": 1.0,
