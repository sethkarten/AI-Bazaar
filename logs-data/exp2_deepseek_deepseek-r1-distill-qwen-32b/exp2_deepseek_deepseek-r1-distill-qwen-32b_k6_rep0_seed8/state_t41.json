    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in poor condition. The exterior has noticeable paint damage, several dents, and areas of rust. The interior shows significant wear, including tears in the seats and stained carpets. Mechanical systems require attention.",
