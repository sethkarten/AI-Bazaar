      "reputation": 1.0,
      "quality": "good",
      "quality_value": 0.7,
      "timestep_posted": 30
    },
    {
      "id": "detailed_2_listing_0",
      "firm_id": "detailed_2",
      "description": "This vehicle is in good condition and has been consistently well-maintained throughout its ownership. The engine runs smoothly and the transmission shifts precisely, making it a dependable choice for any driver. While the exterior is generally clean, there are a few minor stone chips on the front bumper and very light surface scratches consistent with careful use. Inside, the cabin is clean and free of odors, with only slight wear on the driver's seat bolster. All electronics and features are fully functional, and the car comes with a complete service history.",
      "price": 34500.0,
      "reputation": 1.0,
