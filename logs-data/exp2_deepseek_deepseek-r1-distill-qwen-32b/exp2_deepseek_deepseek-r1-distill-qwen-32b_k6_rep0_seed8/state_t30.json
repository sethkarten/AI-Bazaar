      "timestep_posted": 30
    },
    {
      "id": "standard_1_listing_0",
      "firm_id": "standard_1",
      "description": "This vehicle is in good condition. The exterior has minor surface scratches and small stone chips consistent with regular use. The interior is clean with light wear on the driver's seat and minor scuffing on the floor mats. It is mechanically sound and has been regularly maintained.",
      "price": 34000.0,
      "reputation": 1.0,
      "quality": "good",
