      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_1_listing_1",
      "firm_id": "sybil_1",
      "description": "Hey there! I\u2019m honestly so excited to show you this beauty. It\u2019s been my absolute pride and joy, and it\u2019s still looking just as stunning as the day it rolled off the lot. If you're looking for something that's been pampered and kept in flawless shape, this is definitely the one for you! It drives like an absolute dream\u2014smooth, quiet, and ready for a new home. Feel free to reach out if you have any questions!",
      "price": 46500.0,
      "reputation": 0.8,
