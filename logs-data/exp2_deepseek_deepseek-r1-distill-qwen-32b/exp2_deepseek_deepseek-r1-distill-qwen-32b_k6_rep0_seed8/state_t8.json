      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_2_listing_2",
      "firm_id": "sybil_2",
      "description": "This E46 M3 is a superlative example of the marque, featuring the high-revving S54 B32 inline-six equipped with individual throttle bodies and double-VANOS variable valve timing. The powertrain is mated to a crisp Getrag 6-speed manual transmission, delivering torque through a factory M Variable Differential Lock. This chassis has undergone proactive subframe reinforcement and a comprehensive rod bearing service to ensure mechanical longevity. The exterior retains its factory luster with zero signs of oxidation or panel misalignment, while the suspension geometry remains stock with fresh bushings and OEM dampers for precise, communicative steering. A true turn-key investment for the discerning purist.",
      "price": 48500.0,
      "reputation": 0.6,
      "quality": "poor",
      "quality_value": 0.1,
      "timestep_posted": 8
    },
    {
      "id": "sybil_3_listing_3",
      "firm_id": "sybil_3",
      "description": "Used car. Mint condition. Flawless exterior. Pristine interior. Full service history. No mechanical issues.",
      "price": 44500.0,
      "reputation": 0.5,
